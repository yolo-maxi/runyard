# syntax=docker/dockerfile:1
#
# RunYard runner — executes real Smithers workflows.
#
# Bundles the full execution surface the runner shells out to:
#   - node 22 + pnpm        (runs src/smithers-runner.js)
#   - bun >= 1.3            (the smithers-orchestrator engine is a bun app)
#   - smithers-orchestrator (PINNED via bun add -g; resolved by resolveSmithersBin)
#   - git                   (workflows clone/operate on repos)
#   - docker CLI            (talks to the *guest* dockerd inside the CVM)
#
# Agent CLIs (`claude` / `codex`) are NOT baked in — they must be provided and
# authenticated at runtime (mounted creds / encrypted env). No secrets in the
# image. See DEPLOY-DSTACK.md.
#
# On dstack the runner is a long-lived container in the runner CVM; each run
# executes as work on this box (optionally driving `docker build` against the
# guest dockerd). Do NOT spin a CVM per run.

ARG NODE_VERSION=22
ARG PNPM_VERSION=10.33.0
# Pinned, explicit, reproducible engine + tool versions.
ARG SMITHERS_VERSION=0.25.1
ARG BUN_VERSION=1.3.14
ARG DOCKER_CLI_VERSION=29.6.0

FROM node:${NODE_VERSION}-bookworm-slim AS runtime
ARG PNPM_VERSION
ARG SMITHERS_VERSION
ARG BUN_VERSION
ARG DOCKER_CLI_VERSION
WORKDIR /app

# Bun installs here; global packages link their binaries into $BUN_INSTALL/bin,
# which is exactly where resolveSmithersBin() looks for the pinned smithers.
ENV BUN_INSTALL=/usr/local/bun
ENV PATH=${BUN_INSTALL}/bin:${PATH}

# System deps: git, ca-certs, the unzip/curl bun's installer needs, and tini.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates curl git unzip tini \
    && rm -rf /var/lib/apt/lists/*

# Docker CLI only (static binary — no daemon). The runner talks to the guest
# dockerd over its socket; it does not run its own daemon.
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    case "$arch" in \
      amd64) dockerarch=x86_64 ;; \
      arm64) dockerarch=aarch64 ;; \
      *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    curl -fsSL "https://download.docker.com/linux/static/stable/${dockerarch}/docker-${DOCKER_CLI_VERSION}.tgz" -o /tmp/docker.tgz; \
    tar -xzf /tmp/docker.tgz -C /tmp; \
    install -m 0755 /tmp/docker/docker /usr/local/bin/docker; \
    rm -rf /tmp/docker /tmp/docker.tgz; \
    docker --version

# Bun (pinned). Installs to $BUN_INSTALL.
RUN set -eux; \
    curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}"; \
    bun --version

# pnpm via corepack (pinned to package.json's packageManager).
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate

# Pinned smithers-orchestrator engine, installed globally via bun so its binary
# lands at $BUN_INSTALL/bin/smithers.
RUN set -eux; \
    bun add -g "smithers-orchestrator@${SMITHERS_VERSION}"; \
    smithers --version

# App dependencies (frozen lockfile) then source.
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile --prod
COPY package.json ./package.json
COPY bin ./bin
COPY src ./src

# Workspace lives on a mounted volume (large scratch on the runner's disk).
ENV NODE_ENV=production \
    SMITHERS_WORKSPACE=/workspace \
    SMITHERS_RUNNER_LOCATION=vps \
    SMITHERS_BIN=${BUN_INSTALL}/bin/smithers
RUN mkdir -p /workspace
VOLUME ["/workspace"]

# Note: runs as root by default so it can reach the guest docker socket and
# write large scratch in /workspace without uid/gid juggling. See
# DEPLOY-DSTACK.md "verify on target" for the socket-access trade-off.
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["node", "src/smithers-runner.js"]
