ides/api#rate-limits","content":"`POST /api/auth/token-login`"},"821":{"id":"/guides/api-147","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"10 / minute"},"822":{"id":"/guides/api-148","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"`POST /api/auth/telegram-webapp`"},"823":{"id":"/guides/api-149","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"30 / minute"},"824":{"id":"/guides/api-150","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"`POST /api/schedules/:id/run-now`"},"825":{"id":"/guides/api-151","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"60 / minute"},"826":{"id":"/guides/api-152","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"`POST /api/chat` (in-app assistant)"},"827":{"id":"/guides/api-153","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"60 / minute"},"828":{"id":"/guides/api-154","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#see-also","content":"MCP guide — every API operation is also an MCP tool"},"829":{"id":"/guides/api-155","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#see-also","content":"CLI guide — the same API from your terminal"},"830":{"id":"/guides/approvals-telegram","page_id":"/guides/approvals-telegram","type":"page","content":"Approvals and Telegram","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/approvals-telegram"},"831":{"id":"/guides/approvals-telegram-0","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram","content":"Operate human checkpoints — where approval cards appear, what each decision does, timed approvals, and the Telegram integration."},"832":{"id":"/guides/approvals-telegram-1","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#where-approvals-appear","content":"Where approvals appear"},"833":{"id":"/guides/approvals-telegram-2","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#resolving-a-card","content":"Resolving a card"},"834":{"id":"/guides/approvals-telegram-3","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"Timed approvals and fallback"},"835":{"id":"/guides/approvals-telegram-4","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#telegram-integration","content":"Telegram integration"},"836":{"id":"/guides/approvals-telegram-5","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#bot-setup","content":"Bot setup"},"837":{"id":"/guides/approvals-telegram-6","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#webhook","content":"Webhook"},"838":{"id":"/guides/approvals-telegram-7","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#approval-cards-with-buttons","content":"Approval cards with buttons"},"839":{"id":"/guides/approvals-telegram-8","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#telegram-webapp-login","content":"Telegram WebApp login"},"840":{"id":"/guides/approvals-telegram-9","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram","content":"An approval is a declared question with a declared consequence. Cards carry an *ask* — who is asked, what approving does, and why a human is needed — and every surface renders that stored ask verbatim. A run held on a card sits in `waiting_approval` and is never failed or age-reaped for waiting."},"841":{"id":"/guides/approvals-telegram-10","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Surface"},"842":{"id":"/guides/approvals-telegram-11","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"How"},"843":{"id":"/guides/approvals-telegram-12","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Web app"},"844":{"id":"/guides/approvals-telegram-13","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"The **Approvals** view lists pending cards with their ask, consequences, and buttons."},"845":{"id":"/guides/approvals-telegram-14","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"MCP"},"846":{"id":"/guides/approvals-telegram-15","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"`list_pending_approvals` (or `list_approvals` with a `status` filter), `get_approval`."},"847":{"id":"/guides/approvals-telegram-16","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"CLI"},"848":{"id":"/guides/approvals-telegram-17","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"`runyard approvals` lists pending cards."},"849":{"id":"/guides/approvals-telegram-18","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"HTTP"},"850":{"id":"/guides/approvals-telegram-19","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"`GET /api/approvals?status=pending`, `GET /api/approvals/{id}`."},"851":{"id":"/guides/approvals-telegram-20","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Telegram"},"852":{"id":"/guides/approvals-telegram-21","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Cards are posted to the configured chat with inline buttons (see below)."},"853":{"id":"/guides/approvals-telegram-22","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Each card takes one of three decisions:"},"854":{"id":"/guides/approvals-telegram-23","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"HTTP: `POST /api/approvals/{id}/approve|reject|request-changes`. MCP: `approve_run`, `reject_run`, `request_changes_run` — all take an **approvalId**, not a runId. These need a token with the `api`, `mcp`, or `approvals` scope (admin always qualifies)."},"855":{"id":"/guides/approvals-telegram-24","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"What each decision does depends on the card's kind:"},"856":{"id":"/guides/approvals-telegram-25","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Kind"},"857":{"id":"/guides/approvals-telegram-26","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Approve"},"858":{"id":"/guides/approvals-telegram-27","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Request changes"},"859":{"id":"/guides/approvals-telegram-28","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Reject"},"860":{"id":"/guides/approvals-telegram-29","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Run hold (default / `custom`)"},"861":{"id":"/guides/approvals-telegram-30","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The held run is released to the queue and executes."},"862":{"id":"/guides/approvals-telegram-31","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The run is cancelled; your note tells the requester what to change."},"863":{"id":"/guides/approvals-telegram-32","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The run is cancelled — a human \"no\" is a decision, not a failure."},"864":{"id":"/guides/approvals-telegram-33","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`workflow_gate` (mid-run engine gate)"},"865":{"id":"/guides/approvals-telegram-34","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The decision is applied to the paused workflow on the runner and it resumes past the gate."},"866":{"id":"/guides/approvals-telegram-35","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Applied as a deny with your note attached; the workflow's own deny path decides what happens next."},"867":{"id":"/guides/approvals-telegram-36","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Applied as a deny; the workflow's deny path decides what happens next."},"868":{"id":"/guides/approvals-telegram-37","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`escalation` (run already ended)"},"869":{"id":"/guides/approvals-telegram-38","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records your go-ahead on the card; the run is not restarted — re-run it from the run page."},"870":{"id":"/guides/approvals-telegram-39","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records that the workflow or input needs fixing; your note is the guidance."},"871":{"id":"/guides/approvals-telegram-40","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records that the run should be left as it ended."},"872":{"id":"/guides/approvals-telegram-41","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`side_effect`"},"873":{"id":"/guides/approvals-telegram-42","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The gated side effect is allowed to run."},"874":{"id":"/guides/approvals-telegram-43","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The side effect is skipped; your note explains what to change."},"875":{"id":"/guides/approvals-telegram-44","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The side effect is skipped; the run's completed work is unaffected."},"876":{"id":"/guides/approvals-telegram-45","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Resolved cards keep the decision in their `resolution` field (`approved`, `rejected`, `changes_requested`) plus how it was decided (`resolvedVia`: human, fallback timer, engine, policy, or system)."},"877":{"id":"/guides/approvals-telegram-46","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"Approvals are blocking by default: with no timer configured, nothing happens until someone decides, and a linked run is held open indefinitely."},"878":{"id":"/guides/approvals-telegram-47","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"A creator can make a card timed by supplying `timeoutMs` or `timeoutAt`, optionally with a `fallback` decision (`approve` or `reject`) — via `POST /api/approvals` or the `create_approval` MCP tool:"},"879":{"id":"/guides/approvals-telegram-48","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"**Timer + fallback** — if nobody decides before the deadline, the Hub applies the fallback decision on the human's behalf, fully audited (`resolvedVia: fallback_timer`)."},"880":{"id":"/guides/approvals-telegram-49","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"**Timer without fallback** — when the timer elapses the card is flagged `fallback_required` and **stays pending**: it is surfaced as urgent, but no decision is ever invented."},"881":{"id":"/guides/approvals-telegram-50","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"`timeoutMs` is clamped to between 1 second and 30 days."},"882":{"id":"/guides/approvals-telegram-51","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#telegram-integration","content":"The Hub can post approval cards to a Telegram chat and accept decisions from the buttons on them."},"883":{"id":"/guides/approvals-telegram-52","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Create a bot with Telegram's BotFather, then configure the Hub through environment variables (values belong in your env file or secret store — never in code or docs):"},"884":{"id":"/guides/approvals-telegram-53","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Variable"},"885":{"id":"/guides/approvals-telegram-54","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Purpose"},"886":{"id":"/guides/approvals-telegram-55","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_BOT_TOKEN`"},"887":{"id":"/guides/approvals-telegram-56","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"The bot's API token."},"888":{"id":"/guides/approvals-telegram-57","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_APPROVAL_CHAT_ID`"},"889":{"id":"/guides/approvals-telegram-58","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Chat (group or DM) where approval cards are posted."},"890":{"id":"/guides/approvals-telegram-59","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_APPROVAL_USER_IDS`"},"891":{"id":"/guides/approvals-telegram-60","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Comma-separated Telegram user ids allowed to resolve approvals."},"892":{"id":"/guides/approvals-telegram-61","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_WEBHOOK_SECRET`"},"893":{"id":"/guides/approvals-telegram-62","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Secret Telegram echoes back so the Hub can verify webhook calls."},"894":{"id":"/guides/approvals-telegram-63","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_CHAT_ID` / `TELEGRAM_THREAD_ID`"},"895":{"id":"/guides/approvals-telegram-64","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Optional default chat/thread for non-approval notifications."},"896":{"id":"/guides/approvals-telegram-65","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#webhook","content":"Point the bot's webhook at the Hub:"},"897":{"id":"/guides/approvals-telegram-66","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#webhook","content":"`POST /api/telegram/webhook` is the only Telegram-facing route. It is verified against the configured bot and webhook secret and is not a general API."},"898":{"id":"/guides/approvals-telegram-67","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#approval-cards-with-buttons","content":"Each pending card is posted as a message carrying the ask (what approving does, why a human is needed), a sanitized input summary, and inline buttons: **Approve**, **Request changes**, **Reject**. Only the configured approval user ids can act; a button press resolves the card exactly like the web or API would, and the message is edited to show the resolution (\"Approved by ... at ...\") with the buttons removed."},"899":{"id":"/guides/approvals-telegram-68","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#telegram-webapp-login","content":"Cards can deep-link into the Hub as a Telegram WebApp. `POST /api/auth/telegram-webapp` exchanges the WebApp's signed init data for a browser session that is limited to the `approvals` scope — a Telegram identity can review and resolve approval cards, and nothing else. Full app access always requires a real access token."},"900":{"id":"/guides/cli","page_id":"/guides/cli","type":"page","content":"CLI","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/cli"},"901":{"id":"/guides/cli-0","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli","content":"Install the runyard CLI, connect it to a Hub, and drive workflows, runs, approvals, and runners from the terminal."},"902":{"id":"/guides/cli-1","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#install","content":"Install"},"903":{"id":"/guides/cli-2","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#connecting-to-a-hub","content":"Connecting to a Hub"},"904":{"id":"/guides/cli-3","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#discover-and-run-workflows","content":"Discover and run workflows"},"905":{"id":"/guides/cli-4","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#watch-and-manage-runs","content":"Watch and manage runs"},"906":{"id":"/guides/cli-5","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#approvals","content":"Approvals"},"907":{"id":"/guides/cli-6","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#workflow-packages","content":"Workflow packages"},"908":{"id":"/guides/cli-7","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#tokens-audit-and-catalog","content":"Tokens, audit, and catalog"},"909":{"id":"/guides/cli-8","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#runner-setup","content":"Runner setup"},"910":{"id":"/guides/cli-9","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#mcp-helpers","content":"MCP helpers"},"911":{"id":"/guides/cli-10","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#updating-a-host-install","content":"Updating a host install"},"912":{"id":"/guides/cli-11","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli","content":"The `runyard` CLI is a thin client of the Hub's HTTP API. It talks\nto one or more Hubs (\"remotes\"), starts and tails workflow runs, resolves\napprovals, and can set up and start a runner on the local machine."},"913":{"id":"/guides/cli-12","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#install","content":"The fastest path is the install script served by your own Hub, which downloads\nthe CLI tarball from the same instance (`/cli.tgz`), installs `runyard` and\n`runyard-mcp` into `~/.local/bin`, and logs you in:"},"914":{"id":"/guides/cli-13","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#install","content":"It prompts for an access token (Web Hub → Connect) and a name for the\nconnection. Alternatively, run the CLI from a source checkout of the\nrepository with `pnpm cli -- <command>` (the checkout exposes the `runyard`,\n`runyard-mcp`, and `runyard-runner` binaries under `bin/`)."},"915":{"id":"/guides/cli-14","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#connecting-to-a-hub","content":"The CLI stores named remotes (Hub URL + token) in `~/.runyard/config.json`\n(mode `0600`). Every command accepts global options `--url`, `--token`,\n`--remote <name>`, and `--json` (machine-readable output)."},"916":{"id":"/guides/cli-15","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#connecting-to-a-hub","content":"Environment variables `RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN` (and an explicit\n`--url` / `--token`) take precedence over the saved remote."},"917":{"id":"/guides/cli-16","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`runyard run` options:"},"918":{"id":"/guides/cli-17","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Option"},"919":{"id":"/guides/cli-18","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Meaning"},"920":{"id":"/guides/cli-19","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`-i, --input <json>`"},"921":{"id":"/guides/cli-20","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"JSON input for the run"},"922":{"id":"/guides/cli-21","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--where <mode>`"},"923":{"id":"/guides/cli-22","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Execution mode: `local` or `remote` (alias: `--execution-mode`)"},"924":{"id":"/guides/cli-23","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--runner-location <location>`"},"925":{"id":"/guides/cli-24","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Target a specific runner location tag"},"926":{"id":"/guides/cli-25","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--negotiate`"},"927":{"id":"/guides/cli-26","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Preflight first: enqueue only when ready, otherwise print the negotiation state (questions/blockers and a saved draft) without creating a run"},"928":{"id":"/guides/cli-27","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--chain <json>`"},"929":{"id":"/guides/cli-28","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"JSON array of next workflow steps to queue after each run succeeds"},"930":{"id":"/guides/cli-29","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--pin <sha>`"},"931":{"id":"/guides/cli-30","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Pin the run to a specific workflow git SHA (requires workflow versioning)"},"932":{"id":"/guides/cli-31","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Related: `runyard workflow versions <workflow>` lists SHAs seen across runs and\n`runyard workflow rollback <workflow> <sha>` re-runs pinned to a prior SHA\n(`--from-run <id>` links it to the run being rolled back)."},"933":{"id":"/guides/cli-32","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#watch-and-manage-runs","content":"`tail` emits `{ts, kind, source, payload}` lines built from status transitions,\nevents, and artifacts, polling every 2 seconds with a `since` cursor — pipe it\ninto `jq` or downstream tooling."},"934":{"id":"/guides/cli-33","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#workflow-packages","content":"Workflows move between Hubs as portable `.runyard-workflow.json` package files\n— exported from one Hub and imported into another (admin token required).\nImported workflows arrive **disabled** for review before enabling; this is the\nsupported way to carry workflow source around, not files on a runner."},"935":{"id":"/guides/cli-34","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#tokens-audit-and-catalog","content":"Admin-scoped commands:"},"936":{"id":"/guides/cli-35","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#tokens-audit-and-catalog","content":"Reads available to any token: `runyard runners` (runner pool), `runyard agents`,\n`runyard skills`, `runyard knowledge -q <query>`, `runyard hooks [--workflow <slug>]`, and `runyard hook describe|validate <slug>`. Secrets have\nno CLI subcommand — manage them in the web UI, over the\nAPI (`PUT /api/secrets/:key`), or with the MCP `set_secret` tool."},"937":{"id":"/guides/cli-36","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"Turn a machine into a runner in three steps. First scaffold a workspace\n(requires `bun` and the `smithers` engine on `PATH`; it warns if no `claude`,\n`codex`, or `pi` agent CLI is found):"},"938":{"id":"/guides/cli-37","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"Then start the runner against the current remote (it inherits the remote's URL\nand token, or `RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN`):"},"939":{"id":"/guides/cli-38","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"`--location` is `local` or `vps` and drives run routing (`--where local` runs\nland on `local`-tagged runners). You can also register a machine explicitly:"},"940":{"id":"/guides/cli-39","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"For an always-on runner use the systemd unit instead — see\nInstallation."},"941":{"id":"/guides/cli-40","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#mcp-helpers","content":"See the MCP guide for clients and options."},"942":{"id":"/guides/cli-41","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#updating-a-host-install","content":"On a host that runs the Hub from a full checkout (not the thin CLI bundle),\n`runyard update [tag]` applies a release **on that host**: it drains runners,\nswaps the code, restarts the systemd units, verifies health, and rolls back\nautomatically on failure. It is always operator-initiated."},"943":{"id":"/guides/cli-42","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#updating-a-host-install","content":"Options: `--units <units>` (systemd units to restart, default\n`runyard runyard-runner`) and `--grace-ms <ms>` (bounded drain window before\naborting — in-flight runs are never killed)."},"944":{"id":"/guides/installation","page_id":"/guides/installation","type":"page","content":"Installation","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/installation"},"945":{"id":"/guides/installation-0","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"Install and deploy a Runyard Hub and runners — from source, with systemd, or with Docker."},"946":{"id":"/guides/installation-1","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#requirements","content":"Requirements"},"947":{"id":"/guides/installation-2","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#quick-install-host-bootstrap","content":"Quick install (host bootstrap)"},"948":{"id":"/guides/installation-3","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#running-from-source","content":"Running from source"},"949":{"id":"/guides/installation-4","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#systemd","content":"systemd"},"950":{"id":"/guides/installation-5","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#docker-compose","content":"Docker Compose"},"951":{"id":"/guides/installation-6","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"Confidential VMs (dstack / Intel TDX)"},"952":{"id":"/guides/installation-7","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#reverse-proxy","content":"Reverse proxy"},"953":{"id":"/guides/installation-8","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#environment-variables","content":"Environment variables"},"954":{"id":"/guides/installation-9","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#where-state-lives","content":"Where state lives"},"955":{"id":"/guides/installation-10","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#next-steps","content":"Next steps"},"956":{"id":"/guides/installation-11","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"Runyard is a self-hosted control plane for agent runs. A deployment has a small,\nfixed shape:"},"957":{"id":"/guides/installation-12","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Hub** — the HTTP server: API, web UI, MCP-backing endpoints, and the embedded\nSQLite datastore. One per deployment."},"958":{"id":"/guides/installation-13","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Runners** — one or more worker processes that register with the Hub using a\nrunner-scoped token, heartbeat, claim queued runs, and execute workflows. A\nrunner can live on the same host as the Hub or on a separate machine."},"959":{"id":"/guides/installation-14","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Clients** — the `runyard` CLI, the `runyard-mcp` MCP server, and the web app\nare all ordinary API clients of the Hub."},"960":{"id":"/guides/installation-15","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Requirement"},"961":{"id":"/guides/installation-16","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Notes"},"962":{"id":"/guides/installation-17","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Node.js >= 22.5"},"963":{"id":"/guides/installation-18","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"The Hub uses the built-in `node:sqlite` module (started with `--experimental-sqlite`)"},"964":{"id":"/guides/installation-19","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"pnpm"},"965":{"id":"/guides/installation-20","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Dependency install and build (`corepack enable` works)"},"966":{"id":"/guides/installation-21","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"git, curl"},"967":{"id":"/guides/installation-22","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"For source installs and the bootstrap script"},"968":{"id":"/guides/installation-23","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Runner hosts additionally need the Smithers engine and at least one authenticated\nagent CLI (`claude`, `codex`, or `pi`) on `PATH` — see the CLI guide\nfor `runyard runner setup`."},"969":{"id":"/guides/installation-24","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"The repository ships a one-command, idempotent bootstrap script for a fresh\nLinux box:"},"970":{"id":"/guides/installation-25","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"It ensures Node 22 + pnpm, clones the latest release tag into `/opt/runyard`\n(override with `RUNYARD_HOME`), runs `pnpm install --frozen-lockfile`, generates\na `SECRETS_ENC_KEY` and session secret into `/etc/runyard/runyard.env` (never\nclobbering an existing file, never printing secrets), creates the data\ndirectory, installs and enables the systemd units for the Hub and a runner, and\ninstalls a daily *passive* update-check timer (it never auto-applies updates)."},"971":{"id":"/guides/installation-26","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"When it finishes it prints next steps: sign in with the bootstrap token, mint a\nrunner-scoped token, put it in `/etc/runyard/runner.env`, and restart the runner\nunit."},"972":{"id":"/guides/installation-27","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"A running Hub also serves its own **client** install script at\n`https://hub.example.com/install.sh` (plus the CLI tarball at `/cli.tgz`). That\none installs the `runyard` CLI and `runyard-mcp` on a workstation — see\nthe CLI guide."},"973":{"id":"/guides/installation-28","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#running-from-source","content":"The Hub listens on `127.0.0.1:43117` by default. Start a runner in a second\nprocess:"},"974":{"id":"/guides/installation-29","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#running-from-source","content":"The runner authenticates with a runner-scoped token (`RUNYARD_HUB_TOKEN`); on a\nfresh Hub it may use the bootstrap token until you mint one."},"975":{"id":"/guides/installation-30","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"The repository ships generic units in `deploy/`. The Hub unit\n(`deploy/runyard.service`):"},"976":{"id":"/guides/installation-31","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"And the runner unit (`deploy/runyard-runner.service`):"},"977":{"id":"/guides/installation-32","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"The bootstrap script installs these for you, retargeted to your install\ndirectory, env-file location, and node binary. Secrets live in the\n`EnvironmentFile`s (mode `0600`), never in the units."},"978":{"id":"/guides/installation-33","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Runyard publishes two environment-agnostic images to GHCR:"},"979":{"id":"/guides/installation-34","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Image"},"980":{"id":"/guides/installation-35","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Role"},"981":{"id":"/guides/installation-36","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`ghcr.io/yolo-maxi/runyard-hub`"},"982":{"id":"/guides/installation-37","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"control plane + web UI + embedded datastore (HTTP on `PORT`, default 8080 in-container)"},"983":{"id":"/guides/installation-38","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`ghcr.io/yolo-maxi/runyard-runner`"},"984":{"id":"/guides/installation-39","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"claims runs and executes them; workspace volume at `/workspace`"},"985":{"id":"/guides/installation-40","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"The portable base stack is `docker-compose.yml` at the repo root:"},"986":{"id":"/guides/installation-41","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Provide secrets (`RUNYARD_HUB_SESSION_SECRET`, `SECRETS_ENC_KEY`,\n`RUNYARD_HUB_TOKEN`, agent API keys) via a `.env` file or your platform's secret\nmechanism. For production, pin images by `@sha256:` digest rather than mutable\ntags. Optional overlays (all off by default):"},"987":{"id":"/guides/installation-42","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`--profile proxy` — a bundled Caddy container that terminates TLS for\n`SITE_ADDRESS` and proxies to the Hub. Skip it if you already have a gateway."},"988":{"id":"/guides/installation-43","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`-f deploy/compose/runner-docker-socket.yml` — give the runner `docker build`\naccess via the host socket (or run a rootless DinD sidecar instead)."},"989":{"id":"/guides/installation-44","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`-f docker-compose.local.yml` — dev profile using locally built images."},"990":{"id":"/guides/installation-45","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"`deploy/dstack/` contains an overlay that adapts the base compose for dstack\nconfidential-VM deployments: every image **must** be pinned by digest (the\nattestation measures the compose text), the Hub sits on `:80` behind the\ndstack gateway, and updates/rollbacks go through dstack's `UpgradeApp` with new\ndigests. Render a single self-contained file with:"},"991":{"id":"/guides/installation-46","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"See `deploy/dstack/README.md` in the repository for the full contract."},"992":{"id":"/guides/installation-47","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#reverse-proxy","content":"The Hub is a single HTTP listener; any TLS-terminating proxy that forwards **all\npaths** to the Hub port works. With Caddy:"},"993":{"id":"/guides/installation-48","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#reverse-proxy","content":"Then set `BASE_URL=https://hub.example.com` in the Hub's env file and restart.\nAn `https://` base URL switches the Hub into production session mode. If the\nproxy is not on loopback, set the trust-proxy configuration accordingly so\nclient IPs (used by rate limiting) are read from `X-Forwarded-For` only when\nthat header is trustworthy."},"994":{"id":"/guides/installation-49","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Hub (all optional unless noted; legacy `SMITHERS_HUB_*` names are still read as\nfallbacks so old deployments keep working):"},"995":{"id":"/guides/installation-50","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Variable"},"996":{"id":"/guides/installation-51","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Meaning"},"997":{"id":"/guides/installation-52","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`PORT`"},"998":{"id":"/guides/installation-53","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Hub HTTP port (default `43117`; the container image defaults to 8080)"},"999":{"id":"/guides/installation-54","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`HOST`"},"1000":{"id":"/guides/installation-55","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Bind address (default `127.0.0.1`)"},"1001":{"id":"/guides/installation-56","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`BASE_URL`"},"1002":{"id":"/guides/installation-57","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Public URL of the Hub (e.g. `https://hub.example.com`); an `https` value enables production behavior"},"1003":{"id":"/guides/installation-58","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_DATA_DIR`"},"1004":{"id":"/guides/installation-59","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Data directory (default `<repo>/data`) — the DB, artifacts, and bootstrap token live here"},"1005":{"id":"/guides/installation-60","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_DB`"},"1006":{"id":"/guides/installation-61","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Explicit SQLite database path (default `<data dir>/runyard.sqlite`)"},"1007":{"id":"/guides/installation-62","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_SESSION_SECRET`"},"1008":{"id":"/guides/installation-63","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Secret for browser session cookies. Required in production; in dev a generated value is persisted to the data dir"},"1009":{"id":"/guides/installation-64","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SECRETS_ENC_KEY`"},"1010":{"id":"/guides/installation-65","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"32-byte key (base64/hex) for the encrypted secrets store. Keep it safe — rotating it makes stored secrets unreadable"},"1011":{"id":"/guides/installation-66","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_BOOTSTRAP_TOKEN`"},"1012":{"id":"/guides/installation-67","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Optional pre-seeded bootstrap admin/runner token (containers); on host installs one is generated into the data dir"},"1013":{"id":"/guides/installation-68","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_INSTANCE_NAME`"},"1014":{"id":"/guides/installation-69","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Display name of the deployment (default `Runyard`)"},"1015":{"id":"/guides/installation-70","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Runner:"},"1016":{"id":"/guides/installation-71","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Variable"},"1017":{"id":"/guides/installation-72","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Meaning"},"1018":{"id":"/guides/installation-73","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_URL`"},"1019":{"id":"/guides/installation-74","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"How the runner reaches the Hub (e.g. `https://hub.example.com`)"},"1020":{"id":"/guides/installation-75","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_TOKEN`"},"1021":{"id":"/guides/installation-76","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Runner-scoped access token minted on the Hub"},"1022":{"id":"/guides/installation-77","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_WORKSPACE`"},"1023":{"id":"/guides/installation-78","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Workspace directory the runner executes workflows in"},"1024":{"id":"/guides/installation-79","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_RUNNER_LOCATION`"},"1025":{"id":"/guides/installation-80","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Location label (`vps` or `local`) used for run routing"},"1026":{"id":"/guides/installation-81","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_RUNNER_NAME` / `SMITHERS_RUNNER_TAGS`"},"1027":{"id":"/guides/installation-82","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Runner display name and capability tags"},"1028":{"id":"/guides/installation-83","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_RUNNER_CONCURRENCY`"},"1029":{"id":"/guides/installation-84","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Max concurrent runs (default 1)"},"1030":{"id":"/guides/installation-85","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"Everything durable is in the Hub's data directory (`RUNYARD_HUB_DATA_DIR`,\ndefault `data/`; the `hub-data` volume mounted at `/data` in containers). It\nsurvives every update and rollback:"},"1031":{"id":"/guides/installation-86","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`runyard.sqlite` — the SQLite database (runs, workflows, tokens, schedules,\napprovals, encrypted secrets)"},"1032":{"id":"/guides/installation-87","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`artifacts/` — uploaded run artifacts"},"1033":{"id":"/guides/installation-88","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`bootstrap-token.txt` — the first admin token, generated on first boot\n(mode `0600`); use it to sign in once and mint scoped tokens"},"1034":{"id":"/guides/installation-89","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`session-secret.txt` — the persisted dev session secret when none is provided"},"1035":{"id":"/guides/installation-90","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"Back this directory up. The runner workspace, by contrast, is disposable\nscratch space — outputs and event traces are uploaded to the Hub as artifacts."},"1036":{"id":"/guides/installation-91","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#next-steps","content":"Point clients at the Hub: CLI guide, MCP guide"},"1037":{"id":"/guides/installation-92","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#next-steps","content":"Drive it over HTTP: API guide"},"1038":{"id":"/guides/mcp","page_id":"/guides/mcp","type":"page","content":"MCP","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/mcp"},"1039":{"id":"/guides/mcp-0","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp","content":"Connect AI agents to a Runyard Hub with the runyard-mcp stdio server and its 85-tool surface."},"1040":{"id":"/guides/mcp-1","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#install-and-configure","content":"Install and configure"},"1041":{"id":"/guides/mcp-2","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#hub-url-and-token-resolution","content":"Hub URL and token resolution"},"1042":{"id":"/guides/mcp-3","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#the-tool-surface","content":"The tool surface"},"1043":{"id":"/guides/mcp-4","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#the-parity-guarantee","content":"The parity guarantee"},"1044":{"id":"/guides/mcp-5","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#recommended-agent-flow","content":"Recommended agent flow"},"1045":{"id":"/guides/mcp-6","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp","content":"`runyard-mcp` is a stdio Model Context Protocol\nserver that ships with the Runyard CLI. It runs locally next to your AI client\n(Claude Code, Claude Desktop, Codex, Cursor, and others), and translates every\ntool call into an authenticated HTTP request against your Hub. No workflow\nlogic runs in the MCP server itself — it is a thin, faithful client of the\nHTTP API."},"1046":{"id":"/guides/mcp-7","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"Install the CLI first (it bundles `runyard-mcp`) and log in — see the\nCLI guide:"},"1047":{"id":"/guides/mcp-8","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"Then let the CLI write your AI client's MCP config:"},"1048":{"id":"/guides/mcp-9","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"Supported `--client` values: `claude-code`, `claude-desktop`, `codex`,\n`cursor`, `windsurf`, `gemini`, `vscode`. Each writes the appropriate config\nfile (for example `.mcp.json` for Claude Code, `~/.codex/config.toml` for\nCodex, `.vscode/mcp.json` for VS Code) and prints how to activate it."},"1049":{"id":"/guides/mcp-10","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"To configure a client by hand, print the snippet instead:"},"1050":{"id":"/guides/mcp-11","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The server name is `runyard` for the default remote and `runyard-<remote>` for\nothers, so one client can talk to several Hubs. &#x2A;*No token is stored in client\nconfigs.** At startup the server resolves its target in this order:"},"1051":{"id":"/guides/mcp-12","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"`RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN` environment variables\n(legacy `SMITHERS_HUB_URL` / `SMITHERS_HUB_TOKEN` and `HUB_URL` / `HUB_TOKEN`\nstill work)"},"1052":{"id":"/guides/mcp-13","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The `--remote <name>` argument, resolved against the saved remotes in\n`~/.runyard/config.json` (written by `runyard login`)"},"1053":{"id":"/guides/mcp-14","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The current saved remote"},"1054":{"id":"/guides/mcp-15","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The token's scopes decide what the tools may do — a token with `mcp` scope can\ndiscover, preflight, and run workflows; `admin` unlocks the admin tools listed\nbelow."},"1055":{"id":"/guides/mcp-16","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"The server exposes **85 tools**, generated from the same API surface registry\nthe Hub's routes and `/openapi.json` come from. Grouped by resource:"},"1056":{"id":"/guides/mcp-17","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Group"},"1057":{"id":"/guides/mcp-18","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Tools"},"1058":{"id":"/guides/mcp-19","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Discovery & identity"},"1059":{"id":"/guides/mcp-20","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`get_menu`, `whoami`, `get_dashboard`, `list_repo_options`"},"1060":{"id":"/guides/mcp-21","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Workflows"},"1061":{"id":"/guides/mcp-22","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_workflows`, `search_workflows`, `describe_workflow`, `get_workflow_source`, `list_workflow_versions`, `create_workflow`†, `update_workflow`†, `delete_workflow`†"},"1062":{"id":"/guides/mcp-23","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Running"},"1063":{"id":"/guides/mcp-24","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`preflight_workflow`, `run_workflow`, `rerun_workflow_run`, `promote_run`, `cancel_run`"},"1064":{"id":"/guides/mcp-25","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Runs (observe)"},"1065":{"id":"/guides/mcp-26","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_runs`, `get_run_status`, `get_run_events`, `get_run_timeline`, `get_run_diagnostics`, `get_run_logs`"},"1066":{"id":"/guides/mcp-27","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Run drafts"},"1067":{"id":"/guides/mcp-28","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_run_drafts`, `get_run_draft`, `create_run_draft`, `update_run_draft`, `submit_run_draft`, `discard_run_draft`"},"1068":{"id":"/guides/mcp-29","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Schedules"},"1069":{"id":"/guides/mcp-30","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_schedules`, `get_schedule`, `preview_schedule`, `create_schedule`†, `update_schedule`†, `enable_schedule`†, `disable_schedule`†, `delete_schedule`†, `run_schedule_now`†"},"1070":{"id":"/guides/mcp-31","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Approvals"},"1071":{"id":"/guides/mcp-32","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_pending_approvals`, `list_approvals`, `get_approval`, `create_approval`, `approve_run`, `reject_run`, `request_changes_run`"},"1072":{"id":"/guides/mcp-33","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Artifacts"},"1073":{"id":"/guides/mcp-34","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`get_run_artifacts`, `search_artifacts`, `download_artifact`"},"1074":{"id":"/guides/mcp-35","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Runners"},"1075":{"id":"/guides/mcp-36","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_runners`"},"1076":{"id":"/guides/mcp-37","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Tokens"},"1077":{"id":"/guides/mcp-38","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_tokens`†, `create_token`†, `revoke_token`†"},"1078":{"id":"/guides/mcp-39","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Secrets"},"1079":{"id":"/guides/mcp-40","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_secrets`†, `set_secret`†, `delete_secret`† (names and metadata only — values are never readable)"},"1080":{"id":"/guides/mcp-41","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Hooks"},"1081":{"id":"/guides/mcp-42","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_hooks`, `get_hook`, `upsert_hook`†, `validate_hook`†"},"1082":{"id":"/guides/mcp-43","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Workflow endpoints"},"1083":{"id":"/guides/mcp-44","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_workflow_endpoints`†, `get_workflow_endpoint`†, `upsert_workflow_endpoint`†, `submit_workflow_endpoint`"},"1084":{"id":"/guides/mcp-45","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Workflow bundles"},"1085":{"id":"/guides/mcp-46","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_workflow_bundles`, `get_workflow_bundle`, `publish_workflow_bundle`†"},"1086":{"id":"/guides/mcp-47","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Workflow packages"},"1087":{"id":"/guides/mcp-48","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`export_workflow_package`†, `validate_workflow_package`†, `preview_workflow_import`†, `import_workflow_package`†"},"1088":{"id":"/guides/mcp-49","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Catalog"},"1089":{"id":"/guides/mcp-50","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_agents`, `list_skills`, `search_knowledge`, `create_agent`†, `update_agent`†, `create_skill`†, `update_skill`†, `create_knowledge`†, `update_knowledge`†"},"1090":{"id":"/guides/mcp-51","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Admin & updates"},"1091":{"id":"/guides/mcp-52","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`get_audit_log`†, `list_alerts`†, `get_update_status`†, `apply_update`†"},"1092":{"id":"/guides/mcp-53","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Assistant"},"1093":{"id":"/guides/mcp-54","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`get_assistant_status`, `ask_assistant`"},"1094":{"id":"/guides/mcp-55","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Tools marked † require an admin-scoped token."},"1095":{"id":"/guides/mcp-56","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Workflow source is always created and edited **through these tools** —\n`create_workflow` / `update_workflow` take inline source bytes or an existing\n`workflow.bundleId`, and `import_workflow_package` installs a portable package\nas a disabled workflow. Bare file paths on the runner are rejected."},"1096":{"id":"/guides/mcp-57","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-parity-guarantee","content":"The tool list, the HTTP routes, and `/openapi.json` are all generated from one\nregistry, and a test fails the build when they drift: **every Hub API operation\nis either exposed as an MCP tool or carries a documented exemption** (exempt\noperations are browser pages, install assets, the runner-to-Hub machine\nprotocol, SSE streams that tools cover by polling, and legacy aliases). If you\ncan do it in the web UI or over HTTP, your agent can do it over MCP."},"1097":{"id":"/guides/mcp-58","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#recommended-agent-flow","content":"**`get_menu`** — orient: catalog, execution modes, follow-up paths."},"1098":{"id":"/guides/mcp-59","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#recommended-agent-flow","content":"**`preflight_workflow`** — dry-run your input; resolve `needs_input`\nquestions and `blocked` blockers before creating anything (or use\n`run_workflow` with `negotiate: true`, or the run-draft tools for a\nmulti-turn negotiation)."},"1099":{"id":"/guides/mcp-60","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#recommended-agent-flow","content":"**`run_workflow`** — include a short human-readable `input.title` so run\nlists and approval cards read well; choose `executionMode` `local` or\n`remote`."},"1100":{"id":"/guides/mcp-61","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#recommended-agent-flow","content":"**`get_run_timeline`** — poll with the returned `nextSince` cursor to page\nforward; drop to `get_run_logs` / `get_run_diagnostics` when something looks\nwrong, and fetch results with `get_run_artifacts` + `download_artifact`."},"1101":{"id":"/guides/mcp-62","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#recommended-agent-flow","content":"If a run pauses for a human, `list_pending_approvals` shows the card and\n`approve_run` / `reject_run` / `request_changes_run` resolve it (by\n`approvalId`, not `runId`)."},"1102":{"id":"/guides/releases","page_id":"/guides/releases","type":"page","content":"Versioning and releases","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/releases"},"1103":{"id":"/guides/releases-0","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases","content":"How Runyard itself is versioned, gated, released, and self-updated — and how the docs track each release."},"1104":{"id":"/guides/releases-1","page_id":"/guides/releases","type":"heading","tags":[],"url":"/guides/releases#ci-pipeline","content":"CI pipeline"},"1105":{"id":"/guides/releases-2","page_id":"/guides/releases","type":"heading","tags":[],"url":"/guides/releases#the-release-train-helper","content":"The release-train helper"},"1106":{"id":"/guides/releases-3","page_id":"/guides/releases","type":"heading","tags":[],"url":"/guides/releases#self-update-for-deployments","content":"Self-update for deployments"},"1107":{"id":"/guides/releases-4","page_id":"/guides/releases","type":"heading","tags":[],"url":"/guides/releases#docs-stay-current","content":"Docs stay current"},"1108":{"id":"/guides/releases-5","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases","content":"Runyard releases are semver git tags (`vX.Y.Z`). The version in `package.json` is the single source of truth and flows to `/api/version`, the OpenAPI document, the CLI, and the update checker."},"1109":{"id":"/guides/releases-6","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"The GitHub Actions pipeline (`.github/workflows/release.yml` and `images.yml`) has four jobs:"},"1110":{"id":"/guides/releases-7","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Job"},"1111":{"id":"/guides/releases-8","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Trigger"},"1112":{"id":"/guides/releases-9","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"What it does"},"1113":{"id":"/guides/releases-10","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"`test`"},"1114":{"id":"/guides/releases-11","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Every PR and push to `main` (and tags)"},"1115":{"id":"/guides/releases-12","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"`pnpm test` + `pnpm build` on Node 22."},"1116":{"id":"/guides/releases-13","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"`sandbox-smoke`"},"1117":{"id":"/guides/releases-14","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Same"},"1118":{"id":"/guides/releases-15","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Real bubblewrap + AppArmor gate on Ubuntu 24.04: installs bwrap, loads the repo's AppArmor profile via the same script operators run, then runs the sandbox suites with `RUNYARD_REQUIRE_BWRAP=1` so the smoke test fails rather than skips."},"1119":{"id":"/guides/releases-16","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"`release`"},"1120":{"id":"/guides/releases-17","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Pushed `v*` tags"},"1121":{"id":"/guides/releases-18","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Publishes the GitHub Release with generated notes — only after `test` and `sandbox-smoke` are green. A red run never publishes."},"1122":{"id":"/guides/releases-19","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"`build-push` (images)"},"1123":{"id":"/guides/releases-20","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Pushed `v*` tags"},"1124":{"id":"/guides/releases-21","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#ci-pipeline","content":"Builds and pushes GHCR `hub` and `runner` container images behind the same two gates, and records both image digests as a release artifact."},"1125":{"id":"/guides/releases-22","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#the-release-train-helper","content":"`scripts/release-train.mjs` gives operators (and the deployment watchdog) machine-readable release state:"},"1126":{"id":"/guides/releases-23","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#the-release-train-helper","content":"Local gates are `test`, `build`, and `diff-check` (`git diff --check`); `sandbox-smoke` only runs on a real Actions kernel, so its evidence is recorded by hand from a green CI run. Evidence is keyed to the full HEAD SHA in `data/release-evidence.json`, so a green gate can never be inherited across new commits, and `status` tells you the next action (run a gate, fix a failure, tag)."},"1127":{"id":"/guides/releases-24","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"A deployed Hub checks the public GitHub Releases API passively (outbound-only, `UPDATE_CHECK_ENABLED`, default on) and shows admins an update badge."},"1128":{"id":"/guides/releases-25","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"Surface"},"1129":{"id":"/guides/releases-26","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"Operation"},"1130":{"id":"/guides/releases-27","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"HTTP"},"1131":{"id":"/guides/releases-28","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"`GET /api/update-status` (admin) — is a newer release available, current update state."},"1132":{"id":"/guides/releases-29","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"HTTP"},"1133":{"id":"/guides/releases-30","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"`POST /api/update/apply` (admin) — apply the update over HTTP; disabled unless `UPDATE_APPLY_ENABLED=1`."},"1134":{"id":"/guides/releases-31","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"MCP"},"1135":{"id":"/guides/releases-32","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"`get_update_status`, `apply_update`."},"1136":{"id":"/guides/releases-33","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"CLI"},"1137":{"id":"/guides/releases-34","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"`runyard update [tag]` on the host — the recommended path."},"1138":{"id":"/guides/releases-35","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#self-update-for-deployments","content":"`runyard update` drains runners (bounded grace window; it aborts rather than kill in-flight runs), swaps the checkout to the new tag, restarts services, verifies health, and rolls back automatically on failure. The data directory (database, secrets, artifacts) survives every update and rollback."},"1139":{"id":"/guides/releases-36","page_id":"/guides/releases","tags":[],"type":"text","url":"/guides/releases#docs-stay-current","content":"Runyard ships a repo-agnostic `docs-update` workflow that keeps documentation honest against each release. When a release is published, a GitHub Actions step triggers it on the project's own Hub through an authenticated workflow endpoint (`release-docs-update`); the workflow inspects only the git diff between the previous and new release tags — never the whole repository — and reports proposed documentation updates. In its opt-in `apply` mode it edits docs in an isolated worktree branch instead, and that branch reaches the target branch only through a human-approved run promotion. The repository, docs path, docs framework, and file-selection rules are all workflow inputs, so any repo can adopt it."},"1140":{"id":"/guides/security","page_id":"/guides/security","type":"page","content":"Security model","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/security"},"1141":{"id":"/guides/security-0","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security","content":"Trust boundary, token scopes, secrets handling, runner sandboxing, and production posture for a Runyard deployment."},"1142":{"id":"/guides/security-1","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#trust-boundary","content":"Trust boundary"},"1143":{"id":"/guides/security-2","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#scopes","content":"Scopes"},"1144":{"id":"/guides/security-3","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#secrets","content":"Secrets"},"1145":{"id":"/guides/security-4","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#workflow-endpoints","content":"Workflow endpoints"},"1146":{"id":"/guides/security-5","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#approval-gating","content":"Approval gating"},"1147":{"id":"/guides/security-6","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#runner-sandboxing","content":"Runner sandboxing"},"1148":{"id":"/guides/security-7","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#production-posture","content":"Production posture"},"1149":{"id":"/guides/security-8","page_id":"/guides/security","type":"heading","tags":[],"url":"/guides/security#what-stays-out-of-public-discovery-docs","content":"What stays out of public discovery docs"},"1150":{"id":"/guides/security-9","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security","content":"Runyard is one private deployment per company, and the security model follows from that: a small, deliberate unauthenticated surface; scoped bearer tokens for everything else; secrets encrypted at rest and never echoed; and approval gates in front of dangerous work."},"1151":{"id":"/guides/security-10","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Every operation requires either a bearer access token (`Authorization: Bearer ...`) or a browser session created by exchanging such a token — and the session carries exactly the token's scopes, no extra power. The unauthenticated surface is deliberately tiny:"},"1152":{"id":"/guides/security-11","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Endpoint"},"1153":{"id":"/guides/security-12","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Purpose"},"1154":{"id":"/guides/security-13","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"`/healthz`, `/readyz`"},"1155":{"id":"/guides/security-14","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Liveness/readiness probes."},"1156":{"id":"/guides/security-15","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"`/api/version`, `/version`"},"1157":{"id":"/guides/security-16","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Product name and version."},"1158":{"id":"/guides/security-17","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"`/`, `/app`, `/docs`"},"1159":{"id":"/guides/security-18","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Landing page, app shell, documentation pages (data still requires auth)."},"1160":{"id":"/guides/security-19","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"`/llms.txt`"},"1161":{"id":"/guides/security-20","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Static, generic agent discovery document."},"1162":{"id":"/guides/security-21","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"`/openapi.json`"},"1163":{"id":"/guides/security-22","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Generated API description."},"1164":{"id":"/guides/security-23","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"`/install.sh`, `/cli.tgz`"},"1165":{"id":"/guides/security-24","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Client install assets."},"1166":{"id":"/guides/security-25","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#trust-boundary","content":"Two narrow exceptions authenticate by other means: `POST /api/telegram/webhook` is verified against the configured bot and webhook secret, and `POST /api/workflow-endpoints/{slug}` submissions authenticate with that endpoint's own secret (below). `GET /api/setup` returns only a reduced identity payload (instance name, auth mode) to unauthenticated callers."},"1167":{"id":"/guides/security-26","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Tokens carry scopes; admins mint them from the Connect tab or `POST /api/tokens`."},"1168":{"id":"/guides/security-27","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Scope"},"1169":{"id":"/guides/security-28","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Grants"},"1170":{"id":"/guides/security-29","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"`api`"},"1171":{"id":"/guides/security-30","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Run workflows and read runs over HTTP."},"1172":{"id":"/guides/security-31","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"`mcp`"},"1173":{"id":"/guides/security-32","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"The same operations over the MCP server."},"1174":{"id":"/guides/security-33","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"`runner`"},"1175":{"id":"/guides/security-34","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"The runner protocol: register, heartbeat, claim runs, report lifecycle."},"1176":{"id":"/guides/security-35","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"`approvals`"},"1177":{"id":"/guides/security-36","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Create and resolve approval cards (the scope Telegram WebApp sessions get)."},"1178":{"id":"/guides/security-37","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"`admin`"},"1179":{"id":"/guides/security-38","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Superscope: satisfies every scope requirement and gates all mutation of workflows, secrets, tokens, schedules, hooks, and updates."},"1180":{"id":"/guides/security-39","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#scopes","content":"Runner tokens are additionally subject to **run-ownership checks**: a run's lifecycle endpoints (`start`, `events`, `complete`, `fail`, artifact upload) only accept the runner that owns the run, or an admin. One compromised runner token cannot report on, or interfere with, another runner's work."},"1181":{"id":"/guides/security-40","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#secrets","content":"The reusable secret store is enabled by setting `SECRETS_ENC_KEY` (a 32-byte key) on the Hub; without a valid key the feature is disabled rather than degraded. Values are encrypted at rest and are write-only from the API's point of view: `GET /api/secrets` returns names and metadata, never values, and secrets are redacted from API responses, events, approval cards, and audit entries. Workflows reference secrets by name; the Hub injects values into runs that declared them."},"1182":{"id":"/guides/security-41","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#workflow-endpoints","content":"Fixed-purpose webhook-style intake (`POST /api/workflow-endpoints/{slug}`) is designed for exposure to semi-trusted callers: each endpoint has its **own** secret (not a Hub token), plus rate limits, payload size caps, and deduplication. An endpoint can only trigger the single workflow an admin configured it for — a leaked endpoint secret does not grant API access."},"1183":{"id":"/guides/security-42","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#approval-gating","content":"Workflows whose consequences warrant a human get an `approvalPolicy` that holds runs in `waiting_approval` until someone approves; mid-run engine gates and gated side effects (post-run hook profiles are admin-defined and admin-configured) use the same approval cards. See Approvals."},"1184":{"id":"/guides/security-43","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#runner-sandboxing","content":"Runners can execute workflow processes inside a bubblewrap sandbox (`RUNNER_SANDBOX=bubblewrap`), and the repo ships a narrow AppArmor profile (`deploy/apparmor/install.sh`) that grants unprivileged user-namespace creation to bwrap on Ubuntu 24.04+ kernels that restrict it. This is not on faith: CI runs a `sandbox-smoke` job on every push that installs bubblewrap, loads the profile through the same operator install script, and runs the sandbox suites with `RUNYARD_REQUIRE_BWRAP=1` so the real-bwrap smoke test fails instead of silently skipping if the path regresses."},"1185":{"id":"/guides/security-44","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#production-posture","content":"**TLS reverse proxy** — keep the Hub on `127.0.0.1` and terminate TLS in front (the installer prints a Caddy snippet); set `BASE_URL` to the https URL."},"1186":{"id":"/guides/security-45","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#production-posture","content":"**Session secret** — set `RUNYARD_HUB_SESSION_SECRET` explicitly in production (the installer generates one)."},"1187":{"id":"/guides/security-46","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#production-posture","content":"**`SECRETS_ENC_KEY`** — set it once and guard it; rotating the key makes previously stored secrets unreadable."},"1188":{"id":"/guides/security-47","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#production-posture","content":"**Token hygiene** — issue narrow scopes, set `expiresInDays` on tokens for humans, and revoke with `DELETE /api/tokens/{id}`; retire the bootstrap token once real admin tokens exist."},"1189":{"id":"/guides/security-48","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#production-posture","content":"**Audit log review** — every actor-attributable action lands in the audit log (`runyard audit`, `GET /api/audit`, `get_audit_log`)."},"1190":{"id":"/guides/security-49","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#production-posture","content":"**Updates** — leave `UPDATE_APPLY_ENABLED` off unless you want the admin-gated HTTP apply; prefer `runyard update` on the host. See Releases."},"1191":{"id":"/guides/security-50","page_id":"/guides/security","tags":[],"type":"text","url":"/guides/security#what-stays-out-of-public-discovery-docs","content":"`/llms.txt` and `/openapi.json` are static and generic by design: they describe the product and its surfaces, never your deployment. The live workflow catalog, runner details, secret names, and operator configuration are only available behind auth (`GET /api/menu`, `GET /api/workflows`). An unauthenticated crawler learns that a Runyard exists — not what yours can do."},"1192":{"id":"/guides/troubleshooting","page_id":"/guides/troubleshooting","type":"page","content":"Troubleshooting","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/troubleshooting"},"1193":{"id":"/guides/troubleshooting-0","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting","content":"Practical fixes for stuck runs, failure classes, preflight blockers, auth errors, and delivery problems."},"1194":{"id":"/guides/troubleshooting-1","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#a-run-is-stuck-in-queued","content":"A run is stuck in `queued`"},"1195":{"id":"/guides/troubleshooting-2","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#a-run-is-in-waiting_approval","content":"A run is in `waiting_approval`"},"1196":{"id":"/guides/troubleshooting-3","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#failure-classes","content":"Failure classes"},"1197":{"id":"/guides/troubleshooting-4","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#preflight-blockers","content":"Preflight blockers"},"1198":{"id":"/guides/troubleshooting-5","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#401--403-responses","content":"401 / 403 responses"},"1199":{"id":"/guides/troubleshooting-6","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#secrets-not-configured","content":"Secrets not configured"},"1200":{"id":"/guides/troubleshooting-7","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#telegram-not-delivering","content":"Telegram not delivering"},"1201":{"id":"/guides/troubleshooting-8","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#runner-agent-auth-expired","content":"Runner agent auth expired"},"1202":{"id":"/guides/troubleshooting-9","page_id":"/guides/troubleshooting","type":"heading","tags":[],"url":"/guides/troubleshooting#where-to-look-generally","content":"Where to look, generally"},"1203":{"id":"/guides/troubleshooting-10","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#a-run-is-stuck-in-queued","content":"A queued run means no runner has claimed it — either no runner is online, or none matches the run's required tags / requested location (`local` vs `vps`/`remote`)."},"1204":{"id":"/guides/troubleshooting-11","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#a-run-is-stuck-in-queued","content":"A runner is considered offline after \\~30 seconds without a heartbeat. If the runner should be online, check its service logs on the runner host:"},"1205":{"id":"/guides/troubleshooting-12","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#a-run-is-stuck-in-queued","content":"Common causes: the runner unit is idling because `RUNYARD_HUB_TOKEN` is empty or revoked; the runner's tags do not include what the workflow requires (`requiredRunnerTags`, for example `smithers`); or the run asked for `--where local` and only `vps` runners are registered. Running `runyard preflight <workflow>` before enqueueing catches `no_matching_runner` up front."},"1206":{"id":"/guides/troubleshooting-13","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#a-run-is-in-waiting_approval","content":"The run is held on an approval card, which is by design: approval-held runs are never failed or reaped for waiting. Find and resolve the card — web **Approvals**, `runyard approvals` then `runyard approve|reject|request-changes <approval-id>`, or the MCP tools. See Approvals."},"1207":{"id":"/guides/troubleshooting-14","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Terminal failures carry a class so you know whether to fix input, config, or infrastructure:"},"1208":{"id":"/guides/troubleshooting-15","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Class"},"1209":{"id":"/guides/troubleshooting-16","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Meaning"},"1210":{"id":"/guides/troubleshooting-17","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"What to do"},"1211":{"id":"/guides/troubleshooting-18","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`blocked_by_gate`"},"1212":{"id":"/guides/troubleshooting-19","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"A quality gate (tests, lint, typecheck, build, eval) failed inside the workflow."},"1213":{"id":"/guides/troubleshooting-20","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Read the run logs for the gate output; fix the underlying work and re-run."},"1214":{"id":"/guides/troubleshooting-21","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`blocked_by_preflight`"},"1215":{"id":"/guides/troubleshooting-22","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"The runner's preflight refused to execute (missing workflow source, auth not ready, repo path problems)."},"1216":{"id":"/guides/troubleshooting-23","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Check run diagnostics; fix workflow config or runner setup."},"1217":{"id":"/guides/troubleshooting-24","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`provider_limited`"},"1218":{"id":"/guides/troubleshooting-25","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Model provider rate limit / quota / overload."},"1219":{"id":"/guides/troubleshooting-26","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Wait and re-run; check the provider account."},"1220":{"id":"/guides/troubleshooting-27","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`timed_out`"},"1221":{"id":"/guides/troubleshooting-28","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"The run exceeded a deadline or an operation timed out."},"1222":{"id":"/guides/troubleshooting-29","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Re-run; if recurring, raise the workflow's time budget or shrink the job."},"1223":{"id":"/guides/troubleshooting-30","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`invalid_output`"},"1224":{"id":"/guides/troubleshooting-31","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"The agent's output failed schema validation."},"1225":{"id":"/guides/troubleshooting-32","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Inspect logs; tighten the prompt or loosen the output schema."},"1226":{"id":"/guides/troubleshooting-33","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`infra_unavailable`"},"1227":{"id":"/guides/troubleshooting-34","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Network/DNS/disk/spawn failures, runner offline mid-run."},"1228":{"id":"/guides/troubleshooting-35","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Fix the runner host; re-run."},"1229":{"id":"/guides/troubleshooting-36","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`needs_human`"},"1230":{"id":"/guides/troubleshooting-37","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"The workflow concluded a human must act."},"1231":{"id":"/guides/troubleshooting-38","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Read the run output and the linked approval/escalation card."},"1232":{"id":"/guides/troubleshooting-39","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"`failed`"},"1233":{"id":"/guides/troubleshooting-40","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Unclassified failure."},"1234":{"id":"/guides/troubleshooting-41","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#failure-classes","content":"Start with diagnostics and logs."},"1235":{"id":"/guides/troubleshooting-42","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#preflight-blockers","content":"`runyard preflight <workflow>` (or `POST /api/workflows/{id}/preflight`) reports `ready`, `needs_input` (with questions — usually missing required input fields), or `blocked` with coded blockers, including:"},"1236":{"id":"/guides/troubleshooting-43","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#preflight-blockers","content":"`missing_secret` / `secrets_unavailable` — required secrets are not stored, or the secret store is disabled (set `SECRETS_ENC_KEY` on the Hub, then `PUT /api/secrets/{key}`)."},"1237":{"id":"/guides/troubleshooting-44","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#preflight-blockers","content":"`no_matching_runner` — no registered runner matches the required tags/location."},"1238":{"id":"/guides/troubleshooting-45","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#preflight-blockers","content":"`workflow_disabled`, `workflow_not_found` — an admin can re-enable via `PATCH /api/workflows/{id}`."},"1239":{"id":"/guides/troubleshooting-46","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#preflight-blockers","content":"`workflow_bundle_missing` / `workflow_source_missing` — the definition references source that is not published; send source bytes via `update_workflow`."},"1240":{"id":"/guides/troubleshooting-47","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#preflight-blockers","content":"`repo_dir_invalid`, `hook_blocked` — input points outside allowlisted repos, or requests hook profiles that are not enabled for the workflow."},"1241":{"id":"/guides/troubleshooting-48","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#401--403-responses","content":"`401` means no valid token; `403 insufficient scope` means the token lacks the required scope (the response names it). Check what you are authenticated as:"},"1242":{"id":"/guides/troubleshooting-49","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#401--403-responses","content":"Admin actions (creating workflows, secrets, tokens, schedules) need `admin`; running workflows needs `api` or `mcp`; the runner protocol needs `runner`. Ask a Hub admin for a token with the right scopes."},"1243":{"id":"/guides/troubleshooting-50","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#secrets-not-configured","content":"If secret endpoints return an error about the store being disabled, the Hub has no valid `SECRETS_ENC_KEY`. Set a 32-byte base64/hex key in the Hub env file and restart. Note that rotating an existing key makes previously stored secrets unreadable."},"1244":{"id":"/guides/troubleshooting-51","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#telegram-not-delivering","content":"Verify, in order: `TELEGRAM_BOT_TOKEN` and `TELEGRAM_APPROVAL_CHAT_ID` are set on the Hub; the bot's webhook points at `https://hub.example.com/api/telegram/webhook` with the matching `TELEGRAM_WEBHOOK_SECRET`; the bot is a member of the target chat; and the users pressing buttons are listed in `TELEGRAM_APPROVAL_USER_IDS`. Response-endpoint deliveries record their state (`status`, `attempts`, `last_error`) on `GET /api/runs/{id}` under `responseEndpoints[]`."},"1245":{"id":"/guides/troubleshooting-52","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#runner-agent-auth-expired","content":"Runs failing with provider auth errors usually mean the runner's `codex`/`claude` CLI login lapsed. On hosts with `REAUTH_ENABLED=1`, an admin can trigger re-auth from the web app (runner card → Re-auth): the Hub surfaces a verification URL and user code, and never token material. Otherwise, log in on the runner host directly (`codex login`, `claude setup-token`)."},"1246":{"id":"/guides/troubleshooting-53","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"Surface"},"1247":{"id":"/guides/troubleshooting-54","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"What it tells you"},"1248":{"id":"/guides/troubleshooting-55","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"`GET /api/runs/{id}/diagnostics`"},"1249":{"id":"/guides/troubleshooting-56","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"Structured diagnosis + log summary for a run (`get_run_diagnostics`)."},"1250":{"id":"/guides/troubleshooting-57","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"`runyard tail <run-id>`"},"1251":{"id":"/guides/troubleshooting-58","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"Unified timeline: status transitions, events, artifacts as NDJSON."},"1252":{"id":"/guides/troubleshooting-59","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"`runyard audit`"},"1253":{"id":"/guides/troubleshooting-60","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"Who did what (admin)."},"1254":{"id":"/guides/troubleshooting-61","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"`GET /readyz`"},"1255":{"id":"/guides/troubleshooting-62","page_id":"/guides/troubleshooting","tags":[],"type":"text","url":"/guides/troubleshooting#where-to-look-generally","content":"Hub readiness — `503` means the Hub cannot serve (for example a database problem)."},"1256":{"id":"/guides/workflows-authoring","page_id":"/guides/workflows-authoring","type":"page","content":"Authoring workflows","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/workflows-authoring"},"1257":{"id":"/guides/workflows-authoring-0","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring","content":"Create and edit workflows by sending source bytes over the API or MCP; the Hub stores them as immutable, versioned bundles."},"1258":{"id":"/guides/workflows-authoring-1","page_id":"/guides/workflows-authoring","type":"heading","tags":[],"url":"/guides/workflows-authoring#definition-anatomy","content":"Definition anatomy"},"1259":{"id":"/guides/workflows-authoring-2","page_id":"/guides/workflows-authoring","type":"heading","tags":[],"url":"/guides/workflows-authoring#a-minimal-real-example","content":"A minimal, real example"},"1260":{"id":"/guides/workflows-authoring-3","page_id":"/guides/workflows-authoring","type":"heading","tags":[],"url":"/guides/workflows-authoring#updating-a-workflow","content":"Updating a workflow"},"1261":{"id":"/guides/workflows-authoring-4","page_id":"/guides/workflows-authoring","type":"heading","tags":[],"url":"/guides/workflows-authoring#moving-workflows-between-hubs-workflow-packages","content":"Moving workflows between Hubs: workflow packages"},"1262":{"id":"/guides/workflows-authoring-5","page_id":"/guides/workflows-authoring","type":"heading","tags":[],"url":"/guides/workflows-authoring#the-web-editor","content":"The web editor"},"1263":{"id":"/guides/workflows-authoring-6","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring","content":"Workflows are stored in the Hub database as immutable, versioned source bundles. You create or update a workflow by sending its definition — **including the workflow source bytes** — over HTTP (`POST /api/workflows`, `PATCH /api/workflows/{id}`) or MCP (`create_workflow` / `update_workflow`). The Hub publishes the source as a hash-addressed bundle and records its id on the definition as `workflow.bundleId`."},"1264":{"id":"/guides/workflows-authoring-7","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring","content":"Do NOT write workflow files to disk: custom workflow definitions that reference bare `workflow.entry` file paths without source bytes are rejected (`workflow_source_required`). Repository-authored workflow files are reserved for the shipped internal/dev seed catalog only. The web app's workflow editor is not an exception — it calls these same API endpoints."},"1265":{"id":"/guides/workflows-authoring-8","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring","content":"Both operations require an admin-scoped token."},"1266":{"id":"/guides/workflows-authoring-9","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Field"},"1267":{"id":"/guides/workflows-authoring-10","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Meaning"},"1268":{"id":"/guides/workflows-authoring-11","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`slug`"},"1269":{"id":"/guides/workflows-authoring-12","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Stable identifier used in URLs, the CLI, and MCP (`runyard run <slug>`)."},"1270":{"id":"/guides/workflows-authoring-13","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`name`"},"1271":{"id":"/guides/workflows-authoring-14","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Human-readable display name."},"1272":{"id":"/guides/workflows-authoring-15","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`description`"},"1273":{"id":"/guides/workflows-authoring-16","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"What the workflow does; shown in the catalog and menus."},"1274":{"id":"/guides/workflows-authoring-17","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`category`"},"1275":{"id":"/guides/workflows-authoring-18","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Catalog grouping (for example `Examples`, `Operations`)."},"1276":{"id":"/guides/workflows-authoring-19","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`inputSchema`"},"1277":{"id":"/guides/workflows-authoring-20","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"JSON Schema for run input. Required fields drive preflight questions."},"1278":{"id":"/guides/workflows-authoring-21","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`outputSchema`"},"1279":{"id":"/guides/workflows-authoring-22","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"JSON Schema for the structured run output."},"1280":{"id":"/guides/workflows-authoring-23","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`requiredRunnerTags`"},"1281":{"id":"/guides/workflows-authoring-24","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Tags a runner must advertise to claim runs (for example `[\"smithers\"]`)."},"1282":{"id":"/guides/workflows-authoring-25","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`approvalPolicy`"},"1283":{"id":"/guides/workflows-authoring-26","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Whether runs hold for a human approval before executing (`{ \"required\": true }`)."},"1284":{"id":"/guides/workflows-authoring-27","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`workflow.engine`"},"1285":{"id":"/guides/workflows-authoring-28","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Execution engine; `\"smithers\"`."},"1286":{"id":"/guides/workflows-authoring-29","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`workflow.source`"},"1287":{"id":"/guides/workflows-authoring-30","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"The workflow source bytes, sent inline as a string (aliases: `workflow.sourceBytes`, `workflow.code`)."},"1288":{"id":"/guides/workflows-authoring-31","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"`workflow.language`"},"1289":{"id":"/guides/workflows-authoring-32","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#definition-anatomy","content":"Source language, defaults to `tsx`."},"1290":{"id":"/guides/workflows-authoring-33","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#a-minimal-real-example","content":"The source is a small Smithers TSX workflow (modeled on the seeded `hello` workflow): one task, structured output validated with Zod."},"1291":{"id":"/guides/workflows-authoring-34","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#a-minimal-real-example","content":"Create the workflow by sending that source inline as `workflow.source` (a JSON string — the TSX above, escaped):"},"1292":{"id":"/guides/workflows-authoring-35","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#a-minimal-real-example","content":"Over MCP the same payload goes to `create_workflow` as the `workflow` argument. The response definition carries `workflow.bundleId` instead of the inline source — the bytes now live in the Hub DB. Runners fetch the bundle at execution time; nothing needs to exist on any runner's filesystem beforehand."},"1293":{"id":"/guides/workflows-authoring-36","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#updating-a-workflow","content":"Send the changed definition — again with source bytes inline — via `PATCH /api/workflows/{id}` or `update_workflow`. The Hub publishes a **new** bundle version and repoints `workflow.bundleId`; existing bundles are never mutated, so historical runs keep an exact record of what they executed. Identical bytes are deduplicated by hash rather than republished."},"1294":{"id":"/guides/workflows-authoring-37","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#updating-a-workflow","content":"Inspect what is stored:"},"1295":{"id":"/guides/workflows-authoring-38","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#updating-a-workflow","content":"The corresponding MCP tools are `get_workflow_source`, `list_workflow_bundles`, and `get_workflow_bundle` (which does include the source). You can also publish a bundle directly with `POST /api/workflow-bundles` / `publish_workflow_bundle` and reference it by `workflow.bundleId`, but prefer inline source — the Hub publishes the bundle for you."},"1296":{"id":"/guides/workflows-authoring-39","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#moving-workflows-between-hubs-workflow-packages","content":"Admins can export a workflow as a portable `.runyard-workflow.json` package file. It contains the workflow source bytes, metadata, requirements, and content hashes — never secret values."},"1297":{"id":"/guides/workflows-authoring-40","page_id":"/guides/workflows-authoring","tags":[],"type":"text","url":"/guides/workflows-authoring#moving-workflows-between-hubs-workflow-packages","content":"Imports publish the package's source as a DB workflow bundle and install the workflow **disabled** until the receiving Hub's secrets, runners, and configuration are ready; an admin enables it with `PATCH /api/workflows/{id}`. The HTTP equivalents live under `/api/workflow-packages/*`, and MCP exposes `export_workflow_package`, `validate_workflow_package`, `preview_workflow_import`, and `import_workflow_package`."},"1298":{"id":"/guides/workflows