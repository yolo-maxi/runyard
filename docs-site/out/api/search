6":3,"1517":3,"1518":3,"1519":3,"1520":3,"1521":3,"1522":3,"1523":3,"1524":3,"1525":3,"1526":3,"1527":3,"1528":3,"1529":3,"1530":3,"1531":3,"1532":3,"1533":3,"1534":3,"1535":3,"1536":3,"1537":3,"1538":3,"1539":3,"1540":3,"1541":3,"1542":3,"1543":2,"1544":2,"1545":3,"1546":3,"1547":3,"1548":3,"1549":3,"1550":3,"1551":3,"1552":3,"1553":3,"1554":3,"1555":3,"1556":3,"1557":3,"1558":3,"1559":3,"1560":3,"1561":3,"1562":3,"1563":3,"1564":3,"1565":3,"1566":3,"1567":3,"1568":3,"1569":3,"1570":3,"1571":3,"1572":3,"1573":3,"1574":3,"1575":3,"1576":3,"1577":3,"1578":3,"1579":3,"1580":3,"1581":3,"1582":3,"1583":3,"1584":3,"1585":3,"1586":3,"1587":3,"1588":3,"1589":3,"1590":3,"1591":3,"1592":3,"1593":3,"1594":3,"1595":3,"1596":3,"1597":3,"1598":3,"1599":3,"1600":3,"1601":3,"1602":3,"1603":3,"1604":3,"1605":3,"1606":3,"1607":2,"1608":2,"1609":3,"1610":3,"1611":3,"1612":3,"1613":3,"1614":2,"1615":2,"1616":2,"1617":3,"1618":3,"1619":3,"1620":3,"1621":3,"1622":3,"1623":3,"1624":3,"1625":3,"1626":3,"1627":3,"1628":3,"1629":3,"1630":3,"1631":3,"1632":3,"1633":3,"1634":3,"1635":3,"1636":3,"1637":3,"1638":3,"1639":3,"1640":3,"1641":3,"1642":3,"1643":3,"1644":3,"1645":3,"1646":3,"1647":3,"1648":3,"1649":3}}},"docs":{"docs":{"1":{"id":"/","page_id":"/","type":"page","content":"What is Runyard","breadcrumbs":["Docs"],"tags":[],"url":"/"},"2":{"id":"/-0","page_id":"/","tags":[],"type":"text","url":"/","content":"A self-hosted control plane for agent runs — workflows in, durable runs, logs, artifacts, and approvals out."},"3":{"id":"/-1","page_id":"/","type":"heading","tags":[],"url":"/#next-steps","content":"Next steps"},"4":{"id":"/-2","page_id":"/","tags":[],"type":"text","url":"/","content":"Runyard is a self-hosted control plane for agent runs. Agents and humans trigger workflows over MCP, the CLI, the HTTP API, or the web app; runners execute those workflows with the Smithers engine; and the Hub stores the durable record of everything that happened — runs, logs, events, artifacts, approvals, and knowledge. A run started from a chat agent, a cron schedule, or a terminal all leaves the same auditable trail in the same place."},"5":{"id":"/-3","page_id":"/","tags":[],"type":"text","url":"/","content":"Runyard is designed as one private deployment per company. Your Hub holds your workflow catalog, your secrets, your runners, and your history; nothing about your deployment is published to a shared service, and the only outbound call the Hub makes is a passive read of the public GitHub Releases API to check for updates. Operators, teammates, and their agents all authenticate to the same Hub with scoped access tokens."},"6":{"id":"/-4","page_id":"/","tags":[],"type":"text","url":"/","content":"Runyard is API-first by construction. Every HTTP route the Hub serves is declared in a single API surface registry; the OpenAPI document is generated from it and the MCP tool list is parity-tested against it. The web app is an ordinary API client with no privileged endpoints — anything it can show or do is equally available over the API and MCP, so a third-party client built on those surfaces loses nothing."},"7":{"id":"/-5","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"Quickstart\" href=\"./quickstart\" description=\"Install the Hub, start a runner, and run your first workflow.\" />"},"8":{"id":"/-6","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"Concepts\" href=\"./concepts\" description=\"Workflows, runs, runners, approvals, and the Hub's durable record.\" />"},"9":{"id":"/-7","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"HTTP API\" href=\"./guides/api\" description=\"Drive Runyard from any language with bearer-token auth and openapi.json.\" />"},"10":{"id":"/-8","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"MCP\" href=\"./guides/mcp\" description=\"Connect AI agents to your Hub with the runyard-mcp server.\" />"},"11":{"id":"/quickstart","page_id":"/quickstart","type":"page","content":"Quickstart","breadcrumbs":["Docs"],"tags":[],"url":"/quickstart"},"12":{"id":"/quickstart-0","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart","content":"Install the Hub, sign in with the bootstrap token, start a runner, and run the hello workflow."},"13":{"id":"/quickstart-1","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#1-install-the-hub","content":"1\\. Install the Hub"},"14":{"id":"/quickstart-2","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#2-sign-in-with-the-bootstrap-token","content":"2\\. Sign in with the bootstrap token"},"15":{"id":"/quickstart-3","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#3-install-the-cli-and-log-in","content":"3\\. Install the CLI and log in"},"16":{"id":"/quickstart-4","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#4-start-a-runner","content":"4\\. Start a runner"},"17":{"id":"/quickstart-5","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#5-run-the-hello-workflow","content":"5\\. Run the hello workflow"},"18":{"id":"/quickstart-6","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#6-watch-the-run-and-read-the-results","content":"6\\. Watch the run and read the results"},"19":{"id":"/quickstart-7","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#where-to-go-next","content":"Where to go next"},"20":{"id":"/quickstart-8","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart","content":"This page takes you from a fresh Linux box to a completed workflow run with logs and artifacts in the Hub."},"21":{"id":"/quickstart-9","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#1-install-the-hub","content":"The repository's install script is a one-command, idempotent bootstrap. It installs Node 22 and pnpm if needed, clones Runyard at the latest release tag (default `/opt/runyard`), generates an env file with a `SECRETS_ENC_KEY` and session secret, creates the data directory, and installs systemd units for the Hub and a runner:"},"22":{"id":"/quickstart-10","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#1-install-the-hub","content":"Verify the Hub is up:"},"23":{"id":"/quickstart-11","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#1-install-the-hub","content":"The script never prints secrets, never applies updates automatically, and prints a Caddy reverse-proxy snippet if you want TLS in front (recommended for anything non-local — see the security guide)."},"24":{"id":"/quickstart-12","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#2-sign-in-with-the-bootstrap-token","content":"On first boot the Hub writes a full-admin bootstrap token to `bootstrap-token.txt` in its data directory (with the default install, `/opt/runyard/data/bootstrap-token.txt`, mode 600)."},"25":{"id":"/quickstart-13","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#2-sign-in-with-the-bootstrap-token","content":"Open the web app at your Hub URL (for example `https://hub.example.com`) and paste the bootstrap token into the sign-in form. The browser session carries exactly the token's scopes — the bootstrap token is admin, so you can now mint narrower tokens for everything else from the Connect tab."},"26":{"id":"/quickstart-14","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#3-install-the-cli-and-log-in","content":"Each deployment serves its own CLI install script:"},"27":{"id":"/quickstart-15","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#3-install-the-cli-and-log-in","content":"It installs the `runyard` and `runyard-mcp` commands into `~/.local/bin` and prompts for an access token. You can also log in later:"},"28":{"id":"/quickstart-16","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"Runners execute workflows with the Smithers engine, so a runner host needs `bun`, `smithers`, and at least one authenticated agent CLI (`claude`, `codex`, or `pi`) on its PATH."},"29":{"id":"/quickstart-17","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"If you used the Hub install script, a `runyard-runner` systemd unit is already installed and idling. Mint a runner-scoped token, put it in `/etc/runyard/runner.env` as `RUNYARD_HUB_TOKEN=...`, then:"},"30":{"id":"/quickstart-18","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"To run an ad-hoc runner on any other machine (for example your laptop, for `local` execution):"},"31":{"id":"/quickstart-19","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"`runner setup` checks prerequisites and scaffolds the Smithers workspace the runner executes in. Confirm the runner is online:"},"32":{"id":"/quickstart-20","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"`hello` is a minimal seeded workflow that proves end-to-end execution: it asks the runner's Claude CLI for one sentence and returns structured output."},"33":{"id":"/quickstart-21","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"Web: open **Workflows**, pick &#x2A;*Hello (Smithers proof)**, fill in `topic`, and click Run."},"34":{"id":"/quickstart-22","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"CLI:"},"35":{"id":"/quickstart-23","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"MCP (from any connected agent):"},"36":{"id":"/quickstart-24","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#6-watch-the-run-and-read-the-results","content":"The same data lives at `GET /api/runs/{id}`, `/api/runs/{id}/timeline`, `/api/runs/{id}/logs`, and `/api/runs/{id}/artifacts`, and in the web run page — the Hub is the source of truth even when execution happened on a local runner."},"37":{"id":"/quickstart-25","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#where-to-go-next","content":"Authoring workflows — create your own workflows over the API or MCP."},"38":{"id":"/quickstart-26","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#where-to-go-next","content":"Approvals — put human checkpoints in front of dangerous work."},"39":{"id":"/quickstart-27","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#where-to-go-next","content":"Agent consumers — point AI agents at your Hub."},"40":{"id":"/concepts/agents-skills-knowledge","page_id":"/concepts/agents-skills-knowledge","type":"page","content":"Agents, Skills & Knowledge","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/agents-skills-knowledge"},"41":{"id":"/concepts/agents-skills-knowledge-0","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge","content":"The shared catalog of reusable agent roles, skills, and knowledge resources that workflows reference."},"42":{"id":"/concepts/agents-skills-knowledge-1","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"The three catalogs"},"43":{"id":"/concepts/agents-skills-knowledge-2","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#how-workflows-reference-them","content":"How workflows reference them"},"44":{"id":"/concepts/agents-skills-knowledge-3","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#who-can-edit","content":"Who can edit"},"45":{"id":"/concepts/agents-skills-knowledge-4","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#api--mcp","content":"API & MCP"},"46":{"id":"/concepts/agents-skills-knowledge-5","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge","content":"Alongside workflows, the Hub maintains a shared catalog of reusable building blocks. They live in the database, are readable by any authenticated token, and are edited only by admins — so every workflow on the Hub draws from the same curated set."},"47":{"id":"/concepts/agents-skills-knowledge-6","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Catalog"},"48":{"id":"/concepts/agents-skills-knowledge-7","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"What it is"},"49":{"id":"/concepts/agents-skills-knowledge-8","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"**Agents**"},"50":{"id":"/concepts/agents-skills-knowledge-9","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Reusable agent *roles*: a slug, name, description, instructions, a tool list, linked skill slugs, and tags. A role captures \"how this kind of agent should behave\" once, instead of restating it per workflow."},"51":{"id":"/concepts/agents-skills-knowledge-10","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"**Skills**"},"52":{"id":"/concepts/agents-skills-knowledge-11","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Named, versioned instruction bodies (a slug, description, and body text) that agents and workflows can pull in by slug."},"53":{"id":"/concepts/agents-skills-knowledge-12","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"**Knowledge**"},"54":{"id":"/concepts/agents-skills-knowledge-13","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Reference resources — documents or links with a type, body/URL, and tags — searchable with `?q=` / `search_knowledge`."},"55":{"id":"/concepts/agents-skills-knowledge-14","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"All three are versioned and can be individually enabled/disabled."},"56":{"id":"/concepts/agents-skills-knowledge-15","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#how-workflows-reference-them","content":"A workflow definition declares `requiredAgents` and `requiredSkills` as lists of catalog slugs; `describe_workflow` reports them alongside the schemas so a caller can see what a workflow depends on before running it. Workflow package exports record these requirements, and import preview reports whether the target Hub satisfies them."},"57":{"id":"/concepts/agents-skills-knowledge-16","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#who-can-edit","content":"Reading any catalog requires only an authenticated token. Creating and updating entries requires the `admin` scope — the catalogs are part of the Hub's trusted configuration, like secrets and hook profiles."},"58":{"id":"/concepts/agents-skills-knowledge-17","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#who-can-edit","content":"In the web app the three catalogs share one section with deep links `#agents/agents`, `#agents/skills`, and `#agents/knowledge` (see Deep links)."},"59":{"id":"/concepts/agents-skills-knowledge-18","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Endpoint"},"60":{"id":"/concepts/agents-skills-knowledge-19","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"MCP tool"},"61":{"id":"/concepts/agents-skills-knowledge-20","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Notes"},"62":{"id":"/concepts/agents-skills-knowledge-21","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`GET /api/agents`"},"63":{"id":"/concepts/agents-skills-knowledge-22","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`list_agents`"},"64":{"id":"/concepts/agents-skills-knowledge-23","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`POST /api/agents`"},"65":{"id":"/concepts/agents-skills-knowledge-24","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`create_agent`"},"66":{"id":"/concepts/agents-skills-knowledge-25","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"67":{"id":"/concepts/agents-skills-knowledge-26","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/agents/{slug}`"},"68":{"id":"/concepts/agents-skills-knowledge-27","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_agent`"},"69":{"id":"/concepts/agents-skills-knowledge-28","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"70":{"id":"/concepts/agents-skills-knowledge-29","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`GET /api/skills`"},"71":{"id":"/concepts/agents-skills-knowledge-30","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`list_skills`"},"72":{"id":"/concepts/agents-skills-knowledge-31","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`POST /api/skills`"},"73":{"id":"/concepts/agents-skills-knowledge-32","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`create_skill`"},"74":{"id":"/concepts/agents-skills-knowledge-33","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"75":{"id":"/concepts/agents-skills-knowledge-34","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/skills/{slug}`"},"76":{"id":"/concepts/agents-skills-knowledge-35","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_skill`"},"77":{"id":"/concepts/agents-skills-knowledge-36","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"78":{"id":"/concepts/agents-skills-knowledge-37","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`GET /api/knowledge`"},"79":{"id":"/concepts/agents-skills-knowledge-38","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`search_knowledge`"},"80":{"id":"/concepts/agents-skills-knowledge-39","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`?q=` searches."},"81":{"id":"/concepts/agents-skills-knowledge-40","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`POST /api/knowledge`"},"82":{"id":"/concepts/agents-skills-knowledge-41","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`create_knowledge`"},"83":{"id":"/concepts/agents-skills-knowledge-42","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"84":{"id":"/concepts/agents-skills-knowledge-43","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/knowledge/{slug}`"},"85":{"id":"/concepts/agents-skills-knowledge-44","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_knowledge`"},"86":{"id":"/concepts/agents-skills-knowledge-45","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"87":{"id":"/concepts/approvals","page_id":"/concepts/approvals","type":"page","content":"Approvals","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/approvals"},"88":{"id":"/concepts/approvals-0","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"Approval cards - kinds, the ask contract, resolutions, timed approvals with fallbacks, and per-kind consequences."},"89":{"id":"/concepts/approvals-1","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#kinds","content":"Kinds"},"90":{"id":"/concepts/approvals-2","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#the-ask-contract","content":"The ask contract"},"91":{"id":"/concepts/approvals-3","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#status-and-resolution","content":"Status and resolution"},"92":{"id":"/concepts/approvals-4","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#timed-approvals-with-fallback","content":"Timed approvals with fallback"},"93":{"id":"/concepts/approvals-5","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#per-kind-consequences","content":"Per-kind consequences"},"94":{"id":"/concepts/approvals-6","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#api--mcp","content":"API & MCP"},"95":{"id":"/concepts/approvals-7","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"An **approval** is a declared question with a declared consequence, presented to a human as a card in the web app, over Telegram, or through the API/MCP. Cards can hold a run before it executes (`waiting_approval`), pause a workflow mid-run at an engine gate, or simply record a decision. A run held on an approval waits indefinitely — waiting never fails it."},"96":{"id":"/concepts/approvals-8","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Kind"},"97":{"id":"/concepts/approvals-9","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"What it represents"},"98":{"id":"/concepts/approvals-10","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`workflow_gate`"},"99":{"id":"/concepts/approvals-11","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A workflow paused at a gate; the decision releases or denies that step."},"100":{"id":"/concepts/approvals-12","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`escalation`"},"101":{"id":"/concepts/approvals-13","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Autonomous recovery gave up; a human records how to proceed."},"102":{"id":"/concepts/approvals-14","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`side_effect`"},"103":{"id":"/concepts/approvals-15","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A gated side effect asking permission before it runs."},"104":{"id":"/concepts/approvals-16","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`custom`"},"105":{"id":"/concepts/approvals-17","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Any ad-hoc approval raised via the API."},"106":{"id":"/concepts/approvals-18","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"The creator of a card states the ask up front, and every surface renders it verbatim:"},"107":{"id":"/concepts/approvals-19","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`action` — what exactly happens on approve."},"108":{"id":"/concepts/approvals-20","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`reason` — why a human is needed."},"109":{"id":"/concepts/approvals-21","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`audience` — who is asked: `operators` (default) or `admins`."},"110":{"id":"/concepts/approvals-22","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`options` — optional named choices (up to 8)."},"111":{"id":"/concepts/approvals-23","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"An ask without both `action` and `reason` is treated as absent; such cards fall back to a heuristic ask explicitly marked `derived: true`, so a guessed question is never presented as an authored one."},"112":{"id":"/concepts/approvals-24","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"A card's `status` is only ever `pending` or `resolved`. What was decided and by what live in separate fields:"},"113":{"id":"/concepts/approvals-25","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Field"},"114":{"id":"/concepts/approvals-26","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Values"},"115":{"id":"/concepts/approvals-27","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolution`"},"116":{"id":"/concepts/approvals-28","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`approved`, `rejected`, `changes_requested`, `superseded` (the run ended first), or `option:<id>`"},"117":{"id":"/concepts/approvals-29","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolvedVia`"},"118":{"id":"/concepts/approvals-30","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`human`, `fallback_timer` (autopilot), `engine` (decided on the runner), `policy` (auto-approved by policy), `system`"},"119":{"id":"/concepts/approvals-31","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"By default a card is blocking: nothing happens until someone decides. Supplying `timeoutMs` or `timeoutAt` at creation makes it a **timed approval**:"},"120":{"id":"/concepts/approvals-32","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"With a `fallback` decision (`approve` or `reject`), the configured decision is applied automatically when the timer elapses, recorded with `resolvedVia: \"fallback_timer\"`."},"121":{"id":"/concepts/approvals-33","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"Without a fallback, the elapsed card is flagged `fallback_required` and keeps waiting — no decision is invented, and the linked run is never failed by an elapsed timer."},"122":{"id":"/concepts/approvals-34","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"Every card answers \"what will my decision do\" honestly, computed from what resolving actually performs:"},"123":{"id":"/concepts/approvals-35","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`workflow_gate`** — approving a card holding a `waiting_approval` run releases it; approving a mid-run gate applies the decision to the paused workflow on the runner, which resumes past the gate. Reject/changes-requested cancel a held run, or take the workflow's own deny path mid-run."},"124":{"id":"/concepts/approvals-36","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`escalation`** — the run already ended: any decision records the call but does not restart the run (re-run it from the run page)."},"125":{"id":"/concepts/approvals-37","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`side_effect`** — approve allows the gated side effect; reject or changes-requested skip it. The run's completed work is unchanged either way."},"126":{"id":"/concepts/approvals-38","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`custom`** — approving a held run releases it to the queue; reject/changes-requested cancel it. On a card without a held run, the decision is simply recorded."},"127":{"id":"/concepts/approvals-39","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"The API exposes these as `whatHappensIfApproved` / `whatHappensIfRejected` / `whatHappensIfChangesRequested` / `whatHappensIfIgnored` in each card's `context`, alongside the ask, the linked run, and deep links."},"128":{"id":"/concepts/approvals-40","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Endpoint"},"129":{"id":"/concepts/approvals-41","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"MCP tool"},"130":{"id":"/concepts/approvals-42","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Notes"},"131":{"id":"/concepts/approvals-43","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals`"},"132":{"id":"/concepts/approvals-44","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`list_approvals`, `list_pending_approvals`"},"133":{"id":"/concepts/approvals-45","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`?status=pending\\|resolved`."},"134":{"id":"/concepts/approvals-46","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals/{id}`"},"135":{"id":"/concepts/approvals-47","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`get_approval`"},"136":{"id":"/concepts/approvals-48","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Full card with context."},"137":{"id":"/concepts/approvals-49","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals`"},"138":{"id":"/concepts/approvals-50","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`create_approval`"},"139":{"id":"/concepts/approvals-51","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`{title, description, runId?, ask, timeoutMs?/timeoutAt?, fallback?}`."},"140":{"id":"/concepts/approvals-52","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/approve`"},"141":{"id":"/concepts/approvals-53","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`approve_run`"},"142":{"id":"/concepts/approvals-54","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Takes an approval id, not a run id."},"143":{"id":"/concepts/approvals-55","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/reject`"},"144":{"id":"/concepts/approvals-56","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`reject_run`"},"145":{"id":"/concepts/approvals-57","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"A held run is cancelled, never failed."},"146":{"id":"/concepts/approvals-58","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/request-changes`"},"147":{"id":"/concepts/approvals-59","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`request_changes_run`"},"148":{"id":"/concepts/approvals-60","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Comment describes the requested changes."},"149":{"id":"/concepts/approvals-61","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Resolving approvals requires the `api`, `mcp`, or `approvals` scope; Telegram WebApp sessions are approvals-scoped by design (see Tokens & scopes)."},"150":{"id":"/concepts/boards","page_id":"/concepts/boards","type":"page","content":"Boards","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/boards"},"151":{"id":"/concepts/boards-0","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"Durable configured views over work items — the software-factory surfaces that workflows keep up to date."},"152":{"id":"/concepts/boards-1","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#shape","content":"Shape"},"153":{"id":"/concepts/boards-2","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#runyard-dogfooding-loop","content":"RunYard dogfooding loop"},"154":{"id":"/concepts/boards-3","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#runs-move-tickets","content":"Runs move tickets"},"155":{"id":"/concepts/boards-4","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#transition-policy","content":"Transition policy"},"156":{"id":"/concepts/boards-5","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#portable-board-definitions","content":"Portable board definitions"},"157":{"id":"/concepts/boards-6","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#release-notes--social-hook-point","content":"Release-notes / social hook point"},"158":{"id":"/concepts/boards-7","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#api--mcp","content":"API & MCP"},"159":{"id":"/concepts/boards-8","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"A **board** is a durable, configured view over work items: lane definitions in operator language, an optional project scope, and the workflows it suggests launching from tickets. Boards make the Work surface (`/app#work`) a **software factory**: tickets are the durable asks, workflows execute them, and linked runs move tickets across the board as they progress."},"160":{"id":"/concepts/boards-9","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"Every deployment seeds one default board on first boot — &#x2A;\"\\<instance name> Factory\"* (slug `runyard` by default) — so the Work view is a configured product surface from day one, never an empty shell. More boards can be created for product, infra, docs, or release trains."},"161":{"id":"/concepts/boards-10","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"The Work surface has two views over the same board configuration:"},"162":{"id":"/concepts/boards-11","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"**Board** is the operator queue: draggable tickets, lane counts, and the next human action."},"163":{"id":"/concepts/boards-12","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"**Flow** is read-only: a state-machine graph of lanes, permitted moves, guarded shortcuts, lane triggers, and automatic run-status movement. It is for inspection/debugging only; board configuration changes should happen through API/CLI/MCP or agent workflows so they leave an auditable run trail."},"164":{"id":"/concepts/boards-13","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lanes`** group the ten lifecycle statuses into columns; the default is the standard seven-column factory layout (Needs triage · Plan next · Ready to start · In motion · Needs decision · Review / approve · Done). Every lane needs an `id`, `label`, and at least one valid status."},"165":{"id":"/concepts/boards-14","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`project`** scopes membership: `\"\"` means all work items; a project name shows only that project's tickets."},"166":{"id":"/concepts/boards-15","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`defaultWorkflows`** lists workflow slugs the board suggests for launching from its tickets."},"167":{"id":"/concepts/boards-16","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lane.trigger`** makes lane movement workflow-aware without hidden magic. `mode: \"suggest\"` only nudges the operator toward a workflow; `mode: \"confirm\"` asks before enqueueing and linking a run; `mode: \"auto\"` enqueues from config and should be reserved for trusted/cheap/idempotent lanes. A trigger can set `workflow`, `label`, `description`, and default `input`."},"168":{"id":"/concepts/boards-17","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lane.guard`** makes some moves impossible from the board. `allowFromStatuses` permits entry only from specific lifecycle statuses; `denyFromStatuses` blocks entry from specific lifecycle statuses; `message` explains the blocked drop to the operator."},"169":{"id":"/concepts/boards-18","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lane.transitions`** is the transition policy: a per-move allow-list of who can drive the cross-lane hop (manual users, specific workflows, run origins, actor ids/roles). A lane without `transitions` stays unrestricted, matching today's behaviour."},"170":{"id":"/concepts/boards-19","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`isDefault`** marks the board the web app opens at `/app#work`."},"171":{"id":"/concepts/boards-20","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"The seeded RunYard Factory board uses conservative triggers:"},"172":{"id":"/concepts/boards-21","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**Roadmap shaping** suggests `product-workflow` for product proposals and isolated review-branch implementation runs."},"173":{"id":"/concepts/boards-22","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**Ready to start** suggests `runyard-smoke-check`."},"174":{"id":"/concepts/boards-23","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**In motion** asks before launching `runyard-smoke-check` and linking the new run to the ticket."},"175":{"id":"/concepts/boards-24","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**Done** is guarded: cards can enter it only from **Review / approve**, so work cannot be finalized straight from planning or execution."},"176":{"id":"/concepts/boards-25","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"Review stays human-controlled."},"177":{"id":"/concepts/boards-26","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"The built-in `runyard-development-factory` definition is also RunYard's own roadmap factory:"},"178":{"id":"/concepts/boards-27","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"Manual proposals from Telegram, chat, or an operator become work items in **Needs triage**."},"179":{"id":"/concepts/boards-28","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"A disabled-by-default schedule, `runyard-daily-roadmap-shaping`, is pinned to `0 9 * * *` in `America/New_York` and runs `product-workflow` with `execute: true`."},"180":{"id":"/concepts/boards-29","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"When enabled, the daily run queues compact implementation runs sequentially. Each child pushes an isolated review branch targeting `main`; operators inspect and promote the successful branch before `main` changes."},"181":{"id":"/concepts/boards-30","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"A human reviews the resulting branch and explicitly promotes only accepted work into `main`."},"182":{"id":"/concepts/boards-31","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"Enable the schedule only on a Hub where daily proposal runs are desired. Importing the definition in tests or dev keeps it disabled so it cannot create unsolicited runs."},"183":{"id":"/concepts/boards-32","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Linked runs keep the board honest without an operator shepherding every card. The mapping is deliberately conservative:"},"184":{"id":"/concepts/boards-33","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Linked run becomes"},"185":{"id":"/concepts/boards-34","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Ticket moves to"},"186":{"id":"/concepts/boards-35","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Notes"},"187":{"id":"/concepts/boards-36","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`queued` / `assigned` / `running`"},"188":{"id":"/concepts/boards-37","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`running`"},"189":{"id":"/concepts/boards-38","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Including a `blocked` ticket — relaunching is the unblock signal (the stale `blockedReason` is cleared)."},"190":{"id":"/concepts/boards-39","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`waiting_approval` / `paused` / `budget_exceeded`"},"191":{"id":"/concepts/boards-40","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`waiting`"},"192":{"id":"/concepts/boards-41","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"The \"Needs decision\" lane."},"193":{"id":"/concepts/boards-42","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`succeeded`"},"194":{"id":"/concepts/boards-43","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`review`"},"195":{"id":"/concepts/boards-44","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Never straight to `shipped` — a human accepts outcomes."},"196":{"id":"/concepts/boards-45","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`failed`"},"197":{"id":"/concepts/boards-46","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`blocked`"},"198":{"id":"/concepts/boards-47","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"With an explicit `blockedReason`; there is still no failed ticket state."},"199":{"id":"/concepts/boards-48","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`cancelled`"},"200":{"id":"/concepts/boards-49","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"—"},"201":{"id":"/concepts/boards-50","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Cancelling is already an operator act."},"202":{"id":"/concepts/boards-51","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Tickets in `shipped`, `accepted`, or `archived` are never touched, and terminal outcomes (`succeeded`/`failed`) wait until no sibling linked run is still live. Every automated move lands in ticket history as a `work_item.status_changed` event attributed to the run (`actor: \"run:run_…\"`), with the reason."},"203":{"id":"/concepts/boards-52","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A **transition** is a cross-lane move on the board (e.g. Ready → In motion). By default every move a work-item PATCH proposes is allowed — that's what today's Work board does. Adding a `transitions[]` entry to a lane turns it into an **allow-list**: the move is permitted only when the caller matches one of the listed channels."},"204":{"id":"/concepts/boards-53","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"The `allow` clause is a **union**: any single match permits the move. Channels available today:"},"205":{"id":"/concepts/boards-54","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"Channel"},"206":{"id":"/concepts/boards-55","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"What it matches"},"207":{"id":"/concepts/boards-56","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`manual`"},"208":{"id":"/concepts/boards-57","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A human or an authenticated token that hasn't declared a workflow/run origin (the default for any PATCH)."},"209":{"id":"/concepts/boards-58","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`workflows`"},"210":{"id":"/concepts/boards-59","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A workflow slug — set `workflowSlug` on the PATCH body (or the run whose status change is driving the move)."},"211":{"id":"/concepts/boards-60","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`runOrigins`"},"212":{"id":"/concepts/boards-61","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"The originating run's `origin.type` (e.g. `schedule`, `workflow`, `mcp`, `cli`)."},"213":{"id":"/concepts/boards-62","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`actors`"},"214":{"id":"/concepts/boards-63","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A stable actor label: a token name, a run id (`run:<id>`), or a specific caller identity."},"215":{"id":"/concepts/boards-64","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`actorRoles`"},"216":{"id":"/concepts/boards-65","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A role slug: `manual`, `human`, `agent`, `runner`, `schedule`, `workflow`, `system`."},"217":{"id":"/concepts/boards-66","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"Enforcement runs on **every board whose project scope covers the ticket**. A denial from any board rejects the PATCH with `409 Conflict`, the board's `message`, and the offending `{from, to}` transition. Callers driving a move on behalf of a workflow or run should declare it on the PATCH body:"},"218":{"id":"/concepts/boards-67","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"The **read-only Flow view** at `/app#work` continues to render the board's static topology; when a board declares a transition policy the Flow view labels each edge with who can drive it. Editing the policy still happens through the API/CLI/MCP write path — the graph UI stays inspection-only."},"219":{"id":"/concepts/boards-68","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#portable-board-definitions","content":"A board **definition** is a portable JSON document describing a whole kanban — lanes, statuses, triggers, guards, transition policy, `defaultWorkflows`, and optional `schedules[]` (see Schedules). Definitions are the write path agents use to provision or reconcile boards; the DB row is one *instance* of a definition."},"220":{"id":"/concepts/boards-69","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#portable-board-definitions","content":"The importer is idempotent: creating on new slugs, updating when the slug exists, and reconciling `schedules[]` by slug so re-imports never duplicate cron jobs. A production-ready example ships in the repo at `workflow-templates/board-definitions/runyard-development-factory.json`; fetch the same document at `GET /api/board-definitions/examples/runyard-development-factory` or with `runyard board definition example runyard-development-factory`."},"221":{"id":"/concepts/boards-70","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#portable-board-definitions","content":"YAML is deliberately deferred: the format itself is trivially expressible in YAML, but the CLI/MCP stay dependency-free, so today the documented syntax is JSON only."},"222":{"id":"/concepts/boards-71","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#release-notes--social-hook-point","content":"The example factory board leaves a **documented but unwired** hook point for release-notes and social automation: the natural place is a lane trigger on `shipped` that runs a `docs-update` or `release-notes` workflow, plus a schedule entry (e.g. cron `0 15 * * FRI`) that posts a weekly digest. Wiring Twitter or another network is a matter of adding the corresponding secret, a hook profile that consumes it, and a workflow that reads the run's artifacts — none of which this template ships, because the credentials must be operator-provided."},"223":{"id":"/concepts/boards-72","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Endpoint"},"224":{"id":"/concepts/boards-73","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"MCP tool"},"225":{"id":"/concepts/boards-74","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Notes"},"226":{"id":"/concepts/boards-75","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/boards`"},"227":{"id":"/concepts/boards-76","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`list_boards`"},"228":{"id":"/concepts/boards-77","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"All boards, default first."},"229":{"id":"/concepts/boards-78","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/boards/{slug}`"},"230":{"id":"/concepts/boards-79","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`get_board`"},"231":{"id":"/concepts/boards-80","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Board + lanes with per-lane ticket counts + the decorated work items in scope."},"232":{"id":"/concepts/boards-81","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`POST /api/boards`"},"233":{"id":"/concepts/boards-82","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`create_board`"},"234":{"id":"/concepts/boards-83","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`api`/`mcp` scope. Body: `slug`, `title` (+ optional fields above)."},"235":{"id":"/concepts/boards-84","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`PATCH /api/boards/{slug}`"},"236":{"id":"/concepts/boards-85","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`update_board`"},"237":{"id":"/concepts/boards-86","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Any subset; `slug` is immutable."},"238":{"id":"/concepts/boards-87","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/board-definitions`"},"239":{"id":"/concepts/boards-88","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`list_board_d