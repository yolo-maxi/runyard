43","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/knowledge/{slug}`"},"762":{"id":"/concepts/agents-skills-knowledge-44","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_knowledge`"},"763":{"id":"/concepts/agents-skills-knowledge-45","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"764":{"id":"/concepts/approvals","page_id":"/concepts/approvals","type":"page","content":"Approvals","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/approvals"},"765":{"id":"/concepts/approvals-0","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"Approval cards - kinds, the ask contract, resolutions, timed approvals with fallbacks, and per-kind consequences."},"766":{"id":"/concepts/approvals-1","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#kinds","content":"Kinds"},"767":{"id":"/concepts/approvals-2","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#the-ask-contract","content":"The ask contract"},"768":{"id":"/concepts/approvals-3","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#status-and-resolution","content":"Status and resolution"},"769":{"id":"/concepts/approvals-4","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#timed-approvals-with-fallback","content":"Timed approvals with fallback"},"770":{"id":"/concepts/approvals-5","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#per-kind-consequences","content":"Per-kind consequences"},"771":{"id":"/concepts/approvals-6","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#api--mcp","content":"API & MCP"},"772":{"id":"/concepts/approvals-7","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"An **approval** is a declared question with a declared consequence, presented to a human as a card in the web app, over Telegram, or through the API/MCP. Cards can hold a run before it executes (`waiting_approval`), pause a workflow mid-run at an engine gate, or simply record a decision. A run held on an approval waits indefinitely — waiting never fails it."},"773":{"id":"/concepts/approvals-8","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Kind"},"774":{"id":"/concepts/approvals-9","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"What it represents"},"775":{"id":"/concepts/approvals-10","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`workflow_gate`"},"776":{"id":"/concepts/approvals-11","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A workflow paused at a gate; the decision releases or denies that step."},"777":{"id":"/concepts/approvals-12","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`escalation`"},"778":{"id":"/concepts/approvals-13","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Autonomous recovery gave up; a human records how to proceed."},"779":{"id":"/concepts/approvals-14","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`side_effect`"},"780":{"id":"/concepts/approvals-15","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A gated side effect asking permission before it runs."},"781":{"id":"/concepts/approvals-16","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`custom`"},"782":{"id":"/concepts/approvals-17","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Any ad-hoc approval raised via the API."},"783":{"id":"/concepts/approvals-18","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"The creator of a card states the ask up front, and every surface renders it verbatim:"},"784":{"id":"/concepts/approvals-19","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`action` — what exactly happens on approve."},"785":{"id":"/concepts/approvals-20","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`reason` — why a human is needed."},"786":{"id":"/concepts/approvals-21","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`audience` — who is asked: `operators` (default) or `admins`."},"787":{"id":"/concepts/approvals-22","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`options` — optional named choices (up to 8)."},"788":{"id":"/concepts/approvals-23","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"An ask without both `action` and `reason` is treated as absent; such cards fall back to a heuristic ask explicitly marked `derived: true`, so a guessed question is never presented as an authored one."},"789":{"id":"/concepts/approvals-24","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"A card's `status` is only ever `pending` or `resolved`. What was decided and by what live in separate fields:"},"790":{"id":"/concepts/approvals-25","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Field"},"791":{"id":"/concepts/approvals-26","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Values"},"792":{"id":"/concepts/approvals-27","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolution`"},"793":{"id":"/concepts/approvals-28","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`approved`, `rejected`, `changes_requested`, `superseded` (the run ended first), or `option:<id>`"},"794":{"id":"/concepts/approvals-29","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolvedVia`"},"795":{"id":"/concepts/approvals-30","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`human`, `fallback_timer` (autopilot), `engine` (decided on the runner), `policy` (auto-approved by policy), `system`"},"796":{"id":"/concepts/approvals-31","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"By default a card is blocking: nothing happens until someone decides. Supplying `timeoutMs` or `timeoutAt` at creation makes it a **timed approval**:"},"797":{"id":"/concepts/approvals-32","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"With a `fallback` decision (`approve` or `reject`), the configured decision is applied automatically when the timer elapses, recorded with `resolvedVia: \"fallback_timer\"`."},"798":{"id":"/concepts/approvals-33","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"Without a fallback, the elapsed card is flagged `fallback_required` and keeps waiting — no decision is invented, and the linked run is never failed by an elapsed timer."},"799":{"id":"/concepts/approvals-34","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"Every card answers \"what will my decision do\" honestly, computed from what resolving actually performs:"},"800":{"id":"/concepts/approvals-35","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`workflow_gate`** — approving a card holding a `waiting_approval` run releases it; approving a mid-run gate applies the decision to the paused workflow on the runner, which resumes past the gate. Reject/changes-requested cancel a held run, or take the workflow's own deny path mid-run."},"801":{"id":"/concepts/approvals-36","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`escalation`** — the run already ended: any decision records the call but does not restart the run (re-run it from the run page)."},"802":{"id":"/concepts/approvals-37","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`side_effect`** — approve allows the gated side effect; reject or changes-requested skip it. The run's completed work is unchanged either way."},"803":{"id":"/concepts/approvals-38","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`custom`** — approving a held run releases it to the queue; reject/changes-requested cancel it. On a card without a held run, the decision is simply recorded."},"804":{"id":"/concepts/approvals-39","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"The API exposes these as `whatHappensIfApproved` / `whatHappensIfRejected` / `whatHappensIfChangesRequested` / `whatHappensIfIgnored` in each card's `context`, alongside the ask, the linked run, and deep links."},"805":{"id":"/concepts/approvals-40","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Endpoint"},"806":{"id":"/concepts/approvals-41","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"MCP tool"},"807":{"id":"/concepts/approvals-42","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Notes"},"808":{"id":"/concepts/approvals-43","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals`"},"809":{"id":"/concepts/approvals-44","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`list_approvals`, `list_pending_approvals`"},"810":{"id":"/concepts/approvals-45","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`?status=pending\\|resolved`."},"811":{"id":"/concepts/approvals-46","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals/{id}`"},"812":{"id":"/concepts/approvals-47","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`get_approval`"},"813":{"id":"/concepts/approvals-48","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Full card with context."},"814":{"id":"/concepts/approvals-49","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals`"},"815":{"id":"/concepts/approvals-50","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`create_approval`"},"816":{"id":"/concepts/approvals-51","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`{title, description, runId?, ask, timeoutMs?/timeoutAt?, fallback?}`."},"817":{"id":"/concepts/approvals-52","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/approve`"},"818":{"id":"/concepts/approvals-53","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`approve_run`"},"819":{"id":"/concepts/approvals-54","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Takes an approval id, not a run id."},"820":{"id":"/concepts/approvals-55","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/reject`"},"821":{"id":"/concepts/approvals-56","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`reject_run`"},"822":{"id":"/concepts/approvals-57","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"A held run is cancelled, never failed."},"823":{"id":"/concepts/approvals-58","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/request-changes`"},"824":{"id":"/concepts/approvals-59","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`request_changes_run`"},"825":{"id":"/concepts/approvals-60","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Comment describes the requested changes."},"826":{"id":"/concepts/approvals-61","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Resolving approvals requires the `api`, `mcp`, or `approvals` scope; Telegram WebApp sessions are approvals-scoped by design (see Tokens & scopes)."},"827":{"id":"/concepts/boards","page_id":"/concepts/boards","type":"page","content":"Boards","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/boards"},"828":{"id":"/concepts/boards-0","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"Durable configured views over work items — the software-factory surfaces that workflows keep up to date."},"829":{"id":"/concepts/boards-1","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#shape","content":"Shape"},"830":{"id":"/concepts/boards-2","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#runyard-dogfooding-loop","content":"RunYard dogfooding loop"},"831":{"id":"/concepts/boards-3","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#runs-move-tickets","content":"Runs move tickets"},"832":{"id":"/concepts/boards-4","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#transition-policy","content":"Transition policy"},"833":{"id":"/concepts/boards-5","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#portable-board-definitions","content":"Portable board definitions"},"834":{"id":"/concepts/boards-6","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#release-notes--social-hook-point","content":"Release-notes / social hook point"},"835":{"id":"/concepts/boards-7","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#api--mcp","content":"API & MCP"},"836":{"id":"/concepts/boards-8","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"A **board** is a durable, configured view over work items: lane definitions in operator language, an optional project scope, and the workflows it suggests launching from tickets. Boards make the Work surface (`/app#work`) a **software factory**: tickets are the durable asks, workflows execute them, and linked runs move tickets across the board as they progress."},"837":{"id":"/concepts/boards-9","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"Every deployment seeds one default board on first boot — &#x2A;\"\\<instance name> Factory\"* (slug `runyard` by default) — so the Work view is a configured product surface from day one, never an empty shell. More boards can be created for product, infra, docs, or release trains."},"838":{"id":"/concepts/boards-10","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"The Work surface has two views over the same board configuration:"},"839":{"id":"/concepts/boards-11","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"**Board** is the operator queue: draggable tickets, lane counts, and the next human action."},"840":{"id":"/concepts/boards-12","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"**Flow** is read-only: a state-machine graph of lanes, permitted moves, guarded shortcuts, lane triggers, and automatic run-status movement. It is for inspection/debugging only; board configuration changes should happen through API/CLI/MCP or agent workflows so they leave an auditable run trail."},"841":{"id":"/concepts/boards-13","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lanes`** group the ten lifecycle statuses into columns; the default is the standard seven-column factory layout (Needs triage · Plan next · Ready to start · In motion · Needs decision · Review / approve · Done). Every lane needs an `id`, `label`, and at least one valid status."},"842":{"id":"/concepts/boards-14","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`project`** scopes membership: `\"\"` means all work items; a project name shows only that project's tickets."},"843":{"id":"/concepts/boards-15","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`defaultWorkflows`** lists workflow slugs the board suggests for launching from its tickets."},"844":{"id":"/concepts/boards-16","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lane.trigger`** makes lane movement workflow-aware without hidden magic. `mode: \"suggest\"` only nudges the operator toward a workflow; `mode: \"confirm\"` asks before enqueueing and linking a run; `mode: \"auto\"` enqueues from config and should be reserved for trusted/cheap/idempotent lanes. A trigger can set `workflow`, `label`, `description`, and default `input`."},"845":{"id":"/concepts/boards-17","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lane.guard`** makes some moves impossible from the board. `allowFromStatuses` permits entry only from specific lifecycle statuses; `denyFromStatuses` blocks entry from specific lifecycle statuses; `message` explains the blocked drop to the operator."},"846":{"id":"/concepts/boards-18","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lane.transitions`** is the transition policy: a per-move allow-list of who can drive the cross-lane hop (manual users, specific workflows, run origins, actor ids/roles). A lane without `transitions` stays unrestricted, matching today's behaviour."},"847":{"id":"/concepts/boards-19","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`isDefault`** marks the board the web app opens at `/app#work`."},"848":{"id":"/concepts/boards-20","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"The seeded RunYard Factory board uses conservative triggers:"},"849":{"id":"/concepts/boards-21","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**Roadmap shaping** suggests `product-workflow` for product proposals and isolated review-branch implementation runs."},"850":{"id":"/concepts/boards-22","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**Ready to start** suggests `runyard-smoke-check`."},"851":{"id":"/concepts/boards-23","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**In motion** asks before launching `runyard-smoke-check` and linking the new run to the ticket."},"852":{"id":"/concepts/boards-24","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**Done** is guarded: cards can enter it only from **Review / approve**, so work cannot be finalized straight from planning or execution."},"853":{"id":"/concepts/boards-25","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"Review stays human-controlled."},"854":{"id":"/concepts/boards-26","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"The built-in `runyard-development-factory` definition is also RunYard's own roadmap factory:"},"855":{"id":"/concepts/boards-27","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"Manual proposals from Telegram, chat, or an operator become work items in **Needs triage**."},"856":{"id":"/concepts/boards-28","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"A disabled-by-default schedule, `runyard-daily-roadmap-shaping`, is pinned to `0 9 * * *` in `America/New_York` and runs `product-workflow` with `execute: true`."},"857":{"id":"/concepts/boards-29","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"When enabled, the daily run queues compact implementation runs sequentially. Each child pushes an isolated review branch targeting `main`; operators inspect and promote the successful branch before `main` changes."},"858":{"id":"/concepts/boards-30","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"A human reviews the resulting branch and explicitly promotes only accepted work into `main`."},"859":{"id":"/concepts/boards-31","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runyard-dogfooding-loop","content":"Enable the schedule only on a Hub where daily proposal runs are desired. Importing the definition in tests or dev keeps it disabled so it cannot create unsolicited runs."},"860":{"id":"/concepts/boards-32","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Linked runs keep the board honest without an operator shepherding every card. The mapping is deliberately conservative:"},"861":{"id":"/concepts/boards-33","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Linked run becomes"},"862":{"id":"/concepts/boards-34","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Ticket moves to"},"863":{"id":"/concepts/boards-35","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Notes"},"864":{"id":"/concepts/boards-36","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`queued` / `assigned` / `running`"},"865":{"id":"/concepts/boards-37","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`running`"},"866":{"id":"/concepts/boards-38","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Including a `blocked` ticket — relaunching is the unblock signal (the stale `blockedReason` is cleared)."},"867":{"id":"/concepts/boards-39","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`waiting_approval` / `paused` / `budget_exceeded`"},"868":{"id":"/concepts/boards-40","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`waiting`"},"869":{"id":"/concepts/boards-41","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"The \"Needs decision\" lane."},"870":{"id":"/concepts/boards-42","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`succeeded`"},"871":{"id":"/concepts/boards-43","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`review`"},"872":{"id":"/concepts/boards-44","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Never straight to `shipped` — a human accepts outcomes."},"873":{"id":"/concepts/boards-45","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`failed`"},"874":{"id":"/concepts/boards-46","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`blocked`"},"875":{"id":"/concepts/boards-47","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"With an explicit `blockedReason`; there is still no failed ticket state."},"876":{"id":"/concepts/boards-48","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`cancelled`"},"877":{"id":"/concepts/boards-49","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"—"},"878":{"id":"/concepts/boards-50","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Cancelling is already an operator act."},"879":{"id":"/concepts/boards-51","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Tickets in `shipped`, `accepted`, or `archived` are never touched, and terminal outcomes (`succeeded`/`failed`) wait until no sibling linked run is still live. Every automated move lands in ticket history as a `work_item.status_changed` event attributed to the run (`actor: \"run:run_…\"`), with the reason."},"880":{"id":"/concepts/boards-52","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A **transition** is a cross-lane move on the board (e.g. Ready → In motion). By default every move a work-item PATCH proposes is allowed — that's what today's Work board does. Adding a `transitions[]` entry to a lane turns it into an **allow-list**: the move is permitted only when the caller matches one of the listed channels."},"881":{"id":"/concepts/boards-53","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"The `allow` clause is a **union**: any single match permits the move. Channels available today:"},"882":{"id":"/concepts/boards-54","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"Channel"},"883":{"id":"/concepts/boards-55","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"What it matches"},"884":{"id":"/concepts/boards-56","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`manual`"},"885":{"id":"/concepts/boards-57","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A human or an authenticated token that hasn't declared a workflow/run origin (the default for any PATCH)."},"886":{"id":"/concepts/boards-58","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`workflows`"},"887":{"id":"/concepts/boards-59","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A workflow slug — set `workflowSlug` on the PATCH body (or the run whose status change is driving the move)."},"888":{"id":"/concepts/boards-60","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`runOrigins`"},"889":{"id":"/concepts/boards-61","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"The originating run's `origin.type` (e.g. `schedule`, `workflow`, `mcp`, `cli`)."},"890":{"id":"/concepts/boards-62","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`actors`"},"891":{"id":"/concepts/boards-63","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A stable actor label: a token name, a run id (`run:<id>`), or a specific caller identity."},"892":{"id":"/concepts/boards-64","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"`actorRoles`"},"893":{"id":"/concepts/boards-65","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"A role slug: `manual`, `human`, `agent`, `runner`, `schedule`, `workflow`, `system`."},"894":{"id":"/concepts/boards-66","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"Enforcement runs on **every board whose project scope covers the ticket**. A denial from any board rejects the PATCH with `409 Conflict`, the board's `message`, and the offending `{from, to}` transition. Callers driving a move on behalf of a workflow or run should declare it on the PATCH body:"},"895":{"id":"/concepts/boards-67","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#transition-policy","content":"The **read-only Flow view** at `/app#work` continues to render the board's static topology; when a board declares a transition policy the Flow view labels each edge with who can drive it. Editing the policy still happens through the API/CLI/MCP write path — the graph UI stays inspection-only."},"896":{"id":"/concepts/boards-68","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#portable-board-definitions","content":"A board **definition** is a portable JSON document describing a whole kanban — lanes, statuses, triggers, guards, transition policy, `defaultWorkflows`, and optional `schedules[]` (see Schedules). Definitions are the write path agents use to provision or reconcile boards; the DB row is one *instance* of a definition."},"897":{"id":"/concepts/boards-69","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#portable-board-definitions","content":"The importer is idempotent: creating on new slugs, updating when the slug exists, and reconciling `schedules[]` by slug so re-imports never duplicate cron jobs. A production-ready example ships in the repo at `workflow-templates/board-definitions/runyard-development-factory.json`; fetch the same document at `GET /api/board-definitions/examples/runyard-development-factory` or with `runyard board definition example runyard-development-factory`."},"898":{"id":"/concepts/boards-70","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#portable-board-definitions","content":"YAML is deliberately deferred: the format itself is trivially expressible in YAML, but the CLI/MCP stay dependency-free, so today the documented syntax is JSON only."},"899":{"id":"/concepts/boards-71","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#release-notes--social-hook-point","content":"The example factory board leaves a **documented but unwired** hook point for release-notes and social automation: the natural place is a lane trigger on `shipped` that runs a `docs-update` or `release-notes` workflow, plus a schedule entry (e.g. cron `0 15 * * FRI`) that posts a weekly digest. Wiring Twitter or another network is a matter of adding the corresponding secret, a hook profile that consumes it, and a workflow that reads the run's artifacts — none of which this template ships, because the credentials must be operator-provided."},"900":{"id":"/concepts/boards-72","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Endpoint"},"901":{"id":"/concepts/boards-73","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"MCP tool"},"902":{"id":"/concepts/boards-74","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Notes"},"903":{"id":"/concepts/boards-75","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/boards`"},"904":{"id":"/concepts/boards-76","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`list_boards`"},"905":{"id":"/concepts/boards-77","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"All boards, default first."},"906":{"id":"/concepts/boards-78","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/boards/{slug}`"},"907":{"id":"/concepts/boards-79","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`get_board`"},"908":{"id":"/concepts/boards-80","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Board + lanes with per-lane ticket counts + the decorated work items in scope."},"909":{"id":"/concepts/boards-81","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`POST /api/boards`"},"910":{"id":"/concepts/boards-82","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`create_board`"},"911":{"id":"/concepts/boards-83","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`api`/`mcp` scope. Body: `slug`, `title` (+ optional fields above)."},"912":{"id":"/concepts/boards-84","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`PATCH /api/boards/{slug}`"},"913":{"id":"/concepts/boards-85","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`update_board`"},"914":{"id":"/concepts/boards-86","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Any subset; `slug` is immutable."},"915":{"id":"/concepts/boards-87","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/board-definitions`"},"916":{"id":"/concepts/boards-88","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`list_board_definitions`"},"917":{"id":"/concepts/boards-89","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Portable-definition summaries + built-in example slugs."},"918":{"id":"/concepts/boards-90","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/board-definitions/examples/{slug}`"},"919":{"id":"/concepts/boards-91","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`get_example_board_definition`"},"920":{"id":"/concepts/boards-92","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Fetch a built-in example definition as JSON."},"921":{"id":"/concepts/boards-93","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/boards/{slug}/definition`"},"922":{"id":"/concepts/boards-94","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`export_board_definition`"},"923":{"id":"/concep