:"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Purpose"},"202":{"id":"/guides/api-124","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"`POST /api/run-drafts`"},"203":{"id":"/guides/api-125","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Create + preflight a draft: `{workflow, input, executionMode}` → `201` with status `ready` / `needs_input` / `blocked` and open questions"},"204":{"id":"/guides/api-126","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"`GET /api/run-drafts` · `GET /api/run-drafts/:id`"},"205":{"id":"/guides/api-127","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"List / inspect drafts with their latest preflight report"},"206":{"id":"/guides/api-128","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"`PATCH /api/run-drafts/:id`"},"207":{"id":"/guides/api-129","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Answer questions: `input` is shallow-merged (a `null` value deletes a key; `replaceInput: true` replaces it), then re-preflighted"},"208":{"id":"/guides/api-130","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"`POST /api/run-drafts/:id/submit`"},"209":{"id":"/guides/api-131","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Re-preflight and enqueue the real run only when ready — `202` with `{run, draft}`"},"210":{"id":"/guides/api-132","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"`POST /api/run-drafts/:id/discard`"},"211":{"id":"/guides/api-133","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Abandon the negotiation"},"212":{"id":"/guides/api-134","page_id":"/guides/api","tags":[],"type":"text","url":"/gu