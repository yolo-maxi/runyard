"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/import`"},"637":{"id":"/concepts/workflows-75","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`import_workflow_package`"},"638":{"id":"/concepts/workflows-76","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; imports disabled."},"639":{"id":"/concepts/workflows-77","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Running a workflow (`POST /api/workflows/{id}/run`, `run_workflow`) and preflighting it are covered on the Runs page."},"640":{"id":"/guides/agent-consumers","page_id":"/guides/agent-consumers","type":"page","content":"Building agents on Runyard","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/agent-consumers"},"641":{"id":"/guides/agent-consumers-0","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Discovery surfaces, the API-first guarantee, and recommended etiquette for agents and third-party clients."},"642":{"id":"/guides/agent-consumers-1","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#discovery-surfaces","content":"Discovery surfaces"},"643":{"id":"/guides/agent-consumers-2","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#the-api-first-guarantee","content":"The API-first guarantee"},"644":{"id":"/guides/agent-consumers-3","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#auth-expectations","content":"Auth expectations"},"645":{"id":"/guides/agent-consumers-4","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#recommended-agent-etiquette","content":"Recommended agent etiquette"},"646":{"id":"/guides/agent-consumers-5","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"Push instead of poll: response endpoints"},"647":{"id":"/guides/agent-consumers-6","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"Machine intake: workflow endpoints"},"648":{"id":"/guides/agent-consumers-7","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Runyard treats agents as first-class API consumers. This page covers how a client discovers what a Hub can do, what it may rely on, and how to be a good citizen."},"649":{"id":"/guides/agent-consumers-8","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Surface"},"650":{"id":"/guides/agent-consumers-9","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Auth"},"651":{"id":"/guides/agent-consumers-10","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"What it gives you"},"652":{"id":"/guides/agent-consumers-11","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /llms.txt`"},"653":{"id":"/guides/agent-consumers-12","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"654":{"id":"/guides/agent-consumers-13","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Static, generic orientation for agents: what Runyard is, its tool names, the run path. It deliberately contains nothing deployment-specific and points at the authenticated menu."},"655":{"id":"/guides/agent-consumers-14","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /openapi.json`"},"656":{"id":"/guides/agent-consumers-15","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"657":{"id":"/guides/agent-consumers-16","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The full HTTP surface, generated from the Hub's API surface registry — it cannot drift from the routes the server actually registers."},"658":{"id":"/guides/agent-consumers-17","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"MCP `tools/list`"},"659":{"id":"/guides/agent-consumers-18","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"660":{"id":"/guides/agent-consumers-19","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The complete MCP tool set (parity-tested against the API surface). Connect with `runyard mcp install` or the `runyard-mcp` stdio server."},"661":{"id":"/guides/agent-consumers-20","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /api/menu` / `get_menu`"},"662":{"id":"/guides/agent-consumers-21","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"663":{"id":"/guides/agent-consumers-22","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The live, private catalog: workflows with schemas, execution modes, runner pool state, and ready-to-use CLI/MCP invocations."},"664":{"id":"/guides/agent-consumers-23","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Start every session with `get_menu` (or `GET /api/menu`), then `describe_workflow` for anything you intend to run."},"665":{"id":"/guides/agent-consumers-24","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#the-api-first-guarantee","content":"The web app is an ordinary client of the same HTTP API, with no privileged endpoints. Every route is declared in one registry that also generates `openapi.json` and is parity-tested against the MCP tool list — so a lossless third-party client is possible by construction: anything the web app can show or do, your client can too, over HTTP or MCP."},"666":{"id":"/guides/agent-consumers-25","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#auth-expectations","content":"Ask the Hub's administrator for a scoped access token (admins issue them from the Connect tab or `POST /api/tokens`). Agents typically need `api` and/or `mcp` — nothing more. Send it as `Authorization: Bearer <token>` on every HTTP call, or configure it for the MCP server. Never ask for or expect the bootstrap/admin token."},"667":{"id":"/guides/agent-consumers-26","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Set `input.title`.** For agent-created runs, include a short human-readable title (\"Audit checkout flow mobile states\") so run lists, approval cards, and human handoff stay decipherable."},"668":{"id":"/guides/agent-consumers-27","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Preflight first.** When input is rough or unverified, call `preflight_workflow` (`POST /api/workflows/{id}/preflight`) or pass `negotiate: true` to `run_workflow`. You get `ready | needs_input | blocked` with concrete questions and blockers instead of a run that fails."},"669":{"id":"/guides/agent-consumers-28","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Use run drafts for question/answer loops.** `create_run_draft` creates a proposed run and preflights it; `update_run_draft` merges answers into the input and re-preflights; `submit_run_draft` enqueues the real run only once it is ready; `discard_run_draft` abandons it. Nothing executes until submit."},"670":{"id":"/guides/agent-consumers-29","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Poll the timeline with `since` cursors.** `get_run_timeline` (`GET /api/runs/{id}/timeline`) returns a unified, ascending view of status transitions, events, and artifacts. Pass the previous response's `nextSince` as `since` so the Hub never re-sends what you have. Fetch results with `get_run_status`, `get_run_logs`, and `get_run_artifacts` / `download_artifact`."},"671":{"id":"/guides/agent-consumers-30","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"`POST /api/workflows/{id}/run` accepts an optional `responseEndpoint` (`{ \"type\": \"http\" | \"telegram\", \"config\": { ... } }`). When the run reaches a terminal state, the Hub POSTs a sanitized payload to your HTTP endpoint (or sends a concise Telegram message). Delivery state is visible on `GET /api/runs/{id}` under `responseEndpoints[]`, and polling remains the canonical fallback."},"672":{"id":"/guides/agent-consumers-31","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"For fixed-purpose integrations that should not hold a Hub token at all (webhooks, form intake, external systems), an admin can configure a **workflow endpoint**: `POST /api/workflow-endpoints/{slug}` accepts a payload authenticated with that endpoint's own secret, rate-limited, size-capped, and deduplicated, and triggers exactly one preconfigured workflow. This is the narrowest possible credential to hand to an external system."},"673":{"id":"/guides/api","page_id":"/guides/api","type":"page","content":"HTTP API","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/api"},"674":{"id":"/guides/api-0","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Authenticate, discover, and drive workflow runs over the Runyard Hub's HTTP API."},"675":{"id":"/guides/api-1","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#authentication","content":"Authentication"},"676":{"id":"/guides/api-2","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#discovery","content":"Discovery"},"677":{"id":"/guides/api-3","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#api-groups-and-apiv1-aliases","content":"API groups and `/api/v1` aliases"},"678":{"id":"/guides/api-4","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#the-typical-flow","content":"The typical flow"},"679":{"id":"/guides/api-5","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#key-endpoints","content":"Key endpoints"},"680":{"id":"/guides/api-6","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#approvals","content":"Approvals"},"681":{"id":"/guides/api-7","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#run-drafts","content":"Run drafts"},"682":{"id":"/guides/api-8","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#error-conventions","content":"Error conventions"},"683":{"id":"/guides/api-9","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#rate-limits","content":"Rate limits"},"684":{"id":"/guides/api-10","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#see-also","content":"See also"},"685":{"id":"/guides/api-11","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Every Runyard surface — the web app, the CLI, and the MCP server — is an\nordinary client of one HTTP API served by the Hub. Anything they can do, you\ncan do with `curl`."},"686":{"id":"/guides/api-12","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Send an access token as a bearer token on every request:"},"687":{"id":"/guides/api-13","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Tokens are minted by an admin (web UI, `POST /api/tokens`, or the CLI) and carry\n**scopes**:"},"688":{"id":"/guides/api-14","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Scope"},"689":{"id":"/guides/api-15","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Grants"},"690":{"id":"/guides/api-16","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`api`"},"691":{"id":"/guides/api-17","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Start runs, preflight, drafts, rerun/cancel/promote, create approvals"},"692":{"id":"/guides/api-18","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`mcp`"},"693":{"id":"/guides/api-19","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The same operations, issued for MCP clients"},"694":{"id":"/guides/api-20","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`read`"},"695":{"id":"/guides/api-21","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Read-only** — inspect workflows, runs, logs, artifacts, approvals, schedules, and runners; satisfies no mutation endpoint"},"696":{"id":"/guides/api-22","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`runner`"},"697":{"id":"/guides/api-23","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The runner protocol: register, heartbeat, claim runs, report lifecycle events and artifacts"},"698":{"id":"/guides/api-24","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`approvals`"},"699":{"id":"/guides/api-25","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Resolve approval cards (approve / reject / request changes) and create them"},"700":{"id":"/guides/api-26","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`admin`"},"701":{"id":"/guides/api-27","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Superscope** — satisfies every scope requirement, plus admin-only surfaces: tokens, secrets, audit log, schedules, workflow create/update, packages, hooks, updates"},"702":{"id":"/guides/api-28","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`GET /api/tokens/scopes` (admin) returns this vocabulary plus named presets —\n**everything** (`api`+`mcp`+`approvals`, the default), **read-only**,\n**approvals-only**, **runner**, and **admin** — which the Tokens page uses."},"703":{"id":"/guides/api-29","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Reads such as listing runs, workflows, or artifacts require any authenticated\ntoken. A token with only the `read` scope is therefore read-only: it can\ninspect everything non-admin but every create/update/delete/run/approve call\nfails with `403`. A request with no valid token gets\n`401 {\"error\": \"unauthorized\"}`; a token missing a required scope gets:"},"704":{"id":"/guides/api-30","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"with status `403`. `GET /api/me` describes the calling token (name and scopes)."},"705":{"id":"/guides/api-31","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /openapi.json`** (unauthenticated) — generated from the server's API\nsurface registry, the single source of truth every route is registered from,\nso **every endpoint is documented there**. This guide covers the important\nones; use `/openapi.json` for the full list."},"706":{"id":"/guides/api-32","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/menu`** (authenticated) — the agent-facing menu: workflow catalog,\nlocal/remote execution modes, and follow-up paths. The same data backs the\nMCP `get_menu` tool and `/llms.txt`."},"707":{"id":"/guides/api-33","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/version`** (unauthenticated) — product name, version, instance\nname."},"708":{"id":"/guides/api-34","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Operations are organized into eight groups, exposed as OpenAPI tags:\n**workflows**, **runs**, **approvals**, **automation** (schedules + workflow\nendpoints), **library** (agents, skills, knowledge, hooks), **distribution**\n(bundles, packages), **admin** (tokens, secrets, audit, alerts, updates), and\n**system** (health, version, menu, dashboard, runners)."},"709":{"id":"/guides/api-35","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Every grouped operation is also reachable at a stable `/api/v1` alias that\nmakes the group visible in the path — for example:"},"710":{"id":"/guides/api-36","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Canonical"},"711":{"id":"/guides/api-37","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Grouped alias"},"712":{"id":"/guides/api-38","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflows`"},"713":{"id":"/guides/api-39","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/workflows`"},"714":{"id":"/guides/api-40","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/runs/:id`"},"715":{"id":"/guides/api-41","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/:id`"},"716":{"id":"/guides/api-42","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/run-drafts`"},"717":{"id":"/guides/api-43","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/drafts`"},"718":{"id":"/guides/api-44","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/schedules`"},"719":{"id":"/guides/api-45","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/automation/schedules`"},"720":{"id":"/guides/api-46","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/agents`"},"721":{"id":"/guides/api-47","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/library/agents`"},"722":{"id":"/guides/api-48","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflow-bundles`"},"723":{"id":"/guides/api-49","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/distribution/bundles`"},"724":{"id":"/guides/api-50","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/tokens`"},"725":{"id":"/guides/api-51","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/admin/tokens`"},"726":{"id":"/guides/api-52","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/menu`"},"727":{"id":"/guides/api-53","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/system/menu`"},"728":{"id":"/guides/api-54","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Aliases are the same registry entries registered twice, so they always share\nthe canonical route's handler, auth, and scopes; in `openapi.json` each alias\ncarries `x-canonical-path`. Unversioned `/api/...` paths remain fully\nsupported — use whichever reads better. The legacy `/api/capabilities/*`\npaths are deprecated aliases of `/api/workflows/*` and get no `/api/v1` form;\nnew clients should say *workflow* everywhere."},"729":{"id":"/guides/api-55","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"List workflows, preflight your input, start the run, then poll it:"},"730":{"id":"/guides/api-56","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"For agent-created runs, include a short human-readable `input.title` — it labels\nrun lists, approval cards, and handoffs. `executionMode` is `local` or `remote`;\n`run` also accepts an optional `responseEndpoint` (`{type: http|telegram,\nconfig}`) to have the terminal-state reply delivered when the run finishes\n(polling `/api/runs/:id` remains the canonical fallback), and an optional\n`budget` (`{maxTokens?, maxCostMicros?}`, also accepted as `input.budget`) that\nhard-caps the run's metered model usage — a breach terminates the run with the\ndistinct status `budget_exceeded`. Metered usage aggregates onto every run\nobject as `usage` and is detailed at `GET /api/runs/:id/usage`; see\nUsage metering & budgets."},"731":{"id":"/guides/api-57","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"With `\"negotiate\": true`, a non-ready request returns the negotiation state\n(questions, blockers, warnings, plus a saved draft) instead of creating a run —\nfix the input and call again."},"732":{"id":"/guides/api-58","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Workflows and runs (`preflight` and `run` require `api` or `mcp` scope; reads\nrequire any token):"},"733":{"id":"/guides/api-59","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Method + path"},"734":{"id":"/guides/api-60","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Purpose"},"735":{"id":"/guides/api-61","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows`"},"736":{"id":"/guides/api-62","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List workflows (`?q=` searches)"},"737":{"id":"/guides/api-63","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows/:id`"},"738":{"id":"/guides/api-64","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Describe a workflow and its input schema"},"739":{"id":"/guides/api-65","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows/:id/source`"},"740":{"id":"/guides/api-66","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Workflow source, parsed metadata, sections, graph"},"741":{"id":"/guides/api-67","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows/:id/preflight`"},"742":{"id":"/guides/api-68","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Dry-run preflight: `ready` / `needs_input` / `blocked`, nothing created"},"743":{"id":"/guides/api-69","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows/:id/run`"},"744":{"id":"/guides/api-70","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run a workflow: `{input, executionMode, negotiate?}`"},"745":{"id":"/guides/api-71","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows` / `PATCH /api/workflows/:id`"},"746":{"id":"/guides/api-72","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Create/update a workflow (admin). Source is submitted as bytes or a `workflow.bundleId` — never a file path"},"747":{"id":"/guides/api-73","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs`"},"748":{"id":"/guides/api-74","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List runs (filter by `status`, `q`, `workflow`)"},"749":{"id":"/guides/api-75","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id`"},"750":{"id":"/guides/api-76","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run status, outputs, error, response-delivery state"},"751":{"id":"/guides/api-77","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/timeline`"},"752":{"id":"/guides/api-78","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Unified ascending timeline (`since=<iso>`, `limit=<n>`); backs `runyard tail`"},"753":{"id":"/guides/api-79","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/usage`"},"754":{"id":"/guides/api-80","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Metered usage: aggregate totals, per-call records, budget, and `budgetStop`"},"755":{"id":"/guides/api-81","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/events` · `/logs` · `/diagnostics`"},"756":{"id":"/guides/api-82","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Structured events, log lines, diagnostics + log summary"},"757":{"id":"/guides/api-83","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/artifacts` · `GET /api/artifacts/:id/download`"},"758":{"id":"/guides/api-84","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List a run's artifacts; download bytes"},"759":{"id":"/guides/api-85","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/runs/:id/cancel` · `/rerun` · `/promote`"},"760":{"id":"/guides/api-86","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Cancel; re-queue with same/edited input; merge a successful isolated run into its target branch"},"761":{"id":"/guides/api-87","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Other resources (see `/openapi.json` for the rest — schedules, catalog\nagents/skills/knowledge, hooks, workflow bundles and packages, workflow\nendpoints, runners, dashboard):"},"762":{"id":"/guides/api-88","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Method + path"},"763":{"id":"/guides/api-89","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Purpose"},"764":{"id":"/guides/api-90","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/schedules` · `POST /api/schedules`"},"765":{"id":"/guides/api-91","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List schedules; create cron/one-shot schedules (admin)"},"766":{"id":"/guides/api-92","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runners`"},"767":{"id":"/guides/api-93","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Registered runners, heartbeat state, capacity, pool summary"},"768":{"id":"/guides/api-94","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/tokens` · `POST /api/tokens` · `DELETE /api/tokens/:id`"},"769":{"id":"/guides/api-95","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Manage access tokens (admin)"},"770":{"id":"/guides/api-96","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/secrets` · `PUT /api/secrets/:key` · `DELETE /api/secrets/:key`"},"771":{"id":"/guides/api-97","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Encrypted secrets store — names and metadata only, never values (admin)"},"772":{"id":"/guides/api-98","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/hooks`"},"773":{"id":"/guides/api-99","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Post-run hook profiles a workflow may select via `input.postRunHooks`"},"774":{"id":"/guides/api-100","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/audit`"},"775":{"id":"/guides/api-101","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Audit log (admin)"},"776":{"id":"/guides/api-102","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/dashboard`"},"777":{"id":"/guides/api-103","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run counts by status, recent activity, attention items"},"778":{"id":"/guides/api-104","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Workflows can pause on a human decision. Approval cards are first-class API\nobjects (resolving them requires `api`, `mcp`, or `approvals` scope):"},"779":{"id":"/guides/api-105","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Method + path"},"780":{"id":"/guides/api-106","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Purpose"},"781":{"id":"/guides/api-107","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"`GET /api/approvals?status=pending`"},"782":{"id":"/guides/api-108","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"List approval cards (`pending` or `resolved`)"},"783":{"id":"/guides/api-109","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"`GET /api/approvals/:id`"},"784":{"id":"/guides/api-110","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"One card: title, `ask` (action / reason / audience), kind, linked run"},"785":{"id":"/guides/api-111","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"`POST /api/approvals`"},"786":{"id":"/guides/api-112","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Create a card: `{title, description, runId?, ask, timeoutMs?/timeoutAt? + fallback?}` for timed approvals"},"787":{"id":"/guides/api-113","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"`POST /api/approvals/:id/approve`"},"788":{"id":"/guides/api-114","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Approve — a held run is released"},"789":{"id":"/guides/api-115","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"`POST /api/approvals/:id/reject`"},"790":{"id":"/guides/api-116","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Reject — a held run is cancelled (never failed)"},"791":{"id":"/guides/api-117","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"`POST /api/approvals/:id/request-changes`"},"792":{"id":"/guides/api-118","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#approvals","content":"Request changes with a comment; the run is cancelled so it can be re-run with new input"},"793":{"id":"/guides/api-119","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Drafts make run-creation negotiation explicit: a draft is a proposed run that\nhas **not** been enqueued, and its status mirrors the latest preflight."},"794":{"id":"/guides/api-120","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Method + path"},"795":{"id":"/guides/api-121","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Purpose"},"796":{"id":"/guides/api-122","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"`POST /api/run-drafts`"},"797":{"id":"/guides/api-123","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#run-drafts","content":"Create + preflight a draft: `{workflow, input, executionMode}` → `201` with status `ready` / `needs_input` / `blocked` and open questions"},"798":{"i