r","content":"`GET /api/approvals?status=pending`, `GET /api/approvals/{id}`."},"1137":{"id":"/guides/approvals-telegram-20","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Telegram"},"1138":{"id":"/guides/approvals-telegram-21","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Cards are posted to the configured chat with inline buttons (see below)."},"1139":{"id":"/guides/approvals-telegram-22","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Each card takes one of three decisions:"},"1140":{"id":"/guides/approvals-telegram-23","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"HTTP: `POST /api/approvals/{id}/approve|reject|request-changes`. MCP: `approve_run`, `reject_run`, `request_changes_run` — all take an **approvalId**, not a runId. These need a token with the `api`, `mcp`, or `approvals` scope (admin always qualifies)."},"1141":{"id":"/guides/approvals-telegram-24","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"What each decision does depends on the card's kind:"},"1142":{"id":"/guides/approvals-telegram-25","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Kind"},"1143":{"id":"/guides/approvals-telegram-26","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Approve"},"1144":{"id":"/guides/approvals-telegram-27","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Request changes"},"1145":{"id":"/guides/approvals-telegram-28","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Reject"},"1146":{"id":"/guides/approvals-telegram-29","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Run hold (default / `custom`)"},"1147":{"id":"/guides/approvals-telegram-30","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The held run is released to the queue and executes."},"1148":{"id":"/guides/approvals-telegram-31","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The run is cancelled; your note tells the requester what to change."},"1149":{"id":"/guides/approvals-telegram-32","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The run is cancelled — a human \"no\" is a decision, not a failure."},"1150":{"id":"/guides/approvals-telegram-33","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`workflow_gate` (mid-run engine gate)"},"1151":{"id":"/guides/approvals-telegram-34","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The decision is applied to the paused workflow on the runner and it resumes past the gate."},"1152":{"id":"/guides/approvals-telegram-35","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Applied as a deny with your note attached; the workflow's own deny path decides what happens next."},"1153":{"id":"/guides/approvals-telegram-36","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Applied as a deny; the workflow's deny path decides what happens next."},"1154":{"id":"/guides/approvals-telegram-37","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`escalation` (run already ended)"},"1155":{"id":"/guides/approvals-telegram-38","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records your go-ahead on the card; the run is not restarted — re-run it from the run page."},"1156":{"id":"/guides/approvals-telegram-39","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records that the workflow or input needs fixing; your note is the guidance."},"1157":{"id":"/guides/approvals-telegram-40","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records that the run should be left as it ended."},"1158":{"id":"/guides/approvals-telegram-41","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`side_effect`"},"1159":{"id":"/guides/approvals-telegram-42","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The gated side effect is allowed to run."},"1160":{"id":"/guides/approvals-telegram-43","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The side effect is skipped; your note explains what to change."},"1161":{"id":"/guides/approvals-telegram-44","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The side effect is skipped; the run's completed work is unaffected."},"1162":{"id":"/guides/approvals-telegram-45","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Resolved cards keep the decision in their `resolution` field (`approved`, `rejected`, `changes_requested`) plus how it was decided (`resolvedVia`: human, fallback timer, engine, policy, or system)."},"1163":{"id":"/guides/approvals-telegram-46","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"Approvals are blocking by default: with no timer configured, nothing happens until someone decides, and a linked run is held open indefinitely."},"1164":{"id":"/guides/approvals-telegram-47","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"A creator can make a card timed by supplying `timeoutMs` or `timeoutAt`, optionally with a `fallback` decision (`approve` or `reject`) — via `POST /api/approvals` or the `create_approval` MCP tool:"},"1165":{"id":"/guides/approvals-telegram-48","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"**Timer + fallback** — if nobody decides before the deadline, the Hub applies the fallback decision on the human's behalf, fully audited (`resolvedVia: fallback_timer`)."},"1166":{"id":"/guides/approvals-telegram-49","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"**Timer without fallback** — when the timer elapses the card is flagged `fallback_required` and **stays pending**: it is surfaced as urgent, but no decision is ever invented."},"1167":{"id":"/guides/approvals-telegram-50","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"`timeoutMs` is clamped to between 1 second and 30 days."},"1168":{"id":"/guides/approvals-telegram-51","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#telegram-integration","content":"The Hub can post approval cards to a Telegram chat and accept decisions from the buttons on them."},"1169":{"id":"/guides/approvals-telegram-52","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Create a bot with Telegram's BotFather, then configure the Hub through environment variables (values belong in your env file or secret store — never in code or docs):"},"1170":{"id":"/guides/approvals-telegram-53","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Variable"},"1171":{"id":"/guides/approvals-telegram-54","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Purpose"},"1172":{"id":"/guides/approvals-telegram-55","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_BOT_TOKEN`"},"1173":{"id":"/guides/approvals-telegram-56","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"The bot's API token."},"1174":{"id":"/guides/approvals-telegram-57","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_APPROVAL_CHAT_ID`"},"1175":{"id":"/guides/approvals-telegram-58","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Chat (group or DM) where approval cards are posted."},"1176":{"id":"/guides/approvals-telegram-59","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_APPROVAL_USER_IDS`"},"1177":{"id":"/guides/approvals-telegram-60","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Comma-separated Telegram user ids allowed to resolve approvals."},"1178":{"id":"/guides/approvals-telegram-61","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_WEBHOOK_SECRET`"},"1179":{"id":"/guides/approvals-telegram-62","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Secret Telegram echoes back so the Hub can verify webhook calls."},"1180":{"id":"/guides/approvals-telegram-63","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_CHAT_ID` / `TELEGRAM_THREAD_ID`"},"1181":{"id":"/guides/approvals-telegram-64","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Optional default chat/thread for non-approval notifications."},"1182":{"id":"/guides/approvals-telegram-65","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#webhook","content":"Point the bot's webhook at the Hub:"},"1183":{"id":"/guides/approvals-telegram-66","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#webhook","content":"`POST /api/telegram/webhook` is the only Telegram-facing route. It is verified against the configured bot and webhook secret and is not a general API."},"1184":{"id":"/guides/approvals-telegram-67","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#approval-cards-with-buttons","content":"Each pending card is posted as a message carrying the ask (what approving does, why a human is needed), a sanitized input summary, and inline buttons: **Approve**, **Request changes**, **Reject**. Only the configured approval user ids can act; a button press resolves the card exactly like the web or API would, and the message is edited to show the resolution (\"Approved by ... at ...\") with the buttons removed."},"1185":{"id":"/guides/approvals-telegram-68","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#telegram-webapp-login","content":"Cards can deep-link into the Hub as a Telegram WebApp. `POST /api/auth/telegram-webapp` exchanges the WebApp's signed init data for a browser session that is limited to the `approvals` scope — a Telegram identity can review and resolve approval cards, and nothing else. Full app access always requires a real access token."},"1186":{"id":"/guides/ci","page_id":"/guides/ci","type":"page","content":"CI setup","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/ci"},"1187":{"id":"/guides/ci-0","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci","content":"Register the GitHub App, connect repositories, write .runyard/ci.yml, and set up CI runners (native + Dagger)."},"1188":{"id":"/guides/ci-1","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#1-register-a-github-app","content":"1\\. Register a GitHub App"},"1189":{"id":"/guides/ci-2","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#2-configure-the-hub","content":"2\\. Configure the hub"},"1190":{"id":"/guides/ci-3","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#3-connect-and-enable-repositories","content":"3\\. Connect and enable repositories"},"1191":{"id":"/guides/ci-4","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#4-write-runyardciyml","content":"4\\. Write `.runyard/ci.yml`"},"1192":{"id":"/guides/ci-5","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#5-set-up-a-ci-runner","content":"5\\. Set up a CI runner"},"1193":{"id":"/guides/ci-6","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#native-executor","content":"Native executor"},"1194":{"id":"/guides/ci-7","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#dagger-executor","content":"Dagger executor"},"1195":{"id":"/guides/ci-8","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#6-dogfood-and-recovery-surfaces","content":"6\\. Dogfood and recovery surfaces"},"1196":{"id":"/guides/ci-9","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#troubleshooting","content":"Troubleshooting"},"1197":{"id":"/guides/ci-10","page_id":"/guides/ci","type":"heading","tags":[],"url":"/guides/ci#migrating-from-github-actions","content":"Migrating from GitHub Actions"},"1198":{"id":"/guides/ci-11","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci","content":"This guide takes you from nothing to green checks: GitHub App registration, hub configuration, repository enablement, the `.runyard/ci.yml` reference, runner setup, and troubleshooting. Read Concepts → CI first for the model and trust boundary."},"1199":{"id":"/guides/ci-12","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Create a GitHub App (Settings → Developer settings → GitHub Apps → New) owned by your user or org:"},"1200":{"id":"/guides/ci-13","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"**Webhook URL**: `https://<your-hub>/api/ci/webhooks/github`"},"1201":{"id":"/guides/ci-14","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"**Webhook secret**: generate a long random value; you will hand the same value to the hub."},"1202":{"id":"/guides/ci-15","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"**Permissions** (the exact minimum):"},"1203":{"id":"/guides/ci-16","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Repository → **Contents: Read-only** (fetch `.runyard/ci.yml` + git checkout)"},"1204":{"id":"/guides/ci-17","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Repository → **Checks: Read & write** (create/update check runs)"},"1205":{"id":"/guides/ci-18","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Repository → **Metadata: Read-only** (implicit)"},"1206":{"id":"/guides/ci-19","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Repository → **Pull requests: Read-only** (PR event payloads)"},"1207":{"id":"/guides/ci-20","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"**Subscribe to events**: `Push`, `Pull request`, `Check run`, and the installation events are delivered automatically."},"1208":{"id":"/guides/ci-21","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Generate a **private key** (`.pem`) and note the **App ID**."},"1209":{"id":"/guides/ci-22","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#1-register-a-github-app","content":"Install the App on the repositories you want CI for. Installation is *connection only* — nothing runs until an operator enables each repository."},"1210":{"id":"/guides/ci-23","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#2-configure-the-hub","content":"The key and webhook secret never enter the database; installation tokens are minted just in time and held only in memory. Verify with `GET /api/ci/github-app` (admin) or the **CI** page in the web app — it reports configuration presence without any secret values."},"1211":{"id":"/guides/ci-24","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#3-connect-and-enable-repositories","content":"Trust policy governs secrets and native execution (see the trust model). `--runner-tags build,fast` additionally restricts this repository's jobs to runners carrying those tags."},"1212":{"id":"/guides/ci-25","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#4-write-runyardciyml","content":"Committed to the repository (loaded from the **trusted base** revision, pinned by SHA). The schema is deliberately small — it is not GitHub Actions:"},"1213":{"id":"/guides/ci-26","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#4-write-runyardciyml","content":"Validation errors are shown by `GET /api/ci/repos/:id/config`, the repository page in the web app, and — for triggered pipelines — as a failed `runyard/ci` check on the commit."},"1214":{"id":"/guides/ci-27","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#4-write-runyardciyml","content":"RunYard's own repository carries a working example at `.runyard/ci.yml`."},"1215":{"id":"/guides/ci-28","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#5-set-up-a-ci-runner","content":"Any RunYard runner becomes a CI runner by opting in:"},"1216":{"id":"/guides/ci-29","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#5-set-up-a-ci-runner","content":"Job workspaces are isolated per run, path-contained, removed on success, and retained (bounded) on failure for debugging."},"1217":{"id":"/guides/ci-30","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#native-executor","content":"`commands` join into a single `bash -c` script running under `set -euo pipefail` — the first failing command fails the job. The child environment is a strict allowlist baseline plus the job's `env`, the hub-delivered secrets, and `CI`/`RUNYARD_CI_*` context variables. Cancellation and timeouts kill the whole process group."},"1218":{"id":"/guides/ci-31","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#dagger-executor","content":"Install the open-source Dagger engine on the runner host — RunYard never auto-installs it and has no Dagger Cloud dependency. The runner probes `dagger version` at job start; if unavailable, the job fails as `infra_unavailable` with a clear message (checks show `action_required`), and native trusted jobs keep working. A dagger job runs `dagger call -m <module> <function> [--arg value…]` against the checked-out source; secrets ride environment variables through the same non-logging channel as native jobs."},"1219":{"id":"/guides/ci-32","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#6-dogfood-and-recovery-surfaces","content":"Equivalent HTTP endpoints live in the `ci` API group (`/api/v1/ci/...`), and MCP tools `list_ci_repositories`, `get_ci_pipeline`, `dispatch_ci_run` cover agent use. Admin diagnostics: `GET /api/ci/deliveries` (webhook ledger) and `GET /api/ci/diagnostics` (signature failures, duplicates, queue latency, check lag). After a GitHub outage, `POST /api/ci/pipelines/:id/sync-checks` resets the bounded check-retry counters and reconciles."},"1220":{"id":"/guides/ci-33","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Symptom"},"1221":{"id":"/guides/ci-34","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Cause / fix"},"1222":{"id":"/guides/ci-35","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Webhook answers `401 invalid signature`"},"1223":{"id":"/guides/ci-36","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"`RUNYARD_GITHUB_WEBHOOK_SECRET` doesn't match the App's webhook secret."},"1224":{"id":"/guides/ci-37","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Webhook answers `503`"},"1225":{"id":"/guides/ci-38","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"The hub has no GitHub App configuration — see step 2."},"1226":{"id":"/guides/ci-39","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Delivery recorded as `ignored: repository … not enabled`"},"1227":{"id":"/guides/ci-40","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Run `runyard repo enable <repo>` — installation alone never starts CI."},"1228":{"id":"/guides/ci-41","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"`ignored: no .runyard/ci.yml at trusted revision`"},"1229":{"id":"/guides/ci-42","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Commit the config to the default branch (PRs read it from the base)."},"1230":{"id":"/guides/ci-43","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Job blocked: `native CI execution is disabled on this runner`"},"1231":{"id":"/guides/ci-44","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Set `RUNYARD_RUNNER_CI_NATIVE=1` on the runner *and* mark the repo trusted with `allowNative`."},"1232":{"id":"/guides/ci-45","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Job failed `infra_unavailable: Dagger is not available`"},"1233":{"id":"/guides/ci-46","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Install Dagger on the runner or switch the job to `executor: native`."},"1234":{"id":"/guides/ci-47","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"Check stuck `queued` on GitHub"},"1235":{"id":"/guides/ci-48","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"See `GET /api/ci/diagnostics` → check lag; after an outage run `sync-checks`. Reporter failures never affect the run itself."},"1236":{"id":"/guides/ci-49","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"PR check `action_required: merge candidate conflicted`"},"1237":{"id":"/guides/ci-50","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#troubleshooting","content":"The PR no longer merges cleanly into its base — rebase/update the PR."},"1238":{"id":"/guides/ci-51","page_id":"/guides/ci","tags":[],"type":"text","url":"/guides/ci#migrating-from-github-actions","content":"Translate each workflow's `on:` triggers and jobs into the schema above; move repository secrets into the hub's secrets and reference them **by name** in `secrets:`; replace `runs-on` with runner tags + trust policy; keep the GitHub merge-gate by marking the `runyard/*` checks required in branch protection. Explicitly out of scope for now (planned follow-ups, not silently emulated): `act`-style local Actions compatibility, merge queues / speculative gating (Zuul-style), Kubernetes/Tekton executors, and release automation."},"1239":{"id":"/guides/cli","page_id":"/guides/cli","type":"page","content":"CLI","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/cli"},"1240":{"id":"/guides/cli-0","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli","content":"Install the runyard CLI, connect it to a Hub, and drive workflows, runs, approvals, and runners from the terminal."},"1241":{"id":"/guides/cli-1","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#install","content":"Install"},"1242":{"id":"/guides/cli-2","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#connecting-to-a-hub","content":"Connecting to a Hub"},"1243":{"id":"/guides/cli-3","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#discover-and-run-workflows","content":"Discover and run workflows"},"1244":{"id":"/guides/cli-4","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#watch-and-manage-runs","content":"Watch and manage runs"},"1245":{"id":"/guides/cli-5","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#approvals","content":"Approvals"},"1246":{"id":"/guides/cli-6","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#boards-and-portable-definitions","content":"Boards and portable definitions"},"1247":{"id":"/guides/cli-7","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#workflow-packages","content":"Workflow packages"},"1248":{"id":"/guides/cli-8","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#tokens-audit-and-catalog","content":"Tokens, audit, and catalog"},"1249":{"id":"/guides/cli-9","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#runner-setup","content":"Runner setup"},"1250":{"id":"/guides/cli-10","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#mcp-helpers","content":"MCP helpers"},"1251":{"id":"/guides/cli-11","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#updating-a-host-install","content":"Updating a host install"},"1252":{"id":"/guides/cli-12","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli","content":"The `runyard` CLI is a thin client of the Hub's HTTP API. It talks\nto one or more Hubs (\"remotes\"), starts and tails workflow runs, resolves\napprovals, and can set up and start a runner on the local machine."},"1253":{"id":"/guides/cli-13","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#install","content":"The fastest path is the install script served by your own Hub, which downloads\nthe CLI tarball from the same instance (`/cli.tgz`), installs `runyard` and\n`runyard-mcp` into `~/.local/bin`, and logs you in:"},"1254":{"id":"/guides/cli-14","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#install","content":"It prompts for an access token (Web Hub → Connect) and a name for the\nconnection. Alternatively, run the CLI from a source checkout of the\nrepository with `pnpm cli -- <command>` (the checkout exposes the `runyard`,\n`runyard-mcp`, and `runyard-runner` binaries under `bin/`)."},"1255":{"id":"/guides/cli-15","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#connecting-to-a-hub","content":"The CLI stores named remotes (Hub URL + token) in `~/.runyard/config.json`\n(mode `0600`). Every command accepts global options `--url`, `--token`,\n`--remote <name>`, and `--json` (machine-readable output)."},"1256":{"id":"/guides/cli-16","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#connecting-to-a-hub","content":"Environment variables `RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN` (and an explicit\n`--url` / `--token`) take precedence over the saved remote."},"1257":{"id":"/guides/cli-17","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`runyard run` options:"},"1258":{"id":"/guides/cli-18","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Option"},"1259":{"id":"/guides/cli-19","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Meaning"},"1260":{"id":"/guides/cli-20","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`-i, --input <json>`"},"1261":{"id":"/guides/cli-21","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"JSON input for the run"},"1262":{"id":"/guides/cli-22","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--where <mode>`"},"1263":{"id":"/guides/cli-23","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Execution mode: `local` or `remote` (alias: `--execution-mode`)"},"1264":{"id":"/guides/cli-24","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--runner-location <location>`"},"1265":{"id":"/guides/cli-25","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Target a specific runner location tag"},"1266":{"id":"/guides/cli-26","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--negotiate`"},"1267":{"id":"/guides/cli-27","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Preflight first: enqueue only when ready, otherwise print the negotiation state (questions/blockers and a saved draft) without creating a run"},"1268":{"id":"/guides/cli-28","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--chain <json>`"},"1269":{"id":"/guides/cli-29","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"JSON array of next workflow steps to queue after each run succeeds"},"1270":{"id":"/guides/cli-30","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--pin <sha>`"},"1271":{"id":"/guides/cli-31","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Pin the run to a specific workflow git SHA (requires workflow versioning)"},"1272":{"id":"/guides/cli-32","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--max-tokens <n>`"},"1273":{"id":"/guides/cli-33","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Hard budget: stop the run once its metered usage reaches this many tokens"},"1274":{"id":"/guides/cli-34","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--max-cost <usd>`"},"1275":{"id":"/guides/cli-35","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Hard budget: stop the run once its metered cost reaches this many US dollars"},"1276":{"id":"/guides/cli-36","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Related: `runyard workflow versions <workflow>` lists SHAs seen across runs and\n`runyard workflow rollback <workflow> <sha>` re-runs pinned to a prior SHA\n(`--from-run <id>` links it to the run being rolled back)."},"1277":{"id":"/guides/cli-37","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#watch-and-manage-runs","content":"`tail` emits `{ts, kind, source, payload}` lines built from status transitions,\nevents, and artifacts, polling every 2 seconds with a `since` cursor — pipe it\ninto `jq` or downstream tooling."},"1278":{"id":"/guides/cli-38","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#boards-and-portable-definitions","content":"Boards are configured software-factory views over work items. Board **definitions** are portable JSON documents describing a whole kanban — lanes, guards, triggers, transition policy, and optional schedule hookups. Agents provision boards from these documents; the DB row is one instance of a definition."},"1279":{"id":"/guides/cli-39","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#boards-and-portable-definitions","content":"The example ships in the repo at `workflow-templates/board-definitions/runyard-development-factory.json` and is fetchable over the API too. YAML is a future syntax; JSON is the documented format today."},"1280":{"id":"/guides/cli-40","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#workflow-packages","content":"Workflows move between Hubs as portable `.runyard-workflow.json` package files\n— exported from one Hub and imported into another (admin token required).\nImported workflows arrive **disabled** for review before enabling; this is the\nsupported way to carry workflow source around, not files on a runner."},"1281":{"id":"/guides/cli-41","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#tokens-audit-and-catalog","content":"Admin-scoped commands:"},"1282":{"id":"/guides/cli-42","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#tokens-audit-and-catalog","content":"Reads available to any token: `runyard runners` (runner pool), `runyard agents`,\n`runyard skills`, `runyard knowledge -q <query>`, `runyard hooks [--workflow <slug>]`, and `runyard hook describe|validate <slug>`. Secrets have\nno CLI subcommand — manage them in the web UI, over the\nAPI (`PUT /api/secrets/:key`), or with the MCP `set_secret` tool."},"1283":{"id":"/guides/cli-43","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"Turn a machine into a runner in three steps. First scaffold a workspace\n(requires `bun` and the `smithers` engine on `PATH`; it warns if no `claude`,\n`codex`, or `pi` agent CLI is found):"},"1284":{"id":"/guides/cli-44","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"Then start the runner against the current remote (it inherits the remote's URL\nand token, or `RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN`):"},"1285":{"id":"/guides/cli-45","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"`--location` is `local` or `vps` and drives run routing (`--where local` runs\nland on `local`-tagged runners). You can also register a machine explicitly:"},"1286":{"id":"/guides/cli-46","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"For an always-on runner use the systemd unit instead — see\nInstallation."},"1287":{"id":"/guides/cli-47","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#mcp-helpers","content":"See the MCP guide for clients and options."},"1288":{"id":"/guides/cli-48","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#updating-a-host-install","content":"On a host that runs the Hub from a full checkout (not the thin CLI bundle),\n`runyard update [tag]` applies a release **on that host**: it drains runners,\nswaps the code, restarts the systemd units, verifies health, and rolls back\nautomatically on failure. It is always operator-initiated."},"1289":{"id":"/guides/cli-49","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#updating-a-host-install","content":"Options: `--units <units>` (systemd units to restart, default\n`runyard runyard-runner`) and `--grace-ms <ms>` (bounded drain window before\naborting — in-flight runs are never killed)."},"1290":{"id":"/guides/installation","page_id":"/guides/installation","type":"page","content":"Installation","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/installation"},"1291":{"id":"/guides/installation-0","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"Install and deploy a Runyard Hub and runners — from source, with systemd, or with Docker."},"1292":{"id":"/guides/installation-1","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#requirements","content":"Requirements"},"1293":{"id":"/guides/installation-2","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#quick-install-host-bootstrap","content":"Quick install (host bootstrap)"},"1294":{"id":"/guides/installation-3","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#running-from-source","content":"Running from source"},"1295":{"id":"/guides/installation-4","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#systemd","content":"systemd"},"1296":{"id":"/guides/installation-5","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#docker-compose","content":"Docker Compose"},"1297":{"id":"/guides/installation-6","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"Confidential VMs (dstack / Intel TDX)"},"1298":{"id":"/guides/installation-7","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#reverse-proxy","content":"Reverse proxy"},"1299":{"id":"/guides/installation-8","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#environment-variables","content":"Environment variables"},"1300":{"id":"/guides/installation-9","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#where-state-lives","content":"Where state lives"},"1301":{"id":"/guides/installation-10","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#next-steps","content":"Next steps"},"1302":{"id":"/guides/installation-11","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"Runyard is a self-hosted control plane for agent runs. A deployment has a small,\nfixed shape:"},"1303":{"id":"/guides/installation-12","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Hub** — the HTTP server: API, web UI, MCP-backing endpoints, and the embedded\nSQLite datastore. One per deployment."},"1304":{"id":"/guides/installation-13","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Runners** — one or more worker processes that register with the Hub using a\nrunner-scoped token, heartbeat, claim queued runs, and execute workflows. A\nrunner can live on the same host as the Hub or on a separate machine."},"1305":{"id":"/guides/installation-14","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Clients** — the `runyard` CLI, the `runyard-mcp` MCP server, and the web app\nare all ordinary API clients of the Hub."},"1306":{"id":"/guides/installation-15","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Requirement"},"1307":{"id":"/guides/installation-16","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Notes"},"1308":{"id":"/guides/installation-17","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Node.js >= 22.5"},"1309":{"id":"/guides/installation-18","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"The Hub uses the built-in `node:sqlite` module (started with `--experimental-sqlite`)"},"1310":{"id":"/guides/installation-19","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"pnpm"},"1311":{"id":"/guides/installation-20","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Dependency install and build (`corepack enable` works)"},"1312":{"id":"/guides/installation-21","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"git, curl"},"1313":{"id":"/guides/installation-22","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"For source installs and the bootstrap script"},"1314":{"id":"/guides/installation-23","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Runner hosts additionally need the Smithers engine and at least one authenticated\nagent CLI (`claude`, `codex`, or `pi`) on `PATH` — see the CLI guide\nfor `runyard runner setup`."},"1315":{"id":"/guides/installation-24","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"The repository ships a one-command, idempotent bootstrap script for a fresh\nLinux box:"},"1316":{"id":"/guides/installation-25","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"It ensures Node 22 + pnpm, clones the latest release tag into `/opt/runyard`\n(override with `RUNYARD_HOME`), runs `pnpm install --frozen-lockfile`, generates\na `SECRETS_ENC_KEY` and session secret into `/etc/runyard/runyard.env` (never\nclobbering an existing file, never printing secrets), creates the data\ndirectory, installs and enables the systemd units for the Hub and a runner, and\ninstalls a daily *passive* update-check timer (it never auto-applies updates)."},"1317":{"id":"/guides/installation-26","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"When it finishes it prints next steps: sign in with the bootstrap token, mint a\nrunner-scoped token, put it in `/etc/runyard/runner.env`, and restart the runner\nunit."},"1318":{"id":"/guides/installation-27","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"A running Hub also serves its own **client** install script at\n`https://hub.example.com/install.sh` (plus the CLI tarball at `/cli.tgz`). That\none installs the `runyard` CLI and `runyard-mcp` on a workstation — see\nthe CLI guide."},"1319":{"id":"/guides/installation-28","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#running-from-source","content":"The Hub listens on `127.0.0.1:43117` by default. Start a runner in a second\nprocess:"},"1320":{"id":"/guides/installation-29","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#running-from-source","content":"The runner authenticates with a runner-scoped token (`RUNYARD_HUB_TOKEN`); on a\nfresh Hub it may use the bootstrap token until you mint one."},"1321":{"id":"/guides/installation-30","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"The repository ships generic units in `deploy/`. The Hub unit\n(`deploy/runyard.service`):"},"1322":{"id":"/guides/installation-31","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"And the runner unit (`deploy/runyard-runner.service`):"},"1323":{"id":"/guides/installation-32","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"The bootstrap script installs these for you, retargeted to your install\ndirectory, env-file location, and node binary. Secrets live in the\n`EnvironmentFile`s (mode `0600`), never in the units."},"1324":{"id":"/guides/installation-33","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Runyard publishes two environment-agnostic images to GHCR:"},"1325":{"id":"/guides/installation-34","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Image"},"1326":{"id":"/guides/installation-35","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Role"},"1327":{"id":"/guides/installation-36","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`ghcr.io/yolo-maxi/runyard-hub`"},"1328":{"id":"/guides/installation-37","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"control plane + web UI + embedded datastore (HTTP on `PORT`, default 8080 in-container)"},"1329":{"id":"/guides/installation-38","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`ghcr.io/yolo-maxi/runyard-runner`"},"1330":{"id":"/guides/installation-39","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"claims runs and executes them; workspace volume at `/workspace`"},"1331":{"id":"/guides/installation-40","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"The portable base stack is `docker-compose.yml` at the repo root:"},"1332":{"id":"/guides/installation-41","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Provide secrets (`RUNYARD_HUB_SESSION_SECRET`, `SECRETS_ENC_KEY`,\n`RUNYARD_HUB_TOKEN`, agent API keys) via a `.env` file or your platform's secret\nmechanism. For production, pin images by `@sha256:` digest rather than mutable\ntags. Optional overlays (all off by default):"},"1333":{"id":"/guides/installation-42","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`--profile proxy` — a bundled Caddy container that terminates TLS for\n`SITE_ADDRESS` and proxies to the Hub. Skip it if you already have a gateway."},"1334":{"id":"/guides/installation-43","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`-f deploy/compose/runner-docker-socket.yml` — give the runner `docker build`\naccess via the host socket (or run a rootless DinD sidecar instead)."},"1335":{"id":"/guides/installation-44","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`-f docker-compose.local.yml` — dev profile using locally built images."},"1336":{"id":"/guides/installation-45","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"`deploy/dstack/` contains an overlay that adapts the base compose for dstack\nconfidential-VM deployments: every image **must** be pinned by digest (the\nattestation measures the compose text), the Hub sits on `:80` behind the\ndstack gateway, and updates/rollbacks go through dstack's `UpgradeApp` with new\ndigests. Render a single self-contained file with:"},"1337":{"id":"/guides/installation-46","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"See `deploy/dstack/README.md` in the repository for the full contract."},"1338":{"id":"/guides/installation-47","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#reverse-proxy","content":"The Hub is a single HTTP listener; any TLS-terminating proxy that forwards **all\npaths** to the Hub port works. With Caddy:"},"1339":{"id":"/guides/installation-48","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#reverse-proxy","content":"Then set `BASE_URL=https://hub.example.com` in the Hub's env file and restart.\nAn `https://` base URL switches the Hub into production session mode. If the\nproxy is not on loopback, set the trust-proxy configuration accordingly so\nclient IPs (used by rate limiting) are read from `X-Forwarded-For` only when\nthat header is trustworthy."},"1340":{"id":"/guides/installation-49","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Hub (all optional unless noted; legacy `SMITHERS_HUB_*` names are still read as\nfallbacks so old deployments keep working):"},"1341":{"id":"/guides/installation-50","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Variable"},"1342":{"id":"/guides/installation-51","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Meaning"},"1343":{"id":"/guides/installation-52","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`PORT`"},"1344":{"id":"/guides/installation-53","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Hub HTTP port (default `43117`; the container image defaults to 8080)"},"1345":{"id":"/guides/installation-54","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`HOST`"},"1346":{"id":"/guides/installation-55","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Bind address (default `127.0.0.1`)"},"1347":{"id":"/guides/installation-56","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`BASE_URL`"},"1348":{"id":"/guides/installation-57","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Public URL of the Hub (e.g. `https://hub.example.com`); an `https` value enables production behavior"},"1349":{"id":"/guides/installation-58","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_DATA_DIR`"},"1350":{"id":"/guides/installation-59","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Data directory (default `<repo>/data`) — the DB, artifacts, and bootstrap token live here"},"1351":{"id":"/guides/installation-60","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_DB`"},"1352":{"id":"/guides/installation-61","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Explicit SQLite database path (default `<data dir>/runyard.sqlite`)"},"1353":{"id":"/guides/installation-62","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_SESSION_SECRET`"},"1354":{"id":"/guides/installation-63","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Secret for browser session cookies. Required in production; in dev a generated value is persisted to the data dir"},"1355":{"id":"/guides/installation-64","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SECRETS_ENC_KEY`"},"1356":{"id":"/guides/installation-65","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"32-byte key (base64/hex) for the encrypted secrets store. Keep it safe — rotating it makes stored secrets unreadable"},"1357":{"id":"/guides/installation-66","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_BOOTSTRAP_TOKEN`"},"1358":{"id":"/guides/installation-67","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Optional pre-seeded bootstrap admin/runner token (containers); on host installs one is generated into the data dir"},"1359":{"id":"/guides/installation-68","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_INSTANCE_NAME`"},"1360":{"id":"/guides/installation-69","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Display name of the deployment (default `Runyard`)"},"1361":{"id":"/guides/installation-70","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Runner:"},"1362":{"id":"/guides/installation-71","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Variable"},"1363":{"id":"/guides/installation-72","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Meaning"},"1364":{"id":"/guides/installation-73","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_URL`"},"1365":{"id":"/guides/installation-74","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"How the runner reaches the Hub (e.g. `https://hub.example.com`)"},"1366":{"id":"/guides/installation-75","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`RUNYARD_HUB_TOKEN`"},"1367":{"id":"/guides/installation-76","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Runner-scoped access token minted on the Hub"},"1368":{"id":"/guides/installation-77","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_WORKSPACE`"},"1369":{"id":"/guides/installation-78","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Workspace directory the runner executes workflows in"},"1370":{"id":"/guides/installation-79","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_RUNNER_LOCATION`"},"1371":{"id":"/guides/installation-80","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Location label (`vps` or `local`) used for run routing"},"1372":{"id":"/guides/installation-81","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_RUNNER_NAME` / `SMITHERS_RUNNER_TAGS`"},"1373":{"id":"/guides/installation-82","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Runner display name and capability tags"},"1374":{"id":"/guides/installation-83","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"`SMITHERS_RUNNER_CONCURRENCY`"},"1375":{"id":"/guides/installation-84","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Max concurrent runs (default 1)"},"1376":{"id":"/guides/installation-85","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"Everything durable is in the Hub's data directory (`RUNYARD_HUB_DATA_DIR`,\ndefault `data/`; the `hub-data` volume mounted at `/data` in containers). It\nsurvives every update and rollback:"},"1377":{"id":"/guides/installation-86","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`runyard.sqlite` — the SQLite database (runs, workflows, tokens, schedules,\napprovals, encrypted secrets)"},"1378":{"id":"/guides/installation-87","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`artifacts/` — uploaded run artifacts"},"1379":{"id":"/guides/installation-88","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`bootstrap-token.txt` — the first admin token, generated on first boot\n(mode `0600`); use it to sign in once and mint scoped tokens"},"1380":{"id":"/guides/installation-89","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"`session-secret.txt` — the persisted dev session secret when none is provided"},"1381":{"id":"/guides/installation-90","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#where-state-lives","content":"Back this directory up. The runner workspace, by contrast, is disposable\nscratch space — outputs and event traces are uploaded to the Hub as artifacts."},"1382":{"id":"/guides/installation-91","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#next-steps","content":"Point clients at the Hub: CLI guide, MCP guide"},"1383":{"id":"/guides/installation-92","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#next-steps","content":"Drive it over HTTP: API guide"},"1384":{"id":"/guides/mcp","page_id":"/guides/mcp","type":"page","content":"MCP","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/mcp"},"1385":{"id":"/guides/mcp-0","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp","content":"Connect AI agents to a Runyard Hub with the runyard-mcp stdio server and its 87-tool surface."},"1386":{"id":"/guides/mcp-1","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#install-and-configure","content":"Install and configure"},"1387":{"id":"/guides/mcp-2","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#hub-url-and-token-resolution","content":"Hub URL and token resolution"},"1388":{"id":"/guides/mcp-3","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#the-tool-surface","content":"The tool surface"},"1389":{"id":"/guides/mcp-4","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#the-parity-guarantee","content":"The parity guarantee"},"1390":{"id":"/guides/mcp-5","page_id":"/guides/mcp","type":"heading","tags":[],"url":"/guides/mcp#recommended-agent-flow","content":"Recommended agent flow"},"1391":{"id":"/guides/mcp-6","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp","content":"`runyard-mcp` is a stdio Model Context Protocol\nserver that ships with the Runyard CLI. It runs locally next to your AI client\n(Claude Code, Claude Desktop, Codex, Cursor, and others), and translates every\ntool call into an authenticated HTTP request against your Hub. No workflow\nlogic runs in the MCP server itself — it is a thin, faithful client of the\nHTTP API."},"1392":{"id":"/guides/mcp-7","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"Install the CLI first (it bundles `runyard-mcp`) and log in — see the\nCLI guide:"},"1393":{"id":"/guides/mcp-8","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"Then let the CLI write your AI client's MCP config:"},"1394":{"id":"/guides/mcp-9","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"Supported `--client` values: `claude-code`, `claude-desktop`, `codex`,\n`cursor`, `windsurf`, `gemini`, `vscode`. Each writes the appropriate config\nfile (for example `.mcp.json` for Claude Code, `~/.codex/config.toml` for\nCodex, `.vscode/mcp.json` for VS Code) and prints how to activate it."},"1395":{"id":"/guides/mcp-10","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#install-and-configure","content":"To configure a client by hand, print the snippet instead:"},"1396":{"id":"/guides/mcp-11","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The server name is `runyard` for the default remote and `runyard-<remote>` for\nothers, so one client can talk to several Hubs. &#x2A;*No token is stored in client\nconfigs.** At startup the server resolves its target in this order:"},"1397":{"id":"/guides/mcp-12","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"`RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN` environment variables\n(legacy `SMITHERS_HUB_URL` / `SMITHERS_HUB_TOKEN` and `HUB_URL` / `HUB_TOKEN`\nstill work)"},"1398":{"id":"/guides/mcp-13","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The `--remote <name>` argument, resolved against the saved remotes in\n`~/.runyard/config.json` (written by `runyard login`)"},"1399":{"id":"/guides/mcp-14","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The current saved remote"},"1400":{"id":"/guides/mcp-15","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#hub-url-and-token-resolution","content":"The token's scopes decide what the tools may do — a token with `mcp` scope can\ndiscover, preflight, and run workflows; `admin` unlocks the admin tools listed\nbelow."},"1401":{"id":"/guides/mcp-16","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"The server exposes tools generated from the same API surface registry\nthe Hub's routes and `/openapi.json` come from. Grouped by resource:"},"1402":{"id":"/guides/mcp-17","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Group"},"1403":{"id":"/guides/mcp-18","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Tools"},"1404":{"id":"/guides/mcp-19","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Discovery & identity"},"1405":{"id":"/guides/mcp-20","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`get_menu`, `whoami`, `get_dashboard`, `list_repo_options`"},"1406":{"id":"/guides/mcp-21","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Workflows"},"1407":{"id":"/guides/mcp-22","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_workflows`, `search_workflows`, `describe_workflow`, `get_workflow_source`, `list_workflow_versions`, `create_workflow`†, `update_workflow`†, `delete_workflow`†"},"1408":{"id":"/guides/mcp-23","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Running"},"1409":{"id":"/guides/mcp-24","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`preflight_workflow`, `run_workflow`, `rerun_workflow_run`, `promote_run`, `cancel_run`"},"1410":{"id":"/guides/mcp-25","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"Runs (observe)"},"1411":{"id":"/guides/mcp-26","page_id":"/guides/mcp","tags":[],"type":"text","url":"/guides/mcp#the-tool-surface","content":"`list_runs`, `get_run_status`, `get_run_events`, `get_run_timeline`, `get_run_diagno