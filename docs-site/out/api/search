/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"84":{"id":"/concepts/agents-skills-knowledge-43","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/knowledge/{slug}`"},"85":{"id":"/concepts/agents-skills-knowledge-44","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_knowledge`"},"86":{"id":"/concepts/agents-skills-knowledge-45","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"87":{"id":"/concepts/approvals","page_id":"/concepts/approvals","type":"page","content":"Approvals","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/approvals"},"88":{"id":"/concepts/approvals-0","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"Approval cards - kinds, the ask contract, resolutions, timed approvals with fallbacks, and per-kind consequences."},"89":{"id":"/concepts/approvals-1","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#kinds","content":"Kinds"},"90":{"id":"/concepts/approvals-2","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#the-ask-contract","content":"The ask contract"},"91":{"id":"/concepts/approvals-3","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#status-and-resolution","content":"Status and resolution"},"92":{"id":"/concepts/approvals-4","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#timed-approvals-with-fallback","content":"Timed approvals with fallback"},"93":{"id":"/concepts/approvals-5","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#per-kind-consequences","content":"Per-kind consequences"},"94":{"id":"/concepts/approvals-6","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#api--mcp","content":"API & MCP"},"95":{"id":"/concepts/approvals-7","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"An **approval** is a declared question with a declared consequence, presented to a human as a card in the web app, over Telegram, or through the API/MCP. Cards can hold a run before it executes (`waiting_approval`), pause a workflow mid-run at an engine gate, or simply record a decision. A run held on an approval waits indefinitely — waiting never fails it."},"96":{"id":"/concepts/approvals-8","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Kind"},"97":{"id":"/concepts/approvals-9","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"What it represents"},"98":{"id":"/concepts/approvals-10","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`workflow_gate`"},"99":{"id":"/concepts/approvals-11","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A workflow paused at a gate; the decision releases or denies that step."},"100":{"id":"/concepts/approvals-12","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`escalation`"},"101":{"id":"/concepts/approvals-13","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Autonomous recovery gave up; a human records how to proceed."},"102":{"id":"/concepts/approvals-14","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`side_effect`"},"103":{"id":"/concepts/approvals-15","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A gated side effect asking permission before it runs."},"104":{"id":"/concepts/approvals-16","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`custom`"},"105":{"id":"/concepts/approvals-17","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Any ad-hoc approval raised via the API."},"106":{"id":"/concepts/approvals-18","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"The creator of a card states the ask up front, and every surface renders it verbatim:"},"107":{"id":"/concepts/approvals-19","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`action` — what exactly happens on approve."},"108":{"id":"/concepts/approvals-20","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`reason` — why a human is needed."},"109":{"id":"/concepts/approvals-21","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`audience` — who is asked: `operators` (default) or `admins`."},"110":{"id":"/concepts/approvals-22","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`options` — optional named choices (up to 8)."},"111":{"id":"/concepts/approvals-23","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"An ask without both `action` and `reason` is treated as absent; such cards fall back to a heuristic ask explicitly marked `derived: true`, so a guessed question is never presented as an authored one."},"112":{"id":"/concepts/approvals-24","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"A card's `status` is only ever `pending` or `resolved`. What was decided and by what live in separate fields:"},"113":{"id":"/concepts/approvals-25","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Field"},"114":{"id":"/concepts/approvals-26","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Values"},"115":{"id":"/concepts/approvals-27","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolution`"},"116":{"id":"/concepts/approvals-28","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`approved`, `rejected`, `changes_requested`, `superseded` (the run ended first), or `option:<id>`"},"117":{"id":"/concepts/approvals-29","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolvedVia`"},"118":{"id":"/concepts/approvals-30","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`human`, `fallback_timer` (autopilot), `engine` (decided on the runner), `policy` (auto-approved by policy), `system`"},"119":{"id":"/concepts/approvals-31","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"By default a card is blocking: nothing happens until someone decides. Supplying `timeoutMs` or `timeoutAt` at creation makes it a **timed approval**:"},"120":{"id":"/concepts/approvals-32","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"With a `fallback` decision (`approve` or `reject`), the configured decision is applied automatically when the timer elapses, recorded with `resolvedVia: \"fallback_timer\"`."},"121":{"id":"/concepts/approvals-33","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"Without a fallback, the elapsed card is flagged `fallback_required` and keeps waiting — no decision is invented, and the linked run is never failed by an elapsed timer."},"122":{"id":"/concepts/approvals-34","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"Every card answers \"what will my decision do\" honestly, computed from what resolving actually performs:"},"123":{"id":"/concepts/approvals-35","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`workflow_gate`** — approving a card holding a `waiting_approval` run releases it; approving a mid-run gate applies the decision to the paused workflow on the runner, which resumes past the gate. Reject/changes-requested cancel a held run, or take the workflow's own deny path mid-run."},"124":{"id":"/concepts/approvals-36","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`escalation`** — the run already ended: any decision records the call but does not restart the run (re-run it from the run page)."},"125":{"id":"/concepts/approvals-37","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`side_effect`** — approve allows the gated side effect; reject or changes-requested skip it. The run's completed work is unchanged either way."},"126":{"id":"/concepts/approvals-38","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`custom`** — approving a held run releases it to the queue; reject/changes-requested cancel it. On a card without a held run, the decision is simply recorded."},"127":{"id":"/concepts/approvals-39","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"The API exposes these as `whatHappensIfApproved` / `whatHappensIfRejected` / `whatHappensIfChangesRequested` / `whatHappensIfIgnored` in each card's `context`, alongside the ask, the linked run, and deep links."},"128":{"id":"/concepts/approvals-40","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Endpoint"},"129":{"id":"/concepts/approvals-41","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"MCP tool"},"130":{"id":"/concepts/approvals-42","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Notes"},"131":{"id":"/concepts/approvals-43","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals`"},"132":{"id":"/concepts/approvals-44","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`list_approvals`, `list_pending_approvals`"},"133":{"id":"/concepts/approvals-45","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`?status=pending\\|resolved`."},"134":{"id":"/concepts/approvals-46","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals/{id}`"},"135":{"id":"/concepts/approvals-47","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`get_approval`"},"136":{"id":"/concepts/approvals-48","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Full card with context."},"137":{"id":"/concepts/approvals-49","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals`"},"138":{"id":"/concepts/approvals-50","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`create_approval`"},"139":{"id":"/concepts/approvals-51","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`{title, description, runId?, ask, timeoutMs?/timeoutAt?, fallback?}`."},"140":{"id":"/concepts/approvals-52","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/approve`"},"141":{"id":"/concepts/approvals-53","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`approve_run`"},"142":{"id":"/concepts/approvals-54","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Takes an approval id, not a run id."},"143":{"id":"/concepts/approvals-55","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/reject`"},"144":{"id":"/concepts/approvals-56","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`reject_run`"},"145":{"id":"/concepts/approvals-57","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"A held run is cancelled, never failed."},"146":{"id":"/concepts/approvals-58","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/request-changes`"},"147":{"id":"/concepts/approvals-59","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`request_changes_run`"},"148":{"id":"/concepts/approvals-60","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Comment describes the requested changes."},"149":{"id":"/concepts/approvals-61","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Resolving approvals requires the `api`, `mcp`, or `approvals` scope; Telegram WebApp sessions are approvals-scoped by design (see Tokens & scopes)."},"150":{"id":"/concepts/deep-links","page_id":"/concepts/deep-links","type":"page","content":"Deep Links","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/deep-links"},"151":{"id":"/concepts/deep-links-0","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links","content":"Every Hub URL is shareable - the hash-route grammar of the web app and the deep links the API returns."},"152":{"id":"/concepts/deep-links-1","page_id":"/concepts/deep-links","type":"heading","tags":[],"url":"/concepts/deep-links#route-grammar","content":"Route grammar"},"153":{"id":"/concepts/deep-links-2","page_id":"/concepts/deep-links","type":"heading","tags":[],"url":"/concepts/deep-links#deep-links-in-api-payloads","content":"Deep links in API payloads"},"154":{"id":"/concepts/deep-links-3","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links","content":"Every URL in the Runyard web app is shareable: the app is a hash-routed SPA, so any view — a run's logs, a workflow's graph, a pending approval — can be copied from the address bar and opened by anyone with access to the Hub. Links have the form:"},"155":{"id":"/concepts/deep-links-4","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Route"},"156":{"id":"/concepts/deep-links-5","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"View"},"157":{"id":"/concepts/deep-links-6","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runs`"},"158":{"id":"/concepts/deep-links-7","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Run list (also the home view)."},"159":{"id":"/concepts/deep-links-8","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runs/:id`"},"160":{"id":"/concepts/deep-links-9","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Run detail."},"161":{"id":"/concepts/deep-links-10","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runs/:id/logs`"},"162":{"id":"/concepts/deep-links-11","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Run logs tab."},"163":{"id":"/concepts/deep-links-12","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runs/:id/artifacts`"},"164":{"id":"/concepts/deep-links-13","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Run artifacts tab."},"165":{"id":"/concepts/deep-links-14","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runs/:id/artifacts/:artifactId`"},"166":{"id":"/concepts/deep-links-15","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"A specific artifact."},"167":{"id":"/concepts/deep-links-16","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows`"},"168":{"id":"/concepts/deep-links-17","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Workflow catalog."},"169":{"id":"/concepts/deep-links-18","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug`"},"170":{"id":"/concepts/deep-links-19","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Workflow detail."},"171":{"id":"/concepts/deep-links-20","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/graph`"},"172":{"id":"/concepts/deep-links-21","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Visual graph tab."},"173":{"id":"/concepts/deep-links-22","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/code`"},"174":{"id":"/concepts/deep-links-23","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Source code tab."},"175":{"id":"/concepts/deep-links-24","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/runs`"},"176":{"id":"/concepts/deep-links-25","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"The workflow's runs."},"177":{"id":"/concepts/deep-links-26","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/run`"},"178":{"id":"/concepts/deep-links-27","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Start-a-run form."},"179":{"id":"/concepts/deep-links-28","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/edit`"},"180":{"id":"/concepts/deep-links-29","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Edit the workflow (admin)."},"181":{"id":"/concepts/deep-links-30","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#approvals`, `#approvals/:id`"},"182":{"id":"/concepts/deep-links-31","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Approval inbox / one card."},"183":{"id":"/concepts/deep-links-32","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#schedules`, `#schedules/:id`"},"184":{"id":"/concepts/deep-links-33","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Schedules / one schedule."},"185":{"id":"/concepts/deep-links-34","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#agents/agents`, `#agents/skills`, `#agents/knowledge`"},"186":{"id":"/concepts/deep-links-35","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"The shared catalogs (append `/:slug` for one entry)."},"187":{"id":"/concepts/deep-links-36","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runners`"},"188":{"id":"/concepts/deep-links-37","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Runner health and pool."},"189":{"id":"/concepts/deep-links-38","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#tokens`, `#secrets`, `#audit`, `#settings`, `#connect`"},"190":{"id":"/concepts/deep-links-39","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Admin and setup views."},"191":{"id":"/concepts/deep-links-40","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Segments are URL-encoded, so ids and slugs with special characters remain valid links. Some tabs accept aliases (for example `visual` for `graph`, `source` for `code`)."},"192":{"id":"/concepts/deep-links-41","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"The API hands these links back so agents and integrations can point humans at the right screen without building URLs themselves:"},"193":{"id":"/concepts/deep-links-42","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"Approval cards carry `deepLink` (the card) and `deepLinkRun` (the linked run), and their `context` includes workflow and run deep links."},"194":{"id":"/concepts/deep-links-43","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"Run-creating responses (`run_workflow`, schedule run-now, draft submit) include link objects for following the run — its status, events, and artifacts endpoints."},"195":{"id":"/concepts/deep-links-44","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"When an agent hands off to a human — \"approve this\", \"read the logs\" — prefer relaying the payload's deep link over describing where to click."},"196":{"id":"/concepts/hooks","page_id":"/concepts/hooks","type":"page","content":"Hooks","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/hooks"},"197":{"id":"/concepts/hooks-0","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks","content":"Post-run hook profiles - admin-defined, bounded side effects selected per run that never fail a green run."},"198":{"id":"/concepts/hooks-1","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Profiles are bounded on purpose"},"199":{"id":"/concepts/hooks-2","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#selecting-hooks-per-run","content":"Selecting hooks per run"},"200":{"id":"/concepts/hooks-3","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Hook outcomes never turn a green run red"},"201":{"id":"/concepts/hooks-4","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#api--mcp","content":"API & MCP"},"202":{"id":"/concepts/hooks-5","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks","content":"A **post-run hook profile** is an admin-authored recipe for an optional side effect — publishing static output, pushing a work branch, calling a webhook — that runs *after* a run has produced its verified artifacts and its gates have passed. Hooks separate \"the work succeeded\" from \"the side effect happened\": callers opt in per run, and hook outcomes never rewrite a run's status."},"203":{"id":"/concepts/hooks-6","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Each profile has a fixed `kind` with a fixed set of config keys — anything else is rejected, so raw credentials or ad-hoc shell fragments can never be smuggled into a profile:"},"204":{"id":"/concepts/hooks-7","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Kind"},"205":{"id":"/concepts/hooks-8","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Effect"},"206":{"id":"/concepts/hooks-9","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`static-publish`"},"207":{"id":"/concepts/hooks-10","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Copy verified artifacts to a configured target root (optionally with a public URL base)."},"208":{"id":"/concepts/hooks-11","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`git-push`"},"209":{"id":"/concepts/hooks-12","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Push a work branch to a configured remote. Protected branches (`main`, `master`) are refused — merging to the default branch stays behind explicit run promotion."},"210":{"id":"/concepts/hooks-13","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`webhook`"},"211":{"id":"/concepts/hooks-14","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"POST/PUT to an https URL, with optional headers and secret-backed headers."},"212":{"id":"/concepts/hooks-15","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`vercel-preview`"},"213":{"id":"/concepts/hooks-16","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Trigger a preview deploy for a configured project."},"214":{"id":"/concepts/hooks-17","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`custom-script`"},"215":{"id":"/concepts/hooks-18","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Run an allowlisted absolute command with declared, typed arguments — never a shell."},"216":{"id":"/concepts/hooks-19","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Profiles reference secrets by **name only** (`secretNames`), declare typed `params` callers may fill, and can restrict which workflows may use them (`allowedCapabilities`)."},"217":{"id":"/concepts/hooks-20","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"Selection is explicit and two-sided:"},"218":{"id":"/concepts/hooks-21","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"The workflow must opt in via `workflow.hooks.allowedProfiles` (a list of profile slugs, or `\"*\"`); no opt-in means no hooks, default-closed."},"219":{"id":"/concepts/hooks-22","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"The caller selects profiles per run with `input.postRunHooks: [\"publish-docs\", …]`."},"220":{"id":"/concepts/hooks-23","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"Preflight rejects a request naming a profile that is disabled or not allowed for that workflow, so ineligible hooks surface before a run is created."},"221":{"id":"/concepts/hooks-24","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"Non-admin callers see enabled profiles in a caller-safe shape (slug, name, kind, params) — no paths, remotes, URLs, or secret names. Admins with `?all=1` see every profile with full config and readiness."},"222":{"id":"/concepts/hooks-25","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Hooks run after the run's gates pass, and their results are reported separately from the run status:"},"223":{"id":"/concepts/hooks-26","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Outcome"},"224":{"id":"/concepts/hooks-27","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Meaning"},"225":{"id":"/concepts/hooks-28","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`succeeded`"},"226":{"id":"/concepts/hooks-29","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The side effect completed."},"227":{"id":"/concepts/hooks-30","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`hook_failed`"},"228":{"id":"/concepts/hooks-31","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The side effect itself failed."},"229":{"id":"/concepts/hooks-32","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`hook_config_required`"},"230":{"id":"/concepts/hooks-33","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The profile cannot execute — typically missing named secrets or a disabled secret store."},"231":{"id":"/concepts/hooks-34","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`hook_blocked`"},"232":{"id":"/concepts/hooks-35","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The profile was not eligible for this run."},"233":{"id":"/concepts/hooks-36","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`skipped`"},"234":{"id":"/concepts/hooks-37","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The hook did not run."},"235":{"id":"/concepts/hooks-38","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"A failed hook never rewrites a successful run into a failed one: the run keeps its own status and the hook results ride in the run output, aggregated into one headline hook status. `POST /api/hooks/{slug}/validate` is the admin dry-run: it reports `hook_config_required` with missing secret *names* only."},"236":{"id":"/concepts/hooks-39","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Endpoint"},"237":{"id":"/concepts/hooks-40","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"MCP tool"},"238":{"id":"/concepts/hooks-41","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Notes"},"239":{"id":"/concepts/hooks-42","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`GET /api/hooks`"},"240":{"id":"/concepts/hooks-43","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`list_hooks`"},"241":{"id":"/concepts/hooks-44","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`?workflow=<slug>` narrows; admin `?all=1` includes disabled."},"242":{"id":"/concepts/hooks-45","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`GET /api/hooks/{slug}`"},"243":{"id":"/concepts/hooks-46","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`get_hook`"},"244":{"id":"/concepts/hooks-47","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`POST /api/hooks`, `PATCH /api/hooks/{slug}`"},"245":{"id":"/concepts/hooks-48","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`upsert_hook`"},"246":{"id":"/concepts/hooks-49","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Admin."},"247":{"id":"/concepts/hooks-50","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`POST /api/hooks/{slug}/validate`"},"248":{"id":"/concepts/hooks-51","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`validate_hook`"},"249":{"id":"/concepts/hooks-52","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Admin readiness dry-run."},"250":{"id":"/concepts","page_id":"/concepts","type":"page","content":"Concepts","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts"},"251":{"id":"/concepts-0","page_id":"/concepts","tags":[],"type":"text","url":"/concepts","content":"A map of the core Runyard concepts and how they fit together."},"252":{"id":"/concepts-1","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#the-catalog","content":"The catalog"},"253":{"id":"/concepts-2","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#execution","content":"Execution"},"254":{"id":"/concepts-3","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#control","content":"Control"},"255":{"id":"/concepts-4","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#platform","content":"Platform"},"256":{"id":"/concepts-5","page_id":"/concepts","tags":[],"type":"text","url":"/concepts","content":"Runyard is a self-hosted control plane for agent runs. You install **workflows** into a catalog, start **runs** of those workflows from the API, MCP, web app, or a **schedule**, and **runners** claim and execute them. Anything that needs a human decision surfaces as an **approval** card, sensitive values live in the encrypted **secrets** store, and optional side effects after a run are handled by admin-defined **hooks**. Access is governed by scoped **tokens**, and every page in the Hub is a shareable **deep link**."},"257":{"id":"/concepts-6","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#the-catalog","content":"**Workflows** — the unit of the catalog: a named, versioned definition with input/output schemas whose source lives as immutable bundles in the Hub database."},"258":{"id":"/concepts-7","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#the-catalog","content":"**Agents, skills & knowledge** — shared, reusable building blocks (agent roles, skills, knowledge resources) that workflows reference."},"259":{"id":"/concepts-8","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Runs** — a single execution of a workflow: lifecycle statuses, preflight and run drafts, events, logs, artifacts, reruns, and promotion."},"260":{"id":"/concepts-9","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Runners** — the machines that claim queued runs and execute them via the Smithers engine, with tags, capacity, and optional sandboxing."},"261":{"id":"/concepts-10","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Schedules** — cron or one-shot triggers that create ordinary runs on a cadence."},"262":{"id":"/concepts-11","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#control","content":"**Approvals** — declared human decisions: approval cards with an explicit ask, per-kind consequences, and optional timers with fallbacks."},"263":{"id":"/concepts-12","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#control","content":"**Hooks** — admin-defined post-run side effects (publish, push, webhook) that run after a run's gates pass and never fail a green run."},"264":{"id":"/concepts-13","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#platform","content":"**Tokens & scopes** — bearer-token auth with the `api`, `mcp`, `runner`, `approvals`, and `admin` scopes; browser sessions carry exactly a token's scopes."},"265":{"id":"/concepts-14","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#platform","content":"**Secrets** — an encrypted store whose values are only ever decrypted into a run's child process environment, never returned by the API."},"266":{"id":"/concepts-15","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#platform","content":"**Deep links** — the shareable URL grammar of the Hub web app, plus the deep links the API returns in its payloads."},"267":{"id":"/concepts/metering","page_id":"/concepts/metering","type":"page","content":"Usage metering & budgets","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/metering"},"268":{"id":"/concepts/metering-0","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering","content":"Per-run model-call usage as a first-class streamed signal, hard spend budgets, and the metering gateway at the inference boundary."},"269":{"id":"/concepts/metering-1","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Usage records and the run aggregate"},"270":{"id":"/concepts/metering-2","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#budgets","content":"Budgets"},"271":{"id":"/concepts/metering-3","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Capture paths: what is metered today"},"272":{"id":"/concepts/metering-4","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#selecting-gateway-metering","content":"Selecting gateway metering"},"273":{"id":"/concepts/metering-5","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering","content":"Every run durably records not just what it produced, but **what it consumed**. Each model call a run's child agents make is captured as a usage record, streamed as a run event while the run executes, aggregated onto the run, and included in terminal payloads — so dashboards, delegated callers, and budget enforcement all work off real numbers, never log scraping."},"274":{"id":"/concepts/metering-6","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"A usage record is one observed model call:"},"275":{"id":"/concepts/metering-7","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Records fold into the run's persisted aggregate the moment they arrive:"},"276":{"id":"/concepts/metering-8","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`costMicros` is micro-USD (1 000 000 = $1). When the provider reports the call's cost it is used verbatim (`costSource: \"provider\"`); otherwise the Hub estimates from a list-price table for well-known models (`costSource: \"price-table\"`) and records **no cost at all** for unknown models — totals are a floor, never a guess."},"277":{"id":"/concepts/metering-9","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Where usage appears:"},"278":{"id":"/concepts/metering-10","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`GET /api/runs` and `GET /api/runs/{id}` — the `usage` aggregate (and `budget`) on every run object."},"279":{"id":"/concepts/metering-11","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`GET /api/runs/{id}/usage` — the aggregate, the budget, per-call records, and `budgetStop`."},"280":{"id":"/concepts/metering-12","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`run.usage` events on the run's event stream and timeline, emitted in the same write that updates the aggregate."},"281":{"id":"/concepts/metering-13","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Terminal response-endpoint payloads — `usage`, `budget`, and `budgetStop` fields, so delegated callers can bill or cap against real consumption."},"282":{"id":"/concepts/metering-14","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"MCP: `get_run_usage`, plus `get_run_status`/`list_runs` responses."},"283":{"id":"/concepts/metering-15","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"The web app: a usage chip on run cards, usage/budget on run detail, and fleet-wide totals in `GET /api/dashboard` (`stats.usage`)."},"284":{"id":"/concepts/metering-16","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"Run creation accepts an optional hard spend ceiling — as a top-level `budget` field or `input.budget`, on direct runs, negotiated runs, drafts, schedules, endpoint submissions, and reruns (reruns inherit the previous run's budget unless overridden):"},"285":{"id":"/concepts/metering-17","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"Budgets are hard stops, not advisories:"},"286":{"id":"/concepts/metering-18","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"**Before** each gateway-metered call, the Hub refuses to forward (`402`) if the aggregate has already reached the ceiling."},"287":{"id":"/concepts/metering-19","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"**After** every accepted usage record, the Hub re-evaluates; a breach emits `run.budget.exceeded&#x60; and terminates the run with the distinct terminal status &#x2A;*`budget_exceeded`** — never a generic `failed` — with the stop reason on `run.error` and `budgetStop`."},"288":{"id":"/concepts/metering-20","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"The runner observes the terminal status on its next poll and cancels the detached engine run, and the gateway refuses further calls from that run's token (`403`)."},"289":{"id":"/concepts/metering-21","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"An invalid budget is rejected with `400 budget_invalid` at creation (and surfaces as a preflight blocker in negotiation) — a requested cap is never silently dropped."},"290":{"id":"/concepts/metering-22","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Usage is captured at the **inference boundary**, through two paths:"},"291":{"id":"/concepts/metering-23","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Path"},"292":{"id":"/concepts/metering-24","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Source label"},"293":{"id":"/concepts/metering-25","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Coverage"},"294":{"id":"/concepts/metering-26","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Key custody"},"295":{"id":"/concepts/metering-27","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Metering gateway"},"296":{"id":"/concepts/metering-28","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"`gateway`"},"297":{"id":"/concepts/metering-29","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Runs that select `metering: \"gateway\"` with the pi harness (`piModel`, `piBaseUrl`, `piApiKeyEnv`)"},"298":{"id":"/concepts/metering-30","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Provider key stays on the Hub; the child only holds a run-scoped gateway token"},"299":{"id":"/concepts/metering-31","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Runner-observed engine telemetry"},"300":{"id":"/concepts/metering-32","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"`runner`"},"301":{"id":"/concepts/metering-33","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Every claude / codex / pi CLI call the Smithers engine reports via its structured `TokenUsageReported` events"},"302":{"id":"/concepts/metering-34","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Keys delivered per-run via the encrypted secretEnv channel (as before)"},"303":{"id":"/concepts/metering-35","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"**Gateway-metered runs** are pinned at claim time: the Hub mints a stateless per-run token, withholds the named provider key from the child environment entirely, and the runner materializes a per-run pi configuration whose *only* provider is the Hub's OpenAI-compatible gateway (`POST /api/gateway/openai/v1/chat/completions`; an Anthropic-shaped `/api/gateway/anthropic/v1/messages` is also served). The gateway authenticates the token, enforces the budget before forwarding, calls the run's configured upstream with the Hub-held key, streams the response back, and records usage from the provider's own response metadata (including streamed SSE usage frames)."},"304":{"id":"/concepts/metering-36","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"**Runner-observed runs** (the default, `metering: \"observed\"`) report the engine's per-call usage telemetry to `POST /api/runs/{id}/usage` with a stable per-call `requestId`, so replays after a runner restart never double-count. This is real, agent-reported usage from the engine's event stream — but the child still holds its own credentials (e.g. a Claude subscription token), so it is metered without being egress-locked."},"305":{"id":"/concepts/metering-37","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"**Not yet metered:** model calls that bypass both paths — e.g. a child agent calling a provider directly with an ad-hoc key from a tool script, or CLI paths the engine does not report usage for. Full egress locking (denying children any network path except the gateway) is a follow-up; the current sandbox shares the host network so the gateway pin is config-level, not network-level."},"306":{"id":"/concepts/metering-38","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#selecting-gateway-metering","content":"Gateway metering rides the same per-run harness selection surface as the pi custom-endpoint fields:"},"307":{"id":"/concepts/metering-39","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#selecting-gateway-metering","content":"Preflight blocks the run unless the selection is complete (pi harness, model, endpoint URL, and the Hub-secret name for the key) — a run never launches half-pinned. The endpoint key must be stored as a Hub secret; with gateway metering it is decrypted only inside the Hub per call and never enters the child environment."},"308":{"id":"/concepts/runners","page_id":"/concepts/runners","type":"page","content":"Runners","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/runners"},"309":{"id":"/concepts/runners-0","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners","content":"The machines that claim and execute runs via the Smithers engine - registration, tags, capacity, health, and sandboxing."},"310":{"id":"/concepts/runners-1","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#registration-heartbeat-claim","content":"Registration, heartbeat, claim"},"311":{"id":"/concepts/runners-2","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#tags-and-execution-modes","content":"Tags and execution modes"},"312":{"id":"/concepts/runners-3","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#capacity-and-pool","content":"Capacity and pool"},"313":{"id":"/concepts/runners-4","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#sandboxing","content":"Sandboxing"},"314":{"id":"/concepts/runners-5","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#api--mcp","content":"API & MCP"},"315":{"id":"/concepts/runners-6","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners","content":"A **runner** is a machine that executes runs. Runners run the Runyard runner process, which claims queued runs from the Hub and executes each workflow via the **Smithers engine** (`smithers up <workflow> --input <json>`), spawning the local agent CLI as the worker. Nothing is faked: the agent runs on the runner's machine, and the Hub is the durable record — events stream back as run events, and outputs and traces are uploaded as artifacts."},"316":{"id":"/concepts/runners-7","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"Runners speak a small machine protocol authenticated with **runner-scoped tokens** (see Tokens & scopes):"},"317":{"id":"/concepts/runners-8","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"`POST /api/runners/register` — announce name, hostname, platform, version, tags, and capacity."},"318":{"id":"/concepts/runners-9","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"`POST /api/runners/{id}/heartbeat` — periodic liveness; a stale heartbeat marks the runner offline."},"319":{"id":"/concepts/runners-10","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"`GET /api/runners/{id}/next-run` — claim the next matching queued run. The claim payload carries everything the run needs, including decrypted secrets for that run only."},"320":{"id":"/concepts/runners-11","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"Run lifecycle reports (`start`, events, `complete`, `fail`, artifact upload) are restricted to the runner that owns the run: the Hub checks the claiming token's identity, so one runner's token cannot touch another runner's runs."},"321":{"id":"/concepts/runners-12","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"Runners advertise **tags** (for example `local` on a workstation, `vps` on a shared remote pool). Two things match runs to runners:"},"322":{"id":"/concepts/runners-13","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"A workflow's `requiredRunnerTags` must all be present on the runner."},"323":{"id":"/concepts/runners-14","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"The caller's execution intent: `executionMode: \"local\" | \"remote\" | \"auto\"` (optionally a specific `runnerLocation`). `remote` targets the shared remote/VPS pool (default location `vps`); `auto` takes any matching runner."},"324":{"id":"/concepts/runners-15","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"Preflight checks this matching up front and reports `no_matching_runner` (blocker) or `runners_offline` (warning — the run would queue until one returns)."},"325":{"id":"/concepts/runners-16","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#capacity-and-pool","content":"Each runner declares a `capacity` (concurrent run slots) and reports its active runs; the Hub assigns work only to free slots. `GET /api/runners` returns every registered runner with heartbeat state, capacity, active slots, plus a pool summary — the same data the **Runners** page in the web app shows (`#runners`)."},"326":{"id":"/concepts/runners-17","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#sandboxing","content":"By default the runner executes workflows directly on its host. Setting `RUNNER_SANDBOX=bubblewrap` on the runner wraps each workflow *launch* in a generated Bubblewrap (`bwrap`) sandbox: the run's workspace is the only writable mount (bound at the same path inside and out), system directories are bound read-only, and the child gets a fresh workspace-local `HOME` — the host home directory, with its keys and credentials, is never mounted. Polling and control commands stay outside the sandbox. Installing `bwrap` is the deployer's responsibility; the runner verifies at startup that the sandbox actually works before claiming runs."},"327":{"id":"/concepts/runners-18","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Endpoint"},"328":{"id":"/concepts/runners-19","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"MCP tool"},"329":{"id":"/concepts/runners-20","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Notes"},"330":{"id":"/concepts/runners-21","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`GET /api/runners`"},"331":{"id":"/concepts/runners-22","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`list_runners`"},"332":{"id":"/concepts/runners-23","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runners, heartbeat state, capacity, slots, pool summary."},"333":{"id":"/concepts/runners-24","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`POST /api/runners/register`"},"334":{"id":"/concepts/runners-25","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"335":{"id":"/concepts/runners-26","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol (runner scope)."},"336":{"id":"/concepts/runners-27","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`POST /api/runners/{id}/heartbeat`"},"337":{"id":"/concepts/runners-28","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"338":{"id":"/concepts/runners-29","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol."},"339":{"id":"/concepts/runners-30","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`GET /api/runners/{id}/next-run`"},"340":{"id":"/concepts/runners-31","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"341":{"id":"/concepts/runners-32","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol; claims the next run."},"342":{"id":"/concepts/runners-33","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`POST /api/runs/{id}/start` / `/complete` / `/fail` / `/events` / `/artifacts`"},"343":{"id":"/concepts/runners-34","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"344":{"id":"/concepts/runners-35","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol; run ownership enforced."},"345":{"id":"/concepts/runners-36","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"The runner protocol endpoints intentionally have no MCP tools — they are Hub↔runner machinery, not an operator surface."},"346":{"id":"/concepts/runs","page_id":"/concepts/runs","type":"page","content":"Runs","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/runs"},"347":{"id":"/concepts/runs-0","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs","content":"The run lifecycle, preflight and run drafts, events and artifacts, reruns, and promotion."},"348":{"id":"/concepts/runs-1","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#lifecycle","content":"Lifecycle"},"349":{"id":"/concepts/runs-2","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#failure-classes","content":"Failure classes"},"350":{"id":"/concepts/runs-3","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#usage-and-budgets","content":"Usage and budgets"},"351":{"id":"/concepts/runs-4","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"Preflight and run drafts (negotiation)"},"352":{"id":"/concepts/runs-5","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#events-timeline-logs-artifacts","content":"Events, timeline, logs, artifacts"},"353":{"id":"/concepts/runs-6","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#reruns-and-promotion","content":"Reruns and promotion"},"354":{"id":"/concepts/runs-7","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#response-endpoints","content":"Response endpoints"},"355":{"id":"/concepts/runs-8","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#api--mcp","content":"API & MCP"},"356":{"id":"/concepts/runs-9","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs","content":"A **run** is a single execution of a workflow with a JSON input. Runs are created from the API, MCP, web app, CLI, a schedule, or a workflow endpoint; a runner claims each queued run and executes it, streaming events, logs, and artifacts back to the Hub as the durable record."},"357":{"id":"/concepts/runs-10","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Status"},"358":{"id":"/concepts/runs-11","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Meaning"},"359":{"id":"/concepts/runs-12","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`waiting_approval`"},"360":{"id":"/concepts/runs-13","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Held for a human decision before entering the queue (see Approvals). Never times out — waiting cannot fail a run."},"361":{"id":"/concepts/runs-14","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`queued`"},"362":{"id":"/concepts/runs-15","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Ready for a matching runner to claim."},"363":{"id":"/concepts/runs-16","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`assigned`"},"364":{"id":"/concepts/runs-17","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Claimed by a runner, not yet started."},"365":{"id":"/concepts/runs-18","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`running`"},"366":{"id":"/concepts/runs-19","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Executing on the runner."},"367":{"id":"/concepts/runs-20","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`succeeded`"},"368":{"id":"/concepts/runs-21","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Finished with outputs."},"369":{"id":"/concepts/runs-22","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`cancelled`"},"370":{"id":"/concepts/runs-23","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Stopped by an operator or a rejected approval — a human \"no\" is a decision, not a failure."},"371":{"id":"/concepts/runs-24","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`failed` (+ classes)"},"372":{"id":"/concepts/runs-25","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Terminal failure; see failure classes below."},"373":{"id":"/concepts/runs-26","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Terminal states are final: late reports racing a terminal state are absorbed idempotently rather than overwriting the first decision."},"374":{"id":"/concepts/runs-27","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#failure-classes","content":"Failures are classified into specific terminal statuses so operators can tell config problems from real failures: `failed` (generic), `blocked_by_gate` (a verification gate failed), `blocked_by_preflight` (the run could never start as configured), `provider_limited` (rate limits/quota), `timed_out`, `invalid_output` (schema mismatch), `infra_unavailable` (network/runner infrastructure), `needs_human`, and `budget_exceeded` (the run's metered usage reached its spend budget and it was hard-stopped)."},"375":{"id":"/concepts/runs-28","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#usage-and-budgets","content":"Runs also meter the model calls they consume: per-call usage records stream as `run.usage` events and aggregate onto the run as `usage` (`totalTokens`, `costMicros`, `byModel`, ...), and run creation accepts an optional `budget: { maxTokens?, maxCostMicros? }` hard ceiling. See Usage metering & budgets for the data model, the metering gateway, and budget enforcement."},"376":{"id":"/concepts/runs-29","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"Before anything is enqueued, Runyard can run a **deterministic preflight**: schema checks on required input fields, runner/tag availability, secret presence, hook eligibility, and workflow source resolution. The result is `ready`, `needs_input` (with `questions[]` the caller can answer), or `blocked` (with `blockers[]` only an operator can fix), plus warnings, suggested defaults, and a `nextAction` hint."},"377":{"id":"/concepts/runs-30","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"Three ways to use it:"},"378":{"id":"/concepts/runs-31","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"`POST /api/workflows/{id}/preflight` — stateless report, nothing created."},"379":{"id":"/concepts/runs-32","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"`POST /api/workflows/{id}/run` with `negotiate: true` — enqueue only when ready; otherwise the negotiation state and a saved draft come back instead of a doomed run."},"380":{"id":"/concepts/runs-33","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"**Run drafts** — a draft is a proposed run that has *not* been enqueued. Create it, patch its input to answer questions (each patch re-preflights), then submit; submit re-preflights and returns 202 with the run only when ready (422 `needs_input` / 409 `blocked` otherwise)."},"381":{"id":"/concepts/runs-34","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"`input.title` is recommended for agent-created runs: a short human-readable title used in run lists, approval cards, and handoff."},"382":{"id":"/concepts/runs-35","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#events-timeline-logs-artifacts","content":"Runners append structured **events** as the run progresses; `GET /api/runs/{id}/events/stream` serves them live over SSE and `GET /api/runs/{id}/timeline` merges status transitions, events, and artifacts into one ascending feed (with `since`/`limit` paging). Log lines are at `/logs`, a condensed log summary and diagnostics at `/diagnostics`, and uploaded **artifacts** (outputs, traces, files) at `/artifacts`, downloadable by artifact id."},"383":{"id":"/concepts/runs-36","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#reruns-and-promotion","content":"**Rerun** — `POST /api/runs/{id}/rerun` creates a linked new run with the same input, optionally edited."},"384":{"id":"/concepts/runs-37","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#reruns-and-promotion","content":"**Promotion** — for runs that mutated an isolated git worktree, `POST /api/runs/{id}/promote` merges the successful run's work into its target branch, runs gates, pushes, and cleans up the branch/worktree. Merging to the default branch always goes through promotion, never through a hook."},"385":{"id":"/concepts/runs-38","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#response-endpoints","content":"A run request may include `responseEndpoint: {type: \"http\" | \"telegram\", config}` so the terminal-state reply is delivered to the caller when the run finishes. Delivery state is reported in `responseEndpoints[]` on `GET /api/runs/{id}`; polling that endpoint remains the canonical fallback."},"386":{"id":"/concepts/runs-39","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"Endpoint"},"387":{"id":"/concepts/runs-40","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"MCP tool"},"388":{"id":"/concepts/runs-41","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/workflows/{id}/run`"},"389":{"id":"/concepts/runs-42","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`run_workflow`"},"390":{"id":"/concepts/runs-43","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/workflows/{id}/preflight`"},"391":{"id":"/concepts/runs-44","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`preflight_workflow`"},"392":{"id":"/concepts/runs-45","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET/POST /api/run-drafts`, `GET/PATCH /api/run-drafts/{id}`, `POST .../submit`, `POST .../discard`"},"393":{"id":"/concepts/runs-46","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`list_run_drafts`, `create_run_draft`, `get_run_draft`, `update_run_draft`, `submit_run_draft`, `discard_run_draft`"},"394":{"id":"/concepts/runs-47","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs`, `GET /api/runs/{id}`"},"395":{"id":"/concepts/runs-48","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`list_runs`, `get_run_status`"},"396":{"id":"/concepts/runs-49","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs/{id}/events`, `/timeline`, `/diagnostics`, `/logs`"},"397":{"id":"/concepts/runs-50","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_run_events`, `get_run_timeline`, `get_run_diagnostics`, `get_run_logs`"},"398":{"id":"/concepts/runs-51","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs/{id}/artifacts`, `GET /api/artifacts`, `GET /api/artifacts/{id}/download`"},"399":{"id":"/concepts/runs-52","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_run_artifacts`, `search_artifacts`, `download_artifact`"},"400":{"id":"/concepts/runs-53","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/cancel`"},"401":{"id":"/concepts/runs-54","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`cancel_run`"},"402":{"id":"/concepts/runs-55","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/rerun`"},"403":{"id":"/concepts/runs-56","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`rerun_workflow_run`"},"404":{"id":"/concepts/runs-57","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/promote`"},"405":{"id":"/concepts/runs-58","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`promote_run`"},"406":{"id":"/concepts/runs-59","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/dashboard`"},"407":{"id":"/concepts/runs-60","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_dashboard`"},"408":{"id":"/concepts/runs-61","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"The `start`/`complete`/`fail`/event-append and artifact-upload endpoints under `/api/runs/{id}` are the runner protocol (runner-scoped tokens, run ownership enforced) — see Runners."},"409":{"id":"/concepts/schedules","page_id":"/concepts/schedules","type":"page","content":"Schedules","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/schedules"},"410":{"id":"/concepts/schedules-0","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules","content":"Cron and one-shot triggers that create ordinary workflow runs on a cadence."},"411":{"id":"/concepts/schedules-1","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#cron-expressions-and-timezones","content":"Cron expressions and timezones"},"412":{"id":"/concepts/schedules-2","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#one-shot-schedules","content":"One-shot schedules"},"413":{"id":"/concepts/schedules-3","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#enable-disable-run-now","content":"Enable, disable, run now"},"414":{"id":"/concepts/schedules-4","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#what-a-fire-produces","content":"What a fire produces"},"415":{"id":"/concepts/schedules-5","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#api--mcp","content":"API & MCP"},"416":{"id":"/concepts/schedules-6","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules","content":"A **schedule** runs a workflow automatically: either recurring on a **cron** cadence or once at a fixed **runAt** timestamp. Each fire creates a completely ordinary run with the schedule's stored input — it appears in run lists, honors the workflow's approval policy, and is executed by whatever runner matches."},"417":{"id":"/concepts/schedules-7","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#cron-expressions-and-timezones","content":"Runyard uses standard **5-field cron** (`minute hour day-of-month month day-of-week`) with ranges (`a-b`), lists (`a,b,c`), steps (`*/n`, `a-b/n`), month/weekday names (`jan..dec`, `sun..sat`), and the aliases `@yearly`, `@monthly`, `@weekly`, `@daily`, `@hourly`. There is no seconds field — the Hub ticks at minute granularity."},"418":{"id":"/concepts/schedules-8","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#cron-expressions-and-timezones","content":"Every schedule has an **IANA timezone** (default `UTC`); the expression is evaluated against wall-clock time in that zone, so DST shifts are honored."},"419":{"id":"/concepts/schedules-9","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#cron-expressions-and-timezones","content":"The preview returns a human-readable description plus the next fire instants — nothing is created."},"420":{"id":"/concepts/schedules-10","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#one-shot-schedules","content":"Provide `runAt` (an ISO timestamp) instead of `cron` to fire exactly once. A schedule takes one or the other."},"421":{"id":"/concepts/schedules-11","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#enable-disable-run-now","content":"**Disable** stops a schedule from firing without deleting it; **enable** resumes the cadence. Both are admin actions."},"422":{"id":"/concepts/schedules-12","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#enable-disable-run-now","content":"**Run now** fires the schedule immediately without changing its cadence — useful for testing input before the next scheduled fire."},"423":{"id":"/concepts/schedules-13","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#enable-disable-run-now","content":"Each schedule tracks `nextRunAt`, `lastRunAt`, the last run id, and the last fire status, all visible on the Schedules page (`#schedules`) and in the API."},"424":{"id":"/concepts/schedules-14","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#what-a-fire-produces","content":"Every fire dispatches a normal run whose origin identifies the schedule:"},"425":{"id":"/concepts/schedules-15","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#what-a-fire-produces","content":"(`trigger` is `ticker` for cadence fires, `manual` for run-now.) The run also gets a `run.scheduled` event recording the schedule, cron, and timezone. If the workflow's approval policy requires it, the run starts in `waiting_approval` like any other run."},"426":{"id":"/concepts/schedules-16","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Endpoint"},"427":{"id":"/concepts/schedules-17","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"MCP tool"},"428":{"id":"/concepts/schedules-18","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Notes"},"429":{"id":"/concepts/schedules-19","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`GET /api/schedules`"},"430":{"id":"/concepts/schedules-20","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`list_schedules`"},"431":{"id":"/concepts/schedules-21","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Includes next/last run and a readable preview."},"432":{"id":"/concepts/schedules-22","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`GET /api/schedules/preview`"},"433":{"id":"/concepts/schedules-23","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`preview_schedule`"},"434":{"id":"/concepts/schedules-24","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Query: `cron`, `timezone`."},"435":{"id":"/concepts/schedules-25","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`GET /api/schedules/{id}`"},"436":{"id":"/concepts/schedules-26","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`get_schedule`"},"437":{"id":"/concepts/schedules-27","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules`"},"438":{"id":"/concepts/schedules-28","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`create_schedule`"},"439":{"id":"/concepts/schedules-29","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin. Body: `name`, `workflowSlug`, `cron` or `runAt`, `timezone`, `input`, `enabled`."},"440":{"id":"/concepts/schedules-30","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`PATCH /api/schedules/{id}`"},"441":{"id":"/concepts/schedules-31","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`update_schedule`"},"442":{"id":"/concepts/schedules-32","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"443":{"id":"/concepts/schedules-33","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules/{id}/enable`"},"444":{"id":"/concepts/schedules-34","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`enable_schedule`"},"445":{"id":"/concepts/schedules-35","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"446":{"id":"/concepts/schedules-36","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules/{id}/disable`"},"447":{"id":"/concepts/schedules-37","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`disable_schedule`"},"448":{"id":"/concepts/schedules-38","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"449":{"id":"/concepts/schedules-39","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules/{id}/run-now`"},"450":{"id":"/concepts/schedules-40","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`run_schedule_now`"},"451":{"id":"/concepts/schedules-41","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Fires immediately; rate-limited."},"452":{"id":"/concepts/schedules-42","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`DELETE /api/schedules/{id}`"},"453":{"id":"/concepts/schedules-43","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`delete_schedule`"},"454":{"id":"/concepts/schedules-44","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"455":{"id":"/concepts/secrets","page_id":"/concepts/secrets","type":"page","content":"Secrets","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/secrets"},"456":{"id":"/concepts/secrets-0","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets","content":"The encrypted secret store - admin-managed, listable by name only, delivered to runs at claim time and never returned by the API."},"457":{"id":"/concepts/secrets-1","page_id":"/concepts/secrets","type":"heading","tags":[],"url":"/concepts/secrets#management-admin-only","content":"Management (admin only)"},"458":{"id":"/concepts/secrets-2","page_id":"/concepts/secrets","type":"heading","tags":[],"url":"/concepts/secrets#how-runs-get-secrets","content":"How runs get secrets"},"459":{"id":"/concepts/secrets-3","page_id":"/concepts/secrets","type":"heading","tags":[],"url":"/concepts/secrets#api--mcp","content":"API & MCP"},"460":{"id":"/concepts/secrets-4","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets","content":"Runyard keeps reusable credentials (API keys, deploy tokens) in an **encrypted secret store** on the Hub. Values are encrypted at rest, and the API is deliberately one-way: you can list secret *names and metadata*, set a value, and delete one — **values are never returned** by any list or read endpoint, to any scope."},"461":{"id":"/concepts/secrets-5","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#management-admin-only","content":"Secret names are env-var-safe identifiers, because that is exactly how they are delivered. The whole feature is gated on the store being enabled (an encryption key configured on the Hub); when it is not, secret-dependent runs and hooks report that configuration is required instead of failing obscurely."},"462":{"id":"/concepts/secrets-6","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"A run receives the union of:"},"463":{"id":"/concepts/secrets-7","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"the workflow's declared `workflow.secrets` list, and"},"464":{"id":"/concepts/secrets-8","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"the run input's `input.secretNames` list."},"465":{"id":"/concepts/secrets-9","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Preflight verifies every named secret exists before the run is enqueued. At **claim time** — when a runner claims the run — the Hub decrypts exactly those named secrets into an env map that rides the claim payload, and the runner injects them **only into the workflow's child process environment**. That is the sole path a plaintext value ever leaves the store:"},"466":{"id":"/concepts/secrets-10","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Secrets never appear in run events, logs, or the run record."},"467":{"id":"/concepts/secrets-11","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Stored secret values are additionally scrubbed from run output and artifacts before they are persisted."},"468":{"id":"/concepts/secrets-12","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Payload fields with credential-like names are redacted in approval cards and other presentation surfaces."},"469":{"id":"/concepts/secrets-13","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Other consumers reference secrets **by name only**: hook profiles declare `secretNames`, and their readiness checks report missing *names*, never values."},"470":{"id":"/concepts/secrets-14","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Endpoint"},"471":{"id":"/concepts/secrets-15","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"MCP tool"},"472":{"id":"/concepts/secrets-16","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Notes"},"473":{"id":"/concepts/secrets-17","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`GET /api/secrets`"},"474":{"id":"/concepts/secrets-18","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`list_secrets`"},"475":{"id":"/concepts/secrets-19","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Admin. Names and metadata only."},"476":{"id":"/concepts/secrets-20","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`PUT /api/secrets/{key}`"},"477":{"id":"/concepts/secrets-21","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`set_secret`"},"478":{"id":"/concepts/secrets-22","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Admin. `{value, description?}`."},"479":{"id":"/concepts/secrets-23","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`DELETE /api/secrets/{key}`"},"480":{"id":"/concepts/secrets-24","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`delete_secret`"},"481":{"id":"/concepts/secrets-25","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Admin."},"482":{"id":"/concepts/tokens-and-scopes","page_id":"/concepts/tokens-and-scopes","type":"page","content":"Tokens & Scopes","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/tokens-and-scopes"},"483":{"id":"/concepts/tokens-and-scopes-0","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes","content":"Bearer-token authentication, the scope vocabulary and presets (including read-only), the bootstrap token, and how browser and Telegram sessions work."},"484":{"id":"/concepts/tokens-and-scopes-1","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#scopes","content":"Scopes"},"485":{"id":"/concepts/tokens-and-scopes-2","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#presets","content":"Presets"},"486":{"id":"/concepts/tokens-and-scopes-3","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#bootstrap-token","content":"Bootstrap token"},"487":{"id":"/concepts/tokens-and-scopes-4","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#browser-sessions","content":"Browser sessions"},"488":{"id":"/concepts/tokens-and-scopes-5","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#telegram-webapp-sessions","content":"Telegram WebApp sessions"},"489":{"id":"/concepts/tokens-and-scopes-6","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#api--mcp","content":"API & MCP"},"490":{"id":"/concepts/tokens-and-scopes-7","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes","content":"Every Runyard API call is authenticated with a **bearer access token**:"},"491":{"id":"/concepts/tokens-and-scopes-8","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes","content":"`GET /api/me` (or the `whoami` MCP tool) describes the token you are holding: its name and granted scopes. Tokens are issued and revoked by admins and may carry an expiry."},"492":{"id":"/concepts/tokens-and-scopes-9","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"A token carries one or more scopes; each endpoint declares which scopes may call it."},"493":{"id":"/concepts/tokens-and-scopes-10","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Scope"},"494":{"id":"/concepts/tokens-and-scopes-11","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Grants"},"495":{"id":"/concepts/tokens-and-scopes-12","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`api`"},"496":{"id":"/concepts/tokens-and-scopes-13","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Operating runs: start/preflight workflows, run drafts, reruns, promotion, cancel, resolve approvals."},"497":{"id":"/concepts/tokens-and-scopes-14","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`mcp`"},"498":{"id":"/concepts/tokens-and-scopes-15","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"The same operating surface for MCP clients."},"499":{"id":"/concepts/tokens-and-scopes-16","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`read`"},"500":{"id":"/concepts/tokens-and-scopes-17","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"**Read-only.** Inspect workflows, runs, logs, artifacts, approvals, schedules, runners, and the menu — and nothing else. It satisfies no mutation endpoint, so a `read`-only token can never change state."},"501":{"id":"/concepts/tokens-and-scopes-18","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`runner`"},"502":{"id":"/concepts/tokens-and-scopes-19","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"The runner protocol: register, heartbeat, claim runs, report lifecycle, upload artifacts."},"503":{"id":"/concepts/tokens-and-scopes-20","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`approvals`"},"504":{"id":"/concepts/tokens-and-scopes-21","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Resolving and creating approval cards only — the narrow scope for approval surfaces."},"505":{"id":"/concepts/tokens-and-scopes-22","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`admin`"},"506":{"id":"/concepts/tokens-and-scopes-23","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Everything. `admin` is a **superscope**: it satisfies every scope requirement, and admin-only endpoints (tokens, secrets, catalog edits, schedules, hooks, audit) require it."},"507":{"id":"/concepts/tokens-and-scopes-24","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Reads such as listing runs, workflows, runners, or schedules need only an authenticated token, whatever its scopes. Runner lifecycle endpoints additionally enforce **run ownership**: only the runner token that claimed a run (or an admin) may report on it."},"508":{"id":"/concepts/tokens-and-scopes-25","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`GET /api/tokens/scopes` (admin; MCP tool `list_token_scopes`) describes the scope vocabulary and the named presets the Tokens page offers:"},"509":{"id":"/concepts/tokens-and-scopes-26","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Preset"},"510":{"id":"/concepts/tokens-and-scopes-27","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Scopes"},"511":{"id":"/concepts/tokens-and-scopes-28","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Use for"},"512":{"id":"/concepts/tokens-and-scopes-29","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Everything** (default)"},"513":{"id":"/concepts/tokens-and-scopes-30","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`api`, `mcp`, `approvals`"},"514":{"id":"/concepts/tokens-and-scopes-31","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"A normal person or agent: read everything, run workflows, decide approvals. No admin or runner rights."},"515":{"id":"/concepts/tokens-and-scopes-32","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Read-only**"},"516":{"id":"/concepts/tokens-and-scopes-33","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`read`"},"517":{"id":"/concepts/tokens-and-scopes-34","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Dashboards, monitors, and cautious integrations that must never change state."},"518":{"id":"/concepts/tokens-and-scopes-35","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Approvals only**"},"519":{"id":"/concepts/tokens-and-scopes-36","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`approvals`"},"520":{"id":"/concepts/tokens-and-scopes-37","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Approval inboxes and bots that only decide."},"521":{"id":"/concepts/tokens-and-scopes-38","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Runner**"},"522":{"id":"/concepts/tokens-and-scopes-39","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`runner`"},"523":{"id":"/concepts/tokens-and-scopes-40","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Runner machines. Keep separate from human tokens."},"524":{"id":"/concepts/tokens-and-scopes-41","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Admin**"},"525":{"id":"/concepts/tokens-and-scopes-42","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`admin`"},"526":{"id":"/concepts/tokens-and-scopes-43","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Full control, including tokens and secrets. Issue sparingly."},"527":{"id":"/concepts/tokens-and-scopes-44","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Finer-grained per-group write scopes (e.g. a token that can manage schedules but not run workflows) are a documented follow-up; today `api`/`mcp` grant the whole operating surface."},"528":{"id":"/concepts/tokens-and-scopes-45","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#bootstrap-token","content":"On first boot, if no access tokens exist, the Hub creates a `bootstrap-admin` token with the `admin`, `api`, `runner`, and `mcp` scopes and writes it to `data/bootstrap-token.txt` on the server (relative to the Hub's data directory). Use it to log in and mint narrower tokens, one per client or integration."},"529":{"id":"/concepts/tokens-and-scopes-46","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#browser-sessions","content":"The web app is an ordinary API client. `POST /api/auth/token-login` exchanges an access token for a **session cookie** — a signed copy of the token — so the browser session carries *exactly* the token's scopes, no extra power. Admin sections of the web app appear only for admin-scoped sessions. `POST /api/auth/logout` clears the cookie."},"530":{"id":"/concepts/tokens-and-scopes-47","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#telegram-webapp-sessions","content":"Approving from Telegram uses `POST /api/auth/telegram-webapp&#x60;, which verifies Telegram's signed init data against the configured bot and allowlisted users, then issues a session scoped to **`approvals` only** — narrower than any token session. A Telegram session can list and resolve approval cards but cannot start runs or touch admin surfaces."},"531":{"id":"/concepts/tokens-and-scopes-48","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Endpoint"},"532":{"id":"/concepts/tokens-and-scopes-49","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"MCP tool"},"533":{"id":"/concepts/tokens-and-scopes-50","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Notes"},"534":{"id":"/concepts/tokens-and-scopes-51","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/me`"},"535":{"id":"/concepts/tokens-and-scopes-52","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`whoami`"},"536":{"id":"/concepts/tokens-and-scopes-53","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Token name and scopes."},"537":{"id":"/concepts/tokens-and-scopes-54","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/tokens`"},"538":{"id":"/concepts/tokens-and-scopes-55","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`list_tokens`"},"539":{"id":"/concepts/tokens-and-scopes-56","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin."},"540":{"id":"/concepts/tokens-and-scopes-57","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/tokens/scopes`"},"541":{"id":"/concepts/tokens-and-scopes-58","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`list_token_scopes`"},"542":{"id":"/concepts/tokens-and-scopes-59","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin. Scope vocabulary, presets, defaults."},"543":{"id":"/concepts/tokens-and-scopes-60","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/tokens`"},"544":{"id":"/concepts/tokens-and-scopes-61","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`create_token`"},"545":{"id":"/concepts/tokens-and-scopes-62","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin. `{name, scopes, expiresInDays?}`."},"546":{"id":"/concepts/tokens-and-scopes-63","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`DELETE /api/tokens/{id}`"},"547":{"id":"/concepts/tokens-and-scopes-64","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`revoke_token`"},"548":{"id":"/concepts/tokens-and-scopes-65","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin."},"549":{"id":"/concepts/tokens-and-scopes-66","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/auth/token-login`"},"550":{"id":"/concepts/tokens-and-scopes-67","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"—"},"551":{"id":"/concepts/tokens-and-scopes-68","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Browser session bootstrap (rate-limited)."},"552":{"id":"/concepts/tokens-and-scopes-69","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/auth/telegram-webapp`"},"553":{"id":"/concepts/tokens-and-scopes-70","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"—"},"554":{"id":"/concepts/tokens-and-scopes-71","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Approvals-scoped Telegram session."},"555":{"id":"/concepts/tokens-and-scopes-72","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/auth/logout`"},"556":{"id":"/concepts/tokens-and-scopes-73","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"—"},"557":{"id":"/concepts/tokens-and-scopes-74","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Clears the session cookie."},"558":{"id":"/concepts/tokens-and-scopes-75","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/audit`"},"559":{"id":"/concepts/tokens-and-scopes-76","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`get_audit_log`"},"560":{"id":"/concepts/tokens-and-scopes-77","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin; who did what, most recent first."},"561":{"id":"/concepts/workflows","page_id":"/concepts/workflows","type":"page","content":"Workflows","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/workflows"},"562":{"id":"/concepts/workflows-0","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"The catalog unit of Runyard - versioned definitions with schemas, immutable source bundles, and portable packages."},"563":{"id":"/concepts/workflows-1","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#definition","content":"Definition"},"564":{"id":"/concepts/workflows-2","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is data, not files"},"565":{"id":"/concepts/workflows-3","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#db-backed-workflow-bundles","content":"DB-backed workflow bundles"},"566":{"id":"/concepts/workflows-4","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#versioning","content":"Versioning"},"567":{"id":"/concepts/workflows-5","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-packages","content":"Workflow packages"},"568":{"id":"/concepts/workflows-6","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#enabled-and-disabled","content":"Enabled and disabled"},"569":{"id":"/concepts/workflows-7","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#api--mcp","content":"API & MCP"},"570":{"id":"/concepts/workflows-8","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"A **workflow** is the unit of the Runyard catalog: a named, versioned definition of something an agent can do. Each workflow has a slug, a display name and description, input/output schemas, and a source program that the runner executes. In older code and database tables the same object is called a *capability* — that is the legacy/internal synonym; user-facing surfaces say workflow."},"571":{"id":"/concepts/workflows-9","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"A workflow definition carries:"},"572":{"id":"/concepts/workflows-10","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Field"},"573":{"id":"/concepts/workflows-11","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Purpose"},"574":{"id":"/concepts/workflows-12","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`slug`, `name`, `description`, `category`, `keywords`"},"575":{"id":"/concepts/workflows-13","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Identity and catalog discovery (`GET /api/workflows?q=` searches)."},"576":{"id":"/concepts/workflows-14","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`inputSchema` / `outputSchema`"},"577":{"id":"/concepts/workflows-15","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"JSON schemas for run input and output. Required input fields drive preflight questions."},"578":{"id":"/concepts/workflows-16","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredRunnerTags`"},"579":{"id":"/concepts/workflows-17","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Tags a runner must advertise to be assigned a run."},"580":{"id":"/concepts/workflows-18","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredSkills` / `requiredAgents`"},"581":{"id":"/concepts/workflows-19","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"References into the shared catalog."},"582":{"id":"/concepts/workflows-20","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`approvalPolicy`"},"583":{"id":"/concepts/workflows-21","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Whether new runs hold for an approval before executing."},"584":{"id":"/concepts/workflows-22","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`workflow`"},"585":{"id":"/concepts/workflows-23","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Source configuration — most importantly `workflow.bundleId`, plus options like `hooks.allowedProfiles` for post-run hooks and `secrets` for secret delivery."},"586":{"id":"/concepts/workflows-24","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`enabled`"},"587":{"id":"/concepts/workflows-25","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Disabled workflows disappear from the catalog for non-admins and cannot be run."},"588":{"id":"/concepts/workflows-26","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is created and edited through the API/MCP (`create_workflow` / `update_workflow` with inline source bytes) or by importing a workflow package. You never write workflow files to disk on the Hub or runner: custom workflows must carry source bytes or reference an existing `workflow.bundleId` — bare `workflow.entry` file paths are rejected."},"589":{"id":"/concepts/workflows-27","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Published source lives in the Hub database as **workflow bundles**: immutable, hash-addressed rows in the `workflow_bundles` table. Publishing is insert-only — every publish creates a new `(workflow slug, version)` row with a `sha256` of the source, so a bundle id permanently names the exact bytes that were published. Bundles are capped at 500 KB, listing never returns source bytes, and a workflow that references a missing bundle fails preflight rather than silently falling back to a file."},"590":{"id":"/concepts/workflows-28","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Prefer `create_workflow` / `update_workflow` with inline source — they publish a bundle for you and point the workflow at it."},"591":{"id":"/concepts/workflows-29","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#versioning","content":"Updating a workflow bumps its integer `version` and snapshots the previous definition. `GET /api/workflows/{name}/versions` lists the versions observed on past runs, and every run records the `workflowVersion` it executed. Bundle versions count separately, per publish."},"592":{"id":"/concepts/workflows-30","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-packages","content":"A **workflow package** is a portable `.runyard-workflow.json` file for moving a workflow between Hubs. Exports contain source bytes, metadata, requirements, and content/workflow hashes — never secret values. Imports publish the source as a new immutable bundle and create the workflow **disabled by default**, so an admin can configure and preflight it locally before enabling it. `validate` and `preview` let you check a package without writing anything."},"593":{"id":"/concepts/workflows-31","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#enabled-and-disabled","content":"`DELETE /api/workflows/{id}` disables a workflow rather than erasing it: historical runs stay intact, non-admins get a 404, and preflight blocks new runs until an admin re-enables it with `PATCH /api/workflows/{id}`."},"594":{"id":"/concepts/workflows-32","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Endpoint"},"595":{"id":"/concepts/workflows-33","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"MCP tool"},"596":{"id":"/concepts/workflows-34","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Notes"},"597":{"id":"/concepts/workflows-35","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows`"},"598":{"id":"/concepts/workflows-36","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflows`, `search_workflows`"},"599":{"id":"/concepts/workflows-37","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`?q=` searches."},"600":{"id":"/concepts/workflows-38","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflows`"},"601":{"id":"/concepts/workflows-39","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`create_workflow`"},"602":{"id":"/concepts/workflows-40","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin. Inline source or `workflow.bundleId`."},"603":{"id":"/concepts/workflows-41","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{id}`"},"604":{"id":"/concepts/workflows-42","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`describe_workflow`"},"605":{"id":"/concepts/workflows-43","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Definition and input schema."},"606":{"id":"/concepts/workflows-44","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`PATCH /api/workflows/{id}`"},"607":{"id":"/concepts/workflows-45","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`update_workflow`"},"608":{"id":"/concepts/workflows-46","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"609":{"id":"/concepts/workflows-47","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`DELETE /api/workflows/{id}`"},"610":{"id":"/concepts/workflows-48","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`delete_workflow`"},"611":{"id":"/concepts/workflows-49","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; disables."},"612":{"id":"/concepts/workflows-50","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{id}/source`"},"613":{"id":"/concepts/workflows-51","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`get_workflow_source`"},"614":{"id":"/concepts/workflows-52","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Source, metadata, sections, graph."},"615":{"id":"/concepts/workflows-53","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{name}/versions`"},"616":{"id":"/concepts/workflows-54","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflow_versions`"},"617":{"id":"/concepts/workflows-55","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Versions seen on runs."},"618":{"id":"/concepts/workflows-56","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-bundles`"},"619":{"id":"/concepts/workflows-57","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflow_bundles`"},"620":{"id":"/concepts/workflows-58","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Metadata only."},"621":{"id":"/concepts/workflows-59","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-bundles/{id}`"},"622":{"id":"/concepts/workflows-60","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`get_workflow_bundle`"},"623":{"id":"/concepts/workflows-61","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Includes source."},"624":{"id":"/concepts/workflows-62","page_id":"/concepts/workflows","t