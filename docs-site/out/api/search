limits","content":"60 / minute"},"987":{"id":"/guides/api-154","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"`POST /api/chat` (in-app assistant)"},"988":{"id":"/guides/api-155","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#rate-limits","content":"60 / minute"},"989":{"id":"/guides/api-156","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#see-also","content":"MCP guide — every API operation is also an MCP tool"},"990":{"id":"/guides/api-157","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#see-also","content":"CLI guide — the same API from your terminal"},"991":{"id":"/guides/approvals-telegram","page_id":"/guides/approvals-telegram","type":"page","content":"Approvals and Telegram","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/approvals-telegram"},"992":{"id":"/guides/approvals-telegram-0","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram","content":"Operate human checkpoints — where approval cards appear, what each decision does, timed approvals, and the Telegram integration."},"993":{"id":"/guides/approvals-telegram-1","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#where-approvals-appear","content":"Where approvals appear"},"994":{"id":"/guides/approvals-telegram-2","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#resolving-a-card","content":"Resolving a card"},"995":{"id":"/guides/approvals-telegram-3","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"Timed approvals and fallback"},"996":{"id":"/guides/approvals-telegram-4","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#telegram-integration","content":"Telegram integration"},"997":{"id":"/guides/approvals-telegram