workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-packages","content":"Workflow packages"},"780":{"id":"/concepts/workflows-6","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#enabled-and-disabled","content":"Enabled and disabled"},"781":{"id":"/concepts/workflows-7","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#api--mcp","content":"API & MCP"},"782":{"id":"/concepts/workflows-8","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"A **workflow** is the unit of the Runyard catalog: a named, versioned definition of something an agent can do. Each workflow has a slug, a display name and description, input/output schemas, and a source program that the runner executes. In older code and database tables the same object is called a *capability* — that is the legacy/internal synonym; user-facing surfaces say workflow."},"783":{"id":"/concepts/workflows-9","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"A workflow definition carries:"},"784":{"id":"/concepts/workflows-10","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Field"},"785":{"id":"/concepts/workflows-11","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Purpose"},"786":{"id":"/concepts/workflows-12","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`slug`, `name`, `description`, `category`, `keywords`"},"787":{"id":"/concepts/workflows-13","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Identity and catalog discovery (`GET /api/workflows?q=` searches)."},"788":{"id":"/concepts/workflows-14","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`inputSchema` / `outputSchema`"},"789":{"id":"/concepts/workflows-15","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"JSON schemas for run input and output. Required input fields drive preflight questions."},"790":{"id":"/concepts/workflows-16","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredRunnerTags`"},"791":{"id":"/concepts/workflows-17","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Tags a runner must advertise to be assigned a run."},"792":{"id":"/concepts/workflows-18","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredSkills` / `requiredAgents`"},"793":{"id":"/concepts/workflows-19","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"References into the shared catalog."},"794":{"id":"/concepts/workflows-20","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`approvalPolicy`"},"795":{"id":"/concepts/workflows-21","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Whether new runs hold for an approval before executing."},"796":{"id":"/concepts/workflows-22","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`workflow`"},"797":{"id":"/concepts/workflows-23","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Source configuration — most importantly `workflow.bundleId`, plus options like `hooks.allowedProfiles` for post-run hooks and `secrets` for secret delivery."},"798":{"id":"/concepts/workflows-24","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`enabled`"},"799":{"id":"/concepts/workflows-25","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Disabled workflows disappear from the catalog for non-admins and cannot be run."},"800":{"id":"/concepts/workflows-26","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is created and edited through the API/MCP (`create_workflow` / `update_workflow` with inline source bytes) or by importing a workflow package. You never write workflow files to disk on the Hub or runner: custom workflows must carry source bytes or reference an existing `workflow.bundleId` — bare `workflow.entry` file paths are rejected."},"801":{"id":"/concepts/workflows-27","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Published source lives in the Hub database as **workflow bundles**: immutable, hash-addressed rows in the `workflow_bundles` table. Publishing is insert-only — every publish creates a new `(workflow slug, version)` row with a `sha256` of the source, so a bundle id permanently names the exact bytes that were published. Bundles are capped at 500 KB, listing never returns source bytes, and a workflow that references a missing bundle fails preflight rather than silently falling back to a file."},"802":{"id":"/concepts/workflows-28","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Prefer `create_workflow` / `update_workflow` with inline source — they publish a bundle for you and point the workflow at it."},"803":{"id":"/concepts/workflows-29","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#versioning","content":"Updating a workflow bumps its integer `version` and snapshots the previous definition. `GET /api/workflows/{name}/versions` lists the versions observed on past runs, and every run records the `workflowVersion` it executed. Bundle versions count separately, per publish."},"804":{"id":"/concepts/workflows-30","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-packages","content":"A **workflow package** is a portable `.runyard-workflow.json` file for moving a workflow between Hubs. Exports contain source bytes, metadata, requirements, and content/workflow hashes — never secret values. Imports publish the source as a new immutable bundle and create the workflow **disabled by default**, so an admin can configure and preflight it locally before enabling it. `validate` and `preview` let you check a package without writing anything."},"805":{"id":"/concepts/workflows-31","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#enabled-and-disabled","content":"`DELETE /api/workflows/{id}` disables a workflow rather than erasing it: historical runs stay intact, non-admins get a 404, and preflight blocks new runs until an admin re-enables it with `PATCH /api/workflows/{id}`."},"806":{"id":"/concepts/workflows-32","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Endpoint"},"807":{"id":"/concepts/workflows-33","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"MCP tool"},"808":{"id":"/concepts/workflows-34","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Notes"},"809":{"id":"/concepts/workflows-35","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows`"},"810":{"id":"/concepts/workflows-36","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflows`, `search_workflows`"},"811":{"id":"/concepts/workflows-37","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`?q=` sea