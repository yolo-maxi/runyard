/tokens-and-scopes-21","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Resolving and creating approval cards only — the narrow scope for approval surfaces."},"597":{"id":"/concepts/tokens-and-scopes-22","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"`admin`"},"598":{"id":"/concepts/tokens-and-scopes-23","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Everything. `admin` is a **superscope**: it satisfies every scope requirement, and admin-only endpoints (tokens, secrets, catalog edits, schedules, hooks, audit) require it."},"599":{"id":"/concepts/tokens-and-scopes-24","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Reads such as listing runs, workflows, runners, or schedules need only an authenticated token, whatever its scopes. Runner lifecycle endpoints additionally enforce **run ownership**: only the runner token that claimed a run (or an admin) may report on it."},"600":{"id":"/concepts/tokens-and-scopes-25","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`GET /api/tokens/scopes` (admin; MCP tool `list_token_scopes`) describes the scope vocabulary and the named presets the Tokens page offers:"},"601":{"id":"/concepts/tokens-and-scopes-26","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Preset"},"602":{"id":"/concepts/tokens-and-scopes-27","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Scopes"},"603":{"id":"/concepts/tokens-and-scopes-28","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Use for"},"604":{"id":"/concepts/tokens-and-scopes-29","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Everything** (default)"},"605":{"id":"/concepts/tokens-and-scopes-30","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`api`, `mcp`, `approvals`"},"606":{"id":"/concepts/tokens-and-scopes-31","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"A normal person or agent: read everything, run workflows, decide approvals. No admin or runner rights."},"607":{"id":"/concepts/tokens-and-scopes-32","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Read-only**"},"608":{"id":"/concepts/tokens-and-scopes-33","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`read`"},"609":{"id":"/concepts/tokens-and-scopes-34","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Dashboards, monitors, and cautious integrations that must never change state."},"610":{"id":"/concepts/tokens-and-scopes-35","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Approvals only**"},"611":{"id":"/concepts/tokens-and-scopes-36","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`approvals`"},"612":{"id":"/concepts/tokens-and-scopes-37","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Approval inboxes and bots that only decide."},"613":{"id":"/concepts/tokens-and-scopes-38","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Runner**"},"614":{"id":"/concepts/tokens-and-scopes-39","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`runner`"},"615":{"id":"/concepts/tokens-and-scopes-40","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Runner machines. Keep separate from human tokens."},"616":{"id":"/concepts/tokens-and-scopes-41","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"**Admin**"},"617":{"id":"/concepts/tokens-and-scopes-42","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"`admin`"},"618":{"id":"/concepts/tokens-and-scopes-43","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Full control, including tokens and secrets. Issue sparingly."},"619":{"id":"/concepts/tokens-and-scopes-44","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#presets","content":"Finer-grained per-group write scopes (e.g. a token that can manage schedules but not run workflows) are a documented follow-up; today `api`/`mcp` grant the whole operating surface."},"620":{"id":"/concepts/tokens-and-scopes-45","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#bootstrap-token","content":"On first boot, if no access tokens exist, the Hub creates a `bootstrap-admin` token with the `admin`, `api`, `runner`, and `mcp` scopes and writes it to `data/bootstrap-token.txt` on the server (relative to the Hub's data directory). Use it to log in and mint narrower tokens, one per client or integration."},"621":{"id":"/concepts/tokens-and-scopes-46","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#browser-sessions","content":"The web app is an ordinary API client. `POST /api/auth/token-login` exchanges an access token for a **session cookie** — a signed copy of the token — so the browser session carries *exactly* the token's scopes, no extra power. Admin sections of the web app appear only for admin-scoped sessions. `POST /api/auth/logout` clears the cookie."},"622":{"id":"/concepts/tokens-and-scopes-47","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#telegram-webapp-sessions","content":"Approving from Telegram uses `POST /api/auth/telegram-webapp&#x60;, which verifies Telegram's signed init data against the configured bot and allowlisted users, then issues a session scoped to **`approvals` only** — narrower than any token session. A Telegram session can list and resolve approval cards but cannot start runs or touch admin surfaces."},"623":{"id":"/concepts/tokens-and-scopes-48","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Endpoint"},"624":{"id":"/concepts/tokens-and-scopes-49","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"MCP tool"},"625":{"id":"/concepts/tokens-and-scopes-50","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Notes"},"626":{"id":"/concepts/tokens-and-scopes-51","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/me`"},"627":{"id":"/concepts/tokens-and-scopes-52","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`whoami`"},"628":{"id":"/concepts/tokens-and-scopes-53","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Token name and scopes."},"629":{"id":"/concepts/tokens-and-scopes-54","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/tokens`"},"630":{"id":"/concepts/tokens-and-scopes-55","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`list_tokens`"},"631":{"id":"/concepts/tokens-and-scopes-56","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin."},"632":{"id":"/concepts/tokens-and-scopes-57","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/tokens/scopes`"},"633":{"id":"/concepts/tokens-and-scopes-58","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`list_token_scopes`"},"634":{"id":"/concepts/tokens-and-scopes-59","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin. Scope vocabulary, presets, defaults."},"635":{"id":"/concepts/tokens-and-scopes-60","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/tokens`"},"636":{"id":"/concepts/tokens-and-scopes-61","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`create_token`"},"637":{"id":"/concepts/tokens-and-scopes-62","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin. `{name, scopes, expiresInDays?}`."},"638":{"id":"/concepts/tokens-and-scopes-63","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`DELETE /api/tokens/{id}`"},"639":{"id":"/concepts/tokens-and-scopes-64","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`revoke_token`"},"640":{"id":"/concepts/tokens-and-scopes-65","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin."},"641":{"id":"/concepts/tokens-and-scopes-66","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/auth/token-login`"},"642":{"id":"/concepts/tokens-and-scopes-67","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"—"},"643":{"id":"/concepts/tokens-and-scopes-68","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Browser session bootstrap (rate-limited)."},"644":{"id":"/concepts/tokens-and-scopes-69","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/auth/telegram-webapp`"},"645":{"id":"/concepts/tokens-and-scopes-70","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"—"},"646":{"id":"/concepts/tokens-and-scopes-71","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Approvals-scoped Telegram session."},"647":{"id":"/concepts/tokens-and-scopes-72","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`POST /api/auth/logout`"},"648":{"id":"/concepts/tokens-and-scopes-73","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"—"},"649":{"id":"/concepts/tokens-and-scopes-74","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Clears the session cookie."},"650":{"id":"/concepts/tokens-and-scopes-75","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`GET /api/audit`"},"651":{"id":"/concepts/tokens-and-scopes-76","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"`get_audit_log`"},"652":{"id":"/concepts/tokens-and-scopes-77","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin; who did what, most recent first."},"653":{"id":"/concepts/work-items","page_id":"/concepts/work-items","type":"page","content":"Work items","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/work-items"},"654":{"id":"/concepts/work-items-0","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items","content":"Tickets on the Work board — the durable unit of company work that workflows and runs execute for."},"655":{"id":"/concepts/work-items-1","page_id":"/concepts/work-items","type":"heading","tags":[],"url":"/concepts/work-items#lifecycle","content":"Lifecycle"},"656":{"id":"/concepts/work-items-2","page_id":"/concepts/work-items","type":"heading","tags":[],"url":"/concepts/work-items#linked-runs-and-attention","content":"Linked runs and attention"},"657":{"id":"/concepts/work-items-3","page_id":"/concepts/work-items","type":"heading","tags":[],"url":"/concepts/work-items#execution-flow","content":"Execution flow"},"658":{"id":"/concepts/work-items-4","page_id":"/concepts/work-items","type":"heading","tags":[],"url":"/concepts/work-items#api--mcp","content":"API & MCP"},"659":{"id":"/concepts/work-items-5","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items","content":"A **work item*&#x2A; (ticket) is the durable unit of company work: &#x2A;\"Make pause/resume fully supported\"&#x2A;, &#x2A;\"Fix the flaky release gate\"*. It is deliberately distinct from the two execution concepts:"},"660":{"id":"/concepts/work-items-6","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items","content":"a workflow is a reusable **recipe**;"},"661":{"id":"/concepts/work-items-7","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items","content":"a run is **one execution attempt** of a workflow."},"662":{"id":"/concepts/work-items-8","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items","content":"A work item can use one workflow, many workflows, or none yet. Many runs can attach to one work item; a run belongs to at most one work item, and old runs can stay unlinked. Crucially, **there is no failed ticket state** — run failures are execution facts, not ticket verdicts. A failed linked run parks its ticket in `blocked` with an explicit reason (see Boards → Runs move tickets); humans and agents can always re-park or retry."},"663":{"id":"/concepts/work-items-9","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Work items move through a human-legible lifecycle, shown as lanes on the Work board (`/app#work`):"},"664":{"id":"/concepts/work-items-10","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Status"},"665":{"id":"/concepts/work-items-11","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Meaning"},"666":{"id":"/concepts/work-items-12","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`intake`"},"667":{"id":"/concepts/work-items-13","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Raw ask, idea, bug, or product need."},"668":{"id":"/concepts/work-items-14","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`triaged`"},"669":{"id":"/concepts/work-items-15","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Priority, type, owner, and acceptance criteria clarified."},"670":{"id":"/concepts/work-items-16","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`ready`"},"671":{"id":"/concepts/work-items-17","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Next workflow/action selected; dependencies known."},"672":{"id":"/concepts/work-items-18","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`running`"},"673":{"id":"/concepts/work-items-19","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"One or more runs actively working on it."},"674":{"id":"/concepts/work-items-20","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`waiting`"},"675":{"id":"/concepts/work-items-21","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Paused for an approval, human decision, credential, budget, or dependency."},"676":{"id":"/concepts/work-items-22","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`blocked`"},"677":{"id":"/concepts/work-items-23","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Cannot progress without a specific intervention (`blockedReason` says which)."},"678":{"id":"/concepts/work-items-24","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`review`"},"679":{"id":"/concepts/work-items-25","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"A deliverable exists and needs inspection."},"680":{"id":"/concepts/work-items-26","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`shipped`"},"681":{"id":"/concepts/work-items-27","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Merged/released/deployed with evidence."},"682":{"id":"/concepts/work-items-28","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`accepted`"},"683":{"id":"/concepts/work-items-29","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Confirmed to satisfy the original ask."},"684":{"id":"/concepts/work-items-30","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"`archived`"},"685":{"id":"/concepts/work-items-31","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Closed historical item (hidden from lists by default)."},"686":{"id":"/concepts/work-items-32","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Status moves happen two ways, both recorded in ticket history as `work_item.status_changed` events (alongside run link/unlink events and field edits): explicit `PATCH`es by a human or agent, and automatic moves by linked runs where the mapping is reliable — a run going live puts the ticket in `running`, a held run parks it in `waiting`, a succeeded run sends it to `review`, a failed run parks it in `blocked` with a reason. Automated moves are attributed to the run (`actor: \"run:run_…\"`); see Boards for the full mapping."},"687":{"id":"/concepts/work-items-33","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#lifecycle","content":"Each item also carries `type` (`feature`, `bug`, `research`, `release`, `maintenance`, `idea`), `priority` (`urgent`, `high`, `normal`, `low`), `project`, `owner`/`requester`, `acceptanceCriteria`, `nextAction`, `blockedReason`, and an optional `dueAt`."},"688":{"id":"/concepts/work-items-34","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#linked-runs-and-attention","content":"List and detail payloads carry a linked-run rollup — `runs: { total, byStatus, lastRunAt, attention }` — where `attention` counts linked runs whose next step is a human action (`paused`, `waiting_approval`, or `budget_exceeded`), the same signal as `GET /api/runs/attention`. The board surfaces it as a badge, and linked runs also move the ticket across lanes as they progress (see Boards)."},"689":{"id":"/concepts/work-items-35","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#linked-runs-and-attention","content":"Attach runs three ways:"},"690":{"id":"/concepts/work-items-36","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#linked-runs-and-attention","content":"pass `workItemId` at run creation (`POST /api/workflows/{id}/run`, the `run_workflow` MCP tool, or `runyard run --work-item <id>`);"},"691":{"id":"/concepts/work-items-37","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#linked-runs-and-attention","content":"link an existing run: `POST /api/work-items/{id}/link-run` with `{ \"runId\": \"run_...\" }` (relinking moves the run and leaves an unlink event on the old ticket);"},"692":{"id":"/concepts/work-items-38","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#linked-runs-and-attention","content":"launch a workflow from the ticket detail in the web app."},"693":{"id":"/concepts/work-items-39","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#linked-runs-and-attention","content":"Linked runs bring their approvals and artifacts with them: the ticket detail aggregates both across all linked runs."},"694":{"id":"/concepts/work-items-40","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#execution-flow","content":"`GET /api/runs/{id}/flow` (MCP `get_run_flow`, CLI `runyard flow <runId>&#x60;) answers &#x2A;\"where is this run in its workflow?\"*. It takes the workflow's static step graph and folds the run's event stream onto it, yielding one state per step:"},"695":{"id":"/concepts/work-items-41","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#execution-flow","content":"`pending · active · done · failed · waiting · cancelled · skipped`"},"696":{"id":"/concepts/work-items-42","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#execution-flow","content":"The fold is derived, never stored: explicit `node.*` lifecycle events win; an unresolved `engine.approval.waiting` parks its step in `waiting`; the run's own terminal status closes the books (succeeded finishes unfinished active steps, cancelled cancels them, a failure-terminal status fails the step the run died on). When no source graph exists the flow degrades to an event-derived stepper rather than hiding observed work. The ticket detail renders this as the flow view for the active or latest linked run."},"697":{"id":"/concepts/work-items-43","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Endpoint"},"698":{"id":"/concepts/work-items-44","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"MCP tool"},"699":{"id":"/concepts/work-items-45","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Notes"},"700":{"id":"/concepts/work-items-46","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`GET /api/work-items`"},"701":{"id":"/concepts/work-items-47","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`list_work_items`"},"702":{"id":"/concepts/work-items-48","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Filters: `status`, `project`, `owner`, `type`, `q`; `includeArchived=true` shows archived."},"703":{"id":"/concepts/work-items-49","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`GET /api/work-items/{id}`"},"704":{"id":"/concepts/work-items-50","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`get_work_item`"},"705":{"id":"/concepts/work-items-51","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Item + linked runs, approvals, artifacts, ticket history."},"706":{"id":"/concepts/work-items-52","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`POST /api/work-items`"},"707":{"id":"/concepts/work-items-53","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`create_work_item`"},"708":{"id":"/concepts/work-items-54","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`api`/`mcp` scope. Body: `title` (required) + the fields above."},"709":{"id":"/concepts/work-items-55","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`PATCH /api/work-items/{id}`"},"710":{"id":"/concepts/work-items-56","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`update_work_item`"},"711":{"id":"/concepts/work-items-57","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Any subset; move lanes by setting `status`."},"712":{"id":"/concepts/work-items-58","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`DELETE /api/work-items/{id}`"},"713":{"id":"/concepts/work-items-59","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`delete_work_item`"},"714":{"id":"/concepts/work-items-60","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Admin; prefer `status: \"archived\"`."},"715":{"id":"/concepts/work-items-61","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`POST /api/work-items/{id}/link-run`"},"716":{"id":"/concepts/work-items-62","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`link_work_item_run`"},"717":{"id":"/concepts/work-items-63","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Body: `{ runId }`."},"718":{"id":"/concepts/work-items-64","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`POST /api/work-items/{id}/unlink-run`"},"719":{"id":"/concepts/work-items-65","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`unlink_work_item_run`"},"720":{"id":"/concepts/work-items-66","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Body: `{ runId }`."},"721":{"id":"/concepts/work-items-67","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`GET /api/runs/{id}/flow`"},"722":{"id":"/concepts/work-items-68","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"`get_run_flow`"},"723":{"id":"/concepts/work-items-69","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Per-step execution states for the flow view."},"724":{"id":"/concepts/work-items-70","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"CLI: `runyard work` (board list), `runyard work-item show|create|update|link|unlink`, `runyard flow <runId>`, and `runyard run <workflow> --work-item <id>`."},"725":{"id":"/concepts/work-items-71","page_id":"/concepts/work-items","tags":[],"type":"text","url":"/concepts/work-items#api--mcp","content":"Grouped `/api/v1` aliases live under `/api/v1/work/items...`."},"726":{"id":"/concepts/workflows","page_id":"/concepts/workflows","type":"page","content":"Workflows","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/workflows"},"727":{"id":"/concepts/workflows-0","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"The catalog unit of Runyard - versioned definitions with schemas, immutable source bundles, and portable packages."},"728":{"id":"/concepts/workflows-1","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#definition","content":"Definition"},"729":{"id":"/concepts/workflows-2","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is data, not files"},"730":{"id":"/concepts/workflows-3","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#db-backed-workflow-bundles","content":"DB-backed workflow bundles"},"731":{"id":"/concepts/workflows-4","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#versioning","content":"Versioning"},"732":{"id":"/concepts/workflows-5","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-packages","content":"Workflow packages"},"733":{"id":"/concepts/workflows-6","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#enabled-and-disabled","content":"Enabled and disabled"},"734":{"id":"/concepts/workflows-7","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#api--mcp","content":"API & MCP"},"735":{"id":"/concepts/workflows-8","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"A **workflow** is the unit of the Runyard catalog: a named, versioned definition of something an agent can do. Each workflow has a slug, a display name and description, input/output schemas, and a source program that the runner executes. In older code and database tables the same object is called a *capability* — that is the legacy/internal synonym; user-facing surfaces say workflow."},"736":{"id":"/concepts/workflows-9","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"A workflow definition carries:"},"737":{"id":"/concepts/workflows-10","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Field"},"738":{"id":"/concepts/workflows-11","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Purpose"},"739":{"id":"/concepts/workflows-12","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`slug`, `name`, `description`, `category`, `keywords`"},"740":{"id":"/concepts/workflows-13","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Identity and catalog discovery (`GET /api/workflows?q=` searches)."},"741":{"id":"/concepts/workflows-14","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`inputSchema` / `outputSchema`"},"742":{"id":"/concepts/workflows-15","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"JSON schemas for run input and output. Required input fields drive preflight questions."},"743":{"id":"/concepts/workflows-16","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredRunnerTags`"},"744":{"id":"/concepts/workflows-17","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Tags a runner must advertise to be assigned a run."},"745":{"id":"/concepts/workflows-18","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredSkills` / `requiredAgents`"},"746":{"id":"/concepts/workflows-19","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"References into the shared catalog."},"747":{"id":"/concepts/workflows-20","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`approvalPolicy`"},"748":{"id":"/concepts/workflows-21","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Whether new runs hold for an approval before executing."},"749":{"id":"/concepts/workflows-22","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`workflow`"},"750":{"id":"/concepts/workflows-23","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Source configuration — most importantly `workflow.bundleId`, plus options like `hooks.allowedProfiles` for post-run hooks and `secrets` for secret delivery."},"751":{"id":"/concepts/workflows-24","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`enabled`"},"752":{"id":"/concepts/workflows-25","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Disabled workflows disappear from the catalog for non-admins and cannot be run."},"753":{"id":"/concepts/workflows-26","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is created and edited through the API/MCP (`create_workflow` / `update_workflow` with inline source bytes) or by importing a workflow package. You never write workflow files to disk on the Hub or runner: custom workflows must carry source bytes or reference an existing `workflow.bundleId` — bare `workflow.entry` file paths are rejected."},"754":{"id":"/concepts/workflows-27","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Published source lives in the Hub database as **workflow bundles**: immutable, hash-addressed rows in the `workflow_bundles` table. Publishing is insert-only — every publish creates a new `(workflow slug, version)` row with a `sha256` of the source, so a bundle id permanently names the exact bytes that were published. Bundles are capped at 500 KB, listing never returns source bytes, and a workflow that references a missing bundle fails preflight rather than silently falling back to a file."},"755":{"id":"/concepts/workflows-28","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Prefer `create_workflow` / `update_workflow` with inline source — they publish a bundle for you and point the workflow at it."},"756":{"id":"/concepts/workflows-29","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#versioning","content":"Updating a workflow bumps its integer `version` and snapshots the previous definition. `GET /api/workflows/{name}/versions` lists the versions observed on past runs, and every run records the `workflowVersion` it executed. Bundle versions count separately, per publish."},"757":{"id":"/concepts/workflows-30","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-packages","content":"A **workflow package** is a portable `.runyard-workflow.json` file for moving a workflow between Hubs. Exports contain source bytes, metadata, requirements, and content/workflow hashes — never secret values. Imports publish the source as a new immutable bundle and create the workflow **disabled by default**, so an admin can configure and preflight it locally before enabling it. `validate` and `preview` let you check a package without writing anything."},"758":{"id":"/concepts/workflows-31","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#enabled-and-disabled","content":"`DELETE /api/workflows/{id}` disables a workflow rather than erasing it: historical runs stay intact, non-admins get a 404, and preflight blocks new runs until an admin re-enables it with `PATCH /api/workflows/{id}`."},"759":{"id":"/concepts/workflows-32","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Endpoint"},"760":{"id":"/concepts/workflows-33","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"MCP tool"},"761":{"id":"/concepts/workflows-34","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Notes"},"762":{"id":"/concepts/workflows-35","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows`"},"763":{"id":"/concepts/workflows-36","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflows`, `search_workflows`"},"764":{"id":"/concepts/workflows-37","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`?q=` searches."},"765":{"id":"/concepts/workflows-38","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflows`"},"766":{"id":"/concepts/workflows-39","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`create_workflow`"},"767":{"id":"/concepts/workflows-40","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin. Inline source or `workflow.bundleId`."},"768":{"id":"/concepts/workflows-41","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{id}`"},"769":{"id":"/concepts/workflows-42","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`describe_workflow`"},"770":{"id":"/concepts/workflows-43","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Definition and input schema."},"771":{"id":"/concepts/workflows-44","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`PATCH /api/workflows/{id}`"},"772":{"id":"/concepts/workflows-45","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`update_workflow`"},"773":{"id":"/concepts/workflows-46","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"774":{"id":"/concepts/workflows-47","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`DELETE /api/workflows/{id}`"},"775":{"id":"/concepts/workflows-48","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`delete_workflow`"},"776":{"id":"/concepts/workflows-49","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; disables."},"777":{"id":"/concepts/workflows-50","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{id}/source`"},"778":{"id":"/concepts/workflows-51","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`get_workflow_source`"},"779":{"id":"/concepts/workflows-52","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Source, metadata, sections, graph."},"780":{"id":"/concepts/workflows-53","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{name}/versions`"},"781":{"id":"/concepts/workflows-54","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflow_versions`"},"782":{"id":"/concepts/workflows-55","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Versions seen on runs."},"783":{"id":"/concepts/workflows-56","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-bundles`"},"784":{"id":"/concepts/workflows-57","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflow_bundles`"},"785":{"id":"/concepts/workflows-58","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Metadata only."},"786":{"id":"/concepts/workflows-59","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-bundles/{id}`"},"787":{"id":"/concepts/workflows-60","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`get_workflow_bundle`"},"788":{"id":"/concepts/workflows-61","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Includes source."},"789":{"id":"/concepts/workflows-62","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-bundles`"},"790":{"id":"/concepts/workflows-63","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`publish_workflow_bundle`"},"791":{"id":"/concepts/workflows-64","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"792":{"id":"/concepts/workflows-65","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-packages/workflows/{id}/export`"},"793":{"id":"/concepts/workflows-66","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`export_workflow_package`"},"794":{"id":"/concepts/workflows-67","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"795":{"id":"/concepts/workflows-68","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/validate`"},"796":{"id":"/concepts/workflows-69","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`validate_workflow_package`"},"797":{"id":"/concepts/workflows-70","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"798":{"id":"/concepts/workflows-71","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/preview`"},"799":{"id":"/concepts/workflows-72","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`preview_workflow_import`"},"800":{"id":"/concepts/workflows-73","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; nothing written."},"801":{"id":"/concepts/workflows-74","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/import`"},"802":{"id":"/concepts/workflows-75","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`import_workflow_package`"},"803":{"id":"/concepts/workflows-76","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; imports disabled."},"804":{"id":"/concepts/workflows-77","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Running a workflow (`POST /api/workflows/{id}/run`, `run_workflow`) and preflighting it are covered on the Runs page."},"805":{"id":"/guides/agent-consumers","page_id":"/guides/agent-consumers","type":"page","content":"Building agents on Runyard","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/agent-consumers"},"806":{"id":"/guides/agent-consumers-0","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Discovery surfaces, the API-first guarantee, and recommended etiquette for agents and third-party clients."},"807":{"id":"/guides/agent-consumers-1","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#discovery-surfaces","content":"Discovery surfaces"},"808":{"id":"/guides/agent-consumers-2","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#the-api-first-guarantee","content":"The API-first guarantee"},"809":{"id":"/guides/agent-consumers-3","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#auth-expectations","content":"Auth expectations"},"810":{"id":"/guides/agent-consumers-4","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#recommended-agent-etiquette","content":"Recommended agent etiquette"},"811":{"id":"/guides/agent-consumers-5","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"Push instead of poll: response endpoints"},"812":{"id":"/guides/agent-consumers-6","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"Machine intake: workflow endpoints"},"813":{"id":"/guides/agent-consumers-7","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Runyard treats agents as first-class API consumers. This page covers how a client discovers what a Hub can do, what it may rely on, and how to be a good citizen."},"814":{"id":"/guides/agent-consumers-8","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Surface"},"815":{"id":"/guides/agent-consumers-9","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Auth"},"816":{"id":"/guides/agent-consumers-10","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"What it gives you"},"817":{"id":"/guides/agent-consumers-11","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /llms.txt`"},"818":{"id":"/guides/agent-consumers-12","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"819":{"id":"/guides/agent-consumers-13","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Static, generic orientation for agents: what Runyard is, its tool names, the run path. It deliberately contains nothing deployment-specific and points at the authenticated menu."},"820":{"id":"/guides/agent-consumers-14","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /openapi.json`"},"821":{"id":"/guides/agent-consumers-15","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"822":{"id":"/guides/agent-consumers-16","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The full HTTP surface, generated from the Hub's API surface registry — it cannot drift from the routes the server actually registers."},"823":{"id":"/guides/agent-consumers-17","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"MCP `tools/list`"},"824":{"id":"/guides/agent-consumers-18","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"825":{"id":"/guides/agent-consumers-19","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The complete MCP tool set (parity-tested against the API surface). Connect with `runyard mcp install` or the `runyard-mcp` stdio server."},"826":{"id":"/guides/agent-consumers-20","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /api/menu` / `get_menu`"},"827":{"id":"/guides/agent-consumers-21","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"828":{"id":"/guides/agent-consumers-22","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The live, private catalog: workflows with schemas, execution modes, runner pool state, and ready-to-use CLI/MCP invocations."},"829":{"id":"/guides/agent-consumers-23","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Start every session with `get_menu` (or `GET /api/menu`), then `describe_workflow` for anything you intend to run."},"830":{"id":"/guides/agent-consumers-24","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#the-api-first-guarantee","content":"The web app is an ordinary client of the same HTTP API, with no privileged endpoints. Every route is declared in one registry that also generates `openapi.json` and is parity-tested against the MCP tool list — so a lossless third-party client is possible by construction: anything the web app can show or do, your client can too, over HTTP or MCP."},"831":{"id":"/guides/agent-consumers-25","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#auth-expectations","content":"Ask the Hub's administrator for a scoped access token (admins issue them from the Connect tab or `POST /api/tokens`). Agents typically need `api` and/or `mcp` — nothing more. Send it as `Authorization: Bearer <token>` on every HTTP call, or configure it for the MCP server. Never ask for or expect the bootstrap/admin token."},"832":{"id":"/guides/agent-consumers-26","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Set `input.title`.** For agent-created runs, include a short human-readable title (\"Audit checkout flow mobile states\") so run lists, approval cards, and human handoff stay decipherable."},"833":{"id":"/guides/agent-consumers-27","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Preflight first.** When input is rough or unverified, call `preflight_workflow` (`POST /api/workflows/{id}/preflight`) or pass `negotiate: true` to `run_workflow`. You get `ready | needs_input | blocked` with concrete questions and blockers instead of a run that fails."},"834":{"id":"/guides/agent-consumers-28","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Use run drafts for question/answer loops.** `create_run_draft` creates a proposed run and preflights it; `update_run_draft` merges answers into the input and re-preflights; `submit_run_draft` enqueues the real run only once it is ready; `discard_run_draft` abandons it. Nothing executes until submit."},"835":{"id":"/guides/agent-consumers-29","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Poll the timeline with `since` cursors.** `get_run_timeline` (`GET /api/runs/{id}/timeline`) returns a unified, ascending view of status transitions, events, and artifacts. Pass the previous response's `nextSince` as `since` so the Hub never re-sends what you have. Fetch results with `get_run_status`, `get_run_logs`, and `get_run_artifacts` / `download_artifact`."},"836":{"id":"/guides/agent-consumers-30","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Cap what a run may spend.** Pass `budget: { maxTokens, maxCostMicros }` when starting a run; a breach hard-stops the run as the distinct terminal status `budget_exceeded` (never a silent overrun). Read spend as you go from the run's `usage` and `budgetStatus` fields, and use `get_usage_summary` for a fleet rollup. See Usage metering & budgets."},"837":{"id":"/guides/agent-consumers-31","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Expect paused runs, and resume them.** A run interrupted by exhausted provider credits/quota parks as `paused` instead of failing. Check `run.pause` for the reason and required action, fix it, then `resume_run` (`POST /api/runs/{id}/resume`) — it continues from the engine checkpoint when one exists."},"838":{"id":"/guides/agent-consumers-32","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Triage with the attention queue.** `list_attention_runs` (`GET /api/runs/attention`) returns everything waiting on a human — paused, awaiting approval, or recently budget-stopped — with counts. Poll it instead of scanning full run lists for stuck work."},"839":{"id":"/guides/agent-consumers-33","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"A metered, resumable run end to end:"},"840":{"id":"/guides/agent-consumers-34","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"`POST /api/workflows/{id}/run` accepts an optional `responseEndpoint` (`{ \"type\": \"http\" | \"telegram\", \"config\": { ... } }`). When the run reaches a terminal state, the Hub POSTs a sanitized payload to your HTTP endpoint (or sends a concise Telegram message). Delivery state is visible on `GET /api/runs/{id}` under `responseEndpoints[]`, and polling remains the canonical fallback."},"841":{"id":"/guides/agent-consumers-35","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"For fixed-purpose integrations that should not hold a Hub token at all (webhooks, form intake, external systems), an admin can configure a **workflow endpoint**: `POST /api/workflow-endpoints/{slug}` accepts a payload authenticated with that endpoint's own secret, rate-limited, size-capped, and deduplicated, and triggers exactly one preconfigured workflow. This is the narrowest possible credential to hand to an external system."},"842":{"id":"/guides/api","page_id":"/guides/api","type":"page","content":"HTTP API","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/api"},"843":{"id":"/guides/api-0","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Authenticate, discover, and drive workflow runs over the Runyard Hub's HTTP API."},"844":{"id":"/guides/api-1","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#authentication","content":"Authentication"},"845":{"id":"/guides/api-2","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#discovery","content":"Discovery"},"846":{"id":"/guides/api-3","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#api-groups-and-apiv1-aliases","content":"API groups and `/api/v1` aliases"},"847":{"id":"/guides/api-4","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#the-typical-flow","content":"The typical flow"},"848":{"id":"/guides/api-5","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#key-endpoints","content":"Key endpoints"},"849":{"id":"/guides/api-6","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#approvals","content":"Approvals"},"850":{"id":"/guides/api-7","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#run-drafts","content":"Run drafts"},"851":{"id":"/guides/api-8","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#error-conventions","content":"Error conventions"},"852":{"id":"/guides/api-9","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#rate-limits","content":"Rate limits"},"853":{"id":"/guides/api-10","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#see-also","content":"See also"},"854":{"id":"/guides/api-11","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Every Runyard surface — the web app, the CLI, and the MCP server — is an\nordinary client of one HTTP API served by the Hub. Anything they can do, you\ncan do with `curl`."},"855":{"id":"/guides/api-12","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Send an access token as a bearer token on every request:"},"856":{"id":"/guides/api-13","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Tokens are minted by an admin (web UI, `POST /api/tokens`, or the CLI) and carry\n**scopes**:"},"857":{"id":"/guides/api-14","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Scope"},"858":{"id":"/guides/api-15","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Grants"},"859":{"id":"/guides/api-16","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`api`"},"860":{"id":"/guides/api-17","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Start runs, preflight, drafts, rerun/cancel/promote, create approvals"},"861":{"id":"/guides/api-18","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`mcp`"},"862":{"id":"/guides/api-19","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The same operations, issued for MCP clients"},"863":{"id":"/guides/api-20","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`read`"},"864":{"id":"/guides/api-21","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Read-only** — inspect workflows, runs, logs, artifacts, approvals, schedules, and runners; satisfies no mutation endpoint"},"865":{"id":"/guides/api-22","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`runner`"},"866":{"id":"/guides/api-23","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The runner protocol: register, heartbeat, claim runs, report lifecycle events and artifacts"},"867":{"id":"/guides/api-24","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`approvals`"},"868":{"id":"/guides/api-25","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Resolve approval cards (approve / reject / request changes) and create them"},"869":{"id":"/guides/api-26","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`admin`"},"870":{"id":"/guides/api-27","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Superscope** — satisfies every scope requirement, plus admin-only surfaces: tokens, secrets, audit log, schedules, workflow create/update, packages, hooks, updates"},"871":{"id":"/guides/api-28","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`GET /api/tokens/scopes` (admin) returns this vocabulary plus named presets —\n**everything** (`api`+`mcp`+`approvals`, the default), **read-only**,\n**approvals-only**, **runner**, and **admin** — which the Tokens page uses."},"872":{"id":"/guides/api-29","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Reads such as listing runs, workflows, or artifacts require any authenticated\ntoken. A token with only the `read` scope is therefore read-only: it can\ninspect everything non-admin but every create/update/delete/run/approve call\nfails with `403`. A request with no valid token gets\n`401 {\"error\": \"unauthorized\"}`; a token missing a required scope gets:"},"873":{"id":"/guides/api-30","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"with status `403`. `GET /api/me` describes the calling token (name and scopes)."},"874":{"id":"/guides/api-31","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /openapi.json`** (unauthenticated) — generated from the server's API\nsurface registry, the single source of truth every route is registered from,\nso **every endpoint is documented there**. This guide covers the important\nones; use `/openapi.json` for the full list."},"875":{"id":"/guides/api-32","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/menu`** (authenticated) — the agent-facing menu: workflow catalog,\nlocal/remote execution modes, and follow-up paths. The same data backs the\nMCP `get_menu` tool and `/llms.txt`."},"876":{"id":"/guides/api-33","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/version`** (unauthenticated) — product name, version, instance\nname."},"877":{"id":"/guides/api-34","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Operations are organized into eight groups, exposed as OpenAPI tags:\n**workflows**, **runs**, **approvals**, **automation** (schedules + workflow\nendpoints), **library** (agents, skills, knowledge, hooks), **distribution**\n(bundles, packages), **admin** (tokens, secrets, audit, alerts, updates), and\n**system** (health, version, menu, dashboard, runners)."},"878":{"id":"/guides/api-35","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Every grouped operation is also reachable at a stable `/api/v1` alias that\nmakes the group visible in the path — for example:"},"879":{"id":"/guides/api-36","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Canonical"},"880":{"id":"/guides/api-37","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Grouped alias"},"881":{"id":"/guides/api-38","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflows`"},"882":{"id":"/guides/api-39","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/workflows`"},"883":{"id":"/guides/api-40","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/runs/:id`"},"884":{"id":"/guides/api-41","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/:id`"},"885":{"id":"/guides/api-42","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/run-drafts`"},"886":{"id":"/guides/api-43","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/drafts`"},"887":{"id":"/guides/api-44","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/schedules`"},"888":{"id":"/guides/api-45","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/automation/schedules`"},"889":{"id":"/guides/api-46","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/agents`"},"890":{"id":"/guides/api-47","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/library/agents`"},"891":{"id":"/guides/api-48","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflow-bundles`"},"892":{"id":"/guides/api-49","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/distribution/bundles`"},"893":{"id":"/guides/api-50","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/tokens`"},"894":{"id":"/guides/api-51","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/admin/tokens`"},"895":{"id":"/guides/api-52","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/menu`"},"896":{"id":"/guides/api-53","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/system/menu`"},"897":{"id":"/guides/api-54","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Aliases are the same registry entries registered twice, so they always share\nthe canonical route's handler, auth, and scopes; in `openapi.json` each alias\ncarries `x-canonical-path`. Unversioned `/api/...` paths remain fully\nsupported — use whichever reads better. The legacy `/api/capabilities/*`\npaths are deprecated aliases of `/api/workflows/*` and get no `/api/v1` form;\nnew clients should say *workflow* everywhere."},"898":{"id":"/guides/api-55","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"List workflows, preflight your input, start the run, then poll it:"},"899":{"id":"/guides/api-56","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"For agent-created runs, include a short human-readable `input.title` — it labels\nrun lists, approval cards, and handoffs. `executionMode` is `local` or `remote`;\n`run` also accepts an optional `responseEndpoint` (`{type: http|telegram,\nconfig}`) to have the terminal-state reply delivered when the run finishes\n(polling `/api/runs/:id` remains the canonical fallback), and an optional\n`budget` (`{maxTokens?, maxCostMicros?}`, also accepted as `input.budget`) that\nhard-caps the run's metered model usage — a breach terminates the run with the\ndistinct status `budget_exceeded`. Metered usage aggregates onto every run\nobject as `usage` and is detailed at `GET /api/runs/:id/usage`; see\nUsage metering & budgets."},"900":{"id":"/guides/api-57","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"With `\"negotiate\": true`, a non-ready request returns the negotiation state\n(questions, blockers, warnings, plus a saved draft) instead of creating a run —\nfix the input and call again."},"901":{"id":"/guides/api-58","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Workflows and runs (`preflight` and `run` require `api` or `mcp` scope; reads\nrequire any token):"},"902":{"id":"/guides/api-59","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Method + path"},"903":{"id":"/guides/api-60","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Purpose"},"904":{"id":"/guides/api-61","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows`"},"905":{"id":"/guides/api-62","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List workflows (`?q=` searches)"},"906":{"id":"/guides/api-63","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows/:id`"},"907":{"id":"/guides/api-64","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Describe a workflow and its input schema"},"908":{"id":"/guides/api-65","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows/:id/source`"},"909":{"id":"/guides/api-66","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Workflow source, parsed metadata, sections, graph"},"910":{"id":"/guides/api-67","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows/:id/preflight`"},"911":{"id":"/guides/api-68","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Dry-run preflight: `ready` / `needs_input` / `blocked`, nothing created"},"912":{"id":"/guides/api-69","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows/:id/run`"},"913":{"id":"/guides/api-70","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run a workflow: `{input, executionMode, negotiate?}`"},"914":{"id":"/guides/api-71","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows` / `PATCH /api/workflows/:id`"},"915":{"id":"/guides/api-72","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Create/update a workflow (admin). Source is submitted as bytes or a `workflow.bundleId` — never a file path"},"916":{"id":"/guides/api-73","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs`"},"917":{"id":"/guides/api-74","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List runs (filter by `status`, `q`, `workflow`)"},"918":{"id":"/guides/api-75","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id`"},"919":{"id":"/guides/api-76","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run status, outputs, error, response-delivery state"},"920":{"id":"/guides/api-77","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/timeline`"},"921":{"id":"/guides/api-78","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Unified ascending timeline (`since=<iso>`, `limit=<n>`); backs `runyard tail`"},"922":{"id":"/guides/api-79","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/usage`"},"923":{"id":"/guides/api-80","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Metered usage: aggregate totals, per-call records, budget, and `budgetStop`"},"924":{"id":"/guides/api-81","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/events` · `/logs` · `/diagnostics`"},"925":{"id":"/guides/api-82","page_id":"/guides/api","tags":[],"type":"t