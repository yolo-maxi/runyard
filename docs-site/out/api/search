ls-telegram-2","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#resolving-a-card","content":"Resolving a card"},"947":{"id":"/guides/approvals-telegram-3","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"Timed approvals and fallback"},"948":{"id":"/guides/approvals-telegram-4","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#telegram-integration","content":"Telegram integration"},"949":{"id":"/guides/approvals-telegram-5","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#bot-setup","content":"Bot setup"},"950":{"id":"/guides/approvals-telegram-6","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#webhook","content":"Webhook"},"951":{"id":"/guides/approvals-telegram-7","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#approval-cards-with-buttons","content":"Approval cards with buttons"},"952":{"id":"/guides/approvals-telegram-8","page_id":"/guides/approvals-telegram","type":"heading","tags":[],"url":"/guides/approvals-telegram#telegram-webapp-login","content":"Telegram WebApp login"},"953":{"id":"/guides/approvals-telegram-9","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram","content":"An approval is a declared question with a declared consequence. Cards carry an *ask* — who is asked, what approving does, and why a human is needed — and every surface renders that stored ask verbatim. A run held on a card sits in `waiting_approval` and is never failed or age-reaped for waiting."},"954":{"id":"/guides/approvals-telegram-10","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Surface"},"955":{"id":"/guides/approvals-telegram-11","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"How"},"956":{"id":"/guides/approvals-telegram-12","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Web app"},"957":{"id":"/guides/approvals-telegram-13","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"The **Approvals** view lists pending cards with their ask, consequences, and buttons."},"958":{"id":"/guides/approvals-telegram-14","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"MCP"},"959":{"id":"/guides/approvals-telegram-15","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"`list_pending_approvals` (or `list_approvals` with a `status` filter), `get_approval`."},"960":{"id":"/guides/approvals-telegram-16","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"CLI"},"961":{"id":"/guides/approvals-telegram-17","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"`runyard approvals` lists pending cards."},"962":{"id":"/guides/approvals-telegram-18","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"HTTP"},"963":{"id":"/guides/approvals-telegram-19","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"`GET /api/approvals?status=pending`, `GET /api/approvals/{id}`."},"964":{"id":"/guides/approvals-telegram-20","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Telegram"},"965":{"id":"/guides/approvals-telegram-21","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#where-approvals-appear","content":"Cards are posted to the configured chat with inline buttons (see below)."},"966":{"id":"/guides/approvals-telegram-22","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Each card takes one of three decisions:"},"967":{"id":"/guides/approvals-telegram-23","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"HTTP: `POST /api/approvals/{id}/approve|reject|request-changes`. MCP: `approve_run`, `reject_run`, `request_changes_run` — all take an **approvalId**, not a runId. These need a token with the `api`, `mcp`, or `approvals` scope (admin always qualifies)."},"968":{"id":"/guides/approvals-telegram-24","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"What each decision does depends on the card's kind:"},"969":{"id":"/guides/approvals-telegram-25","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Kind"},"970":{"id":"/guides/approvals-telegram-26","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Approve"},"971":{"id":"/guides/approvals-telegram-27","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Request changes"},"972":{"id":"/guides/approvals-telegram-28","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Reject"},"973":{"id":"/guides/approvals-telegram-29","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Run hold (default / `custom`)"},"974":{"id":"/guides/approvals-telegram-30","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The held run is released to the queue and executes."},"975":{"id":"/guides/approvals-telegram-31","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The run is cancelled; your note tells the requester what to change."},"976":{"id":"/guides/approvals-telegram-32","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The run is cancelled — a human \"no\" is a decision, not a failure."},"977":{"id":"/guides/approvals-telegram-33","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`workflow_gate` (mid-run engine gate)"},"978":{"id":"/guides/approvals-telegram-34","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The decision is applied to the paused workflow on the runner and it resumes past the gate."},"979":{"id":"/guides/approvals-telegram-35","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Applied as a deny with your note attached; the workflow's own deny path decides what happens next."},"980":{"id":"/guides/approvals-telegram-36","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Applied as a deny; the workflow's deny path decides what happens next."},"981":{"id":"/guides/approvals-telegram-37","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`escalation` (run already ended)"},"982":{"id":"/guides/approvals-telegram-38","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records your go-ahead on the card; the run is not restarted — re-run it from the run page."},"983":{"id":"/guides/approvals-telegram-39","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records that the workflow or input needs fixing; your note is the guidance."},"984":{"id":"/guides/approvals-telegram-40","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Records that the run should be left as it ended."},"985":{"id":"/guides/approvals-telegram-41","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"`side_effect`"},"986":{"id":"/guides/approvals-telegram-42","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The gated side effect is allowed to run."},"987":{"id":"/guides/approvals-telegram-43","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The side effect is skipped; your note explains what to change."},"988":{"id":"/guides/approvals-telegram-44","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"The side effect is skipped; the run's completed work is unaffected."},"989":{"id":"/guides/approvals-telegram-45","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#resolving-a-card","content":"Resolved cards keep the decision in their `resolution` field (`approved`, `rejected`, `changes_requested`) plus how it was decided (`resolvedVia`: human, fallback timer, engine, policy, or system)."},"990":{"id":"/guides/approvals-telegram-46","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"Approvals are blocking by default: with no timer configured, nothing happens until someone decides, and a linked run is held open indefinitely."},"991":{"id":"/guides/approvals-telegram-47","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"A creator can make a card timed by supplying `timeoutMs` or `timeoutAt`, optionally with a `fallback` decision (`approve` or `reject`) — via `POST /api/approvals` or the `create_approval` MCP tool:"},"992":{"id":"/guides/approvals-telegram-48","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"**Timer + fallback** — if nobody decides before the deadline, the Hub applies the fallback decision on the human's behalf, fully audited (`resolvedVia: fallback_timer`)."},"993":{"id":"/guides/approvals-telegram-49","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"**Timer without fallback** — when the timer elapses the card is flagged `fallback_required` and **stays pending**: it is surfaced as urgent, but no decision is ever invented."},"994":{"id":"/guides/approvals-telegram-50","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#timed-approvals-and-fallback","content":"`timeoutMs` is clamped to between 1 second and 30 days."},"995":{"id":"/guides/approvals-telegram-51","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#telegram-integration","content":"The Hub can post approval cards to a Telegram chat and accept decisions from the buttons on them."},"996":{"id":"/guides/approvals-telegram-52","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Create a bot with Telegram's BotFather, then configure the Hub through environment variables (values belong in your env file or secret store — never in code or docs):"},"997":{"id":"/guides/approvals-telegram-53","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Variable"},"998":{"id":"/guides/approvals-telegram-54","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Purpose"},"999":{"id":"/guides/approvals-telegram-55","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_BOT_TOKEN`"},"1000":{"id":"/guides/approvals-telegram-56","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"The bot's API token."},"1001":{"id":"/guides/approvals-telegram-57","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_APPROVAL_CHAT_ID`"},"1002":{"id":"/guides/approvals-telegram-58","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Chat (group or DM) where approval cards are posted."},"1003":{"id":"/guides/approvals-telegram-59","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_APPROVAL_USER_IDS`"},"1004":{"id":"/guides/approvals-telegram-60","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Comma-separated Telegram user ids allowed to resolve approvals."},"1005":{"id":"/guides/approvals-telegram-61","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_WEBHOOK_SECRET`"},"1006":{"id":"/guides/approvals-telegram-62","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Secret Telegram echoes back so the Hub can verify webhook calls."},"1007":{"id":"/guides/approvals-telegram-63","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"`TELEGRAM_CHAT_ID` / `TELEGRAM_THREAD_ID`"},"1008":{"id":"/guides/approvals-telegram-64","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#bot-setup","content":"Optional default chat/thread for non-approval notifications."},"1009":{"id":"/guides/approvals-telegram-65","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#webhook","content":"Point the bot's webhook at the Hub:"},"1010":{"id":"/guides/approvals-telegram-66","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#webhook","content":"`POST /api/telegram/webhook` is the only Telegram-facing route. It is verified against the configured bot and webhook secret and is not a general API."},"1011":{"id":"/guides/approvals-telegram-67","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#approval-cards-with-buttons","content":"Each pending card is posted as a message carrying the ask (what approving does, why a human is needed), a sanitized input summary, and inline buttons: **Approve**, **Request changes**, **Reject**. Only the configured approval user ids can act; a button press resolves the card exactly like the web or API would, and the message is edited to show the resolution (\"Approved by ... at ...\") with the buttons removed."},"1012":{"id":"/guides/approvals-telegram-68","page_id":"/guides/approvals-telegram","tags":[],"type":"text","url":"/guides/approvals-telegram#telegram-webapp-login","content":"Cards can deep-link into the Hub as a Telegram WebApp. `POST /api/auth/telegram-webapp` exchanges the WebApp's signed init data for a browser session that is limited to the `approvals` scope — a Telegram identity can review and resolve approval cards, and nothing else. Full app access always requires a real access token."},"1013":{"id":"/guides/cli","page_id":"/guides/cli","type":"page","content":"CLI","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/cli"},"1014":{"id":"/guides/cli-0","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli","content":"Install the runyard CLI, connect it to a Hub, and drive workflows, runs, approvals, and runners from the terminal."},"1015":{"id":"/guides/cli-1","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#install","content":"Install"},"1016":{"id":"/guides/cli-2","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#connecting-to-a-hub","content":"Connecting to a Hub"},"1017":{"id":"/guides/cli-3","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#discover-and-run-workflows","content":"Discover and run workflows"},"1018":{"id":"/guides/cli-4","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#watch-and-manage-runs","content":"Watch and manage runs"},"1019":{"id":"/guides/cli-5","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#approvals","content":"Approvals"},"1020":{"id":"/guides/cli-6","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#workflow-packages","content":"Workflow packages"},"1021":{"id":"/guides/cli-7","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#tokens-audit-and-catalog","content":"Tokens, audit, and catalog"},"1022":{"id":"/guides/cli-8","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#runner-setup","content":"Runner setup"},"1023":{"id":"/guides/cli-9","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#mcp-helpers","content":"MCP helpers"},"1024":{"id":"/guides/cli-10","page_id":"/guides/cli","type":"heading","tags":[],"url":"/guides/cli#updating-a-host-install","content":"Updating a host install"},"1025":{"id":"/guides/cli-11","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli","content":"The `runyard` CLI is a thin client of the Hub's HTTP API. It talks\nto one or more Hubs (\"remotes\"), starts and tails workflow runs, resolves\napprovals, and can set up and start a runner on the local machine."},"1026":{"id":"/guides/cli-12","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#install","content":"The fastest path is the install script served by your own Hub, which downloads\nthe CLI tarball from the same instance (`/cli.tgz`), installs `runyard` and\n`runyard-mcp` into `~/.local/bin`, and logs you in:"},"1027":{"id":"/guides/cli-13","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#install","content":"It prompts for an access token (Web Hub → Connect) and a name for the\nconnection. Alternatively, run the CLI from a source checkout of the\nrepository with `pnpm cli -- <command>` (the checkout exposes the `runyard`,\n`runyard-mcp`, and `runyard-runner` binaries under `bin/`)."},"1028":{"id":"/guides/cli-14","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#connecting-to-a-hub","content":"The CLI stores named remotes (Hub URL + token) in `~/.runyard/config.json`\n(mode `0600`). Every command accepts global options `--url`, `--token`,\n`--remote <name>`, and `--json` (machine-readable output)."},"1029":{"id":"/guides/cli-15","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#connecting-to-a-hub","content":"Environment variables `RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN` (and an explicit\n`--url` / `--token`) take precedence over the saved remote."},"1030":{"id":"/guides/cli-16","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`runyard run` options:"},"1031":{"id":"/guides/cli-17","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Option"},"1032":{"id":"/guides/cli-18","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Meaning"},"1033":{"id":"/guides/cli-19","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`-i, --input <json>`"},"1034":{"id":"/guides/cli-20","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"JSON input for the run"},"1035":{"id":"/guides/cli-21","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--where <mode>`"},"1036":{"id":"/guides/cli-22","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Execution mode: `local` or `remote` (alias: `--execution-mode`)"},"1037":{"id":"/guides/cli-23","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--runner-location <location>`"},"1038":{"id":"/guides/cli-24","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Target a specific runner location tag"},"1039":{"id":"/guides/cli-25","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--negotiate`"},"1040":{"id":"/guides/cli-26","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Preflight first: enqueue only when ready, otherwise print the negotiation state (questions/blockers and a saved draft) without creating a run"},"1041":{"id":"/guides/cli-27","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--chain <json>`"},"1042":{"id":"/guides/cli-28","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"JSON array of next workflow steps to queue after each run succeeds"},"1043":{"id":"/guides/cli-29","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--pin <sha>`"},"1044":{"id":"/guides/cli-30","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Pin the run to a specific workflow git SHA (requires workflow versioning)"},"1045":{"id":"/guides/cli-31","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--max-tokens <n>`"},"1046":{"id":"/guides/cli-32","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Hard budget: stop the run once its metered usage reaches this many tokens"},"1047":{"id":"/guides/cli-33","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"`--max-cost <usd>`"},"1048":{"id":"/guides/cli-34","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Hard budget: stop the run once its metered cost reaches this many US dollars"},"1049":{"id":"/guides/cli-35","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#discover-and-run-workflows","content":"Related: `runyard workflow versions <workflow>` lists SHAs seen across runs and\n`runyard workflow rollback <workflow> <sha>` re-runs pinned to a prior SHA\n(`--from-run <id>` links it to the run being rolled back)."},"1050":{"id":"/guides/cli-36","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#watch-and-manage-runs","content":"`tail` emits `{ts, kind, source, payload}` lines built from status transitions,\nevents, and artifacts, polling every 2 seconds with a `since` cursor — pipe it\ninto `jq` or downstream tooling."},"1051":{"id":"/guides/cli-37","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#workflow-packages","content":"Workflows move between Hubs as portable `.runyard-workflow.json` package files\n— exported from one Hub and imported into another (admin token required).\nImported workflows arrive **disabled** for review before enabling; this is the\nsupported way to carry workflow source around, not files on a runner."},"1052":{"id":"/guides/cli-38","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#tokens-audit-and-catalog","content":"Admin-scoped commands:"},"1053":{"id":"/guides/cli-39","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#tokens-audit-and-catalog","content":"Reads available to any token: `runyard runners` (runner pool), `runyard agents`,\n`runyard skills`, `runyard knowledge -q <query>`, `runyard hooks [--workflow <slug>]`, and `runyard hook describe|validate <slug>`. Secrets have\nno CLI subcommand — manage them in the web UI, over the\nAPI (`PUT /api/secrets/:key`), or with the MCP `set_secret` tool."},"1054":{"id":"/guides/cli-40","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"Turn a machine into a runner in three steps. First scaffold a workspace\n(requires `bun` and the `smithers` engine on `PATH`; it warns if no `claude`,\n`codex`, or `pi` agent CLI is found):"},"1055":{"id":"/guides/cli-41","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"Then start the runner against the current remote (it inherits the remote's URL\nand token, or `RUNYARD_HUB_URL` / `RUNYARD_HUB_TOKEN`):"},"1056":{"id":"/guides/cli-42","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"`--location` is `local` or `vps` and drives run routing (`--where local` runs\nland on `local`-tagged runners). You can also register a machine explicitly:"},"1057":{"id":"/guides/cli-43","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#runner-setup","content":"For an always-on runner use the systemd unit instead — see\nInstallation."},"1058":{"id":"/guides/cli-44","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#mcp-helpers","content":"See the MCP guide for clients and options."},"1059":{"id":"/guides/cli-45","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#updating-a-host-install","content":"On a host that runs the Hub from a full checkout (not the thin CLI bundle),\n`runyard update [tag]` applies a release **on that host**: it drains runners,\nswaps the code, restarts the systemd units, verifies health, and rolls back\nautomatically on failure. It is always operator-initiated."},"1060":{"id":"/guides/cli-46","page_id":"/guides/cli","tags":[],"type":"text","url":"/guides/cli#updating-a-host-install","content":"Options: `--units <units>` (systemd units to restart, default\n`runyard runyard-runner`) and `--grace-ms <ms>` (bounded drain window before\naborting — in-flight runs are never killed)."},"1061":{"id":"/guides/installation","page_id":"/guides/installation","type":"page","content":"Installation","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/installation"},"1062":{"id":"/guides/installation-0","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"Install and deploy a Runyard Hub and runners — from source, with systemd, or with Docker."},"1063":{"id":"/guides/installation-1","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#requirements","content":"Requirements"},"1064":{"id":"/guides/installation-2","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#quick-install-host-bootstrap","content":"Quick install (host bootstrap)"},"1065":{"id":"/guides/installation-3","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#running-from-source","content":"Running from source"},"1066":{"id":"/guides/installation-4","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#systemd","content":"systemd"},"1067":{"id":"/guides/installation-5","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#docker-compose","content":"Docker Compose"},"1068":{"id":"/guides/installation-6","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"Confidential VMs (dstack / Intel TDX)"},"1069":{"id":"/guides/installation-7","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#reverse-proxy","content":"Reverse proxy"},"1070":{"id":"/guides/installation-8","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#environment-variables","content":"Environment variables"},"1071":{"id":"/guides/installation-9","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#where-state-lives","content":"Where state lives"},"1072":{"id":"/guides/installation-10","page_id":"/guides/installation","type":"heading","tags":[],"url":"/guides/installation#next-steps","content":"Next steps"},"1073":{"id":"/guides/installation-11","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"Runyard is a self-hosted control plane for agent runs. A deployment has a small,\nfixed shape:"},"1074":{"id":"/guides/installation-12","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Hub** — the HTTP server: API, web UI, MCP-backing endpoints, and the embedded\nSQLite datastore. One per deployment."},"1075":{"id":"/guides/installation-13","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Runners** — one or more worker processes that register with the Hub using a\nrunner-scoped token, heartbeat, claim queued runs, and execute workflows. A\nrunner can live on the same host as the Hub or on a separate machine."},"1076":{"id":"/guides/installation-14","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation","content":"**Clients** — the `runyard` CLI, the `runyard-mcp` MCP server, and the web app\nare all ordinary API clients of the Hub."},"1077":{"id":"/guides/installation-15","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Requirement"},"1078":{"id":"/guides/installation-16","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Notes"},"1079":{"id":"/guides/installation-17","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Node.js >= 22.5"},"1080":{"id":"/guides/installation-18","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"The Hub uses the built-in `node:sqlite` module (started with `--experimental-sqlite`)"},"1081":{"id":"/guides/installation-19","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"pnpm"},"1082":{"id":"/guides/installation-20","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Dependency install and build (`corepack enable` works)"},"1083":{"id":"/guides/installation-21","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"git, curl"},"1084":{"id":"/guides/installation-22","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"For source installs and the bootstrap script"},"1085":{"id":"/guides/installation-23","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#requirements","content":"Runner hosts additionally need the Smithers engine and at least one authenticated\nagent CLI (`claude`, `codex`, or `pi`) on `PATH` — see the CLI guide\nfor `runyard runner setup`."},"1086":{"id":"/guides/installation-24","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"The repository ships a one-command, idempotent bootstrap script for a fresh\nLinux box:"},"1087":{"id":"/guides/installation-25","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"It ensures Node 22 + pnpm, clones the latest release tag into `/opt/runyard`\n(override with `RUNYARD_HOME`), runs `pnpm install --frozen-lockfile`, generates\na `SECRETS_ENC_KEY` and session secret into `/etc/runyard/runyard.env` (never\nclobbering an existing file, never printing secrets), creates the data\ndirectory, installs and enables the systemd units for the Hub and a runner, and\ninstalls a daily *passive* update-check timer (it never auto-applies updates)."},"1088":{"id":"/guides/installation-26","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"When it finishes it prints next steps: sign in with the bootstrap token, mint a\nrunner-scoped token, put it in `/etc/runyard/runner.env`, and restart the runner\nunit."},"1089":{"id":"/guides/installation-27","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#quick-install-host-bootstrap","content":"A running Hub also serves its own **client** install script at\n`https://hub.example.com/install.sh` (plus the CLI tarball at `/cli.tgz`). That\none installs the `runyard` CLI and `runyard-mcp` on a workstation — see\nthe CLI guide."},"1090":{"id":"/guides/installation-28","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#running-from-source","content":"The Hub listens on `127.0.0.1:43117` by default. Start a runner in a second\nprocess:"},"1091":{"id":"/guides/installation-29","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#running-from-source","content":"The runner authenticates with a runner-scoped token (`RUNYARD_HUB_TOKEN`); on a\nfresh Hub it may use the bootstrap token until you mint one."},"1092":{"id":"/guides/installation-30","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"The repository ships generic units in `deploy/`. The Hub unit\n(`deploy/runyard.service`):"},"1093":{"id":"/guides/installation-31","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"And the runner unit (`deploy/runyard-runner.service`):"},"1094":{"id":"/guides/installation-32","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#systemd","content":"The bootstrap script installs these for you, retargeted to your install\ndirectory, env-file location, and node binary. Secrets live in the\n`EnvironmentFile`s (mode `0600`), never in the units."},"1095":{"id":"/guides/installation-33","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Runyard publishes two environment-agnostic images to GHCR:"},"1096":{"id":"/guides/installation-34","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Image"},"1097":{"id":"/guides/installation-35","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Role"},"1098":{"id":"/guides/installation-36","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`ghcr.io/yolo-maxi/runyard-hub`"},"1099":{"id":"/guides/installation-37","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"control plane + web UI + embedded datastore (HTTP on `PORT`, default 8080 in-container)"},"1100":{"id":"/guides/installation-38","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`ghcr.io/yolo-maxi/runyard-runner`"},"1101":{"id":"/guides/installation-39","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"claims runs and executes them; workspace volume at `/workspace`"},"1102":{"id":"/guides/installation-40","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"The portable base stack is `docker-compose.yml` at the repo root:"},"1103":{"id":"/guides/installation-41","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"Provide secrets (`RUNYARD_HUB_SESSION_SECRET`, `SECRETS_ENC_KEY`,\n`RUNYARD_HUB_TOKEN`, agent API keys) via a `.env` file or your platform's secret\nmechanism. For production, pin images by `@sha256:` digest rather than mutable\ntags. Optional overlays (all off by default):"},"1104":{"id":"/guides/installation-42","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`--profile proxy` — a bundled Caddy container that terminates TLS for\n`SITE_ADDRESS` and proxies to the Hub. Skip it if you already have a gateway."},"1105":{"id":"/guides/installation-43","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`-f deploy/compose/runner-docker-socket.yml` — give the runner `docker build`\naccess via the host socket (or run a rootless DinD sidecar instead)."},"1106":{"id":"/guides/installation-44","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#docker-compose","content":"`-f docker-compose.local.yml` — dev profile using locally built images."},"1107":{"id":"/guides/installation-45","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"`deploy/dstack/` contains an overlay that adapts the base compose for dstack\nconfidential-VM deployments: every image **must** be pinned by digest (the\nattestation measures the compose text), the Hub sits on `:80` behind the\ndstack gateway, and updates/rollbacks go through dstack's `UpgradeApp` with new\ndigests. Render a single self-contained file with:"},"1108":{"id":"/guides/installation-46","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#confidential-vms-dstack--intel-tdx","content":"See `deploy/dstack/README.md` in the repository for the full contract."},"1109":{"id":"/guides/installation-47","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#reverse-proxy","content":"The Hub is a single HTTP listener; any TLS-terminating proxy that forwards **all\npaths** to the Hub port works. With Caddy:"},"1110":{"id":"/guides/installation-48","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#reverse-proxy","content":"Then set `BASE_URL=https://hub.example.com` in the Hub's env file and restart.\nAn `https://` base URL switches the Hub into production session mode. If the\nproxy is not on loopback, set the trust-proxy configuration accordingly so\nclient IPs (used by rate limiting) are read from `X-Forwarded-For` only when\nthat header is trustworthy."},"1111":{"id":"/guides/installation-49","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Hub (all optional unless noted; legacy `SMITHERS_HUB_*` names are still read as\nfallbacks so old deployments keep working):"},"1112":{"id":"/guides/installation-50","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Variable"},"1113":{"id":"/guides/installation-51","page_id":"/guides/installation","tags":[],"type":"text","url":"/guides/installation#environment-variables","content":"Meaning"},"1114":{"id":"/guides/installation-52","page_id":"/guides/installation","tags