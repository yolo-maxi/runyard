1248":3,"1249":3,"1250":3,"1251":3,"1252":3,"1253":3,"1254":3,"1255":3,"1256":3,"1257":2,"1258":2,"1259":3,"1260":3,"1261":3,"1262":3,"1263":3,"1264":3,"1265":3,"1266":3,"1267":2,"1268":3,"1269":3,"1270":3,"1271":3,"1272":3,"1273":3,"1274":3,"1275":3,"1276":3,"1277":3,"1278":3,"1279":3,"1280":3,"1281":3,"1282":3,"1283":3,"1284":3,"1285":3,"1286":3,"1287":3,"1288":3,"1289":3,"1290":3,"1291":3,"1292":3,"1293":3,"1294":3,"1295":3,"1296":3,"1297":3,"1298":3,"1299":3,"1300":3,"1301":3,"1302":3,"1303":3,"1304":3,"1305":3,"1306":3,"1307":3,"1308":3,"1309":2,"1310":2,"1311":3,"1312":3,"1313":3,"1314":3,"1315":3,"1316":3,"1317":3,"1318":3,"1319":3,"1320":3,"1321":3,"1322":3,"1323":3,"1324":3,"1325":3,"1326":3,"1327":3,"1328":3,"1329":3,"1330":3,"1331":3,"1332":3,"1333":3,"1334":3,"1335":3,"1336":3,"1337":3,"1338":3,"1339":3,"1340":3,"1341":3,"1342":3,"1343":3,"1344":3,"1345":3,"1346":3,"1347":3,"1348":3,"1349":3,"1350":3,"1351":3,"1352":3,"1353":3,"1354":3,"1355":3,"1356":3,"1357":3,"1358":3,"1359":3,"1360":3,"1361":3,"1362":3,"1363":3,"1364":3,"1365":3,"1366":3,"1367":3,"1368":3,"1369":3,"1370":3,"1371":3,"1372":3,"1373":2,"1374":2,"1375":3,"1376":3,"1377":3,"1378":3,"1379":3,"1380":2,"1381":2,"1382":2,"1383":3,"1384":3,"1385":3,"1386":3,"1387":3,"1388":3,"1389":3,"1390":3,"1391":3,"1392":3,"1393":3,"1394":3,"1395":3,"1396":3,"1397":3,"1398":3,"1399":3,"1400":3,"1401":3,"1402":3,"1403":3,"1404":3,"1405":3,"1406":3,"1407":3,"1408":3,"1409":3,"1410":3,"1411":3,"1412":3,"1413":3,"1414":3,"1415":3}}},"docs":{"docs":{"1":{"id":"/","page_id":"/","type":"page","content":"What is Runyard","breadcrumbs":["Docs"],"tags":[],"url":"/"},"2":{"id":"/-0","page_id":"/","tags":[],"type":"text","url":"/","content":"A self-hosted control plane for agent runs — workflows in, durable runs, logs, artifacts, and approvals out."},"3":{"id":"/-1","page_id":"/","type":"heading","tags":[],"url":"/#next-steps","content":"Next steps"},"4":{"id":"/-2","page_id":"/","tags":[],"type":"text","url":"/","content":"Runyard is a self-hosted control plane for agent runs. Agents and humans trigger workflows over MCP, the CLI, the HTTP API, or the web app; runners execute those workflows with the Smithers engine; and the Hub stores the durable record of everything that happened — runs, logs, events, artifacts, approvals, and knowledge. A run started from a chat agent, a cron schedule, or a terminal all leaves the same auditable trail in the same place."},"5":{"id":"/-3","page_id":"/","tags":[],"type":"text","url":"/","content":"Runyard is designed as one private deployment per company. Your Hub holds your workflow catalog, your secrets, your runners, and your history; nothing about your deployment is published to a shared service, and the only outbound call the Hub makes is a passive read of the public GitHub Releases API to check for updates. Operators, teammates, and their agents all authenticate to the same Hub with scoped access tokens."},"6":{"id":"/-4","page_id":"/","tags":[],"type":"text","url":"/","content":"Runyard is API-first by construction. Every HTTP route the Hub serves is declared in a single API surface registry; the OpenAPI document is generated from it and the MCP tool list is parity-tested against it. The web app is an ordinary API client with no privileged endpoints — anything it can show or do is equally available over the API and MCP, so a third-party client built on those surfaces loses nothing."},"7":{"id":"/-5","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"Quickstart\" href=\"./quickstart\" description=\"Install the Hub, start a runner, and run your first workflow.\" />"},"8":{"id":"/-6","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"Concepts\" href=\"./concepts\" description=\"Workflows, runs, runners, approvals, and the Hub's durable record.\" />"},"9":{"id":"/-7","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"HTTP API\" href=\"./guides/api\" description=\"Drive Runyard from any language with bearer-token auth and openapi.json.\" />"},"10":{"id":"/-8","page_id":"/","tags":[],"type":"text","url":"/#next-steps","content":"<Card title=\"MCP\" href=\"./guides/mcp\" description=\"Connect AI agents to your Hub with the runyard-mcp server.\" />"},"11":{"id":"/quickstart","page_id":"/quickstart","type":"page","content":"Quickstart","breadcrumbs":["Docs"],"tags":[],"url":"/quickstart"},"12":{"id":"/quickstart-0","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart","content":"Install the Hub, sign in with the bootstrap token, start a runner, and run the hello workflow."},"13":{"id":"/quickstart-1","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#1-install-the-hub","content":"1\\. Install the Hub"},"14":{"id":"/quickstart-2","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#2-sign-in-with-the-bootstrap-token","content":"2\\. Sign in with the bootstrap token"},"15":{"id":"/quickstart-3","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#3-install-the-cli-and-log-in","content":"3\\. Install the CLI and log in"},"16":{"id":"/quickstart-4","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#4-start-a-runner","content":"4\\. Start a runner"},"17":{"id":"/quickstart-5","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#5-run-the-hello-workflow","content":"5\\. Run the hello workflow"},"18":{"id":"/quickstart-6","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#6-watch-the-run-and-read-the-results","content":"6\\. Watch the run and read the results"},"19":{"id":"/quickstart-7","page_id":"/quickstart","type":"heading","tags":[],"url":"/quickstart#where-to-go-next","content":"Where to go next"},"20":{"id":"/quickstart-8","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart","content":"This page takes you from a fresh Linux box to a completed workflow run with logs and artifacts in the Hub."},"21":{"id":"/quickstart-9","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#1-install-the-hub","content":"The repository's install script is a one-command, idempotent bootstrap. It installs Node 22 and pnpm if needed, clones Runyard at the latest release tag (default `/opt/runyard`), generates an env file with a `SECRETS_ENC_KEY` and session secret, creates the data directory, and installs systemd units for the Hub and a runner:"},"22":{"id":"/quickstart-10","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#1-install-the-hub","content":"Verify the Hub is up:"},"23":{"id":"/quickstart-11","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#1-install-the-hub","content":"The script never prints secrets, never applies updates automatically, and prints a Caddy reverse-proxy snippet if you want TLS in front (recommended for anything non-local — see the security guide)."},"24":{"id":"/quickstart-12","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#2-sign-in-with-the-bootstrap-token","content":"On first boot the Hub writes a full-admin bootstrap token to `bootstrap-token.txt` in its data directory (with the default install, `/opt/runyard/data/bootstrap-token.txt`, mode 600)."},"25":{"id":"/quickstart-13","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#2-sign-in-with-the-bootstrap-token","content":"Open the web app at your Hub URL (for example `https://hub.example.com`) and paste the bootstrap token into the sign-in form. The browser session carries exactly the token's scopes — the bootstrap token is admin, so you can now mint narrower tokens for everything else from the Connect tab."},"26":{"id":"/quickstart-14","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#3-install-the-cli-and-log-in","content":"Each deployment serves its own CLI install script:"},"27":{"id":"/quickstart-15","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#3-install-the-cli-and-log-in","content":"It installs the `runyard` and `runyard-mcp` commands into `~/.local/bin` and prompts for an access token. You can also log in later:"},"28":{"id":"/quickstart-16","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"Runners execute workflows with the Smithers engine, so a runner host needs `bun`, `smithers`, and at least one authenticated agent CLI (`claude`, `codex`, or `pi`) on its PATH."},"29":{"id":"/quickstart-17","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"If you used the Hub install script, a `runyard-runner` systemd unit is already installed and idling. Mint a runner-scoped token, put it in `/etc/runyard/runner.env` as `RUNYARD_HUB_TOKEN=...`, then:"},"30":{"id":"/quickstart-18","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"To run an ad-hoc runner on any other machine (for example your laptop, for `local` execution):"},"31":{"id":"/quickstart-19","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#4-start-a-runner","content":"`runner setup` checks prerequisites and scaffolds the Smithers workspace the runner executes in. Confirm the runner is online:"},"32":{"id":"/quickstart-20","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"`hello` is a minimal seeded workflow that proves end-to-end execution: it asks the runner's Claude CLI for one sentence and returns structured output."},"33":{"id":"/quickstart-21","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"Web: open **Workflows**, pick &#x2A;*Hello (Smithers proof)**, fill in `topic`, and click Run."},"34":{"id":"/quickstart-22","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"CLI:"},"35":{"id":"/quickstart-23","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#5-run-the-hello-workflow","content":"MCP (from any connected agent):"},"36":{"id":"/quickstart-24","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#6-watch-the-run-and-read-the-results","content":"The same data lives at `GET /api/runs/{id}`, `/api/runs/{id}/timeline`, `/api/runs/{id}/logs`, and `/api/runs/{id}/artifacts`, and in the web run page — the Hub is the source of truth even when execution happened on a local runner."},"37":{"id":"/quickstart-25","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#where-to-go-next","content":"Authoring workflows — create your own workflows over the API or MCP."},"38":{"id":"/quickstart-26","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#where-to-go-next","content":"Approvals — put human checkpoints in front of dangerous work."},"39":{"id":"/quickstart-27","page_id":"/quickstart","tags":[],"type":"text","url":"/quickstart#where-to-go-next","content":"Agent consumers — point AI agents at your Hub."},"40":{"id":"/concepts/agents-skills-knowledge","page_id":"/concepts/agents-skills-knowledge","type":"page","content":"Agents, Skills & Knowledge","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/agents-skills-knowledge"},"41":{"id":"/concepts/agents-skills-knowledge-0","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge","content":"The shared catalog of reusable agent roles, skills, and knowledge resources that workflows reference."},"42":{"id":"/concepts/agents-skills-knowledge-1","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"The three catalogs"},"43":{"id":"/concepts/agents-skills-knowledge-2","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#how-workflows-reference-them","content":"How workflows reference them"},"44":{"id":"/concepts/agents-skills-knowledge-3","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#who-can-edit","content":"Who can edit"},"45":{"id":"/concepts/agents-skills-knowledge-4","page_id":"/concepts/agents-skills-knowledge","type":"heading","tags":[],"url":"/concepts/agents-skills-knowledge#api--mcp","content":"API & MCP"},"46":{"id":"/concepts/agents-skills-knowledge-5","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge","content":"Alongside workflows, the Hub maintains a shared catalog of reusable building blocks. They live in the database, are readable by any authenticated token, and are edited only by admins — so every workflow on the Hub draws from the same curated set."},"47":{"id":"/concepts/agents-skills-knowledge-6","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Catalog"},"48":{"id":"/concepts/agents-skills-knowledge-7","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"What it is"},"49":{"id":"/concepts/agents-skills-knowledge-8","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"**Agents**"},"50":{"id":"/concepts/agents-skills-knowledge-9","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Reusable agent *roles*: a slug, name, description, instructions, a tool list, linked skill slugs, and tags. A role captures \"how this kind of agent should behave\" once, instead of restating it per workflow."},"51":{"id":"/concepts/agents-skills-knowledge-10","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"**Skills**"},"52":{"id":"/concepts/agents-skills-knowledge-11","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Named, versioned instruction bodies (a slug, description, and body text) that agents and workflows can pull in by slug."},"53":{"id":"/concepts/agents-skills-knowledge-12","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"**Knowledge**"},"54":{"id":"/concepts/agents-skills-knowledge-13","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"Reference resources — documents or links with a type, body/URL, and tags — searchable with `?q=` / `search_knowledge`."},"55":{"id":"/concepts/agents-skills-knowledge-14","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#the-three-catalogs","content":"All three are versioned and can be individually enabled/disabled."},"56":{"id":"/concepts/agents-skills-knowledge-15","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#how-workflows-reference-them","content":"A workflow definition declares `requiredAgents` and `requiredSkills` as lists of catalog slugs; `describe_workflow` reports them alongside the schemas so a caller can see what a workflow depends on before running it. Workflow package exports record these requirements, and import preview reports whether the target Hub satisfies them."},"57":{"id":"/concepts/agents-skills-knowledge-16","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#who-can-edit","content":"Reading any catalog requires only an authenticated token. Creating and updating entries requires the `admin` scope — the catalogs are part of the Hub's trusted configuration, like secrets and hook profiles."},"58":{"id":"/concepts/agents-skills-knowledge-17","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#who-can-edit","content":"In the web app the three catalogs share one section with deep links `#agents/agents`, `#agents/skills`, and `#agents/knowledge` (see Deep links)."},"59":{"id":"/concepts/agents-skills-knowledge-18","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Endpoint"},"60":{"id":"/concepts/agents-skills-knowledge-19","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"MCP tool"},"61":{"id":"/concepts/agents-skills-knowledge-20","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Notes"},"62":{"id":"/concepts/agents-skills-knowledge-21","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`GET /api/agents`"},"63":{"id":"/concepts/agents-skills-knowledge-22","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`list_agents`"},"64":{"id":"/concepts/agents-skills-knowledge-23","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`POST /api/agents`"},"65":{"id":"/concepts/agents-skills-knowledge-24","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`create_agent`"},"66":{"id":"/concepts/agents-skills-knowledge-25","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"67":{"id":"/concepts/agents-skills-knowledge-26","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/agents/{slug}`"},"68":{"id":"/concepts/agents-skills-knowledge-27","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_agent`"},"69":{"id":"/concepts/agents-skills-knowledge-28","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"70":{"id":"/concepts/agents-skills-knowledge-29","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`GET /api/skills`"},"71":{"id":"/concepts/agents-skills-knowledge-30","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`list_skills`"},"72":{"id":"/concepts/agents-skills-knowledge-31","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`POST /api/skills`"},"73":{"id":"/concepts/agents-skills-knowledge-32","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`create_skill`"},"74":{"id":"/concepts/agents-skills-knowledge-33","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"75":{"id":"/concepts/agents-skills-knowledge-34","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/skills/{slug}`"},"76":{"id":"/concepts/agents-skills-knowledge-35","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_skill`"},"77":{"id":"/concepts/agents-skills-knowledge-36","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"78":{"id":"/concepts/agents-skills-knowledge-37","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`GET /api/knowledge`"},"79":{"id":"/concepts/agents-skills-knowledge-38","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`search_knowledge`"},"80":{"id":"/concepts/agents-skills-knowledge-39","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`?q=` searches."},"81":{"id":"/concepts/agents-skills-knowledge-40","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`POST /api/knowledge`"},"82":{"id":"/concepts/agents-skills-knowledge-41","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`create_knowledge`"},"83":{"id":"/concepts/agents-skills-knowledge-42","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"84":{"id":"/concepts/agents-skills-knowledge-43","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`PATCH /api/knowledge/{slug}`"},"85":{"id":"/concepts/agents-skills-knowledge-44","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"`update_knowledge`"},"86":{"id":"/concepts/agents-skills-knowledge-45","page_id":"/concepts/agents-skills-knowledge","tags":[],"type":"text","url":"/concepts/agents-skills-knowledge#api--mcp","content":"Admin."},"87":{"id":"/concepts/approvals","page_id":"/concepts/approvals","type":"page","content":"Approvals","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/approvals"},"88":{"id":"/concepts/approvals-0","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"Approval cards - kinds, the ask contract, resolutions, timed approvals with fallbacks, and per-kind consequences."},"89":{"id":"/concepts/approvals-1","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#kinds","content":"Kinds"},"90":{"id":"/concepts/approvals-2","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#the-ask-contract","content":"The ask contract"},"91":{"id":"/concepts/approvals-3","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#status-and-resolution","content":"Status and resolution"},"92":{"id":"/concepts/approvals-4","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#timed-approvals-with-fallback","content":"Timed approvals with fallback"},"93":{"id":"/concepts/approvals-5","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#per-kind-consequences","content":"Per-kind consequences"},"94":{"id":"/concepts/approvals-6","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#api--mcp","content":"API & MCP"},"95":{"id":"/concepts/approvals-7","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"An **approval** is a declared question with a declared consequence, presented to a human as a card in the web app, over Telegram, or through the API/MCP. Cards can hold a run before it executes (`waiting_approval`), pause a workflow mid-run at an engine gate, or simply record a decision. A run held on an approval waits indefinitely — waiting never fails it."},"96":{"id":"/concepts/approvals-8","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Kind"},"97":{"id":"/concepts/approvals-9","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"What it represents"},"98":{"id":"/concepts/approvals-10","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`workflow_gate`"},"99":{"id":"/concepts/approvals-11","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A workflow paused at a gate; the decision releases or denies that step."},"100":{"id":"/concepts/approvals-12","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`escalation`"},"101":{"id":"/concepts/approvals-13","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Autonomous recovery gave up; a human records how to proceed."},"102":{"id":"/concepts/approvals-14","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`side_effect`"},"103":{"id":"/concepts/approvals-15","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A gated side effect asking permission before it runs."},"104":{"id":"/concepts/approvals-16","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`custom`"},"105":{"id":"/concepts/approvals-17","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Any ad-hoc approval raised via the API."},"106":{"id":"/concepts/approvals-18","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"The creator of a card states the ask up front, and every surface renders it verbatim:"},"107":{"id":"/concepts/approvals-19","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`action` — what exactly happens on approve."},"108":{"id":"/concepts/approvals-20","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`reason` — why a human is needed."},"109":{"id":"/concepts/approvals-21","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`audience` — who is asked: `operators` (default) or `admins`."},"110":{"id":"/concepts/approvals-22","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`options` — optional named choices (up to 8)."},"111":{"id":"/concepts/approvals-23","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"An ask without both `action` and `reason` is treated as absent; such cards fall back to a heuristic ask explicitly marked `derived: true`, so a guessed question is never presented as an authored one."},"112":{"id":"/concepts/approvals-24","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"A card's `status` is only ever `pending` or `resolved`. What was decided and by what live in separate fields:"},"113":{"id":"/concepts/approvals-25","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Field"},"114":{"id":"/concepts/approvals-26","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Values"},"115":{"id":"/concepts/approvals-27","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolution`"},"116":{"id":"/concepts/approvals-28","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`approved`, `rejected`, `changes_requested`, `superseded` (the run ended first), or `option:<id>`"},"117":{"id":"/concepts/approvals-29","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolvedVia`"},"118":{"id":"/concepts/approvals-30","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`human`, `fallback_timer` (autopilot), `engine` (decided on the runner), `policy` (auto-approved by policy), `system`"},"119":{"id":"/concepts/approvals-31","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"By default a card is blocking: nothing happens until someone decides. Supplying `timeoutMs` or `timeoutAt` at creation makes it a **timed approval**:"},"120":{"id":"/concepts/approvals-32","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"With a `fallback` decision (`approve` or `reject`), the configured decision is applied automatically when the timer elapses, recorded with `resolvedVia: \"fallback_timer\"`."},"121":{"id":"/concepts/approvals-33","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"Without a fallback, the elapsed card is flagged `fallback_required` and keeps waiting — no decision is invented, and the linked run is never failed by an elapsed timer."},"122":{"id":"/concepts/approvals-34","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"Every card answers \"what will my decision do\" honestly, computed from what resolving actually performs:"},"123":{"id":"/concepts/approvals-35","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`workflow_gate`** — approving a card holding a `waiting_approval` run releases it; approving a mid-run gate applies the decision to the paused workflow on the runner, which resumes past the gate. Reject/changes-requested cancel a held run, or take the workflow's own deny path mid-run."},"124":{"id":"/concepts/approvals-36","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`escalation`** — the run already ended: any decision records the call but does not restart the run (re-run it from the run page)."},"125":{"id":"/concepts/approvals-37","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`side_effect`** — approve allows the gated side effect; reject or changes-requested skip it. The run's completed work is unchanged either way."},"126":{"id":"/concepts/approvals-38","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`custom`** — approving a held run releases it to the queue; reject/changes-requested cancel it. On a card without a held run, the decision is simply recorded."},"127":{"id":"/concepts/approvals-39","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"The API exposes these as `whatHappensIfApproved` / `whatHappensIfRejected` / `whatHappensIfChangesRequested` / `whatHappensIfIgnored` in each card's `context`, alongside the ask, the linked run, and deep links."},"128":{"id":"/concepts/approvals-40","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Endpoint"},"129":{"id":"/concepts/approvals-41","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"MCP tool"},"130":{"id":"/concepts/approvals-42","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Notes"},"131":{"id":"/concepts/approvals-43","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals`"},"132":{"id":"/concepts/approvals-44","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`list_approvals`, `list_pending_approvals`"},"133":{"id":"/concepts/approvals-45","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`?status=pending\\|resolved`."},"134":{"id":"/concepts/approvals-46","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals/{id}`"},"135":{"id":"/concepts/approvals-47","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`get_approval`"},"136":{"id":"/concepts/approvals-48","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Full card with context."},"137":{"id":"/concepts/approvals-49","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals`"},"138":{"id":"/concepts/approvals-50","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`create_approval`"},"139":{"id":"/concepts/approvals-51","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`{title, description, runId?, ask, timeoutMs?/timeoutAt?, fallback?}`."},"140":{"id":"/concepts/approvals-52","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/approve`"},"141":{"id":"/concepts/approvals-53","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`approve_run`"},"142":{"id":"/concepts/approvals-54","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Takes an approval id, not a run id."},"143":{"id":"/concepts/approvals-55","page_id":"/concepts/approvals","tags":[],"t