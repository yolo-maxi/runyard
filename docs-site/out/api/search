"page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows`"},"226":{"id":"/concepts/deep-links-17","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Workflow catalog."},"227":{"id":"/concepts/deep-links-18","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug`"},"228":{"id":"/concepts/deep-links-19","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Workflow detail."},"229":{"id":"/concepts/deep-links-20","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/graph`"},"230":{"id":"/concepts/deep-links-21","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Visual graph tab."},"231":{"id":"/concepts/deep-links-22","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/code`"},"232":{"id":"/concepts/deep-links-23","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Source code tab."},"233":{"id":"/concepts/deep-links-24","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/runs`"},"234":{"id":"/concepts/deep-links-25","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"The workflow's runs."},"235":{"id":"/concepts/deep-links-26","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/run`"},"236":{"id":"/concepts/deep-links-27","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Start-a-run form."},"237":{"id":"/concepts/deep-links-28","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#workflows/:slug/edit`"},"238":{"id":"/concepts/deep-links-29","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Edit the workflow (admin)."},"239":{"id":"/concepts/deep-links-30","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#approvals`, `#approvals/:id`"},"240":{"id":"/concepts/deep-links-31","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Approval inbox / one card."},"241":{"id":"/concepts/deep-links-32","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#schedules`, `#schedules/:id`"},"242":{"id":"/concepts/deep-links-33","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Schedules / one schedule."},"243":{"id":"/concepts/deep-links-34","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#agents/agents`, `#agents/skills`, `#agents/knowledge`"},"244":{"id":"/concepts/deep-links-35","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"The shared catalogs (append `/:slug` for one entry)."},"245":{"id":"/concepts/deep-links-36","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#runners`"},"246":{"id":"/concepts/deep-links-37","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Runner health and pool."},"247":{"id":"/concepts/deep-links-38","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"`#tokens`, `#secrets`, `#audit`, `#settings`, `#connect`"},"248":{"id":"/concepts/deep-links-39","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Admin and setup views."},"249":{"id":"/concepts/deep-links-40","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#route-grammar","content":"Segments are URL-encoded, so ids and slugs with special characters remain valid links. Some tabs accept aliases (for example `visual` for `graph`, `source` for `code`)."},"250":{"id":"/concepts/deep-links-41","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"The API hands these links back so agents and integrations can point humans at the right screen without building URLs themselves:"},"251":{"id":"/concepts/deep-links-42","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"Approval cards carry `deepLink` (the card) and `deepLinkRun` (the linked run), and their `context` includes workflow and run deep links."},"252":{"id":"/concepts/deep-links-43","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"Run-creating responses (`run_workflow`, schedule run-now, draft submit) include link objects for following the run — its status, events, and artifacts endpoints."},"253":{"id":"/concepts/deep-links-44","page_id":"/concepts/deep-links","tags":[],"type":"text","url":"/concepts/deep-links#deep-links-in-api-payloads","content":"When an agent hands off to a human — \"approve this\", \"read the logs\" — prefer relaying the payload's deep link over describing where to click."},"254":{"id":"/concepts/hooks","page_id":"/concepts/hooks","type":"page","content":"Hooks","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/hooks"},"255":{"id":"/concepts/hooks-0","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks","content":"Post-run hook profiles - admin-defined, bounded side effects selected per run that never fail a green run."},"256":{"id":"/concepts/hooks-1","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Profiles are bounded on purpose"},"257":{"id":"/concepts/hooks-2","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#selecting-hooks-per-run","content":"Selecting hooks per run"},"258":{"id":"/concepts/hooks-3","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Hook outcomes never turn a green run red"},"259":{"id":"/concepts/hooks-4","page_id":"/concepts/hooks","type":"heading","tags":[],"url":"/concepts/hooks#api--mcp","content":"API & MCP"},"260":{"id":"/concepts/hooks-5","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks","content":"A **post-run hook profile** is an admin-authored recipe for an optional side effect — publishing static output, pushing a work branch, calling a webhook — that runs *after* a run has produced its verified artifacts and its gates have passed. Hooks separate \"the work succeeded\" from \"the side effect happened\": callers opt in per run, and hook outcomes never rewrite a run's status."},"261":{"id":"/concepts/hooks-6","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Each profile has a fixed `kind` with a fixed set of config keys — anything else is rejected, so raw credentials or ad-hoc shell fragments can never be smuggled into a profile:"},"262":{"id":"/concepts/hooks-7","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Kind"},"263":{"id":"/concepts/hooks-8","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Effect"},"264":{"id":"/concepts/hooks-9","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`static-publish`"},"265":{"id":"/concepts/hooks-10","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Copy verified artifacts to a configured target root (optionally with a public URL base)."},"266":{"id":"/concepts/hooks-11","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`git-push`"},"267":{"id":"/concepts/hooks-12","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Push a work branch to a configured remote. Protected branches (`main`, `master`) are refused — merging to the default branch stays behind explicit run promotion."},"268":{"id":"/concepts/hooks-13","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`webhook`"},"269":{"id":"/concepts/hooks-14","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"POST/PUT to an https URL, with optional headers and secret-backed headers."},"270":{"id":"/concepts/hooks-15","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`vercel-preview`"},"271":{"id":"/concepts/hooks-16","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Trigger a preview deploy for a configured project."},"272":{"id":"/concepts/hooks-17","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"`custom-script`"},"273":{"id":"/concepts/hooks-18","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Run an allowlisted absolute command with declared, typed arguments — never a shell."},"274":{"id":"/concepts/hooks-19","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#profiles-are-bounded-on-purpose","content":"Profiles reference secrets by **name only** (`secretNames`), declare typed `params` callers may fill, and can restrict which workflows may use them (`allowedCapabilities`)."},"275":{"id":"/concepts/hooks-20","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"Selection is explicit and two-sided:"},"276":{"id":"/concepts/hooks-21","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"The workflow must opt in via `workflow.hooks.allowedProfiles` (a list of profile slugs, or `\"*\"`); no opt-in means no hooks, default-closed."},"277":{"id":"/concepts/hooks-22","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"The caller selects profiles per run with `input.postRunHooks: [\"publish-docs\", …]`."},"278":{"id":"/concepts/hooks-23","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"Preflight rejects a request naming a profile that is disabled or not allowed for that workflow, so ineligible hooks surface before a run is created."},"279":{"id":"/concepts/hooks-24","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#selecting-hooks-per-run","content":"Non-admin callers see enabled profiles in a caller-safe shape (slug, name, kind, params) — no paths, remotes, URLs, or secret names. Admins with `?all=1` see every profile with full config and readiness."},"280":{"id":"/concepts/hooks-25","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Hooks run after the run's gates pass, and their results are reported separately from the run status:"},"281":{"id":"/concepts/hooks-26","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Outcome"},"282":{"id":"/concepts/hooks-27","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"Meaning"},"283":{"id":"/concepts/hooks-28","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`succeeded`"},"284":{"id":"/concepts/hooks-29","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The side effect completed."},"285":{"id":"/concepts/hooks-30","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`hook_failed`"},"286":{"id":"/concepts/hooks-31","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The side effect itself failed."},"287":{"id":"/concepts/hooks-32","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`hook_config_required`"},"288":{"id":"/concepts/hooks-33","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The profile cannot execute — typically missing named secrets or a disabled secret store."},"289":{"id":"/concepts/hooks-34","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`hook_blocked`"},"290":{"id":"/concepts/hooks-35","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The profile was not eligible for this run."},"291":{"id":"/concepts/hooks-36","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"`skipped`"},"292":{"id":"/concepts/hooks-37","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"The hook did not run."},"293":{"id":"/concepts/hooks-38","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#hook-outcomes-never-turn-a-green-run-red","content":"A failed hook never rewrites a successful run into a failed one: the run keeps its own status and the hook results ride in the run output, aggregated into one headline hook status. `POST /api/hooks/{slug}/validate` is the admin dry-run: it reports `hook_config_required` with missing secret *names* only."},"294":{"id":"/concepts/hooks-39","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Endpoint"},"295":{"id":"/concepts/hooks-40","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"MCP tool"},"296":{"id":"/concepts/hooks-41","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Notes"},"297":{"id":"/concepts/hooks-42","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`GET /api/hooks`"},"298":{"id":"/concepts/hooks-43","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`list_hooks`"},"299":{"id":"/concepts/hooks-44","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`?workflow=<slug>` narrows; admin `?all=1` includes disabled."},"300":{"id":"/concepts/hooks-45","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`GET /api/hooks/{slug}`"},"301":{"id":"/concepts/hooks-46","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`get_hook`"},"302":{"id":"/concepts/hooks-47","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`POST /api/hooks`, `PATCH /api/hooks/{slug}`"},"303":{"id":"/concepts/hooks-48","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`upsert_hook`"},"304":{"id":"/concepts/hooks-49","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Admin."},"305":{"id":"/concepts/hooks-50","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`POST /api/hooks/{slug}/validate`"},"306":{"id":"/concepts/hooks-51","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"`validate_hook`"},"307":{"id":"/concepts/hooks-52","page_id":"/concepts/hooks","tags":[],"type":"text","url":"/concepts/hooks#api--mcp","content":"Admin readiness dry-run."},"308":{"id":"/concepts","page_id":"/concepts","type":"page","content":"Concepts","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts"},"309":{"id":"/concepts-0","page_id":"/concepts","tags":[],"type":"text","url":"/concepts","content":"A map of the core Runyard concepts and how they fit together."},"310":{"id":"/concepts-1","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#the-catalog","content":"The catalog"},"311":{"id":"/concepts-2","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#execution","content":"Execution"},"312":{"id":"/concepts-3","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#control","content":"Control"},"313":{"id":"/concepts-4","page_id":"/concepts","type":"heading","tags":[],"url":"/concepts#platform","content":"Platform"},"314":{"id":"/concepts-5","page_id":"/concepts","tags":[],"type":"text","url":"/concepts","content":"Runyard is a self-hosted control plane for agent runs. You install **workflows** into a catalog, start **runs** of those workflows from the API, MCP, web app, or a **schedule**, and **runners** claim and execute them. The durable company asks those runs work on are **work items** — tickets on the Work board. Anything that needs a human decision surfaces as an **approval** card, sensitive values live in the encrypted **secrets** store, and optional side effects after a run are handled by admin-defined **hooks**. Access is governed by scoped **tokens**, and every page in the Hub is a shareable **deep link**."},"315":{"id":"/concepts-6","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#the-catalog","content":"**Workflows** — the unit of the catalog: a named, versioned definition with input/output schemas whose source lives as immutable bundles in the Hub database."},"316":{"id":"/concepts-7","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#the-catalog","content":"**Agents, skills & knowledge** — shared, reusable building blocks (agent roles, skills, knowledge resources) that workflows reference."},"317":{"id":"/concepts-8","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Runs** — a single execution of a workflow: lifecycle statuses, preflight and run drafts, events, logs, artifacts, reruns, and promotion."},"318":{"id":"/concepts-9","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Work items** — tickets on the Work board: the durable unit of company work that runs attach to, with a human-legible kanban lifecycle and a per-run execution flow view."},"319":{"id":"/concepts-10","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Runners** — the machines that claim queued runs and execute them via the Smithers engine, with tags, capacity, and optional sandboxing."},"320":{"id":"/concepts-11","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#execution","content":"**Schedules** — cron or one-shot triggers that create ordinary runs on a cadence."},"321":{"id":"/concepts-12","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#control","content":"**Approvals** — declared human decisions: approval cards with an explicit ask, per-kind consequences, and optional timers with fallbacks."},"322":{"id":"/concepts-13","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#control","content":"**Hooks** — admin-defined post-run side effects (publish, push, webhook) that run after a run's gates pass and never fail a green run."},"323":{"id":"/concepts-14","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#platform","content":"**Tokens & scopes** — bearer-token auth with the `api`, `mcp`, `runner`, `approvals`, and `admin` scopes; browser sessions carry exactly a token's scopes."},"324":{"id":"/concepts-15","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#platform","content":"**Secrets** — an encrypted store whose values are only ever decrypted into a run's child process environment, never returned by the API."},"325":{"id":"/concepts-16","page_id":"/concepts","tags":[],"type":"text","url":"/concepts#platform","content":"**Deep links** — the shareable URL grammar of the Hub web app, plus the deep links the API returns in its payloads."},"326":{"id":"/concepts/metering","page_id":"/concepts/metering","type":"page","content":"Usage metering & budgets","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/metering"},"327":{"id":"/concepts/metering-0","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering","content":"Per-run model-call usage as a first-class streamed signal, hard spend budgets, and the metering gateway at the inference boundary."},"328":{"id":"/concepts/metering-1","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Usage records and the run aggregate"},"329":{"id":"/concepts/metering-2","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#the-fleet-rollup-get-apiusagesummary","content":"The fleet rollup: `GET /api/usage/summary`"},"330":{"id":"/concepts/metering-3","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#budgets","content":"Budgets"},"331":{"id":"/concepts/metering-4","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Capture paths: what is metered today"},"332":{"id":"/concepts/metering-5","page_id":"/concepts/metering","type":"heading","tags":[],"url":"/concepts/metering#selecting-gateway-metering","content":"Selecting gateway metering"},"333":{"id":"/concepts/metering-6","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering","content":"Every run durably records not just what it produced, but **what it consumed**. Each model call a run's child agents make is captured as a usage record, streamed as a run event while the run executes, aggregated onto the run, and included in terminal payloads — so dashboards, delegated callers, and budget enforcement all work off real numbers, never log scraping."},"334":{"id":"/concepts/metering-7","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"A usage record is one observed model call:"},"335":{"id":"/concepts/metering-8","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Records fold into the run's persisted aggregate the moment they arrive:"},"336":{"id":"/concepts/metering-9","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`costMicros` is micro-USD (1 000 000 = $1). When the provider reports the call's cost it is used verbatim (`costSource: \"provider\"`); otherwise the Hub estimates from a list-price table for well-known models (`costSource: \"price-table\"`) and records **no cost at all** for unknown models — totals are a floor, never a guess."},"337":{"id":"/concepts/metering-10","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Where usage appears:"},"338":{"id":"/concepts/metering-11","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`GET /api/runs` and `GET /api/runs/{id}` — the `usage` aggregate (and `budget` + computed `budgetStatus`) on every run object."},"339":{"id":"/concepts/metering-12","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`GET /api/runs/{id}/usage` — the aggregate, the budget, per-call records, `budgetStatus`, and `budgetStop`."},"340":{"id":"/concepts/metering-13","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`GET /api/usage/summary` — the windowed fleet rollup (below)."},"341":{"id":"/concepts/metering-14","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"`run.usage` events on the run's event stream and timeline, emitted in the same write that updates the aggregate."},"342":{"id":"/concepts/metering-15","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"Terminal response-endpoint payloads — `usage`, `budget`, and `budgetStop` fields, so delegated callers can bill or cap against real consumption."},"343":{"id":"/concepts/metering-16","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"MCP: `get_run_usage` and `get_usage_summary`, plus `get_run_status`/`list_runs` responses."},"344":{"id":"/concepts/metering-17","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"CLI: `runyard usage` (fleet rollup) and `runyard usage <runId>` (one run's detail)."},"345":{"id":"/concepts/metering-18","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#usage-records-and-the-run-aggregate","content":"The web app: a usage chip on run cards, spent-vs-limit budget pairing on run detail, and fleet-wide totals in `GET /api/dashboard` (`stats.usage`)."},"346":{"id":"/concepts/metering-19","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#the-fleet-rollup-get-apiusagesummary","content":"One call answers \"what is this deployment spending, and on what?\" for a time window (`?days=`, default 30, max 365):"},"347":{"id":"/concepts/metering-20","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#the-fleet-rollup-get-apiusagesummary","content":"`byWorkflow` is sorted by spend (highest first); `budgetStopped` counts runs that hit their budget inside the window. MCP: `get_usage_summary`; CLI: `runyard usage --days 7`. Totals follow the same floor semantics as everywhere else — unknown-model calls contribute tokens but no cost."},"348":{"id":"/concepts/metering-21","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"Run creation accepts an optional hard spend ceiling — as a top-level `budget` field or `input.budget`, on direct runs, negotiated runs, drafts, schedules, endpoint submissions, and reruns (reruns inherit the previous run's budget unless overridden):"},"349":{"id":"/concepts/metering-22","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"Budgets are hard stops, not advisories:"},"350":{"id":"/concepts/metering-23","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"**Before** each gateway-metered call, the Hub refuses to forward (`402`) if the aggregate has already reached the ceiling."},"351":{"id":"/concepts/metering-24","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"**After** every accepted usage record, the Hub re-evaluates; a breach emits `run.budget.exceeded&#x60; and terminates the run with the distinct terminal status &#x2A;*`budget_exceeded`** — never a generic `failed` — with the stop reason on `run.error` and `budgetStop`."},"352":{"id":"/concepts/metering-25","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"The runner observes the terminal status on its next poll and cancels the detached engine run, and the gateway refuses further calls from that run's token (`403`)."},"353":{"id":"/concepts/metering-26","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"An invalid budget is rejected with `400 budget_invalid` at creation (and surfaces as a preflight blocker in negotiation) — a requested cap is never silently dropped."},"354":{"id":"/concepts/metering-27","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"The CLI takes budgets as flags: `runyard run research --max-tokens 200000 --max-cost 2` (`--max-cost` is US dollars; the same flags work on `runyard preflight`)."},"355":{"id":"/concepts/metering-28","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"Every budgeted run also carries a computed &#x2A;*`budgetStatus`** — spent vs limit, per dimension — so no client re-derives the arithmetic:"},"356":{"id":"/concepts/metering-29","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#budgets","content":"`percentUsed` is the worst dimension (the one that will stop the run first) and `nearLimit` trips at 80%. The web run list shows a \"Budget 82% used\" chip on near-limit runs and \"Stopped at budget\" after a stop; the run detail page pairs spent / limit with the percentage. Runs that stopped on their budget appear in the needs-attention queue for 7 days so the recovery path (raise the budget, re-run) is visible, not archaeological."},"357":{"id":"/concepts/metering-30","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Usage is captured at the **inference boundary**, through two paths:"},"358":{"id":"/concepts/metering-31","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Path"},"359":{"id":"/concepts/metering-32","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Source label"},"360":{"id":"/concepts/metering-33","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Coverage"},"361":{"id":"/concepts/metering-34","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Key custody"},"362":{"id":"/concepts/metering-35","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Metering gateway"},"363":{"id":"/concepts/metering-36","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"`gateway`"},"364":{"id":"/concepts/metering-37","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Runs that select `metering: \"gateway\"` with the pi harness (`piModel`, `piBaseUrl`, `piApiKeyEnv`)"},"365":{"id":"/concepts/metering-38","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Provider key stays on the Hub; the child only holds a run-scoped gateway token"},"366":{"id":"/concepts/metering-39","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Runner-observed engine telemetry"},"367":{"id":"/concepts/metering-40","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"`runner`"},"368":{"id":"/concepts/metering-41","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Every claude / codex / pi CLI call the Smithers engine reports via its structured `TokenUsageReported` events"},"369":{"id":"/concepts/metering-42","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"Keys delivered per-run via the encrypted secretEnv channel (as before)"},"370":{"id":"/concepts/metering-43","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"**Gateway-metered runs** are pinned at claim time: the Hub mints a stateless per-run token, withholds the named provider key from the child environment entirely, and the runner materializes a per-run pi configuration whose *only* provider is the Hub's OpenAI-compatible gateway (`POST /api/gateway/openai/v1/chat/completions`; an Anthropic-shaped `/api/gateway/anthropic/v1/messages` is also served). The gateway authenticates the token, enforces the budget before forwarding, calls the run's configured upstream with the Hub-held key, streams the response back, and records usage from the provider's own response metadata (including streamed SSE usage frames)."},"371":{"id":"/concepts/metering-44","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"**Runner-observed runs** (the default, `metering: \"observed\"`) report the engine's per-call usage telemetry to `POST /api/runs/{id}/usage` with a stable per-call `requestId`, so replays after a runner restart never double-count. This is real, agent-reported usage from the engine's event stream — but the child still holds its own credentials (e.g. a Claude subscription token), so it is metered without being egress-locked."},"372":{"id":"/concepts/metering-45","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#capture-paths-what-is-metered-today","content":"**Not yet metered:** model calls that bypass both paths — e.g. a child agent calling a provider directly with an ad-hoc key from a tool script, or CLI paths the engine does not report usage for. Full egress locking (denying children any network path except the gateway) is a follow-up; the current sandbox shares the host network so the gateway pin is config-level, not network-level."},"373":{"id":"/concepts/metering-46","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#selecting-gateway-metering","content":"Gateway metering rides the same per-run harness selection surface as the pi custom-endpoint fields:"},"374":{"id":"/concepts/metering-47","page_id":"/concepts/metering","tags":[],"type":"text","url":"/concepts/metering#selecting-gateway-metering","content":"Preflight blocks the run unless the selection is complete (pi harness, model, endpoint URL, and the Hub-secret name for the key) — a run never launches half-pinned. The endpoint key must be stored as a Hub secret; with gateway metering it is decrypted only inside the Hub per call and never enters the child environment."},"375":{"id":"/concepts/runners","page_id":"/concepts/runners","type":"page","content":"Runners","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/runners"},"376":{"id":"/concepts/runners-0","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners","content":"The machines that claim and execute runs via the Smithers engine - registration, tags, capacity, health, and sandboxing."},"377":{"id":"/concepts/runners-1","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#registration-heartbeat-claim","content":"Registration, heartbeat, claim"},"378":{"id":"/concepts/runners-2","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#tags-and-execution-modes","content":"Tags and execution modes"},"379":{"id":"/concepts/runners-3","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#capacity-and-pool","content":"Capacity and pool"},"380":{"id":"/concepts/runners-4","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#sandboxing","content":"Sandboxing"},"381":{"id":"/concepts/runners-5","page_id":"/concepts/runners","type":"heading","tags":[],"url":"/concepts/runners#api--mcp","content":"API & MCP"},"382":{"id":"/concepts/runners-6","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners","content":"A **runner** is a machine that executes runs. Runners run the Runyard runner process, which claims queued runs from the Hub and executes each workflow via the **Smithers engine** (`smithers up <workflow> --input <json>`), spawning the local agent CLI as the worker. Nothing is faked: the agent runs on the runner's machine, and the Hub is the durable record — events stream back as run events, and outputs and traces are uploaded as artifacts."},"383":{"id":"/concepts/runners-7","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"Runners speak a small machine protocol authenticated with **runner-scoped tokens** (see Tokens & scopes):"},"384":{"id":"/concepts/runners-8","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"`POST /api/runners/register` — announce name, hostname, platform, version, tags, and capacity."},"385":{"id":"/concepts/runners-9","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"`POST /api/runners/{id}/heartbeat` — periodic liveness; a stale heartbeat marks the runner offline."},"386":{"id":"/concepts/runners-10","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"`GET /api/runners/{id}/next-run` — claim the next matching queued run. The claim payload carries everything the run needs, including decrypted secrets for that run only."},"387":{"id":"/concepts/runners-11","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#registration-heartbeat-claim","content":"Run lifecycle reports (`start`, events, `complete`, `fail`, artifact upload) are restricted to the runner that owns the run: the Hub checks the claiming token's identity, so one runner's token cannot touch another runner's runs."},"388":{"id":"/concepts/runners-12","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"Runners advertise **tags** (for example `local` on a workstation, `vps` on a shared remote pool). Two things match runs to runners:"},"389":{"id":"/concepts/runners-13","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"A workflow's `requiredRunnerTags` must all be present on the runner."},"390":{"id":"/concepts/runners-14","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"The caller's execution intent: `executionMode: \"local\" | \"remote\" | \"auto\"` (optionally a specific `runnerLocation`). `remote` targets the shared remote/VPS pool (default location `vps`); `auto` takes any matching runner."},"391":{"id":"/concepts/runners-15","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#tags-and-execution-modes","content":"Preflight checks this matching up front and reports `no_matching_runner` (blocker) or `runners_offline` (warning — the run would queue until one returns)."},"392":{"id":"/concepts/runners-16","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#capacity-and-pool","content":"Each runner declares a `capacity` (concurrent run slots) and reports its active runs; the Hub assigns work only to free slots. `GET /api/runners` returns every registered runner with heartbeat state, capacity, active slots, plus a pool summary — the same data the **Runners** page in the web app shows (`#runners`)."},"393":{"id":"/concepts/runners-17","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#sandboxing","content":"By default the runner executes workflows directly on its host. Setting `RUNNER_SANDBOX=bubblewrap` on the runner wraps each workflow *launch* in a generated Bubblewrap (`bwrap`) sandbox: the run's workspace is the only writable mount (bound at the same path inside and out), system directories are bound read-only, and the child gets a fresh workspace-local `HOME` — the host home directory, with its keys and credentials, is never mounted. Polling and control commands stay outside the sandbox. Installing `bwrap` is the deployer's responsibility; the runner verifies at startup that the sandbox actually works before claiming runs."},"394":{"id":"/concepts/runners-18","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Endpoint"},"395":{"id":"/concepts/runners-19","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"MCP tool"},"396":{"id":"/concepts/runners-20","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Notes"},"397":{"id":"/concepts/runners-21","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`GET /api/runners`"},"398":{"id":"/concepts/runners-22","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`list_runners`"},"399":{"id":"/concepts/runners-23","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runners, heartbeat state, capacity, slots, pool summary."},"400":{"id":"/concepts/runners-24","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`POST /api/runners/register`"},"401":{"id":"/concepts/runners-25","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"402":{"id":"/concepts/runners-26","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol (runner scope)."},"403":{"id":"/concepts/runners-27","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`POST /api/runners/{id}/heartbeat`"},"404":{"id":"/concepts/runners-28","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"405":{"id":"/concepts/runners-29","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol."},"406":{"id":"/concepts/runners-30","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`GET /api/runners/{id}/next-run`"},"407":{"id":"/concepts/runners-31","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"408":{"id":"/concepts/runners-32","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol; claims the next run."},"409":{"id":"/concepts/runners-33","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"`POST /api/runs/{id}/start` / `/complete` / `/fail` / `/events` / `/artifacts`"},"410":{"id":"/concepts/runners-34","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"—"},"411":{"id":"/concepts/runners-35","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"Runner protocol; run ownership enforced."},"412":{"id":"/concepts/runners-36","page_id":"/concepts/runners","tags":[],"type":"text","url":"/concepts/runners#api--mcp","content":"The runner protocol endpoints intentionally have no MCP tools — they are Hub↔runner machinery, not an operator surface."},"413":{"id":"/concepts/runs","page_id":"/concepts/runs","type":"page","content":"Runs","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/runs"},"414":{"id":"/concepts/runs-0","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs","content":"The run lifecycle, preflight and run drafts, events and artifacts, reruns, and promotion."},"415":{"id":"/concepts/runs-1","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#lifecycle","content":"Lifecycle"},"416":{"id":"/concepts/runs-2","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"Paused runs (recoverable interruptions)"},"417":{"id":"/concepts/runs-3","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#failure-classes","content":"Failure classes"},"418":{"id":"/concepts/runs-4","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#usage-and-budgets","content":"Usage and budgets"},"419":{"id":"/concepts/runs-5","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#the-needs-attention-queue","content":"The needs-attention queue"},"420":{"id":"/concepts/runs-6","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"Preflight and run drafts (negotiation)"},"421":{"id":"/concepts/runs-7","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#events-timeline-logs-artifacts","content":"Events, timeline, logs, artifacts"},"422":{"id":"/concepts/runs-8","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#reruns-and-promotion","content":"Reruns and promotion"},"423":{"id":"/concepts/runs-9","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#response-endpoints","content":"Response endpoints"},"424":{"id":"/concepts/runs-10","page_id":"/concepts/runs","type":"heading","tags":[],"url":"/concepts/runs#api--mcp","content":"API & MCP"},"425":{"id":"/concepts/runs-11","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs","content":"A **run** is a single execution of a workflow with a JSON input. Runs are created from the API, MCP, web app, CLI, a schedule, or a workflow endpoint; a runner claims each queued run and executes it, streaming events, logs, and artifacts back to the Hub as the durable record."},"426":{"id":"/concepts/runs-12","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Status"},"427":{"id":"/concepts/runs-13","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Meaning"},"428":{"id":"/concepts/runs-14","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`waiting_approval`"},"429":{"id":"/concepts/runs-15","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Held for a human decision before entering the queue (see Approvals). Never times out — waiting cannot fail a run."},"430":{"id":"/concepts/runs-16","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`queued`"},"431":{"id":"/concepts/runs-17","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Ready for a matching runner to claim."},"432":{"id":"/concepts/runs-18","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`assigned`"},"433":{"id":"/concepts/runs-19","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Claimed by a runner, not yet started."},"434":{"id":"/concepts/runs-20","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`running`"},"435":{"id":"/concepts/runs-21","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Executing on the runner."},"436":{"id":"/concepts/runs-22","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`paused`"},"437":{"id":"/concepts/runs-23","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Parked on a recoverable external interruption (provider credits or quota exhausted, or an operator pause). Non-terminal: the run keeps its engine checkpoint, frees its runner slot, is never reaped, and waits for resume or cancel."},"438":{"id":"/concepts/runs-24","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`succeeded`"},"439":{"id":"/concepts/runs-25","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Finished with outputs."},"440":{"id":"/concepts/runs-26","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`cancelled`"},"441":{"id":"/concepts/runs-27","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Stopped by an operator or a rejected approval — a human \"no\" is a decision, not a failure."},"442":{"id":"/concepts/runs-28","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"`failed` (+ classes)"},"443":{"id":"/concepts/runs-29","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Terminal failure; see failure classes below."},"444":{"id":"/concepts/runs-30","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#lifecycle","content":"Terminal states are final: late reports racing a terminal state are absorbed idempotently rather than overwriting the first decision."},"445":{"id":"/concepts/runs-31","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"When execution is interrupted by a condition a human can fix — the classic case is **the provider account ran out of credits** — the run parks as `paused` instead of failing. Pause metadata lives on `run.pause`:"},"446":{"id":"/concepts/runs-32","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**How runs pause.** The metering gateway pauses a gateway-metered run when the upstream provider answers with a credit/quota-exhaustion response (e.g. HTTP 402) — a structured signal at the inference boundary. The runner pauses a run whose engine failure text clearly means exhausted credits/quota (today Smithers 0.22 exposes no structured pause/credit event, so this path classifies the engine's error text; it will sharpen as engines emit richer signals). Operators can pause explicitly via `POST /api/runs/{id}/pause` (`pause_run`, `runyard pause`)."},"447":{"id":"/concepts/runs-33","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**What paused means.** The run releases its runner slot (a parked run never occupies capacity), keeps its `runner_id` so resume lands on the runner holding the local engine checkpoint, and is exempt from liveness/stall/deadline reaping. `run.paused` / `run.resumed` timeline events record the transitions."},"448":{"id":"/concepts/runs-34","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**Resume.** `POST /api/runs/{id}/resume` (`resume_run`, `runyard resume`) re-queues the *same* run. With a recorded checkpoint it continues via the engine's resume (`smithers up --resume`); without one it re-runs from scratch and the response (`resume.strategy: \"rerun_from_scratch\"`) plus the run timeline say so explicitly. Cancel still works from `paused`."},"449":{"id":"/concepts/runs-35","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**Resume strategies.** The resume body optionally forces a strategy: `{\"strategy\": \"rerun_from_scratch\"}` discards the recorded checkpoint *and* clears the runner pin so any live runner can take the run (`runyard resume --from-scratch`, the web \"Restart from scratch\" button); `{\"strategy\": \"smithers_resume\"}` insists on the checkpoint and answers `409` when none is recorded. Omitted, the strategy resolves automatically."},"450":{"id":"/concepts/runs-36","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**Offline checkpoint runner.** A checkpointed resume only executes once the runner holding the checkpoint claims it. If that runner is offline, the resume still succeeds but the response carries a `warning` (and the `run.resumed` event records it): the run stays queued until the runner reconnects, or you resume again with `rerun_from_scratch` to run anywhere."},"451":{"id":"/concepts/runs-37","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**Resume failure.** If the runner cannot find the recorded checkpoint in its local `.smithers` state (state cleaned, workspace replaced), it does **not** hang or fake a timeout: it emits `runner.resume_checkpoint_missing` and re-parks the run as `paused` with `reason: \"resume_failed\"` and the stale checkpoint dropped, so the next resume honestly re-runs from scratch. (The engine validates `--resume` inside its detached child, so the Hub runner verifies the checkpoint with `smithers inspect` *before* launching.)"},"452":{"id":"/concepts/runs-38","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#paused-runs-recoverable-interruptions","content":"**Not a budget stop.** `budget_exceeded` remains a distinct *terminal* status for the Hub's own hard spend ceiling; a budget breach is never converted into a pause."},"453":{"id":"/concepts/runs-39","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#failure-classes","content":"Failures are classified into specific terminal statuses so operators can tell config problems from real failures: `failed` (generic), `blocked_by_gate` (a verification gate failed), `blocked_by_preflight` (the run could never start as configured), `provider_limited` (rate limits/quota), `timed_out`, `invalid_output` (schema mismatch), `infra_unavailable` (network/runner infrastructure), `needs_human`, and `budget_exceeded` (the run's metered usage reached its spend budget and it was hard-stopped)."},"454":{"id":"/concepts/runs-40","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#usage-and-budgets","content":"Runs also meter the model calls they consume: per-call usage records stream as `run.usage` events and aggregate onto the run as `usage` (`totalTokens`, `costMicros`, `byModel`, ...), and run creation accepts an optional `budget: { maxTokens?, maxCostMicros? }` hard ceiling. Budgeted runs additionally carry a computed `budgetStatus` (spent vs limit, remaining, percent used, `nearLimit` at 80%) in list and detail payloads. See Usage metering & budgets for the data model, the fleet rollup (`GET /api/usage/summary`), the metering gateway, and budget enforcement."},"455":{"id":"/concepts/runs-41","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#the-needs-attention-queue","content":"`GET /api/runs/attention` (`list_attention_runs`, `runyard attention`) returns every run whose next step is a human action, grouped with counts:"},"456":{"id":"/concepts/runs-42","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#the-needs-attention-queue","content":"**`paused`** — resume them once the interruption is fixed;"},"457":{"id":"/concepts/runs-43","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#the-needs-attention-queue","content":"**`waitingApproval`** — a decision is pending on an approval card;"},"458":{"id":"/concepts/runs-44","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#the-needs-attention-queue","content":"**`budgetStopped`** — hit their spend ceiling in the last 7 days; raise the budget and re-run to finish the work."},"459":{"id":"/concepts/runs-45","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#the-needs-attention-queue","content":"`counts` also includes `pendingApprovals` (open approval cards). The web Home view renders this as a triage strip above the runs list with resume/review/inspect actions inline; it disappears entirely when nothing needs a human. `GET /api/runs?status=paused` (or any other status) remains the raw filter underneath."},"460":{"id":"/concepts/runs-46","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"Before anything is enqueued, Runyard can run a **deterministic preflight**: schema checks on required input fields, runner/tag availability, secret presence, hook eligibility, and workflow source resolution. The result is `ready`, `needs_input` (with `questions[]` the caller can answer), or `blocked` (with `blockers[]` only an operator can fix), plus warnings, suggested defaults, and a `nextAction` hint."},"461":{"id":"/concepts/runs-47","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"Three ways to use it:"},"462":{"id":"/concepts/runs-48","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"`POST /api/workflows/{id}/preflight` — stateless report, nothing created."},"463":{"id":"/concepts/runs-49","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"`POST /api/workflows/{id}/run` with `negotiate: true` — enqueue only when ready; otherwise the negotiation state and a saved draft come back instead of a doomed run."},"464":{"id":"/concepts/runs-50","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"**Run drafts** — a draft is a proposed run that has *not* been enqueued. Create it, patch its input to answer questions (each patch re-preflights), then submit; submit re-preflights and returns 202 with the run only when ready (422 `needs_input` / 409 `blocked` otherwise)."},"465":{"id":"/concepts/runs-51","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#preflight-and-run-drafts-negotiation","content":"`input.title` is recommended for agent-created runs: a short human-readable title used in run lists, approval cards, and handoff."},"466":{"id":"/concepts/runs-52","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#events-timeline-logs-artifacts","content":"Runners append structured **events** as the run progresses; `GET /api/runs/{id}/events/stream` serves them live over SSE and `GET /api/runs/{id}/timeline` merges status transitions, events, and artifacts into one ascending feed (with `since`/`limit` paging). Log lines are at `/logs`, a condensed log summary and diagnostics at `/diagnostics`, and uploaded **artifacts** (outputs, traces, files) at `/artifacts`, downloadable by artifact id."},"467":{"id":"/concepts/runs-53","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#reruns-and-promotion","content":"**Rerun** — `POST /api/runs/{id}/rerun` creates a linked new run with the same input, optionally edited."},"468":{"id":"/concepts/runs-54","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#reruns-and-promotion","content":"**Promotion** — for runs that mutated an isolated git worktree, `POST /api/runs/{id}/promote` merges the successful run's work into its target branch, runs gates, pushes, and cleans up the branch/worktree. Merging to the default branch always goes through promotion, never through a hook."},"469":{"id":"/concepts/runs-55","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#response-endpoints","content":"A run request may include `responseEndpoint: {type: \"http\" | \"telegram\", config}` so the terminal-state reply is delivered to the caller when the run finishes. Delivery state is reported in `responseEndpoints[]` on `GET /api/runs/{id}`; polling that endpoint remains the canonical fallback."},"470":{"id":"/concepts/runs-56","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"Endpoint"},"471":{"id":"/concepts/runs-57","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"MCP tool"},"472":{"id":"/concepts/runs-58","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/workflows/{id}/run`"},"473":{"id":"/concepts/runs-59","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`run_workflow`"},"474":{"id":"/concepts/runs-60","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/workflows/{id}/preflight`"},"475":{"id":"/concepts/runs-61","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`preflight_workflow`"},"476":{"id":"/concepts/runs-62","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET/POST /api/run-drafts`, `GET/PATCH /api/run-drafts/{id}`, `POST .../submit`, `POST .../discard`"},"477":{"id":"/concepts/runs-63","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`list_run_drafts`, `create_run_draft`, `get_run_draft`, `update_run_draft`, `submit_run_draft`, `discard_run_draft`"},"478":{"id":"/concepts/runs-64","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs`, `GET /api/runs/{id}`"},"479":{"id":"/concepts/runs-65","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`list_runs`, `get_run_status`"},"480":{"id":"/concepts/runs-66","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs/attention`"},"481":{"id":"/concepts/runs-67","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`list_attention_runs`"},"482":{"id":"/concepts/runs-68","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs/{id}/usage`, `GET /api/usage/summary`"},"483":{"id":"/concepts/runs-69","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_run_usage`, `get_usage_summary`"},"484":{"id":"/concepts/runs-70","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs/{id}/events`, `/timeline`, `/diagnostics`, `/logs`"},"485":{"id":"/concepts/runs-71","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_run_events`, `get_run_timeline`, `get_run_diagnostics`, `get_run_logs`"},"486":{"id":"/concepts/runs-72","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/runs/{id}/artifacts`, `GET /api/artifacts`, `GET /api/artifacts/{id}/download`"},"487":{"id":"/concepts/runs-73","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_run_artifacts`, `search_artifacts`, `download_artifact`"},"488":{"id":"/concepts/runs-74","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/cancel`"},"489":{"id":"/concepts/runs-75","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`cancel_run`"},"490":{"id":"/concepts/runs-76","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/pause`"},"491":{"id":"/concepts/runs-77","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`pause_run`"},"492":{"id":"/concepts/runs-78","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/resume`"},"493":{"id":"/concepts/runs-79","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`resume_run`"},"494":{"id":"/concepts/runs-80","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/rerun`"},"495":{"id":"/concepts/runs-81","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`rerun_workflow_run`"},"496":{"id":"/concepts/runs-82","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`POST /api/runs/{id}/promote`"},"497":{"id":"/concepts/runs-83","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`promote_run`"},"498":{"id":"/concepts/runs-84","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`GET /api/dashboard`"},"499":{"id":"/concepts/runs-85","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"`get_dashboard`"},"500":{"id":"/concepts/runs-86","page_id":"/concepts/runs","tags":[],"type":"text","url":"/concepts/runs#api--mcp","content":"The `start`/`complete`/`fail`/event-append and artifact-upload endpoints under `/api/runs/{id}` are the runner protocol (runner-scoped tokens, run ownership enforced) — see Runners."},"501":{"id":"/concepts/schedules","page_id":"/concepts/schedules","type":"page","content":"Schedules","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/schedules"},"502":{"id":"/concepts/schedules-0","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules","content":"Cron and one-shot triggers that create ordinary workflow runs on a cadence."},"503":{"id":"/concepts/schedules-1","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#cron-expressions-and-timezones","content":"Cron expressions and timezones"},"504":{"id":"/concepts/schedules-2","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#one-shot-schedules","content":"One-shot schedules"},"505":{"id":"/concepts/schedules-3","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#enable-disable-run-now","content":"Enable, disable, run now"},"506":{"id":"/concepts/schedules-4","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#what-a-fire-produces","content":"What a fire produces"},"507":{"id":"/concepts/schedules-5","page_id":"/concepts/schedules","type":"heading","tags":[],"url":"/concepts/schedules#api--mcp","content":"API & MCP"},"508":{"id":"/concepts/schedules-6","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules","content":"A **schedule** runs a workflow automatically: either recurring on a **cron** cadence or once at a fixed **runAt** timestamp. Each fire creates a completely ordinary run with the schedule's stored input — it appears in run lists, honors the workflow's approval policy, and is executed by whatever runner matches."},"509":{"id":"/concepts/schedules-7","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#cron-expressions-and-timezones","content":"Runyard uses standard **5-field cron** (`minute hour day-of-month month day-of-week`) with ranges (`a-b`), lists (`a,b,c`), steps (`*/n`, `a-b/n`), month/weekday names (`jan..dec`, `sun..sat`), and the aliases `@yearly`, `@monthly`, `@weekly`, `@daily`, `@hourly`. There is no seconds field — the Hub ticks at minute granularity."},"510":{"id":"/concepts/schedules-8","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#cron-expressions-and-timezones","content":"Every schedule has an **IANA timezone** (default `UTC`); the expression is evaluated against wall-clock time in that zone, so DST shifts are honored."},"511":{"id":"/concepts/schedules-9","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#cron-expressions-and-timezones","content":"The preview returns a human-readable description plus the next fire instants — nothing is created."},"512":{"id":"/concepts/schedules-10","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#one-shot-schedules","content":"Provide `runAt` (an ISO timestamp) instead of `cron` to fire exactly once. A schedule takes one or the other."},"513":{"id":"/concepts/schedules-11","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#enable-disable-run-now","content":"**Disable** stops a schedule from firing without deleting it; **enable** resumes the cadence. Both are admin actions."},"514":{"id":"/concepts/schedules-12","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#enable-disable-run-now","content":"**Run now** fires the schedule immediately without changing its cadence — useful for testing input before the next scheduled fire."},"515":{"id":"/concepts/schedules-13","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#enable-disable-run-now","content":"Each schedule tracks `nextRunAt`, `lastRunAt`, the last run id, and the last fire status, all visible on the Schedules page (`#schedules`) and in the API."},"516":{"id":"/concepts/schedules-14","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#what-a-fire-produces","content":"Every fire dispatches a normal run whose origin identifies the schedule:"},"517":{"id":"/concepts/schedules-15","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#what-a-fire-produces","content":"(`trigger` is `ticker` for cadence fires, `manual` for run-now.) The run also gets a `run.scheduled` event recording the schedule, cron, and timezone. If the workflow's approval policy requires it, the run starts in `waiting_approval` like any other run."},"518":{"id":"/concepts/schedules-16","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Endpoint"},"519":{"id":"/concepts/schedules-17","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"MCP tool"},"520":{"id":"/concepts/schedules-18","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Notes"},"521":{"id":"/concepts/schedules-19","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`GET /api/schedules`"},"522":{"id":"/concepts/schedules-20","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`list_schedules`"},"523":{"id":"/concepts/schedules-21","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Includes next/last run and a readable preview."},"524":{"id":"/concepts/schedules-22","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`GET /api/schedules/preview`"},"525":{"id":"/concepts/schedules-23","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`preview_schedule`"},"526":{"id":"/concepts/schedules-24","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Query: `cron`, `timezone`."},"527":{"id":"/concepts/schedules-25","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`GET /api/schedules/{id}`"},"528":{"id":"/concepts/schedules-26","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`get_schedule`"},"529":{"id":"/concepts/schedules-27","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules`"},"530":{"id":"/concepts/schedules-28","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`create_schedule`"},"531":{"id":"/concepts/schedules-29","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin. Body: `name`, `workflowSlug`, `cron` or `runAt`, `timezone`, `input`, `enabled`."},"532":{"id":"/concepts/schedules-30","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`PATCH /api/schedules/{id}`"},"533":{"id":"/concepts/schedules-31","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`update_schedule`"},"534":{"id":"/concepts/schedules-32","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"535":{"id":"/concepts/schedules-33","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules/{id}/enable`"},"536":{"id":"/concepts/schedules-34","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`enable_schedule`"},"537":{"id":"/concepts/schedules-35","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"538":{"id":"/concepts/schedules-36","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules/{id}/disable`"},"539":{"id":"/concepts/schedules-37","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`disable_schedule`"},"540":{"id":"/concepts/schedules-38","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"541":{"id":"/concepts/schedules-39","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`POST /api/schedules/{id}/run-now`"},"542":{"id":"/concepts/schedules-40","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`run_schedule_now`"},"543":{"id":"/concepts/schedules-41","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Fires immediately; rate-limited."},"544":{"id":"/concepts/schedules-42","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`DELETE /api/schedules/{id}`"},"545":{"id":"/concepts/schedules-43","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"`delete_schedule`"},"546":{"id":"/concepts/schedules-44","page_id":"/concepts/schedules","tags":[],"type":"text","url":"/concepts/schedules#api--mcp","content":"Admin."},"547":{"id":"/concepts/secrets","page_id":"/concepts/secrets","type":"page","content":"Secrets","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/secrets"},"548":{"id":"/concepts/secrets-0","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets","content":"The encrypted secret store - admin-managed, listable by name only, delivered to runs at claim time and never returned by the API."},"549":{"id":"/concepts/secrets-1","page_id":"/concepts/secrets","type":"heading","tags":[],"url":"/concepts/secrets#management-admin-only","content":"Management (admin only)"},"550":{"id":"/concepts/secrets-2","page_id":"/concepts/secrets","type":"heading","tags":[],"url":"/concepts/secrets#how-runs-get-secrets","content":"How runs get secrets"},"551":{"id":"/concepts/secrets-3","page_id":"/concepts/secrets","type":"heading","tags":[],"url":"/concepts/secrets#api--mcp","content":"API & MCP"},"552":{"id":"/concepts/secrets-4","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets","content":"Runyard keeps reusable credentials (API keys, deploy tokens) in an **encrypted secret store** on the Hub. Values are encrypted at rest, and the API is deliberately one-way: you can list secret *names and metadata*, set a value, and delete one — **values are never returned** by any list or read endpoint, to any scope."},"553":{"id":"/concepts/secrets-5","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#management-admin-only","content":"Secret names are env-var-safe identifiers, because that is exactly how they are delivered. The whole feature is gated on the store being enabled (an encryption key configured on the Hub); when it is not, secret-dependent runs and hooks report that configuration is required instead of failing obscurely."},"554":{"id":"/concepts/secrets-6","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"A run receives the union of:"},"555":{"id":"/concepts/secrets-7","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"the workflow's declared `workflow.secrets` list, and"},"556":{"id":"/concepts/secrets-8","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"the run input's `input.secretNames` list."},"557":{"id":"/concepts/secrets-9","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Preflight verifies every named secret exists before the run is enqueued. At **claim time** — when a runner claims the run — the Hub decrypts exactly those named secrets into an env map that rides the claim payload, and the runner injects them **only into the workflow's child process environment**. That is the sole path a plaintext value ever leaves the store:"},"558":{"id":"/concepts/secrets-10","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Secrets never appear in run events, logs, or the run record."},"559":{"id":"/concepts/secrets-11","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Stored secret values are additionally scrubbed from run output and artifacts before they are persisted."},"560":{"id":"/concepts/secrets-12","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Payload fields with credential-like names are redacted in approval cards and other presentation surfaces."},"561":{"id":"/concepts/secrets-13","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#how-runs-get-secrets","content":"Other consumers reference secrets **by name only**: hook profiles declare `secretNames`, and their readiness checks report missing *names*, never values."},"562":{"id":"/concepts/secrets-14","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Endpoint"},"563":{"id":"/concepts/secrets-15","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"MCP tool"},"564":{"id":"/concepts/secrets-16","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Notes"},"565":{"id":"/concepts/secrets-17","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`GET /api/secrets`"},"566":{"id":"/concepts/secrets-18","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`list_secrets`"},"567":{"id":"/concepts/secrets-19","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Admin. Names and metadata only."},"568":{"id":"/concepts/secrets-20","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`PUT /api/secrets/{key}`"},"569":{"id":"/concepts/secrets-21","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`set_secret`"},"570":{"id":"/concepts/secrets-22","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Admin. `{value, description?}`."},"571":{"id":"/concepts/secrets-23","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`DELETE /api/secrets/{key}`"},"572":{"id":"/concepts/secrets-24","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"`delete_secret`"},"573":{"id":"/concepts/secrets-25","page_id":"/concepts/secrets","tags":[],"type":"text","url":"/concepts/secrets#api--mcp","content":"Admin."},"574":{"id":"/concepts/tokens-and-scopes","page_id":"/concepts/tokens-and-scopes","type":"page","content":"Tokens & Scopes","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/tokens-and-scopes"},"575":{"id":"/concepts/tokens-and-scopes-0","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes","content":"Bearer-token authentication, the scope vocabulary and presets (including read-only), the bootstrap token, and how browser and Telegram sessions work."},"576":{"id":"/concepts/tokens-and-scopes-1","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#scopes","content":"Scopes"},"577":{"id":"/concepts/tokens-and-scopes-2","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#presets","content":"Presets"},"578":{"id":"/concepts/tokens-and-scopes-3","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#bootstrap-token","content":"Bootstrap token"},"579":{"id":"/concepts/tokens-and-scopes-4","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#browser-sessions","content":"Browser sessions"},"580":{"id":"/concepts/tokens-and-scopes-5","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#telegram-webapp-sessions","content":"Telegram WebApp sessions"},"581":{"id":"/concepts/tokens-and-scopes-6","page_id":"/concepts/tokens-and-scopes","type":"heading","tags":[],"url":"/concepts/tokens-and-scopes#api--mcp","content":"API & MCP"},"582":{"id":"/concepts/tokens-and-scopes-7","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes","content":"Every Runyard API call is authenticated with a **bearer access token**:"},"583":{"id":"/concepts/tokens-and-scopes-8","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes","content":"`GET /api/me` (or the `whoami` MCP tool) describes the token you are holding: its name and granted scopes. Tokens are issued and revoked by admins and may carry an expiry."},"584":{"id":"/concepts/tokens-and-scopes-9","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"A token carries one or more scopes; each endpoint declares which scopes may call it."},"585":{"id":"/concepts/tokens-and-scopes-10","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","content":"Scope"},"586":{"id":"/concepts/tokens-and-scopes-11","page_id":"/concepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#scopes","cont