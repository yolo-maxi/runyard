ontent":"Kinds"},"90":{"id":"/concepts/approvals-2","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#the-ask-contract","content":"The ask contract"},"91":{"id":"/concepts/approvals-3","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#status-and-resolution","content":"Status and resolution"},"92":{"id":"/concepts/approvals-4","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#timed-approvals-with-fallback","content":"Timed approvals with fallback"},"93":{"id":"/concepts/approvals-5","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#per-kind-consequences","content":"Per-kind consequences"},"94":{"id":"/concepts/approvals-6","page_id":"/concepts/approvals","type":"heading","tags":[],"url":"/concepts/approvals#api--mcp","content":"API & MCP"},"95":{"id":"/concepts/approvals-7","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals","content":"An **approval** is a declared question with a declared consequence, presented to a human as a card in the web app, over Telegram, or through the API/MCP. Cards can hold a run before it executes (`waiting_approval`), pause a workflow mid-run at an engine gate, or simply record a decision. A run held on an approval waits indefinitely — waiting never fails it."},"96":{"id":"/concepts/approvals-8","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Kind"},"97":{"id":"/concepts/approvals-9","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"What it represents"},"98":{"id":"/concepts/approvals-10","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`workflow_gate`"},"99":{"id":"/concepts/approvals-11","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A workflow paused at a gate; the decision releases or denies that step."},"100":{"id":"/concepts/approvals-12","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`escalation`"},"101":{"id":"/concepts/approvals-13","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Autonomous recovery gave up; a human records how to proceed."},"102":{"id":"/concepts/approvals-14","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`side_effect`"},"103":{"id":"/concepts/approvals-15","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"A gated side effect asking permission before it runs."},"104":{"id":"/concepts/approvals-16","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"`custom`"},"105":{"id":"/concepts/approvals-17","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#kinds","content":"Any ad-hoc approval raised via the API."},"106":{"id":"/concepts/approvals-18","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"The creator of a card states the ask up front, and every surface renders it verbatim:"},"107":{"id":"/concepts/approvals-19","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`action` — what exactly happens on approve."},"108":{"id":"/concepts/approvals-20","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`reason` — why a human is needed."},"109":{"id":"/concepts/approvals-21","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`audience` — who is asked: `operators` (default) or `admins`."},"110":{"id":"/concepts/approvals-22","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"`options` — optional named choices (up to 8)."},"111":{"id":"/concepts/approvals-23","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#the-ask-contract","content":"An ask without both `action` and `reason` is treated as absent; such cards fall back to a heuristic ask explicitly marked `derived: true`, so a guessed question is never presented as an authored one."},"112":{"id":"/concepts/approvals-24","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"A card's `status` is only ever `pending` or `resolved`. What was decided and by what live in separate fields:"},"113":{"id":"/concepts/approvals-25","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Field"},"114":{"id":"/concepts/approvals-26","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"Values"},"115":{"id":"/concepts/approvals-27","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolution`"},"116":{"id":"/concepts/approvals-28","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`approved`, `rejected`, `changes_requested`, `superseded` (the run ended first), or `option:<id>`"},"117":{"id":"/concepts/approvals-29","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`resolvedVia`"},"118":{"id":"/concepts/approvals-30","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#status-and-resolution","content":"`human`, `fallback_timer` (autopilot), `engine` (decided on the runner), `policy` (auto-approved by policy), `system`"},"119":{"id":"/concepts/approvals-31","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"By default a card is blocking: nothing happens until someone decides. Supplying `timeoutMs` or `timeoutAt` at creation makes it a **timed approval**:"},"120":{"id":"/concepts/approvals-32","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"With a `fallback` decision (`approve` or `reject`), the configured decision is applied automatically when the timer elapses, recorded with `resolvedVia: \"fallback_timer\"`."},"121":{"id":"/concepts/approvals-33","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#timed-approvals-with-fallback","content":"Without a fallback, the elapsed card is flagged `fallback_required` and keeps waiting — no decision is invented, and the linked run is never failed by an elapsed timer."},"122":{"id":"/concepts/approvals-34","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"Every card answers \"what will my decision do\" honestly, computed from what resolving actually performs:"},"123":{"id":"/concepts/approvals-35","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`workflow_gate`** — approving a card holding a `waiting_approval` run releases it; approving a mid-run gate applies the decision to the paused workflow on the runner, which resumes past the gate. Reject/changes-requested cancel a held run, or take the workflow's own deny path mid-run."},"124":{"id":"/concepts/approvals-36","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`escalation`** — the run already ended: any decision records the call but does not restart the run (re-run it from the run page)."},"125":{"id":"/concepts/approvals-37","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`side_effect`** — approve allows the gated side effect; reject or changes-requested skip it. The run's completed work is unchanged either way."},"126":{"id":"/concepts/approvals-38","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"**`custom`** — approving a held run releases it to the queue; reject/changes-requested cancel it. On a card without a held run, the decision is simply recorded."},"127":{"id":"/concepts/approvals-39","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#per-kind-consequences","content":"The API exposes these as `whatHappensIfApproved` / `whatHappensIfRejected` / `whatHappensIfChangesRequested` / `whatHappensIfIgnored` in each card's `context`, alongside the ask, the linked run, and deep links."},"128":{"id":"/concepts/approvals-40","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Endpoint"},"129":{"id":"/concepts/approvals-41","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"MCP tool"},"130":{"id":"/concepts/approvals-42","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Notes"},"131":{"id":"/concepts/approvals-43","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals`"},"132":{"id":"/concepts/approvals-44","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`list_approvals`, `list_pending_approvals`"},"133":{"id":"/concepts/approvals-45","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`?status=pending\\|resolved`."},"134":{"id":"/concepts/approvals-46","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`GET /api/approvals/{id}`"},"135":{"id":"/concepts/approvals-47","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`get_approval`"},"136":{"id":"/concepts/approvals-48","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Full card with context."},"137":{"id":"/concepts/approvals-49","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals`"},"138":{"id":"/concepts/approvals-50","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`create_approval`"},"139":{"id":"/concepts/approvals-51","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`{title, description, runId?, ask, timeoutMs?/timeoutAt?, fallback?}`."},"140":{"id":"/concepts/approvals-52","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/approve`"},"141":{"id":"/concepts/approvals-53","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`approve_run`"},"142":{"id":"/concepts/approvals-54","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Takes an approval id, not a run id."},"143":{"id":"/concepts/approvals-55","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/reject`"},"144":{"id":"/concepts/approvals-56","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`reject_run`"},"145":{"id":"/concepts/approvals-57","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"A held run is cancelled, never failed."},"146":{"id":"/concepts/approvals-58","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`POST /api/approvals/{id}/request-changes`"},"147":{"id":"/concepts/approvals-59","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"`request_changes_run`"},"148":{"id":"/concepts/approvals-60","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Comment describes the requested changes."},"149":{"id":"/concepts/approvals-61","page_id":"/concepts/approvals","tags":[],"type":"text","url":"/concepts/approvals#api--mcp","content":"Resolving approvals requires the `api`, `mcp`, or `approvals` scope; Telegram WebApp sessions are approvals-scoped by design (see Tokens & scopes)."},"150":{"id":"/concepts/boards","page_id":"/concepts/boards","type":"page","content":"Boards","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/boards"},"151":{"id":"/concepts/boards-0","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"Durable configured views over work items — the software-factory surfaces that workflows keep up to date."},"152":{"id":"/concepts/boards-1","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#shape","content":"Shape"},"153":{"id":"/concepts/boards-2","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#runs-move-tickets","content":"Runs move tickets"},"154":{"id":"/concepts/boards-3","page_id":"/concepts/boards","type":"heading","tags":[],"url":"/concepts/boards#api--mcp","content":"API & MCP"},"155":{"id":"/concepts/boards-4","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"A **board** is a durable, configured view over work items: lane definitions in operator language, an optional project scope, and the workflows it suggests launching from tickets. Boards make the Work surface (`/app#work`) a **software factory**: tickets are the durable asks, workflows execute them, and linked runs move tickets across the board as they progress."},"156":{"id":"/concepts/boards-5","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards","content":"Every deployment seeds one default board on first boot — &#x2A;\"\\<instance name> Factory\"* (slug `runyard` by default) — so the Work view is a configured product surface from day one, never an empty shell. More boards can be created for product, infra, docs, or release trains."},"157":{"id":"/concepts/boards-6","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`lanes`** group the ten lifecycle statuses into columns; the default is the standard seven-column factory layout (Needs triage · Plan next · Ready to start · In motion · Needs decision · Review / approve · Done). Every lane needs an `id`, `label`, and at least one valid status."},"158":{"id":"/concepts/boards-7","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`project`** scopes membership: `\"\"` means all work items; a project name shows only that project's tickets."},"159":{"id":"/concepts/boards-8","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`defaultWorkflows`** lists workflow slugs the board suggests for launching from its tickets."},"160":{"id":"/concepts/boards-9","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#shape","content":"**`isDefault`** marks the board the web app opens at `/app#work`."},"161":{"id":"/concepts/boards-10","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Linked runs keep the board honest without an operator shepherding every card. The mapping is deliberately conservative:"},"162":{"id":"/concepts/boards-11","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Linked run becomes"},"163":{"id":"/concepts/boards-12","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Ticket moves to"},"164":{"id":"/concepts/boards-13","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Notes"},"165":{"id":"/concepts/boards-14","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`queued` / `assigned` / `running`"},"166":{"id":"/concepts/boards-15","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`running`"},"167":{"id":"/concepts/boards-16","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Including a `blocked` ticket — relaunching is the unblock signal (the stale `blockedReason` is cleared)."},"168":{"id":"/concepts/boards-17","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`waiting_approval` / `paused` / `budget_exceeded`"},"169":{"id":"/concepts/boards-18","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`waiting`"},"170":{"id":"/concepts/boards-19","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"The \"Needs decision\" lane."},"171":{"id":"/concepts/boards-20","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`succeeded`"},"172":{"id":"/concepts/boards-21","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`review`"},"173":{"id":"/concepts/boards-22","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Never straight to `shipped` — a human accepts outcomes."},"174":{"id":"/concepts/boards-23","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`failed`"},"175":{"id":"/concepts/boards-24","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`blocked`"},"176":{"id":"/concepts/boards-25","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"With an explicit `blockedReason`; there is still no failed ticket state."},"177":{"id":"/concepts/boards-26","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"`cancelled`"},"178":{"id":"/concepts/boards-27","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"—"},"179":{"id":"/concepts/boards-28","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Cancelling is already an operator act."},"180":{"id":"/concepts/boards-29","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#runs-move-tickets","content":"Tickets in `shipped`, `accepted`, or `archived` are never touched, and terminal outcomes (`succeeded`/`failed`) wait until no sibling linked run is still live. Every automated move lands in ticket history as a `work_item.status_changed` event attributed to the run (`actor: \"run:run_…\"`), with the reason."},"181":{"id":"/concepts/boards-30","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Endpoint"},"182":{"id":"/concepts/boards-31","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"MCP tool"},"183":{"id":"/concepts/boards-32","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"Notes"},"184":{"id":"/concepts/boards-33","page_id":"/concepts/boards","tags":[],"type":"text","url":"/concepts/boards#api--mcp","content":"`GET /api/boards`"},"185":{"id":"/concepts/boards-34","page_id":"/concepts/boards","tags":[],"type"