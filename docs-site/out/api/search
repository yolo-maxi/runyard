orkflows#api--mcp","content":"Admin; nothing written."},"848":{"id":"/concepts/workflows-74","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/import`"},"849":{"id":"/concepts/workflows-75","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`import_workflow_package`"},"850":{"id":"/concepts/workflows-76","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; imports disabled."},"851":{"id":"/concepts/workflows-77","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Running a workflow (`POST /api/workflows/{id}/run`, `run_workflow`) and preflighting it are covered on the Runs page."},"852":{"id":"/guides/agent-consumers","page_id":"/guides/agent-consumers","type":"page","content":"Building agents on Runyard","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/agent-consumers"},"853":{"id":"/guides/agent-consumers-0","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Discovery surfaces, the API-first guarantee, and recommended etiquette for agents and third-party clients."},"854":{"id":"/guides/agent-consumers-1","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#discovery-surfaces","content":"Discovery surfaces"},"855":{"id":"/guides/agent-consumers-2","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#the-api-first-guarantee","content":"The API-first guarantee"},"856":{"id":"/guides/agent-consumers-3","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#auth-expectations","content":"Auth expectations"},"857":{"id":"/guides/agent-consumers-4","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#recommended-agent-etiquette","content":"Recommended agent etiquette"},"858":{"id":"/guides/agent-consumers-5","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"Push instead of poll: response endpoints"},"859":{"id":"/guides/agent-consumers-6","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"Machine intake: workflow endpoints"},"860":{"id":"/guides/agent-consumers-7","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Runyard treats agents as first-class API consumers. This page covers how a client discovers what a Hub can do, what it may rely on, and how to be a good citizen."},"861":{"id":"/guides/agent-consumers-8","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Surface"},"862":{"id":"/guides/agent-consumers-9","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Auth"},"863":{"id":"/guides/agent-consumers-10","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"What it gives you"},"864":{"id":"/guides/agent-consumers-11","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /llms.txt`"},"865":{"id":"/guides/agent-consumers-12","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"866":{"id":"/guides/agent-consumers-13","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Static, generic orientation for agents: what Runyard is, its tool names, the run path. It deliberately contains nothing deployment-specific and points at the authenticated menu."},"867":{"id":"/guides/agent-consumers-14","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /openapi.json`"},"868":{"id":"/guides/agent-consumers-15","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"869":{"id":"/guides/agent-consumers-16","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The full HTTP surface, generated from the Hub's API surface registry — it cannot drift from the routes the server actually registers."},"870":{"id":"/guides/agent-consumers-17","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"MCP `tools/list`"},"871":{"id":"/guides/agent-consumers-18","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"872":{"id":"/guides/agent-consumers-19","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The complete MCP tool set (parity-tested against the API surface). Connect with `runyard mcp install` or the `runyard-mcp` stdio server."},"873":{"id":"/guides/agent-consumers-20","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /api/menu` / `get_menu`"},"874":{"id":"/guides/agent-consumers-21","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"875":{"id":"/guides/agent-consumers-22","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The live, private catalog: workflows with schemas, execution modes, runner pool state, and ready-to-use CLI/MCP invocations."},"876":{"id":"/guides/agent-consumers-23","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Start every session with `get_menu` (or `GET /api/menu`), then `describe_workflow` for anything you intend to run."},"877":{"id":"/guides/agent-consumers-24","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#the-api-first-guarantee","content":"The web app is an ordinary client of the same HTTP API, with no privileged endpoints. Every route is declared in one registry that also generates `openapi.json` and is parity-tested against the MCP tool list — so a lossless third-party client is possible by construction: anything the web app can show or do, your client can too, over HTTP or MCP."},"878":{"id":"/guides/agent-consumers-25","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#auth-expectations","content":"Ask the Hub's administrator for a scoped access token (admins issue them from the Connect tab or `POST /api/tokens`). Agents typically need `api` and/or `mcp` — nothing more. Send it as `Authorization: Bearer <token>` on every HTTP call, or configure it for the MCP server. Never ask for or expect the bootstrap/admin token."},"879":{"id":"/guides/agent-consumers-26","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Set `input.title`.** For agent-created runs, include a short human-readable title (\"Audit checkout flow mobile states\") so run lists, approval cards, and human handoff stay decipherable."},"880":{"id":"/guides/agent-consumers-27","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Preflight first.** When input is rough or unverified, call `preflight_workflow` (`POST /api/workflows/{id}/preflight`) or pass `negotiate: true` to `run_workflow`. You get `ready | needs_input | blocked` with concrete questions and blockers instead of a run that fails."},"881":{"id":"/guides/agent-consumers-28","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Use run drafts for question/answer loops.** `create_run_draft` creates a proposed run and preflights it; `update_run_draft` merges answers into the input and re-preflights; `submit_run_draft` enqueues the real run only once it is ready; `discard_run_draft` abandons it. Nothing executes until submit."},"882":{"id":"/guides/agent-consumers-29","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Poll the timeline with `since` cursors.** `get_run_timeline` (`GET /api/runs/{id}/timeline`) returns a unified, ascending view of status transitions, events, and artifacts. Pass the previous response's `nextSince` as `since` so the Hub never re-sends what you have. Fetch results with `get_run_status`, `get_run_logs`, and `get_run_artifacts` / `download_artifact`."},"883":{"id":"/guides/agent-consumers-30","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Cap what a run may spend.** Pass `budget: { maxTokens, maxCostMicros }` when starting a run; a breach hard-stops the run as the distinct terminal status `budget_exceeded` (never a silent overrun). Read spend as you go from the run's `usage` and `budgetStatus` fields, and use `get_usage_summary` for a fleet rollup. See Usage metering & budgets."},"884":{"id":"/guides/agent-consumers-31","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Expect paused runs, and resume them.** A run interrupted by exhausted provider credits/quota parks as `paused` instead of failing. Check `run.pause` for the reason and required action, fix it, then `resume_run` (`POST /api/runs/{id}/resume`) — it continues from the engine checkpoint when one exists."},"885":{"id":"/guides/agent-consumers-32","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Triage with the attention queue.** `list_attention_runs` (`GET /api/runs/attention`) returns everything waiting on a human — paused, awaiting approval, or recently budget-stopped — with counts. Poll it instead of scanning full run lists for stuck work."},"886":{"id":"/guides/agent-consumers-33","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"A metered, resumable run end to end:"},"887":{"id":"/guides/agent-consumers-34","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"`POST /api/workflows/{id}/run` accepts an optional `responseEndpoint` (`{ \"type\": \"http\" | \"telegram\", \"config\": { ... } }`). When the run reaches a terminal state, the Hub POSTs a sanitized payload to your HTTP endpoint (or sends a concise Telegram message). Delivery state is visible on `GET /api/runs/{id}` under `responseEndpoints[]`, and polling remains the canonical fallback."},"888":{"id":"/guides/agent-consumers-35","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"For fixed-purpose integrations that should not hold a Hub token at all (webhooks, form intake, external systems), an admin can configure a **workflow endpoint**: `POST /api/workflow-endpoints/{slug}` accepts a payload authenticated with that endpoint's own secret, rate-limited, size-capped, and deduplicated, and triggers exactly one preconfigured workflow. This is the narrowest possible credential to hand to an external system."},"889":{"id":"/guides/api","page_id":"/guides/api","type":"page","content":"HTTP API","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/api"},"890":{"id":"/guides/api-0","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Authenticate, discover, and drive workflow runs over the Runyard Hub's HTTP API."},"891":{"id":"/guides/api-1","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#authentication","content":"Authentication"},"892":{"id":"/guides/api-2","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#discovery","content":"Discovery"},"893":{"id":"/guides/api-3","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#api-groups-and-apiv1-aliases","content":"API groups and `/api/v1` aliases"},"894":{"id":"/guides/api-4","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#the-typical-flow","content":"The typical flow"},"895":{"id":"/guides/api-5","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#key-endpoints","content":"Key endpoints"},"896":{"id":"/guides/api-6","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#approvals","content":"Approvals"},"897":{"id":"/guides/api-7","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#run-drafts","content":"Run drafts"},"898":{"id":"/guides/api-8","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#error-conventions","content":"Error conventions"},"899":{"id":"/guides/api-9","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#rate-limits","content":"Rate limits"},"900":{"id":"/guides/api-10","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#see-also","content":"See also"},"901":{"id":"/guides/api-11","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Every Runyard surface — the web app, the CLI, and the MCP server — is an\nordinary client of one HTTP API served by the Hub. Anything they can do, you\ncan do with `curl`."},"902":{"id":"/guides/api-12","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Send an access token as a bearer token on every request:"},"903":{"id":"/guides/api-13","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Tokens are minted by an admin (web UI, `POST /api/tokens`, or the CLI) and carry\n**scopes**:"},"904":{"id":"/guides/api-14","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Scope"},"905":{"id":"/guides/api-15","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Grants"},"906":{"id":"/guides/api-16","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`api`"},"907":{"id":"/guides/api-17","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Start runs, preflight, drafts, rerun/cancel/promote, create approvals"},"908":{"id":"/guides/api-18","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`mcp`"},"909":{"id":"/guides/api-19","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The same operations, issued for MCP clients"},"910":{"id":"/guides/api-20","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`read`"},"911":{"id":"/guides/api-21","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Read-only** — inspect workflows, runs, logs, artifacts, approvals, schedules, and runners; satisfies no mutation endpoint"},"912":{"id":"/guides/api-22","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`runner`"},"913":{"id":"/guides/api-23","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The runner protocol: register, heartbeat, claim runs, report lifecycle events and artifacts"},"914":{"id":"/guides/api-24","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`approvals`"},"915":{"id":"/guides/api-25","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Resolve approval cards (approve / reject / request changes) and create them"},"916":{"id":"/guides/api-26","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`admin`"},"917":{"id":"/guides/api-27","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Superscope** — satisfies every scope requirement, plus admin-only surfaces: tokens, secrets, audit log, schedules, workflow create/update, packages, hooks, updates"},"918":{"id":"/guides/api-28","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`GET /api/tokens/scopes` (admin) returns this vocabulary plus named presets —\n**everything** (`api`+`mcp`+`approvals`, the default), **read-only**,\n**approvals-only**, **runner**, and **admin** — which the Tokens page uses."},"919":{"id":"/guides/api-29","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Reads such as listing runs, workflows, or artifacts require any authenticated\ntoken. A token with only the `read` scope is therefore read-only: it can\ninspect everything non-admin but every create/update/delete/run/approve call\nfails with `403`. A request with no valid token gets\n`401 {\"error\": \"unauthorized\"}`; a token missing a required scope gets:"},"920":{"id":"/guides/api-30","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"with status `403`. `GET /api/me` describes the calling token (name and scopes)."},"921":{"id":"/guides/api-31","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /openapi.json`** (unauthenticated) — generated from the server's API\nsurface registry, the single source of truth every route is registered from,\nso **every endpoint is documented there**. This guide covers the important\nones; use `/openapi.json` for the full list."},"922":{"id":"/guides/api-32","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/menu`** (authenticated) — the agent-facing menu: workflow catalog,\nlocal/remote execution modes, and follow-up paths. The same data backs the\nMCP `get_menu` tool and `/llms.txt`."},"923":{"id":"/guides/api-33","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/version`** (unauthenticated) — product name, version, instance\nname."},"924":{"id":"/guides/api-34","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Operations are organized into eight groups, exposed as OpenAPI tags:\n**workflows**, **runs**, **approvals**, **automation** (schedules + workflow\nendpoints), **library** (agents, skills, knowledge, hooks), **distribution**\n(bundles, packages), **admin** (tokens, secrets, audit, alerts, updates), and\n**system** (health, version, menu, dashboard, runners)."},"925":{"id":"/guides/api-35","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Every grouped operation is also reachable at a stable `/api/v1` alias that\nmakes the group visible in the path — for example:"},"926":{"id":"/guides/api-36","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Canonical"},"927":{"id":"/guides/api-37","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Grouped alias"},"928":{"id":"/guides/api-38","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflows`"},"929":{"id":"/guides/api-39","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/workflows`"},"930":{"id":"/guides/api-40","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/runs/:id`"},"931":{"id":"/guides/api-41","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/:id`"},"932":{"id":"/guides/api-42","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/run-drafts`"},"933":{"id":"/guides/api-43","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/drafts`"},"934":{"id":"/guides/api-44","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/schedules`"},"935":{"id":"/guides/api-45","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/automation/schedules`"},"936":{"id":"/guides/api-46","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/agents`"},"937":{"id":"/guides/api-47","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/library/agents`"},"938":{"id":"/guides/api-48","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflow-bundles`"},"939":{"id":"/guides/api-49","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/distribution/bundles`"},"940":{"id":"/guides/api-50","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/tokens`"},"941":{"id":"/guides/api-51","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/admin/tokens`"},"942":{"id":"/guides/api-52","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/menu`"},"943":{"id":"/guides/api-53","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/system/menu`"},"944":{"id":"/guides/api-54","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Aliases are the same registry entries registered twice, so they always share\nthe canonical route's handler, auth, and scopes; in `openapi.json` each alias\ncarries `x-canonical-path`. Unversioned `/api/...` paths remain fully\nsupported — use whichever reads better. The legacy `/api/capabilities/*`\npaths are deprecated aliases of `/api/workflows/*` and get no `/api/v1` form;\nnew clients should say *workflow* everywhere."},"945":{"id":"/guides/api-55","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"List workflows, preflight your input, start the run, then poll it:"},"946":{"id":"/guides/api-56","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"For agent-created runs, include a short human-readable `input.title` — it labels\nrun lists, approval cards, and handoffs. `executionMode` is `local` or `remote`;\n`run` also accepts an optional `responseEndpoint` (`{type: http|telegram,\nconfig}`) to have the terminal-state reply delivered when the run finishes\n(polling `/api/runs/:id` remains the canonical fallback), and an optional\n`budget` (`{maxTokens?, maxCostMicros?}`, also accepted as `input.budget`) that\nhard-caps the run's metered model usage — a breach terminates the run with the\ndistinct status `budget_exceeded`. Metered usage aggregates onto every run\nobject as `usage` and is detailed at `GET /api/runs/:id/usage`; see\nUsage metering & budgets."},