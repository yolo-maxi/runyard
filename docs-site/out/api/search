oncepts/tokens-and-scopes","tags":[],"type":"text","url":"/concepts/tokens-and-scopes#api--mcp","content":"Admin; who did what, most recent first."},"594":{"id":"/concepts/workflows","page_id":"/concepts/workflows","type":"page","content":"Workflows","breadcrumbs":["Docs","Concepts"],"tags":[],"url":"/concepts/workflows"},"595":{"id":"/concepts/workflows-0","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"The catalog unit of Runyard - versioned definitions with schemas, immutable source bundles, and portable packages."},"596":{"id":"/concepts/workflows-1","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#definition","content":"Definition"},"597":{"id":"/concepts/workflows-2","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is data, not files"},"598":{"id":"/concepts/workflows-3","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#db-backed-workflow-bundles","content":"DB-backed workflow bundles"},"599":{"id":"/concepts/workflows-4","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#versioning","content":"Versioning"},"600":{"id":"/concepts/workflows-5","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#workflow-packages","content":"Workflow packages"},"601":{"id":"/concepts/workflows-6","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#enabled-and-disabled","content":"Enabled and disabled"},"602":{"id":"/concepts/workflows-7","page_id":"/concepts/workflows","type":"heading","tags":[],"url":"/concepts/workflows#api--mcp","content":"API & MCP"},"603":{"id":"/concepts/workflows-8","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows","content":"A **workflow** is the unit of the Runyard catalog: a named, versioned definition of something an agent can do. Each workflow has a slug, a display name and description, input/output schemas, and a source program that the runner executes. In older code and database tables the same object is called a *capability* — that is the legacy/internal synonym; user-facing surfaces say workflow."},"604":{"id":"/concepts/workflows-9","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"A workflow definition carries:"},"605":{"id":"/concepts/workflows-10","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Field"},"606":{"id":"/concepts/workflows-11","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Purpose"},"607":{"id":"/concepts/workflows-12","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`slug`, `name`, `description`, `category`, `keywords`"},"608":{"id":"/concepts/workflows-13","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Identity and catalog discovery (`GET /api/workflows?q=` searches)."},"609":{"id":"/concepts/workflows-14","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`inputSchema` / `outputSchema`"},"610":{"id":"/concepts/workflows-15","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"JSON schemas for run input and output. Required input fields drive preflight questions."},"611":{"id":"/concepts/workflows-16","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredRunnerTags`"},"612":{"id":"/concepts/workflows-17","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Tags a runner must advertise to be assigned a run."},"613":{"id":"/concepts/workflows-18","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`requiredSkills` / `requiredAgents`"},"614":{"id":"/concepts/workflows-19","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"References into the shared catalog."},"615":{"id":"/concepts/workflows-20","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`approvalPolicy`"},"616":{"id":"/concepts/workflows-21","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Whether new runs hold for an approval before executing."},"617":{"id":"/concepts/workflows-22","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`workflow`"},"618":{"id":"/concepts/workflows-23","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Source configuration — most importantly `workflow.bundleId`, plus options like `hooks.allowedProfiles` for post-run hooks and `secrets` for secret delivery."},"619":{"id":"/concepts/workflows-24","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"`enabled`"},"620":{"id":"/concepts/workflows-25","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#definition","content":"Disabled workflows disappear from the catalog for non-admins and cannot be run."},"621":{"id":"/concepts/workflows-26","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-source-is-data-not-files","content":"Workflow source is created and edited through the API/MCP (`create_workflow` / `update_workflow` with inline source bytes) or by importing a workflow package. You never write workflow files to disk on the Hub or runner: custom workflows must carry source bytes or reference an existing `workflow.bundleId` — bare `workflow.entry` file paths are rejected."},"622":{"id":"/concepts/workflows-27","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Published source lives in the Hub database as **workflow bundles**: immutable, hash-addressed rows in the `workflow_bundles` table. Publishing is insert-only — every publish creates a new `(workflow slug, version)` row with a `sha256` of the source, so a bundle id permanently names the exact bytes that were published. Bundles are capped at 500 KB, listing never returns source bytes, and a workflow that references a missing bundle fails preflight rather than silently falling back to a file."},"623":{"id":"/concepts/workflows-28","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#db-backed-workflow-bundles","content":"Prefer `create_workflow` / `update_workflow` with inline source — they publish a bundle for you and point the workflow at it."},"624":{"id":"/concepts/workflows-29","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#versioning","content":"Updating a workflow bumps its integer `version` and snapshots the previous definition. `GET /api/workflows/{name}/versions` lists the versions observed on past runs, and every run records the `workflowVersion` it executed. Bundle versions count separately, per publish."},"625":{"id":"/concepts/workflows-30","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#workflow-packages","content":"A **workflow package** is a portable `.runyard-workflow.json` file for moving a workflow between Hubs. Exports contain source bytes, metadata, requirements, and content/workflow hashes — never secret values. Imports publish the source as a new immutable bundle and create the workflow **disabled by default**, so an admin can configure and preflight it locally before enabling it. `validate` and `preview` let you check a package without writing anything."},"626":{"id":"/concepts/workflows-31","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#enabled-and-disabled","content":"`DELETE /api/workflows/{id}` disables a workflow rather than erasing it: historical runs stay intact, non-admins get a 404, and preflight blocks new runs until an admin re-enables it with `PATCH /api/workflows/{id}`."},"627":{"id":"/concepts/workflows-32","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Endpoint"},"628":{"id":"/concepts/workflows-33","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"MCP tool"},"629":{"id":"/concepts/workflows-34","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Notes"},"630":{"id":"/concepts/workflows-35","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows`"},"631":{"id":"/concepts/workflows-36","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflows`, `search_workflows`"},"632":{"id":"/concepts/workflows-37","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`?q=` searches."},"633":{"id":"/concepts/workflows-38","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflows`"},"634":{"id":"/concepts/workflows-39","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`create_workflow`"},"635":{"id":"/concepts/workflows-40","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin. Inline source or `workflow.bundleId`."},"636":{"id":"/concepts/workflows-41","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{id}`"},"637":{"id":"/concepts/workflows-42","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`describe_workflow`"},"638":{"id":"/concepts/workflows-43","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Definition and input schema."},"639":{"id":"/concepts/workflows-44","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`PATCH /api/workflows/{id}`"},"640":{"id":"/concepts/workflows-45","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`update_workflow`"},"641":{"id":"/concepts/workflows-46","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"642":{"id":"/concepts/workflows-47","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`DELETE /api/workflows/{id}`"},"643":{"id":"/concepts/workflows-48","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`delete_workflow`"},"644":{"id":"/concepts/workflows-49","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; disables."},"645":{"id":"/concepts/workflows-50","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{id}/source`"},"646":{"id":"/concepts/workflows-51","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`get_workflow_source`"},"647":{"id":"/concepts/workflows-52","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Source, metadata, sections, graph."},"648":{"id":"/concepts/workflows-53","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflows/{name}/versions`"},"649":{"id":"/concepts/workflows-54","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflow_versions`"},"650":{"id":"/concepts/workflows-55","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Versions seen on runs."},"651":{"id":"/concepts/workflows-56","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-bundles`"},"652":{"id":"/concepts/workflows-57","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`list_workflow_bundles`"},"653":{"id":"/concepts/workflows-58","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Metadata only."},"654":{"id":"/concepts/workflows-59","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-bundles/{id}`"},"655":{"id":"/concepts/workflows-60","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`get_workflow_bundle`"},"656":{"id":"/concepts/workflows-61","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Includes source."},"657":{"id":"/concepts/workflows-62","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-bundles`"},"658":{"id":"/concepts/workflows-63","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`publish_workflow_bundle`"},"659":{"id":"/concepts/workflows-64","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"660":{"id":"/concepts/workflows-65","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`GET /api/workflow-packages/workflows/{id}/export`"},"661":{"id":"/concepts/workflows-66","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`export_workflow_package`"},"662":{"id":"/concepts/workflows-67","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"663":{"id":"/concepts/workflows-68","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/validate`"},"664":{"id":"/concepts/workflows-69","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`validate_workflow_package`"},"665":{"id":"/concepts/workflows-70","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin."},"666":{"id":"/concepts/workflows-71","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/preview`"},"667":{"id":"/concepts/workflows-72","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`preview_workflow_import`"},"668":{"id":"/concepts/workflows-73","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; nothing written."},"669":{"id":"/concepts/workflows-74","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`POST /api/workflow-packages/import`"},"670":{"id":"/concepts/workflows-75","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"`import_workflow_package`"},"671":{"id":"/concepts/workflows-76","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Admin; imports disabled."},"672":{"id":"/concepts/workflows-77","page_id":"/concepts/workflows","tags":[],"type":"text","url":"/concepts/workflows#api--mcp","content":"Running a workflow (`POST /api/workflows/{id}/run`, `run_workflow`) and preflighting it are covered on the Runs page."},"673":{"id":"/guides/agent-consumers","page_id":"/guides/agent-consumers","type":"page","content":"Building agents on Runyard","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/agent-consumers"},"674":{"id":"/guides/agent-consumers-0","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Discovery surfaces, the API-first guarantee, and recommended etiquette for agents and third-party clients."},"675":{"id":"/guides/agent-consumers-1","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#discovery-surfaces","content":"Discovery surfaces"},"676":{"id":"/guides/agent-consumers-2","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#the-api-first-guarantee","content":"The API-first guarantee"},"677":{"id":"/guides/agent-consumers-3","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#auth-expectations","content":"Auth expectations"},"678":{"id":"/guides/agent-consumers-4","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#recommended-agent-etiquette","content":"Recommended agent etiquette"},"679":{"id":"/guides/agent-consumers-5","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"Push instead of poll: response endpoints"},"680":{"id":"/guides/agent-consumers-6","page_id":"/guides/agent-consumers","type":"heading","tags":[],"url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"Machine intake: workflow endpoints"},"681":{"id":"/guides/agent-consumers-7","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers","content":"Runyard treats agents as first-class API consumers. This page covers how a client discovers what a Hub can do, what it may rely on, and how to be a good citizen."},"682":{"id":"/guides/agent-consumers-8","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Surface"},"683":{"id":"/guides/agent-consumers-9","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Auth"},"684":{"id":"/guides/agent-consumers-10","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"What it gives you"},"685":{"id":"/guides/agent-consumers-11","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /llms.txt`"},"686":{"id":"/guides/agent-consumers-12","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"687":{"id":"/guides/agent-consumers-13","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Static, generic orientation for agents: what Runyard is, its tool names, the run path. It deliberately contains nothing deployment-specific and points at the authenticated menu."},"688":{"id":"/guides/agent-consumers-14","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /openapi.json`"},"689":{"id":"/guides/agent-consumers-15","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"none"},"690":{"id":"/guides/agent-consumers-16","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The full HTTP surface, generated from the Hub's API surface registry — it cannot drift from the routes the server actually registers."},"691":{"id":"/guides/agent-consumers-17","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"MCP `tools/list`"},"692":{"id":"/guides/agent-consumers-18","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"693":{"id":"/guides/agent-consumers-19","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The complete MCP tool set (parity-tested against the API surface). Connect with `runyard mcp install` or the `runyard-mcp` stdio server."},"694":{"id":"/guides/agent-consumers-20","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"`GET /api/menu` / `get_menu`"},"695":{"id":"/guides/agent-consumers-21","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"token"},"696":{"id":"/guides/agent-consumers-22","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"The live, private catalog: workflows with schemas, execution modes, runner pool state, and ready-to-use CLI/MCP invocations."},"697":{"id":"/guides/agent-consumers-23","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#discovery-surfaces","content":"Start every session with `get_menu` (or `GET /api/menu`), then `describe_workflow` for anything you intend to run."},"698":{"id":"/guides/agent-consumers-24","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#the-api-first-guarantee","content":"The web app is an ordinary client of the same HTTP API, with no privileged endpoints. Every route is declared in one registry that also generates `openapi.json` and is parity-tested against the MCP tool list — so a lossless third-party client is possible by construction: anything the web app can show or do, your client can too, over HTTP or MCP."},"699":{"id":"/guides/agent-consumers-25","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#auth-expectations","content":"Ask the Hub's administrator for a scoped access token (admins issue them from the Connect tab or `POST /api/tokens`). Agents typically need `api` and/or `mcp` — nothing more. Send it as `Authorization: Bearer <token>` on every HTTP call, or configure it for the MCP server. Never ask for or expect the bootstrap/admin token."},"700":{"id":"/guides/agent-consumers-26","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Set `input.title`.** For agent-created runs, include a short human-readable title (\"Audit checkout flow mobile states\") so run lists, approval cards, and human handoff stay decipherable."},"701":{"id":"/guides/agent-consumers-27","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Preflight first.** When input is rough or unverified, call `preflight_workflow` (`POST /api/workflows/{id}/preflight`) or pass `negotiate: true` to `run_workflow`. You get `ready | needs_input | blocked` with concrete questions and blockers instead of a run that fails."},"702":{"id":"/guides/agent-consumers-28","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Use run drafts for question/answer loops.** `create_run_draft` creates a proposed run and preflights it; `update_run_draft` merges answers into the input and re-preflights; `submit_run_draft` enqueues the real run only once it is ready; `discard_run_draft` abandons it. Nothing executes until submit."},"703":{"id":"/guides/agent-consumers-29","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Poll the timeline with `since` cursors.** `get_run_timeline` (`GET /api/runs/{id}/timeline`) returns a unified, ascending view of status transitions, events, and artifacts. Pass the previous response's `nextSince` as `since` so the Hub never re-sends what you have. Fetch results with `get_run_status`, `get_run_logs`, and `get_run_artifacts` / `download_artifact`."},"704":{"id":"/guides/agent-consumers-30","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Cap what a run may spend.** Pass `budget: { maxTokens, maxCostMicros }` when starting a run; a breach hard-stops the run as the distinct terminal status `budget_exceeded` (never a silent overrun). Read spend as you go from the run's `usage` and `budgetStatus` fields, and use `get_usage_summary` for a fleet rollup. See Usage metering & budgets."},"705":{"id":"/guides/agent-consumers-31","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Expect paused runs, and resume them.** A run interrupted by exhausted provider credits/quota parks as `paused` instead of failing. Check `run.pause` for the reason and required action, fix it, then `resume_run` (`POST /api/runs/{id}/resume`) — it continues from the engine checkpoint when one exists."},"706":{"id":"/guides/agent-consumers-32","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"**Triage with the attention queue.** `list_attention_runs` (`GET /api/runs/attention`) returns everything waiting on a human — paused, awaiting approval, or recently budget-stopped — with counts. Poll it instead of scanning full run lists for stuck work."},"707":{"id":"/guides/agent-consumers-33","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#recommended-agent-etiquette","content":"A metered, resumable run end to end:"},"708":{"id":"/guides/agent-consumers-34","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#push-instead-of-poll-response-endpoints","content":"`POST /api/workflows/{id}/run` accepts an optional `responseEndpoint` (`{ \"type\": \"http\" | \"telegram\", \"config\": { ... } }`). When the run reaches a terminal state, the Hub POSTs a sanitized payload to your HTTP endpoint (or sends a concise Telegram message). Delivery state is visible on `GET /api/runs/{id}` under `responseEndpoints[]`, and polling remains the canonical fallback."},"709":{"id":"/guides/agent-consumers-35","page_id":"/guides/agent-consumers","tags":[],"type":"text","url":"/guides/agent-consumers#machine-intake-workflow-endpoints","content":"For fixed-purpose integrations that should not hold a Hub token at all (webhooks, form intake, external systems), an admin can configure a **workflow endpoint**: `POST /api/workflow-endpoints/{slug}` accepts a payload authenticated with that endpoint's own secret, rate-limited, size-capped, and deduplicated, and triggers exactly one preconfigured workflow. This is the narrowest possible credential to hand to an external system."},"710":{"id":"/guides/api","page_id":"/guides/api","type":"page","content":"HTTP API","breadcrumbs":["Docs","Guides"],"tags":[],"url":"/guides/api"},"711":{"id":"/guides/api-0","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Authenticate, discover, and drive workflow runs over the Runyard Hub's HTTP API."},"712":{"id":"/guides/api-1","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#authentication","content":"Authentication"},"713":{"id":"/guides/api-2","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#discovery","content":"Discovery"},"714":{"id":"/guides/api-3","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#api-groups-and-apiv1-aliases","content":"API groups and `/api/v1` aliases"},"715":{"id":"/guides/api-4","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#the-typical-flow","content":"The typical flow"},"716":{"id":"/guides/api-5","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#key-endpoints","content":"Key endpoints"},"717":{"id":"/guides/api-6","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#approvals","content":"Approvals"},"718":{"id":"/guides/api-7","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#run-drafts","content":"Run drafts"},"719":{"id":"/guides/api-8","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#error-conventions","content":"Error conventions"},"720":{"id":"/guides/api-9","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#rate-limits","content":"Rate limits"},"721":{"id":"/guides/api-10","page_id":"/guides/api","type":"heading","tags":[],"url":"/guides/api#see-also","content":"See also"},"722":{"id":"/guides/api-11","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api","content":"Every Runyard surface — the web app, the CLI, and the MCP server — is an\nordinary client of one HTTP API served by the Hub. Anything they can do, you\ncan do with `curl`."},"723":{"id":"/guides/api-12","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Send an access token as a bearer token on every request:"},"724":{"id":"/guides/api-13","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Tokens are minted by an admin (web UI, `POST /api/tokens`, or the CLI) and carry\n**scopes**:"},"725":{"id":"/guides/api-14","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Scope"},"726":{"id":"/guides/api-15","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Grants"},"727":{"id":"/guides/api-16","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`api`"},"728":{"id":"/guides/api-17","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Start runs, preflight, drafts, rerun/cancel/promote, create approvals"},"729":{"id":"/guides/api-18","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`mcp`"},"730":{"id":"/guides/api-19","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The same operations, issued for MCP clients"},"731":{"id":"/guides/api-20","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`read`"},"732":{"id":"/guides/api-21","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Read-only** — inspect workflows, runs, logs, artifacts, approvals, schedules, and runners; satisfies no mutation endpoint"},"733":{"id":"/guides/api-22","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`runner`"},"734":{"id":"/guides/api-23","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"The runner protocol: register, heartbeat, claim runs, report lifecycle events and artifacts"},"735":{"id":"/guides/api-24","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`approvals`"},"736":{"id":"/guides/api-25","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Resolve approval cards (approve / reject / request changes) and create them"},"737":{"id":"/guides/api-26","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`admin`"},"738":{"id":"/guides/api-27","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"**Superscope** — satisfies every scope requirement, plus admin-only surfaces: tokens, secrets, audit log, schedules, workflow create/update, packages, hooks, updates"},"739":{"id":"/guides/api-28","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"`GET /api/tokens/scopes` (admin) returns this vocabulary plus named presets —\n**everything** (`api`+`mcp`+`approvals`, the default), **read-only**,\n**approvals-only**, **runner**, and **admin** — which the Tokens page uses."},"740":{"id":"/guides/api-29","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"Reads such as listing runs, workflows, or artifacts require any authenticated\ntoken. A token with only the `read` scope is therefore read-only: it can\ninspect everything non-admin but every create/update/delete/run/approve call\nfails with `403`. A request with no valid token gets\n`401 {\"error\": \"unauthorized\"}`; a token missing a required scope gets:"},"741":{"id":"/guides/api-30","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#authentication","content":"with status `403`. `GET /api/me` describes the calling token (name and scopes)."},"742":{"id":"/guides/api-31","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /openapi.json`** (unauthenticated) — generated from the server's API\nsurface registry, the single source of truth every route is registered from,\nso **every endpoint is documented there**. This guide covers the important\nones; use `/openapi.json` for the full list."},"743":{"id":"/guides/api-32","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/menu`** (authenticated) — the agent-facing menu: workflow catalog,\nlocal/remote execution modes, and follow-up paths. The same data backs the\nMCP `get_menu` tool and `/llms.txt`."},"744":{"id":"/guides/api-33","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#discovery","content":"**`GET /api/version`** (unauthenticated) — product name, version, instance\nname."},"745":{"id":"/guides/api-34","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Operations are organized into eight groups, exposed as OpenAPI tags:\n**workflows**, **runs**, **approvals**, **automation** (schedules + workflow\nendpoints), **library** (agents, skills, knowledge, hooks), **distribution**\n(bundles, packages), **admin** (tokens, secrets, audit, alerts, updates), and\n**system** (health, version, menu, dashboard, runners)."},"746":{"id":"/guides/api-35","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Every grouped operation is also reachable at a stable `/api/v1` alias that\nmakes the group visible in the path — for example:"},"747":{"id":"/guides/api-36","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Canonical"},"748":{"id":"/guides/api-37","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Grouped alias"},"749":{"id":"/guides/api-38","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflows`"},"750":{"id":"/guides/api-39","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/workflows`"},"751":{"id":"/guides/api-40","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/runs/:id`"},"752":{"id":"/guides/api-41","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/:id`"},"753":{"id":"/guides/api-42","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/run-drafts`"},"754":{"id":"/guides/api-43","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/runs/drafts`"},"755":{"id":"/guides/api-44","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/schedules`"},"756":{"id":"/guides/api-45","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/automation/schedules`"},"757":{"id":"/guides/api-46","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/agents`"},"758":{"id":"/guides/api-47","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/library/agents`"},"759":{"id":"/guides/api-48","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/workflow-bundles`"},"760":{"id":"/guides/api-49","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/distribution/bundles`"},"761":{"id":"/guides/api-50","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/tokens`"},"762":{"id":"/guides/api-51","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/admin/tokens`"},"763":{"id":"/guides/api-52","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/menu`"},"764":{"id":"/guides/api-53","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"`GET /api/v1/system/menu`"},"765":{"id":"/guides/api-54","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#api-groups-and-apiv1-aliases","content":"Aliases are the same registry entries registered twice, so they always share\nthe canonical route's handler, auth, and scopes; in `openapi.json` each alias\ncarries `x-canonical-path`. Unversioned `/api/...` paths remain fully\nsupported — use whichever reads better. The legacy `/api/capabilities/*`\npaths are deprecated aliases of `/api/workflows/*` and get no `/api/v1` form;\nnew clients should say *workflow* everywhere."},"766":{"id":"/guides/api-55","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"List workflows, preflight your input, start the run, then poll it:"},"767":{"id":"/guides/api-56","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"For agent-created runs, include a short human-readable `input.title` — it labels\nrun lists, approval cards, and handoffs. `executionMode` is `local` or `remote`;\n`run` also accepts an optional `responseEndpoint` (`{type: http|telegram,\nconfig}`) to have the terminal-state reply delivered when the run finishes\n(polling `/api/runs/:id` remains the canonical fallback), and an optional\n`budget` (`{maxTokens?, maxCostMicros?}`, also accepted as `input.budget`) that\nhard-caps the run's metered model usage — a breach terminates the run with the\ndistinct status `budget_exceeded`. Metered usage aggregates onto every run\nobject as `usage` and is detailed at `GET /api/runs/:id/usage`; see\nUsage metering & budgets."},"768":{"id":"/guides/api-57","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#the-typical-flow","content":"With `\"negotiate\": true`, a non-ready request returns the negotiation state\n(questions, blockers, warnings, plus a saved draft) instead of creating a run —\nfix the input and call again."},"769":{"id":"/guides/api-58","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Workflows and runs (`preflight` and `run` require `api` or `mcp` scope; reads\nrequire any token):"},"770":{"id":"/guides/api-59","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Method + path"},"771":{"id":"/guides/api-60","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Purpose"},"772":{"id":"/guides/api-61","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows`"},"773":{"id":"/guides/api-62","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List workflows (`?q=` searches)"},"774":{"id":"/guides/api-63","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows/:id`"},"775":{"id":"/guides/api-64","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Describe a workflow and its input schema"},"776":{"id":"/guides/api-65","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/workflows/:id/source`"},"777":{"id":"/guides/api-66","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Workflow source, parsed metadata, sections, graph"},"778":{"id":"/guides/api-67","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows/:id/preflight`"},"779":{"id":"/guides/api-68","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Dry-run preflight: `ready` / `needs_input` / `blocked`, nothing created"},"780":{"id":"/guides/api-69","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows/:id/run`"},"781":{"id":"/guides/api-70","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run a workflow: `{input, executionMode, negotiate?}`"},"782":{"id":"/guides/api-71","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`POST /api/workflows` / `PATCH /api/workflows/:id`"},"783":{"id":"/guides/api-72","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Create/update a workflow (admin). Source is submitted as bytes or a `workflow.bundleId` — never a file path"},"784":{"id":"/guides/api-73","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs`"},"785":{"id":"/guides/api-74","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"List runs (filter by `status`, `q`, `workflow`)"},"786":{"id":"/guides/api-75","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id`"},"787":{"id":"/guides/api-76","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Run status, outputs, error, response-delivery state"},"788":{"id":"/guides/api-77","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/timeline`"},"789":{"id":"/guides/api-78","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Unified ascending timeline (`since=<iso>`, `limit=<n>`); backs `runyard tail`"},"790":{"id":"/guides/api-79","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/usage`"},"791":{"id":"/guides/api-80","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Metered usage: aggregate totals, per-call records, budget, and `budgetStop`"},"792":{"id":"/guides/api-81","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"`GET /api/runs/:id/events` · `/logs` · `/diagnostics`"},"793":{"id":"/guides/api-82","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","content":"Structured events, log lines, diagnostics + log summary"},"794":{"id":"/guides/api-83","page_id":"/guides/api","tags":[],"type":"text","url":"/guides/api#key-endpoints","cont