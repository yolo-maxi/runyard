{
  "name": "runyard-docs-site",
  "version": "0.1.0",
  "private": true,
  "description": "Static Fumadocs site for RunYard, exported to out/ and served under /docs by the hub's Express static handler.",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "postinstall": "fumadocs-mdx",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@orama/orama": "3.1.18",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.1",
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/mdx": "2.0.14",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.16",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  }
}
