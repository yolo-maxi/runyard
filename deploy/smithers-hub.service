[Unit]
Description=Smithers Hub
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/fran/smithers-hub
EnvironmentFile=/home/fran/smithers-hub/.env
ExecStart=/home/fran/.local/node-v22.16.0-linux-x64/bin/node --experimental-sqlite /home/fran/smithers-hub/src/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
