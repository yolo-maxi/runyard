{
  "name": "runyard",
  "version": "0.3.1",
  "description": "Runyard: self-hosted control plane, runner, CLI, and MCP server for agent runs.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yolo-maxi/runyard.git"
  },
  "homepage": "https://runyard.repo.box",
  "bugs": {
    "url": "https://github.com/yolo-maxi/runyard/issues"
  },
  "type": "module",
  "bin": {
    "runyard": "./bin/runyard.js",
    "runyard-mcp": "./bin/runyard-mcp.js",
    "runyard-runner": "./bin/runyard-runner.js"
  },
  "scripts": {
    "start": "node --experimental-sqlite src/server.js",
    "runner": "node src/runner.js",
    "mcp": "node src/mcp.js",
    "cli": "node src/cli.js",
    "build:vendor": "node bin/build-vendor.mjs",
    "build:web": "node bin/build-web.mjs",
    "watch:web": "node bin/build-web.mjs --watch",
    "build": "node bin/build-vendor.mjs && node bin/build-web.mjs",
    "smoke:smart-contract-audit": "node scripts/smoke-smart-contract-audit.mjs",
    "release:train": "node scripts/release-train.mjs",
    "test": "node --experimental-sqlite --test tests/*.test.js"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "express": "^4.19.2",
    "smithers-orchestrator": "0.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/db": "^0.6.10",
    "@tanstack/query-db-collection": "^1.0.42",
    "@tanstack/react-db": "^0.1.88",
    "@tanstack/react-query": "^5.101.1",
    "@xyflow/react": "^12.11.0",
    "esbuild": "^0.28.1",
    "highlight.js": "^11.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": ">=22.5"
  },
  "packageManager": "pnpm@10.33.0"
}
