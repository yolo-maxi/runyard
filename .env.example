# RunYard hub config. The RUNYARD_HUB_* names below are the current ones; the
# legacy SMITHERS_HUB_* equivalents are still read as fallbacks for back-compat.
BASE_URL=https://hub.example.com
HOST=127.0.0.1
PORT=43117
RUNYARD_HUB_INSTANCE_NAME=Runyard
# Required in production. If unset, a random secret is generated and persisted to data/session-secret.txt.
# The Hub refuses to start if this is left at the insecure development default while BASE_URL is https.
RUNYARD_HUB_SESSION_SECRET=replace-with-a-long-random-secret
RUNYARD_HUB_BOOTSTRAP_TOKEN=
RUNYARD_HUB_DATA_DIR=/var/lib/runyard/data

# Runners are marked offline if no heartbeat arrives within this window (ms).
SMITHERS_RUNNER_OFFLINE_MS=30000
# Maximum concurrent Smithers runs this runner process will execute. Defaults to 1
# (preserves single-runner behavior). On a dedicated VPS pool host you can set this
# to ~4 to drain backlog faster without overloading the box. The Hub queue stays
# centralized — runners just advertise capacity and the Hub honours it on /next-run.
# Avoid stacking high-capacity runners on the same machine that serves the Hub.
SMITHERS_RUNNER_CONCURRENCY=1

# Encrypted reusable-secrets store (Hub). 32-byte key as base64 or hex; generate with:
#   openssl rand -base64 32
# If unset, the secrets feature is disabled and /api/secrets returns 503 — values are
# never stored as plaintext. Required to use the Secrets page / run secret injection.
SECRETS_ENC_KEY=

# Per-runner CLI re-auth. Set REAUTH_ENABLED=1 ONLY on the runner host that is
# allowed to drive `codex login --device-auth` / `claude setup-token` from the Hub.
# The runner must also advertise the `reauth` tag (SMITHERS_RUNNER_TAGS=...,reauth)
# so the admin-only reauth-cli capability targets it. Off by default everywhere.
REAUTH_ENABLED=
# Optional auth-health cache TTL on the runner (ms); how often it re-reads the
# Codex/Claude auth files for its heartbeat. Default 30s.
SMITHERS_AUTH_HEALTH_TTL_MS=30000

# --- Self-host update check + apply -----------------------------------------
# Passive update CHECK: poll the public GitHub Releases API (outbound-only,
# read-only) and surface "update available" in the admin UI. Default ON; set to
# 0 to disable. There is NO phone-home — the GitHub read is the only outbound call.
UPDATE_CHECK_ENABLED=1
# How often the hub refreshes the latest-release reading (ms). Also the cache TTL,
# so the GitHub API is never hammered. Default 1h.
UPDATE_CHECK_INTERVAL_MS=3600000
# owner/repo to check releases for. Defaults to the canonical RunYard repo.
GITHUB_REPO=yolo-maxi/runyard
# Allow triggering `runyard update` over HTTP (admin-only UI button / endpoint).
# OFF by default: a privileged self-update reachable over the network is sensitive.
# When off, run `runyard update` on the host. The endpoint stays admin-gated even
# when enabled, and applying NEVER kills in-flight runs (it drains, then aborts
# if work doesn't finish within RUNYARD_DRAIN_GRACE_MS).
UPDATE_APPLY_ENABLED=0
# Bounded grace window the updater waits for runners to finish in-flight work
# before swapping code (ms). Exceeding it ABORTS the update. Default 45 minutes.
RUNYARD_DRAIN_GRACE_MS=2700000
# Optional: your own Slack/Discord/etc. webhook to receive update OUTCOMES. Generic
# outbound POST only — never a maintainer endpoint. Leave empty for UI/logs only.
UPDATE_NOTIFY_WEBHOOK=

# Optional approval channel
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_THREAD_ID=
# Secret token set on the Telegram setWebhook call and verified on every webhook request.
# The webhook endpoint is disabled until this is set.
TELEGRAM_WEBHOOK_SECRET=

# --- Runner execution model (unopinionated seam) ---
# By default the runner executes each workflow directly on its own host.
# RunYard does NOT impose a container/sandbox model — the runner is a standalone
# worker that can live anywhere (same box as the hub, another VPS, a laptop, a
# confidential VM) and you decide how it executes work.
# To run each engine invocation through a sandbox/container/job launcher, set a
# wrapper command. Examples:
#   RUNNER_EXEC_WRAPPER=firejail --quiet
#   RUNNER_EXEC_WRAPPER=docker run --rm -v /srv/runner-workspace:/workspace -w /workspace runyard-exec
#   RUNNER_EXEC_WRAPPER=["docker","run","--rm","-v","/path with spaces:/workspace","img"]   # JSON array for args with spaces
# Unset = run on the host (default; works everywhere). The wrapper you set owns
# its own behavior: workspace sharing, run lifecycle (note `smithers up -d` is
# detached), and cleanup. RUNYARD_RUNNER_EXEC_WRAPPER is accepted as an alias.
# Only the workflow launch is wrapped; runner polling/control commands
# (events/inspect/output/cancel) always run on the host.
# RUNNER_EXEC_WRAPPER=
#
# Bubblewrap sandbox preset (built-in, no hand-written argv). Set to generate a
# conservative bwrap command that binds the system dirs read-only and the run's
# workspace read-write, isolating the filesystem per launch. The workflow gets a
# writable HOME at <workspace>/.home (host HOME/XDG dirs are walled off, so no
# runner secrets leak in). Requires `bwrap` installed on the runner host AND
# unprivileged user namespaces permitted — on Ubuntu 23.10+ install the narrow
# AppArmor profile (`sudo deploy/apparmor/install.sh`; see deploy/apparmor/
# README.md), else launches fail with "setting up uid map: Permission denied".
# Takes precedence over RUNNER_EXEC_WRAPPER.
#   RUNNER_SANDBOX=bubblewrap
# Optional knobs (only apply when RUNNER_SANDBOX=bubblewrap):
#   RUNNER_SANDBOX_BWRAP=/usr/bin/bwrap   # path to the bwrap binary (default: bwrap on PATH)
#   RUNNER_SANDBOX_NETWORK=0              # 0/off/false => --unshare-net (default: network shared)
#   RUNNER_SANDBOX_RO_BIND=/opt/toolchain /home/runner/.bun  # extra read-only binds (JSON array or space list)
# RUNNER_SANDBOX=

# --- Agent harness selection + Pi custom endpoints (Fugu / Venice / GLM ...) ---
# Which agent CLI drives workflows on this runner: pi | claude | codex.
# Per-workflow override: RUNYARD_<WORKFLOW>_AGENT_CLI (IMPLEMENT, IMPROVE, SUPPORT,
# IDEA, PRODUCT, KNOWLEDGE, AUDIT, APP_SKINNER, WORKFLOW_DOCTOR, GOBBLER_COMIC).
# When unset and a Pi endpoint is configured below, Pi is the default harness.
# RUNYARD_AGENT_CLI=pi
#
# Pi custom endpoint (OpenAI-compatible) — see docs/pi-custom-endpoints.md.
# The provider label must match a provider entry in the runner host's
# ~/.pi/agent/models.json (that file carries the endpoint baseUrl and a
# "$ENV_VAR" apiKey reference). RUNYARD_PI_BASE_URL is the same URL, surfaced to
# workflows for diagnostics. RUNYARD_PI_API_KEY_ENV is the NAME of the variable
# that carries the key — deliver the key itself as a Hub secret with that name
# (Secrets page / `runyard secrets`), never as ambient runner env: the child-env
# allowlist passes these descriptor vars through but strips any *_API_KEY.
# RUNYARD_PI_PROVIDER=venice
# RUNYARD_PI_MODEL=llama-3.3-70b
# RUNYARD_PI_BASE_URL=https://api.venice.ai/api/v1
# RUNYARD_PI_API_KEY_ENV=VENICE_API_KEY
# Per-workflow endpoint override, e.g. GLM for implementation work only:
# RUNYARD_IMPLEMENT_PI_PROVIDER=glm
# RUNYARD_IMPLEMENT_PI_MODEL=glm-4.7
# RUNYARD_IMPLEMENT_PI_API_KEY_ENV=ZAI_API_KEY
